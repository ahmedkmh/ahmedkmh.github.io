{"status": "success", "totalResults": 4399, "results": [{"article_id": "db22da6ac6d478d3e5a8ae393d9c0cb4", "link": "https://www.alyaum.com/articles/6664442/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%82%D9%8A%D8%A7%D8%AF%D8%A9-%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D9%85%D8%AF%D9%8A%D9%86%D8%A9-%D8%A7%D9%84%D9%85%D9%86%D9%88%D8%B1%D8%A9-%D8%AA%D8%B3%D8%AA%D9%82%D8%A8%D9%84-%D8%B6%D9%8A%D9%88%D9%81-%D8%A7%D9%84%D8%AF%D9%81%D8%A7%D8%B9-%D8%A8%D8%B9%D8%AF-%D8%A3%D8%AF%D8%A7%D8%A6%D9%87%D9%85-%D9%85%D9%86%D8%A7%D8%B3%D9%83-%D8%A7%D9%84%D8%AD%D8%AC", "title": "\u0642\u064a\u0627\u062f\u0629 \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629 \u062a\u0633\u062a\u0642\u0628\u0644 \u0636\u064a\u0648\u0641 \u0627\u0644\u062f\u0641\u0627\u0639 \u0628\u0639\u062f \u0627\u0654\u062f\u0627\u064a\u0654\u0647\u0645 \u0645\u0646\u0627\u0633\u0643 \u0627\u0644\u062d\u062c", "description": "\u0627\u0633\u062a\u0642\u0628\u0644\u062a \u0642\u064a\u0627\u062f\u0629 \u0645\u0646\u0637\u0642\u0629 <a href=\"https://www.alyaum.com/articles/6664426/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A7%D9%84%D8%AA%D8%B2%D8%A7%D9%85-%D8%A7%D9%84%D8%A8%D9%8A%D8%A6%D9%8A-%D9%8A%D8%B1%D9%81%D8%B9-%D8%AC%D8%A7%D9%87%D8%B2%D9%8A%D8%AA%D9%87-%D9%81%D9%8A-%D8%A7%D9%84%D9%85%D8%AF%D9%8A%D9%86%D8%A9-%D8%A7%D9%84%D9%85%D9%86%D9%88%D8%B1%D8%A9-%D8%A7%D8%B3%D8%AA%D8%B9%D8%AF%D8%A7%D8%AF%D8%A7-%D9%84%D8%A7%D8%B3%D8%AA%D9%82%D8%A8%D8%A7%D9%84-%D8%A7%D9%84%D8%B2%D9%88%D8%A7%D8%B1\" target=\"_blank\">\u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629</a> \u0627\u0644\u064a\u0648\u0645\u060c \u0636\u064a\u0648\u0641 <a href=\"https://www.alyaum.com/articles/6664119/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D9%82%D9%88%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D8%B4%D8%AA%D8%B1%D9%83%D8%A9-%D8%AA%D9%88%D8%A7%D8%B5%D9%84-%D8%AC%D9%87%D9%88%D8%AF%D9%87%D8%A7-%D9%81%D9%8A-%D8%AA%D9%81%D9%88%D9%8A%D8%AC-%D8%B6%D9%8A%D9%88%D9%81-%D9%88%D8%B2%D8%A7%D8%B1%D8%A9-%D8%A7%D9%84%D8%AF%D9%81%D8%A7%D8%B9\" target=\"_blank\">\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062f\u0641\u0627\u0639</a> \u0645\u0646 \u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u062f\u0641\u0627\u0639\u060c \u0648\u0631\u0648\u0654\u0633\u0627\u0621 \u0627\u0644\u0627\u0654\u0631\u0643\u0627\u0646\u060c \u0648\u0642\u0627\u062f\u0629 \u0627\u0644\u062c\u064a\u0648\u0634\u060c \u0648\u0643\u0628\u0627\u0631 \u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0646 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u064a\u0646 \u0645\u0646 \u0627\u0644\u062f\u0648\u0644 \u0627\u0644\u0634\u0642\u064a\u0642\u0629 \u0648\u0627\u0644\u0635\u062f\u064a\u0642\u0629\u060c \u0648\u0630\u0644\u0643 \u0639\u0642\u0628 \u0627\u0654\u062f\u0627\u064a\u0654\u0647\u0645 <a href=\"https://www.alyaum.com/articles/6663970/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%AC%D8%A7%D9%85%D8%B9%D8%A9-%D8%A7%D9%84%D8%A5%D8%B3%D9%84%D8%A7%D9%85%D9%8A%D8%A9-%D8%AA%D9%85%D9%83%D9%86-700-%D8%B7%D8%A7%D9%84%D8%A8-%D8%AF%D9%88%D9%84%D9%8A-%D9%85%D9%86-%D8%A3%D8%AF%D8%A7%D8%A1-%D9%85%D9%86%D8%A7%D8%B3%D9%83-%D8%A7%D9%84%D8%AD%D8%AC\" target=\"_blank\">\u0645\u0646\u0627\u0633\u0643 \u0627\u0644\u062d\u062c</a> \u0644\u0639\u0627\u0645 1447\u0647\u0640\u060c \u0636\u0645\u0646 \u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0627\u0633\u062a\u0636\u0627\u0641\u0629 \u0648\u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0633\u0646\u0648\u064a \u0627\u0644\u0630\u064a \u062a\u0646\u0641\u0630\u0647 \u0627\u0644\u0648\u0632\u0627\u0631\u0629.<br />\u0648\u062a\u0634\u0645\u0644 \u0627\u0644\u0628\u0631\u0627\u0645\u062c \u0627\u0644\u0645\u0639\u062f\u0629 \u0644\u0644\u0636\u064a\u0648\u0641 \u0627\u0633\u062a\u0642\u0628\u0627\u0644\u0647\u0645 \u0641\u064a \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629\u060c \u0648\u062a\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0644\u0627\u0632\u0645\u0629 \u0644\u0647\u0645 \u0628\u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0645\u0639 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u062a\u0648\u0641\u064a\u0631 \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u0646\u0642\u0644 \u0648\u0645\u062a\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0627\u0655\u0642\u0627\u0645\u0629\u060c \u0648\u0627\u0644\u062a\u0646\u0633\u064a\u0642 \u0645\u0639 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0627\u0644\u0645\u062e\u062a\u0635\u0629 \u0644\u062a\u0633\u0647\u064a\u0644 \u0632\u064a\u0627\u0631\u062a\u0647\u0645 \u0644\u0644\u0645\u0633\u062c\u062f \u0627\u0644\u0646\u0628\u0648\u064a \u0648\u0627\u0644\u0631\u0648\u0636\u0629 \u0627\u0644\u0634\u0631\u064a\u0641\u0629\u060c \u0648\u0641\u0642 \u062a\u0631\u062a\u064a\u0628\u0627\u062a \u0645\u0646\u0638\u0645\u0629 \u062a\u0633\u0647\u0645 \u0641\u064a \u062a\u0648\u0641\u064a\u0631 \u0627\u0644\u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0627\u0655\u064a\u0645\u0627\u0646\u064a\u0629 \u0648\u0627\u0644\u0631\u0648\u062d\u0627\u0646\u064a\u0629 \u0628\u0643\u0644 \u064a\u064f\u0633\u0631 \u0648\u0637\u0645\u0627\u0654\u0646\u064a\u0646\u0629.<h2>\u0632\u064a\u0627\u0631\u0629 \u0645\u0648\u0627\u0642\u0639 \u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629 \u0648\u062a\u0627\u0631\u064a\u062e\u064a\u0629</h2>\u0643\u0645\u0627 \u062a\u0636\u0645\u0646 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0632\u064a\u0627\u0631\u0629 \u0639\u062f\u062f\u064d \u0645\u0646 \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629 \u0648\u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629\u060c \u0634\u0645\u0644\u062a \u0632\u064a\u0627\u0631\u0629 \u0645\u0642\u0628\u0631\u0629 \u0634\u0647\u062f\u0627\u0621 \u0627\u064f\u0654\u062d\u062f \u0648\u0645\u0633\u062c\u062f \u0642\u0628\u0627\u0621\u060c \u0636\u0645\u0646 \u0628\u0631\u0646\u0627\u0645\u062c \u062b\u0642\u0627\u0641\u064a \u0648\u0627\u0655\u062b\u0631\u0627\u064a\u0654\u064a \u064a\u064f\u0639\u0631\u0651\u0641 \u0627\u0644\u0636\u064a\u0648\u0641 \u0628\u0627\u0644\u0645\u0643\u0627\u0646\u0629 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u0629 \u0648\u0627\u0644\u062f\u064a\u0646\u064a\u0629 \u0644\u0647\u0630\u0647 \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629 \u0628\u0627\u0644\u0633\u064a\u0631\u0629 \u0627\u0644\u0646\u0628\u0648\u064a\u0629.<br />\u0648\u0627\u0654\u0643\u062f \u0642\u0627\u064a\u0654\u062f \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629 \u0627\u0644\u0644\u0648\u0627\u0621 \u0627\u0644\u0631\u0643\u0646 \u0645\u062d\u0645\u062f \u0628\u0646 \u0639\u0644\u064a \u0627\u0644\u0627\u0654\u0633\u0645\u0631\u064a\u060c \u0627\u0654\u0646 \u0646\u062c\u0627\u062d \u0645\u0648\u0633\u0645 \u062d\u062c \u0647\u0630\u0627 \u0627\u0644\u0639\u0627\u0645 \u062a\u062d\u0642\u0642 \u0628\u0641\u0636\u0644 \u0627\u0644\u0644\u0647 \u062a\u0639\u0627\u0644\u0649\u060c \u062b\u0645 \u0628\u0627\u0644\u062f\u0639\u0645 \u0648\u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0643\u0631\u064a\u0645\u0629 \u0645\u0646 \u062e\u0627\u062f\u0645 \u0627\u0644\u062d\u0631\u0645\u064a\u0646 \u0627\u0644\u0634\u0631\u064a\u0641\u064a\u0646 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0653\u0644 \u0633\u0639\u0648\u062f\u060c \u0648\u0635\u0627\u062d\u0628 \u0627\u0644\u0633\u0645\u0648 \u0627\u0644\u0645\u0644\u0643\u064a \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0645\u062d\u0645\u062f \u0628\u0646 \u0633\u0644\u0645\u0627\u0646 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0653\u0644 \u0633\u0639\u0648\u062f \u0648\u0644\u064a \u0627\u0644\u0639\u0647\u062f \u0631\u064a\u0654\u064a\u0633 \u0645\u062c\u0644\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 - \u062d\u0641\u0638\u0647\u0645\u0627 \u0627\u0644\u0644\u0647 -\u060c \u0648\u0645\u0627 \u0648\u0641\u0631\u062a\u0647 \u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0631\u0634\u064a\u062f\u0629 \u0645\u0646 \u0627\u0655\u0645\u0643\u0627\u0646\u0627\u062a \u0648\u062e\u062f\u0645\u0627\u062a \u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u0644\u062e\u062f\u0645\u0629 \u0636\u064a\u0648\u0641 \u0627\u0644\u0631\u062d\u0645\u0646.<br /> <h2>\u0645\u0646\u0638\u0648\u0645\u0629 \u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u0645\u0646 \u0627\u0644\u062e\u062f\u0645\u0627\u062a</h2>\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0644\u0644\u0648\u0627\u0621 \u0627\u0644\u0627\u0654\u0633\u0645\u0631\u064a \u0627\u0655\u0644\u0649 \u062a\u0643\u0627\u0645\u0644 \u0627\u0644\u062c\u0647\u0648\u062f \u0628\u064a\u0646 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629 \u0628\u0642\u064a\u0627\u062f\u0629 \u0648\u0627\u0655\u0634\u0631\u0627\u0641 \u0635\u0627\u062d\u0628 \u0627\u0644\u0633\u0645\u0648 \u0627\u0644\u0645\u0644\u0643\u064a \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0633\u0644\u0645\u0627\u0646 \u0628\u0646 \u0633\u0644\u0637\u0627\u0646 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0654\u0645\u064a\u0631 \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629\u060c \u0648\u0635\u0627\u062d\u0628 \u0627\u0644\u0633\u0645\u0648 \u0627\u0644\u0645\u0644\u0643\u064a \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0633\u0639\u0648\u062f \u0628\u0646 \u0646\u0647\u0627\u0631 \u0628\u0646 \u0633\u0639\u0648\u062f \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0646\u0627\u064a\u0654\u0628 \u0627\u0654\u0645\u064a\u0631 \u0627\u0644\u0645\u0646\u0637\u0642\u0629\u060c \u0644\u062e\u062f\u0645\u0629 \u0627\u0644\u062d\u062c\u0627\u062c \u0648\u0632\u0648\u0627\u0631 \u0627\u0644\u0645\u0633\u062c\u062f \u0627\u0644\u0646\u0628\u0648\u064a\u060c \u0639\u0628\u0631 \u0645\u0646\u0638\u0648\u0645\u0629 \u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u0645\u0646 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0648\u0627\u0644\u062a\u0646\u0638\u064a\u0645\u064a\u0629 \u0648\u0627\u0644\u0631\u0639\u0648\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0639\u0632\u0632 \u0631\u0627\u062d\u0629 \u0627\u0644\u0632\u0627\u064a\u0654\u0631 \u0648\u0633\u0644\u0627\u0645\u062a\u0647.<br />\u0648\u0627\u0654\u0643\u062f \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u062c\u0647\u0648\u062f \u062a\u062c\u0633\u062f \u0648\u0627\u062c\u0628\u064b\u0627 \u062f\u064a\u0646\u064a\u064b\u0627 \u0648\u0648\u0637\u0646\u064a\u064b\u0627\u060c \u0648\u062a\u0639\u0643\u0633 \u0627\u0644\u0645\u0643\u0627\u0646\u0629 \u0627\u0644\u0631\u064a\u0627\u062f\u064a\u0629 \u0644\u0644\u0645\u0645\u0644\u0643\u0629 \u0641\u064a \u062e\u062f\u0645\u0629 \u0636\u064a\u0648\u0641 \u0627\u0644\u0631\u062d\u0645\u0646.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["lifestyle", "top"], "datatype": "news", "pubDate": "2026-05-30 02:44:00", "pubDateTZ": "UTC", "fetched_at": "2026-05-30 03:16:22", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "785d507c2e63a34062ea6928768afd37", "link": "https://www.alyaum.com/articles/6664441/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%88%D8%A7%D8%B4%D9%86%D8%B7%D9%86-%D8%AA%D8%B9%D9%84%D9%86-%D8%AA%D9%81%D9%83%D9%8A%D9%83-%D8%B4%D8%A8%D9%83%D8%A9-%D8%AA%D9%86%D9%82%D9%84-%D8%AA%D9%82%D9%86%D9%8A%D8%A7%D8%AA-%D8%AF%D9%81%D8%A7%D8%B9%D9%8A%D8%A9-%D8%A5%D9%84%D9%89-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86", "title": "\u0648\u0627\u0634\u0646\u0637\u0646 \u062a\u0639\u0644\u0646 \u062a\u0641\u0643\u064a\u0643 \u0634\u0628\u0643\u0629 \u062a\u0646\u0642\u0644 \u062a\u0642\u0646\u064a\u0627\u062a \u062f\u0641\u0627\u0639\u064a\u0629 \u0627\u0655\u0644\u0649 \u0627\u0655\u064a\u0631\u0627\u0646", "description": "\u0627\u0654\u0639\u0644\u0646\u062a <a href=\"https://www.alyaum.com/articles/6664417/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A7%D9%84%D8%AE%D8%A7%D8%B1%D8%AC%D9%8A%D8%A9-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9-%D9%84%D9%85-%D9%86%D8%AA%D9%88%D8%B5%D9%84-%D8%A5%D9%84%D9%89-%D8%A7%D8%AA%D9%81%D8%A7%D9%82-%D9%85%D8%B9-%D8%A7%D9%84%D9%88%D9%84%D8%A7%D9%8A%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D8%AA%D8%AD%D8%AF%D8%A9-%D8%AD%D8%AA%D9%89-%D8%A7%D9%84%D8%A2%D9%86\" target=\"_blank\">\u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629</a> \u0627\u0654\u0646\u0647\u0627 \u0641\u0643\u0643\u062a \u0646\u0638\u0627\u0645\u064b\u0627 \u0645\u0639\u0642\u062f\u064b\u0627 \u0644\u0646\u0642\u0644 \u062a\u0642\u0646\u064a\u0627\u062a \u062f\u0641\u0627\u0639\u064a\u0629 \u0627\u0655\u0644\u0649 <a href=\"https://www.alyaum.com/articles/6664425/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A7%D9%84%D8%A8%D9%8A%D8%AA-%D8%A7%D9%84%D8%A3%D8%A8%D9%8A%D8%B6-%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%84%D9%86-%D9%8A%D9%82%D8%A8%D9%84-%D8%A8%D8%A3%D9%8A-%D8%A7%D8%AA%D9%81%D8%A7%D9%82-%D9%85%D8%B9-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%84%D8%A7-%D9%8A%D8%B3%D8%AA%D9%88%D9%81%D9%8A-%D9%83%D9%84-%D8%B4%D8%B1%D9%88%D8%B7%D9%87\" target=\"_blank\">\u0627\u0655\u064a\u0631\u0627\u0646</a>\u060c \u0641\u064a \u062e\u0636\u0645 \u0645\u062d\u0627\u062f\u062b\u0627\u062a \u0644\u0627\u0655\u0646\u0647\u0627\u0621 <a href=\"https://www.alyaum.com/articles/6663740/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D8%A7%D9%84%D8%B7%D8%A7%D9%82%D8%A9/%D8%A8%D9%86%D9%83-%D9%8A%D9%88-%D8%A8%D9%8A-%D8%A5%D8%B3-%D9%8A%D8%B3%D8%AA%D8%A8%D8%B9%D8%AF-%D8%B9%D9%88%D8%AF%D8%A9-%D8%A3%D8%B3%D8%B9%D8%A7%D8%B1-%D8%A7%D9%84%D9%86%D9%81%D8%B7-%D9%84%D8%B7%D8%A8%D9%8A%D8%B9%D8%AA%D9%87%D8%A7-%D8%B1%D8%BA%D9%85-%D8%A8%D9%88%D8%A7%D8%AF%D8%B1-%D8%A5%D9%86%D9%87%D8%A7%D8%A1-%D8%A7%D9%84%D8%AD%D8%B1%D8%A8\" target=\"_blank\">\u0627\u0644\u062d\u0631\u0628</a> \u0641\u064a \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637.<br />\u0648\u0642\u0627\u0644\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0641\u064a \u0628\u064a\u0627\u0646 \u064a\u0648\u0645 \u0627\u0644\u062c\u0645\u0639\u0629\u060c \u0627\u0655\u0646 \u0627\u0644\u0634\u0628\u0643\u0629 \u0627\u0646\u062a\u062d\u0644\u062a \u0635\u0641\u0629 \u0634\u0631\u0643\u0627\u062a \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629\u060c \u0648\u0627\u062d\u062a\u0627\u0644\u062a \u0639\u0644\u064a\u