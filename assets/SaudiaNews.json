u062f \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0645\u0644\u0627\u0639\u0628 \u0627\u0644\u0645\u062a\u062e\u0635\u0635\u0629 \u0641\u064a \u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u0641\u064a \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629\u060c \u0648\u064a\u0642\u0639 \u0641\u064a \u0645\u062f\u064a\u0646\u0629 \u0627\u0654\u0648\u0633\u062a\u0646 \u0628\u0648\u0644\u0627\u064a\u0629 \u062a\u0643\u0633\u0627\u0633.<br />\u0648\u064a\u0639\u062a\u0628\u0631 \u0627\u0644\u0645\u0644\u0639\u0628 \u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a \u0644\u0646\u0627\u062f\u064a \u0627\u0654\u0648\u0633\u062a\u0646 \u0627\u0655\u0641 \u0633\u064a \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a MLS.<br />\u064a\u062a\u0645\u064a\u0632 \u0627\u0644\u0645\u0644\u0639\u0628 \u0628\u0633\u0639\u0629 20,738 \u0645\u0642\u0639\u062f\u064b\u0627\u060c \u0648\u0645\u0644\u0639\u0628 \u0643\u0631\u0629 \u0642\u062f\u0645 \u0645\u062a\u062e\u0635\u0635 \u0628\u0639\u0634\u0628 \u0637\u0628\u064a\u0639\u064a\u060c \u0648\u0633\u0642\u0641 \u0643\u0628\u064a\u0631 \u064a\u063a\u0637\u064a \u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u0642\u0627\u0639\u062f \u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u062c\u0645\u0647\u0648\u0631 \u0645\u0646 \u0627\u0644\u0634\u0645\u0633 \u0648\u0627\u0644\u0645\u0637\u0631\u060c \u0648\u0642\u062f \u062a\u0645 \u0627\u0641\u062a\u062a\u0627\u062d\u0647 \u0631\u0633\u0645\u064a\u064b\u0627 \u0641\u064a \u064a\u0648\u0646\u064a\u0648 2021\u060c \u0648 \u0628\u0644\u063a\u062a \u062a\u0643\u0644\u0641\u0629 \u0627\u0655\u0646\u0634\u0627\u064a\u0654\u0647 \u062d\u0648\u0627\u0644\u064a 260 \u0645\u0644\u064a\u0648\u0646 \u062f\u0648\u0644\u0627\u0631.<br />\u0648\u062d\u0635\u0644 \u0627\u0644\u0645\u0644\u0639\u0628 \u0639\u0644\u0649 \u0634\u0647\u0627\u062f\u0629 LEED Gold \u0644\u0644\u0627\u0633\u062a\u062f\u0627\u0645\u0629 \u0627\u0644\u0628\u064a\u064a\u0654\u064a\u0629\u060c \u0648\u064a\u064f\u0639\u062a\u0628\u0631 \u0645\u0646 \u0627\u0654\u0641\u0636\u0644 \u0627\u0644\u0645\u0644\u0627\u0639\u0628 \u0645\u0646 \u062d\u064a\u062b \u0627\u0644\u062a\u0635\u0645\u064a\u0645 \u0627\u0644\u0628\u064a\u064a\u0654\u064a \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u060c \u062d\u064a\u062b \u064a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u0645\u0631\u0627\u0641\u0642 \u062d\u062f\u064a\u062b\u0629 \u0648\u062a\u0635\u0645\u064a\u0645 \u0645\u0641\u062a\u0648\u062d \u064a\u0633\u0645\u062d \u0628\u062f\u062e\u0648\u0644 \u0627\u0644\u0647\u0648\u0627\u0621 \u0627\u0644\u0637\u0628\u064a\u0639\u064a\u060c \u0645\u0639 \u0627\u0654\u0643\u0628\u0631 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0645\u0642\u0627\u0639\u062f \u0627\u0644\u0645\u0635\u0646\u0648\u0639\u0629 \u0645\u0646 \u0642\u0645\u0627\u0634 \u0642\u0627\u0628\u0644 \u0644\u0644\u062a\u0646\u0641\u0633.<br />\u064a\u064f\u0639\u0631\u0641 \u0645\u0644\u0639\u0628 Q2 \u0628\u0627\u0654\u062c\u0648\u0627\u064a\u0654\u0647 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0645\u064a\u0632\u0629\u060c \u0648\u064a\u064f\u0637\u0644\u0642 \u0639\u0644\u064a\u0647 \u0644\u0642\u0628 \u201c\u0627\u0654\u0643\u0628\u0631 \u062d\u062f\u064a\u0642\u0629 \u062e\u0644\u0641\u064a\u0629 \u0641\u064a \u0627\u0654\u0648\u0633\u062a\u0646\u201d. \u0643\u0645\u0627 \u064a\u062d\u0645\u0644 \u0631\u0642\u0645\u064b\u0627 \u0642\u064a\u0627\u0633\u064a\u064b\u0627 \u0628\u0627\u0654\u0637\u0648\u0644 \u0633\u0644\u0633\u0644\u0629 \u062d\u0636\u0648\u0631 \u062c\u0645\u0627\u0647\u064a\u0631\u064a \u0643\u0627\u0645\u0644 (sellout) \u0641\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a MLS.<br />\u0648\u064a\u0642\u0639 \u0627\u0644\u0645\u0644\u0639\u0628 \u0634\u0645\u0627