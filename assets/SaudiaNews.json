u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629.\u0648\u062a\u0639\u062f \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u0627\u0654\u064a\u0631\u0644\u0646\u062f\u064a\u0629 \u0645\u0646 \u0627\u0654\u0643\u062b\u0631 \u0627\u0644\u062d\u0643\u0648\u0645\u0627\u062a \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a\u0629 \u0627\u0646\u062a\u0642\u0627\u062f\u0627\u064b \u0644\u0644\u062d\u0631\u0628 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 \u0639\u0644\u0649 \u063a\u0632\u0629\u060c \u0648\u062a\u0639\u0647\u062f\u062a \u0645\u0646\u0630 \u0627\u0654\u0643\u062a\u0648\u0628\u0631 2024 \u0628\u0641\u0631\u0636 \u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0636\u062f \u0627\u0644\u0645\u0633\u062a\u0648\u0637\u0646\u0627\u062a \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629. \u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u0645\u0634\u0631\u0648\u0639 \u0627\u0644\u0642\u0627\u0646\u0648\u0646 \u0648\u0627\u062c\u0647 \u062a\u0627\u0654\u062e\u064a\u0631\u0627\u062a \u0628\u0633\u0628\u0628 \u062e\u0644\u0627\u0641\u0627\u062a \u0633\u064a\u0627\u0633\u064a\u0629 \u0648\u0636\u063a\u0648\u0637 \u0645\u0646 \u062c\u0645\u0627\u0639\u0627\u062a \u0636\u063a\u0637 \u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629 \u0648\u0634\u0631\u0643\u0627\u062a \u062f\u0648\u0644\u064a\u0629.\u0648\u0627\u0654\u062b\u0627\u0631 \u0648\u0632\u064a\u0631 \u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u0642\u0648\u0645\u064a \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u0627\u0655\u064a\u062a\u0645\u0627\u0631 \u0628\u0646 \u063a\u0641\u064a\u0631 \u062c\u062f\u0644\u0627\u064b \u0648\u0627\u0633\u0639\u0627\u064b \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0628\u0639\u062f\u0645\u0627 \u0646\u0634\u0631 \u0645\u0642\u0637\u0639 \u0641\u064a\u062f\u064a\u0648 \u064a\u0648\u062b\u0642 \u0627\u062d\u062a\u062c\u0627\u0632 \u0646\u0627\u