%85%D8%B2\">\u0627\u0655\u064a\u0631\u0627\u0646 </a>\u0643\u0627\u0646\u062a \"\u0645\u062c\u0631\u062f \u0627\u0646\u0639\u0637\u0627\u0641\u0629 \u0628\u0633\u064a\u0637\u0629\" \u062e\u0644\u0627\u0644 \u0648\u0644\u0627\u064a\u062a\u0647 \u0627\u0644\u062b\u0627\u0646\u064a\u0629\u060c \u0641\u064a \u0638\u0644 \u0627\u0633\u062a\u0637\u0644\u0627\u0639\u0627\u062a \u0631\u0627\u0654\u064a \u062d\u062f\u064a\u062b\u0629 \u062a\u064f\u0638\u0647\u0631 \u0639\u062f\u0645 \u0634\u0639\u0628\u064a\u0629 \u0627\u0644\u062d\u0631\u0628 \u0644\u062f\u0649 \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a.<br /><br />\u0648\u0641\u064a \u0644\u0642\u0627\u0621 \u0627\u064f\u0654\u0642\u064a\u0645 \u0641\u064a \u0644\u0627\u0633 \u0641\u064a\u063a\u0627\u0633 \u0628\u0648\u0644\u0627\u064a\u0629 \u0646\u064a\u0641\u0627\u062f\u0627 \u0644\u0644\u062a\u0631\u0648\u064a\u062c \u0644\u0642\u0627\u0646\u0648\u0646 \"\u0627\u0655\u0644\u063a\u0627\u0621 \u0627\u0644\u0636\u0631\u0627\u064a\u0654\u0628 \u0639\u0644\u0649 \u0627\u0644\u0627\u0655\u0643\u0631\u0627\u0645\u064a\u0627\u062a\" \u0644\u0644\u0639\u0645\u0627\u0644 \u0627\u0644\u0630\u064a \u0627\u0654\u0642\u0631 \u0636\u0645\u0646 \u0627\u0644\u0627\u0655\u0635\u0644\u0627\u062d \u0627\u0644\u0636\u0631\u064a\u0628\u064a \u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u062a\u0641\u0627\u062e\u0631 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0628\u0627\u0644\u063a 79 \u0639\u0627\u0645\u0627 \u0628\u0627\u0655\u0646\u062c\u0627\u0632\u0627\u062a\u0647 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629 \u0645\u0646\u0630 \u0639\u0648\u062f\u062a\u0647 \u0627\u0655\u0644\u0649 \u0645\u0646\u0635\u0628\u0647 \u0639\u0627\u0645 2025.<br /> <h2>\u0627\u0644\u0642\u062f\u0631\u0627\u062a \u0627\u0644\u0646\u0648\u0648\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629</h2>\u0648\u0642\u0627\u0644 <a href=\"https://www.alyaum.com/articles/6656567/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A8%D8%B9%D8%AF-%D8%AA%D9%87%D8%AF%D9%8A%D8%AF-%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D8%A7%D9%84%D8%A7%D8%AA%D8%AD%D8%A7%D8%AF-%D8%A7%D9%84%D8%A3%D9%88%D8%B1%D9%88%D8%A8%D9%8A-%D9%88%D8%A7%D9%84%D9%86%D8%A7%D8%AA%D9%88-%D9%8A%D8%A8%D8%AD%D8%AB%D8%A7%D9%86-%D8%B2%D9%8A%D8%A7%D8%AF%D8%A9-%D8%A5%D9%86%D8%AA%D8%A7%D8%AC-%D8%A7%D9%84%D8%A3%D8%B3%D9%84%D8%AD%D8%A9\">\u062a\u0631\u0627\u0645\u0628 </a>\u0627\u0654\u0645\u0627\u0645 \u062d\u0634\u062f \u0645\u0646 \u0627\u0654\u0646\u0635\u0627\u0631\u0647: \"\u062d\u0642\u0642\u0646\u0627 \u0627\u0654\u0641\u0636\u0644 \u0627\u0642\u062a\u0635\u0627\u062f \u0641\u064a \u062a\u0627\u0631\u064a\u062e \u0628\u0644\u0627\u062f\u0646\u0627 (...) \u0631\u063a\u0645 \u0627\u0644\u0627\u0646\u0639\u0637\u0627\u0641\u0629 \u0627\u0644\u0628\u0633\u064a\u0637\u0629 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646 \u0627\u0644\u062c\u0645\u064a\u0644\u0629\". \u0627\u0654\u0636\u0627\u0641: \"\u0644\u0643\u0646 \u0643\u0627\u0646 \u0639\u0644\u064a\u0646\u0627 \u0641\u0639\u0644 \u0630\u0644\u0643\u060c \u0644\u0627\u0654\u0646\u0647 \u0644\u0648\u0644\u0627 \u0630\u0644\u0643\u060c \u0627\u0654\u0645\u0648\u0631 \u0633\u064a\u064a\u0654\u0629 \u0642\u062f \u062a\u062d\u0635\u0644\u060c \u0627\u0654\u0645\u0648\u0631 \u0633\u064a\u064a\u0654\u0629 \u062c\u062f\u0627\"\u060c \u0641\u064a \u0627\u0655\u0634\u0627\u0631\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0642\u062f\u0631\u0627\u062a \u0627\u0644\u0646\u0648\u0648\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629.<br /><br />\u0648\u0627\u0654\u0643\u062f \u062a\u0631\u0627\u0645\u0628: \"\u0646\u062d\u0646 \u0639\u0644\u0649 \u0648\u0634\u0643 \u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0646\u0635\u0631\"\u060c \u0645\u0636\u064a\u0641\u0627: \"\u0642\u0636\u064a\u0646\u0627 17 \u0639\u0627\u0645\u0627 \u0641\u064a \u0641\u064a\u062a\u0646\u0627\u0645 \u0648\u062e\u0645\u0633\u0629 \u0627\u0654\u0639\u0648\u0627\u0645 \u0641\u064a \u0627\u0654\u0641\u063a\u0627\u0646\u0633\u062a\u0627\u0646 \u0648\u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0630\u0644\u0643 \u0628\u0643\u062b\u064a\u0631 \u0641\u064a \u0627\u0654\u0645\u0627\u0643\u0646 \u0645\u062e\u062a\u0644\u0641\u0629. \u0627\u0654\u0645\u0627 \u0646\u062d\u0646\u060c \u0641\u0642\u062f \u0642\u0644\u062a \u0627\u0655\u0646\u0646\u0627 \u0644\u0645 \u0646\u0645\u0643\u062b \u0647\u0646\u0627\u0643 \u0633\u0648\u0649 \u0634\u0647\u0631\u064a\u0646\".<br /> <h2>\u0627\u0644\u062a\u0643\u0627\u0644\u064a\u0641 \u0627\u0644\u0628\u0627\u0647\u0638\u0629</h2>\u0648\u0627\u0654\u0638\u0647\u0631 \u0627\u0633\u062a\u0637\u0644\u0627\u0639 \u0644\u0644\u0631\u0627\u0654\u064a \u0627\u0654\u062c\u0631\u062a\u0647 \u0645\u0648\u0654\u0633\u0633\u0629 \u0627\u064a\u0628\u0633\u0648\u0633 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0627\u0644\u0645\u0627\u0636\u064a \u0627\u0654\u0646 51% \u0645\u0646 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0627\u0654\u0644\u0641 \u0645\u0634\u0627\u0631\u0643 \u064a\u0639\u062a\u0642\u062f\u0648\u0646 \u0627\u0654\u0646 \u0627\u0644\u062d\u0631\u0628 \u0645\u0639 \u0627\u0655\u064a\u0631\u0627\u0646 \u0644\u0645 \u062a\u0643\u0646 \u062a\u0633\u062a\u062d\u0642 \u0627\u0644\u062a\u0643\u0627\u0644\u064a\u0641 \u0627\u0644\u0628\u0627\u0647\u0638\u0629 \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629 \u0628\u0647\u0627.<br /><br />\u0648\u0642\u0627\u0644 \u0627\u0654\u0642\u0644 \u0645\u0646 \u0631\u0628\u0639 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0641\u064a \u0627\u0644\u0627\u0633\u062a\u0637\u0644\u0627\u0639\u060c \u0627\u0654\u064a 24%\u060c \u0639\u0643\u0633 \u0630\u0644\u0643.<br /> <h2>\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0628\u0646\u0632\u064a\u0646</h2>\u0648\u0641\u064a \u0627\u0633\u062a\u06