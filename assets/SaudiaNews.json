u0649 26.1 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0628\u0627\u0644\u0631\u0628\u0639 \u0627\u0644\u0627\u0654\u0648\u0644 \u0645\u0646 2026", "description": "\u0627\u0631\u062a\u0641\u0639\u062a \u0627\u0654\u0631\u0628\u0627\u062d \u0634\u0631\u0643\u0629 \u0627\u0644\u0628\u0646\u0649 \u0627\u0644\u062a\u062d\u062a\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u062f\u0627\u0645\u0629 \u0627\u0644\u0642\u0627\u0628\u0636\u0629 \"\u0633\u064a\u0633\u0643\u0648 \u0627\u0644\u0642\u0627\u0628\u0636\u0629\" \u0641\u064a \u0627\u0644\u0631\u0628\u0639 \u0627\u0644\u0627\u0654\u0648\u0644 \u0645\u0646 2026 \u0628\u0646\u0633\u0628\u0629 5.6% \u0627\u0655\u0644\u0649 26.1 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0645\u0642\u0627\u0628\u0644 24.7 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0641\u064a \u0627\u0644\u0631\u0628\u0639 \u0627\u0644\u0645\u0645\u0627\u062b\u0644 \u0645\u0646 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0645\u0627\u0636\u064a.<br /><br />\u0648\u0648\u0641\u0642\u0627 \u0644\u0628\u064a\u0627\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\"\u060c \u064a\u064f\u0639\u0632\u0649 \u0647\u0630\u0627 \u0627\u0644\u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0655\u0644\u0649 \u0645\u0627 \u064a\u0644\u064a:<br /><br />\u2022 \u062a\u062d\u0642\u064a\u0642 \u0646\u0645\u0648 \u0642\u0648\u064a \u0641\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u062f\u0627\u062a \u0628\u0645\u0642\u062f\u0627\u0631 98.6 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0648\u062a\u062d\u0633\u0646 \u0641\u064a \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0631\u0628\u062d \u0628\u0645\u0642\u062f\u0627\u0631 40.1 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644.<br /><br />\u2022 \u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u062f\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u0631\u0649 \u0628\u0645\u0642\u062f\u0627\u0631 3.3 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644.<br /><br />\u0648\u0642\u062f \u0642\u0627\u0628\u0644 \u0647\u0630\u0647 \u0627\u0644\u0632\u064a\u0627\u062f\u0629 \u0645\u0627 \u064a\u0644\u064a:<br /><br />\u2022 \u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0644\u0645\u0635\u0631\u0648\u0641\u0627\u062a \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0628\u0645\u0642\u062f\u0627\u0631 27.8 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0648\u0627\u0631\u062a\u0641\u0627\u0639 \u062a\u0643\u0627\u0644\u064a\u0641 \u0627\u0644\u062a\u0645\u0648\u064a\u0644 \u0628\u0645\u0642\u062f\u0627\u0631 11.0 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0648\u064a\u064f\u0639\u0632\u0649 \u0630\u0644\u0643 \u0628\u0634\u0643\u0644 \u0631\u064a\u0654\u064a\u0633\u064a \u0627\u0655\u0644\u0649 \u0642\u0637\u0627\u0639\u064a \u0627\u0644\u0645\u0648\u0627\u0646\u064a\u0654 \u0648\u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0644\u0648\u062c\u0633\u062a\u064a\u0629\u060c \u0648\u0644\u0627 \u0633\u064a\u0645\u0627 \u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u062d\u0637\u0627\u062a \u0627\u0644\u0645\u062a\u0639\u062f\u062f\u0629 \u0627\u0644\u0627\u0654\u063a\u0631\u0627\u0636 (MPT) \u0648\u0634\u0631\u0643\u0629 \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u0648\u0627\u0646\u064a\u0654 \u0648\u0627\u0644\u062a\u062e\u0632\u064a\u0646. (PSS).<br /><br />\u2022 \u0627\u0646\u062e\u0641\u0627\u0636 \u0627\u0644\u062f\u062e\u0644 \u0645\u0646 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0632\u0645\u064a\u0644\u0629 \u0627\u0644\u0645\u062d\u062a\u0633\u0628\u0629 \u0628\u062d\u0642\u0648\u0642 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0628\u0645\u0642\u062f\u0627\u0631 1.8 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644,<br /><br />\u0628\u0644\u063a \u0635\u0627\u0641\u064a \u0627\u0644\u0631\u0628\u062d \u0627\u0644\u0645\u064f\u0639\u0644\u0646 \u0644\u0644\u0631\u0628\u0639 \u0627\u0644\u0627\u0654\u0648\u0644 \u0645\u0646 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a\u060c 26.1 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0645\u0642\u0627\u0631\u0646\u0629\u064b \u0628\u0640 34.6 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0641\u064a \u0627\u0644\u0631\u0628\u0639 \u0627\u0644\u0631\u0627\u0628\u0639 \u0645\u0646 \u0639\u0627\u0645 2025. \u0648\u064a\u064f\u0639\u0632\u0649 \u0647\u0630\u0627 \u0627\u0644\u0627\u0646\u062e\u0641\u0627\u0636 \u0627\u0655\u0644\u0649 \u0645\u0627 \u064a\u0644\u064a:<br /><br />\u2022 \u0627\u0646\u062e\u0641\u0627\u0636 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u062f\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u0631\u0649 \u0628\u0645\u0642\u062f\u0627\u0631 46.4 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0648\u064a\u064f\u0639\u0632\u0649 \u0630\u0644\u0643 \u0628\u0634\u0643\u0644 \u0631\u064a\u0654\u064a\u0633\u064a \u0627\u0655\u0644\u0649 \u0639\u0643\u0633 \u0645\u062e\u0635\u0635\u0627\u062a \u0627\u0644\u0645\u062d\u062a\u062c\u0632\u0627\u062a \u0641\u064a \u0634\u0631\u0643\u0629 \u0645\u062d\u0637\u0629 \u0628\u0648\u0627\u0628\u0629 \u0627\u0644\u0628\u062d\u0631 \u0627\u0644\u0627\u0654\u062d\u0645\u0631 (RSGT).<br /><br />\u2022 \u0627\u0646\u062e\u0641\u0627\u0636 \u0627\u0644\u062f\u062e\u0644 \u0645\u0646 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0632\u0645\u064a\u0644\u0629 \u0627\u0644\u0645\u062d\u062a\u0633\u0628\u0629 \u0628\u062d\u0642\u0648\u0642 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0628\u0645\u0642\u062f\u0627\u0631 2.6 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644.<br /><br />\u2022 \u0627\u0646\u062e\u0641\u0627\u0636 \u062f\u062e\u0644 \u0627\u0644\u062a\u0645\u0648\u064a\u0644 \u0628\u0645\u0642\u062f\u0627\u0631 3.3 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644.<br /><br />\u0648\u0642\u062f \u062a\u0645 \u062a\u0639\u0648\u064a\u0636 \u0647\u0630\u0627 \u0627\u0644\u0627\u0646\u062e\u0641\u0627\u0636 \u062c\u0632\u064a\u0654\u064a\u064b\u0627 \u0628\u0645\u0627 \u064a\u0644\u064a:<br /><br />\u2022 \u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0631\u0628\u062d \u0628\u0645\u0642\u062f\u0627\u0631 29.8 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644.<br /><br />\u2022 \u0627\u0646\u062e\u0641\u0627\u0636 \u0627\u0644\u0645\u0635\u0631\u0648\u0641\u0627\u062a \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0628\u0645\u0642\u062f\u0627\u0631 21.0 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0648\u064a\u064f\u0639\u0632\u0649 \u0630\u0644\u0643 \u0628\u0634\u0643\u0644 \u0631\u064a\u0654\u064a\u0633\u064a \u0627\u0655\u0644\u0649 \u062a\u0633\u062c\u064a\u0644 \u062a\u0643\u0627\u0644\u064a\u0641 \u0645\u0627 \u0642\u0628\u0644 \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0644\u0645\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u062d\u0637\u0627\u062a \u0645\u062a\u0639\u062f\u062f\u0629 \u0627\u0644\u0627\u0654\u063a\u0631\u0627\u0636 (MPT) \u062e\u0644\u0627\u0644 \u0627\u0644\u0631\u0628\u0639 \u0627\u0644\u0631\u0627\u0628\u0639 \u0645\u0646 \u0639\u0627\u0645 2025.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["business"], "datatype": "news", "pubDate": "2026-05-10 07:14:00", "pubDateTZ": "UTC", "fetched_at": "2026-05-10 07:48:17", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL A