ABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "1a5abc779a66c0eb1bd3b79008052dfa", "link": "https://www.alyaum.com/articles/6671542/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D9%84%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%AA%D8%B3%D8%AA%D8%AD%D9%88%D8%B0-%D8%B9%D9%84%D9%89-40-%D9%85%D9%86-%D8%A7%D9%84%D9%85%D8%B4%D8%A7%D8%B1%D9%8A%D8%B9-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%AE%D9%84%D8%A7%D9%84-%D9%8A%D9%88%D9%86%D9%8A%D9%88-2026", "title": "\u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u062a\u0633\u062a\u062d\u0648\u0630 \u0639\u0644\u0649 40% \u0645\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u062e\u0644\u0627\u0644 \u064a\u0648\u0646\u064a\u0648 2026", "description": "\u0634\u0647\u062f \u0634\u0647\u0631 \u064a\u0648\u0646\u064a\u0648 2026 \u0627\u0654\u0639\u0644\u0649 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0644\u0645\u0631\u0633\u0627\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0639\u0627\u0644\u0645 \u0627\u0644\u062c\u0627\u0631\u064a\u060c \u0628\u0627\u0655\u062c\u0645\u0627\u0644\u064a 25 \u0645\u0634\u0631\u0648\u0639\u064b\u0627\u060c \u0628\u0642\u064a\u0645\u0629 \u0628\u0644\u063a\u062a 29.5 \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644 (7.84 \u0645\u0644\u064a\u0627\u0631 \u062f\u0648\u0644\u0627\u0631 \u0627\u0654\u0645\u0631\u064a\u0643\u064a)\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u062a\u0642\u0631\u064a\u0631 \"\u062a\u0648\u0642\u0639\u0627\u062a \u0642\u0637\u0627\u0639 \u0627\u0644\u0645\u0642\u0627\u0648\u0644\u0627\u062a \u2013 \u064a\u0648\u0646\u064a\u0648 2026\" \u0627\u0644\u0635\u0627\u062f\u0631 \u0639\u0646 \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0644\u0644\u0645\u0642\u0627\u0648\u0644\u064a\u0646.<br /><br />\u0648\u0648\u0641\u0642\u064b\u0627 \u0644\u0644\u062a\u0642\u0631\u064a\u0631\u060c \u0633\u062c\u0644 \u0634\u0647\u0631 \u064a\u0648\u0646\u064a\u0648 \u0627\u0654\u0639\u0644\u0649 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0645\u064f\u0631\u0633\u0627\u0629 \u0644\u0639\u0627\u0645 2026\u060c \u0644\u064a\u062d\u062a\u0644 \u0628\u0630\u0644\u0643 \u0627\u0644\u0645\u0631\u062a\u0628\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0645\u0646 \u062d\u064a\u062b \u0627\u0644\u0642\u064a\u0645\u0629 \u0628\u0639\u062f \u0634\u0647\u0631 \u0645\u0627\u064a\u0648\u060c \u0627\u0644\u0630\u064a \u062a\u062c\u0627\u0648\u0632\u062a \u0641\u064a\u0647 \u0642\u064a\u0645\u0629 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 30 \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644.<h2>\u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0645\u0646 \u062d\u064a\u062b \u0639\u062f\u062f \u0627\u0644\u0645\u0634\u0631\u0648\u0639\u0627\u062a</h2>\u0648\u0627\u0633\u062a\u062d\u0648\u0630 \u0642\u0637\u0627\u0639<a href=\"https://www.alyaum.com/articles/6670789/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D8%B9%D9%82%D8%A7%D8%B1%D8%A7%D8%AA/%D9%84%D8%A7%D8%A6%D8%AD%D8%A9-%D8%AA%D9%85%D9%84%D9%83-%D8%BA%D9%8A%D8%B1-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D9%8A%D9%86-%D9%84%D9%84%D8%B9%D9%82%D8%A7%D8%B1-%D9%87%D9%88%D9%8A%D8%A9-%D8%B1%D9%82%D9%85%D9%8A%D8%A9-%D9%88%D8%BA%D8%B1%D8%A7%D9%85%D8%A7%D8%AA-%D8%A810-%D9%85%D9%84%D8%A7%D9%8A%D9%8A%D9%86-%D8%B1%D9%8A%D8%A7%D9%84-%D9%84%D9%84%D9%85%D8%AE%D8%A7%D9%84%D9%81%D9%8A%D9%86\" target=\"_blank\"> \u0627\u0644\u0628\u0646\u0627\u0621 \u0648\u0627\u0644\u062a\u0634\u064a\u064a\u062f</a> \u0639\u0644\u0649 \u0627\u0644\u062d\u0635\u0629 \u0627\u0644\u0627\u0654\u0643\u0628\u0631 \u0645\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639\u060c \u0628\u0648\u0627\u0642\u0639 14 \u0645\u0634\u0631\u0648\u0639\u064b\u0627 \u0628\u0642\u064a\u0645\u0629 \u062a\u0632\u064a\u062f \u0639\u0646 20.6 \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644\u060c \u0645\u0627 \u064a\u0645\u062b\u0644 56% \u0645\u0646 \u0627\u0644\u0627\u0655\u062c\u0645\u0627\u0644\u064a. \u062a\u0644\u0627\u0647 \u0642\u0637\u0627\u0639 \u0627\u0644\u0628\u0646\u064a\u0629 \u0627\u0644\u062a\u062d\u062a\u064a\u0629 \u0648\u0642\u0637\u0627\u0639 \u0627\u0644\u0645\u064a\u0627\u0647 \u0648\u0627\u0644\u0637\u0627\u0642\u0629\u060c \u0628\u0646\u0633\u0628\u0629 20% \u0644\u0643\u0644 \u0645\u0646\u0647\u0645\u0627\u060c \u0628\u064a\u0646\u0645\u0627 \u0634\u0643\u0644 \u0642\u0637\u0627\u0639 \u0627\u0644\u0646\u0641\u0637 \u0648\u0627\u0644\u063a\u0627\u0632 4%.<br /><br />\u0648\u062a\u0635\u062f\u0631\u062a \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u0642\u0627\u064a\u0654\u0645\u0629 \u0627\u0644\u0645\u0646\u0627\u0637\u0642 \u0645\u0646 \u062d\u064a\u062b \u0639\u062f\u062f<a href=\"https://www.alyaum.com/articles/6670558/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%87%D9%8A%D8%A6%D8%A9-%D8%A7%D9%84%D8%B9%D9%82%D8%A7%D8%B1-%D8%AA%D9%86%D9%81%D8%B0-27-%D8%AC%D9%88%D9%84%D8%A9-%D8%B1%D9%82%D8%A7%D8%A8%D9%8A%D8%A9-%D9%84%D8%B6%D9%85%D8%A7%D9%86-%D8%A7%D9%84%D8%A7%D9%85%D8%AA%D8%AB%D8%A7%D9%84-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D9%88%D9%82-%D8%A7%D9%84%D8%B9%D9%82%D8%A7%D8%B1%D9%8A\" target=\"_blank\"> \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0645\u064f\u0631\u0633\u0627\u0629</a> \u062e\u0644\u0627\u0644 \u0634\u0647\u0631 \u064a\u0648\u0646\u064a\u0648\u060c \u0628\u0648\u0627\u0642\u0639 10 \u0645\u0634\u0627\u0631\u064a\u0639 \u062a\u0645\u062b\u0644 40% \u0645\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639. \u0643\u0645\u0627 \u0627\u062d\u062a\u0644\u062a \u0627\u0644\u0645\u0631\u062a\u0628\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0645\u0646 \u062d\u064a\u062b \u0642\u064a\u0645\u0629 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u060c \u0628\u0627\u0655\u062c\u0645\u0627\u0644\u064a \u062a\u062c\u0627\u0648\u0632 11.4 \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644\u060c \u062a\u0644\u062a\u0647\u0627 \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0631\u064a\u0627\u0636 \u0628\u0627\u0654\u0643\u062b\u0631 \u0645\u0646 10.8 \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644.<br /><br />\u0648\u062a\u0648\u0632\u0639\u062a \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0639\u0644\u0649 14 \u0642\u0637\u0627\u0639\u064b\u0627 \u0641\u0631\u0639\u064a\u064b\u0627. \u0648\u0633\u062c\u0644\u062a \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0627\u0644\u0639\u062f\u062f \u0627\u0644\u0627\u0654\u0643\u0628\u0631\u060c \u0628\u0648\u0627\u0642\u0639 4 \u0645\u0634\u0627\u0631\u064a\u0639\u060c \u0628\u064a\u0646\u0645\u0627 \u062d\u0642\u0642 \u0642\u0637\u0627\u0639 \u0627\u0644\u0634\u0642\u0642 \u0627\u0644\u0633\u0643\u0646\u064a\u0629 \u0645\u062a\u0639\u062f\u062f\u0629 \u0627\u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645\u0627\u062a \u0627\u0654\u0639\u0644\u0649 \u0642\u064a\u0645\u0629 \u0645\u0627\u0644\u064a\u0629\u060c \u0645\u062a\u062c\u0627\u0648\u0632\u064b\u0627 6 \u0645\u0644\u064a\u0627\u0631\u0627\u062a \u0631\u064a\u0627\u0644.<h2>\u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u062e\u0644\u0627\u0644 \u064a\u0648\u0644\u064a\u0648 2026</h2> <br />\u0648\u062a\u0648\u0642\u0639 \u0627\u0644\