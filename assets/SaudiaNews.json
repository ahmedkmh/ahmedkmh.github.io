\u064a \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u0627\u0644\u062a\u062c\u0631\u064a\u0628\u064a\u062a\u064a\u0646 \u0636\u062f \u0643\u0644 \u0645\u0646 \u0628\u0644\u062c\u064a\u0643\u0627 \u0648\u0627\u0644\u0628\u0631\u062a\u063a\u0627\u0644\u060c \u0628\u0633\u0628\u0628 \u0627\u0655\u0635\u0627\u0628\u0629 \u0641\u064a \u0627\u0644\u0641\u062e\u0630\u060c \u0628\u064a\u0646\u0645\u0627 \u0645\u0646 \u0627\u0644\u0645\u0631\u062c\u062d \u0627\u0654\u064a\u0636\u064b\u0627 \u0627\u0654\u0646 \u064a\u0643\u0648\u0646 \u0643\u0631\u064a\u0633 \u0631\u064a\u062a\u0634\u0627\u0631\u062f\u0632 \u062e\u0627\u0631\u062c \u0627\u0644\u062d\u0633\u0627\u0628\u0627\u062a \u0644\u0644\u0645\u0628\u0627\u0631\u0627\u062a\u064a\u0646 \u0628\u0633\u0628\u0628 \u0645\u0634\u0643\u0644\u0629 \u0641\u064a \u0627\u0644\u0631\u0643\u0628\u0629. \u0648\u062a\u0634\u0643\u0644 \u0647\u0627\u062a\u064a\u0646 \u0627\u0644\u0627\u0655\u0635\u0627\u0628\u062a\u064a\u0646 \u0645\u0639\u0636\u0644\u0629 \u0644\u0644\u0645\u062f\u0631\u0628 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0645\u0627\u0648\u0631\u064a\u0633\u064a\u0648 \u0628\u0648\u0643\u064a\u062a\u064a\u0646\u0648 \u0627\u0654\u0632\u0645\u0629 \u0628\u0633\u0628\u0628 \u0646\u0642\u0635 \u0627\u0644\u062e\u064a\u0627\u0631\u0627\u062a \u0627\u0644\u062f\u0641\u0627\u0639\u064a\u0629 \u0627\u0644\u0645\u062a\u0627\u062d\u0629\u060c \u0641\u064a \u0627\u0653\u062e\u0631 \u0645\u0628\u0627\u0631\u0627\u062a\u064a\u0646 \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0639\u0644\u0646 \u0642\u0627\u064a\u0654\u0645\u0629 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645. \u0648\u064a\u062a\u0648\u0641\u0631 \u0644\u0628\u0648\u0643\u064a\u062a\u064a\u0646\u0648 \u062d\u0627\u0644\u064a\u064b\u0627 \u062b\u0644\u0627\u062b\u0629 \u0644\u0627\u0639\u0628\u064a\u0646 \u0641\u0642\u0637 \u0641\u064a \u0645\u0631\u0643\u0632 \u0642\u0644\u0628 \u062