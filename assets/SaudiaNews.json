46\u064a \u0627\u0644\u0633\u062a\u0627\u0631 \u0639\u0644\u0649 \u0645\u0634\u0627\u0631\u0643\u062a\u0647 \u0641\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026 \u0628\u062e\u0633\u0627\u0631\u0629 \u0645\u0648\u0654\u0644\u0645\u0629 \u0627\u0654\u0645\u0627\u0645 \u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627 \u0641\u064a \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u0644\u062a\u0628\u062f\u0627\u0654 \u0645\u0639\u0647\u0627 \u062a\u0633\u0627\u0648\u0654\u0644\u0627\u062a \u0643\u0628\u064a\u0631\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0627\u0654\u0648\u0633\u0627\u0637 \u0627\u0644\u0643\u0631\u0648\u064a\u0629: \u0647\u0644 \u0643\u0627\u0646\u062a \u062a\u0644\u0643 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0639\u0635\u0631 \u0627\u0644\u0630\u0647\u0628\u064a \u0644\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0628\u0642\u064a\u0627\u062f\u0629 \u0644\u064a\u0648\u0646\u064a\u0644 \u0645\u064a\u0633\u064a\u060c \u0627\u0654\u0645 \u0627\u0654\u0646 \"\u0627\u0644\u062a\u0627\u0646\u063a\u0648\" \u064a\u0645\u0644\u0643 \u0645\u0627 \u064a\u0643\u0641\u064a \u0644\u0644\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0628\u064a\u0646 \u0643\u0628\u0627\u0631 \u0627\u0644\u0639\u0627\u0644\u0645\u061f<br /> </p><p>\u064a\u0635\u0639\u0628 \u0627\u0644\u062d\u062f\u064a\u062b \u0639\u0646 \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0633\u0646\u0648\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u062f\u0648\u0646 \u0630\u0643\u0631 \u0644\u064a\u0648\u0646\u064a\u0644 \u0645\u064a\u0633\u064a\u060c \u0627\u0644\u0630\u064a \u0642\u0627\u062f \u0628\u0644\u0627\u062f\u0647 \u0644\u062a\u062d\u0642\u064a\u0642 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2022\u060c \u0648\u0643\u0627\u0654\u0633\u064e\u064a \u0643\u0648\u0628\u0627 \u0627\u0654\u0645\u0631\u064a\u0643\u0627 2021 \u06482024\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0628\u0644\u063a \u0646\u0647\u0627\u064a\u0654\u064a \u0645\u0648\u0646\u062f\u064a\u0627\u0644 2026 \u0648\u0647\u0648 \u0641\u064a \u0627\u0644\u062a\u0627\u0633\u0639\u0629 \u0648\u0627\u0644\u062b\u0644\u0627\u062b\u064a\u0646 \u0645\u0646 \u0639\u0645\u0631\u0647\u060c \u0645\u0642\u062f\u0645\u0627\u064b \u0628\u0637\u0648\u0644\u0629 \u0627\u0633\u062a\u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0627\u0654\u0643\u062f \u062e\u0644\u0627\u0644\u0647\u0627 \u0627\u0644\u0645\u062f\u0631\u0628 \u0644\u064a\u0648\u0646\u064a\u0644 \u0633\u0643\u0627\u0644\u0648\u0646\u064a \u0627\u0654\u0646\u0647 \"\u0644\u0627 \u064a\u0632\u0627\u0644 \u0627\u0644\u0644\u0627\u0639\u0628 \u0627\u0644\u0627\u0654\u0639\u0638\u0645\"\u060c \u0628\u0639\u062f\u0645\u0627 \u0633\u062c\u0644 \u062b\u0645\u0627\u0646\u064a\u0629 \u0627\u0654\u0647\u062f\u0627\u0641 \u0648\u062e\u0627\u0636 \u062c\u0645\u064a\u0639 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0627\u0644\u0627\u0655\u0642\u0635\u0627\u064a\u0654\u064a\u0629.<br /> </p><p>\u0644\u0643\u0646 \u0627\u0644\u0648\u0627\u0642\u0639 \u064a\u0641\u0631\u0636 \u0646\u0641\u0633\u0647. \u0641\u062c\u064a\u0644 \u0645\u064a\u0633\u064a \u064a\u0642\u062a\u0631\u0628 \u0645\u0646 \u0646\u0647\u0627\u064a\u0629 \u0631\u062d\u0644\u062a\u0647 \u0627\u0644\u062f\u0648\u0644\u064a\u0629\u060c \u0627\u0655\u0630 \u064a\u0636\u0645 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0639\u062f\u062f\u0627\u064b \u0645\u0646 \u0627\u0644\u0644\u0627\u0639\u0628\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u062a\u062c\u0627\u0648\u0632\u0648\u0627 \u0627\u0644\u062b\u0644\u0627\u062b\u064a\u0646 \u0639\u0627\u0645\u0627\u064b\u060c \u0648\u0641\u064a \u0645\u0642\u062f\u0645\u062a\u0647\u0645 \u0646\u064a\u0643\u0648\u0644\u0627\u0633 \u0627\u0654\u0648\u062a\u0627\u0645\u064a\u0646\u062f\u064a\u060c \u0628\u064a\u0646\u0645\u0627 \u0628\u0627\u062a \u0645\u0633\u062a\u0642\u0628\u0644 \u0645\u064a\u0633\u064a \u0645\u0639 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0645\u062d\u0644 \u062a\u0631\u0642\u0628 \u0628\u0639\u062f \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0628\u0637\u0648\u0644\u0629\u060c \u0641\u064a \u0648\u0642\u062a \u0644\u0645\u062d \u0641\u064a\u0647 \u0633\u0643\u0627\u0644\u0648\u0646\u064a \u0627\u0654\u064a\u0636\u0627\u064b \u0627\u0655\u0644\u0649 \u062d\u0627\u062c\u062a\u0647 \u0644\u0644\u062a\u0641\u0643\u064a\u0631 \u0641\u064a \u0645\u0633\u062a\u0642\u0628\u0644\u0647 \u0645\u0639 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0639\u0642\u0628 \u0627\u0644\u062e\u0633\u0627\u0631\u0629 \u0641\u064a \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a.<br /> </p><p>\u0648\u0631\u063a\u0645 \u0630\u0644\u0643\u060c \u0641\u0627\u0655\u0646 \u0627\u0644\u062d\u062f\u064a\u062b \u0639\u0646 \"\u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\" \u064a\u0628\u062f\u0648 \u0645\u0628\u0627\u0644\u063a\u0627\u064b \u0641\u064a\u0647. \u0641\u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0628\u0644\u063a \u0646\u0647\u0627\u064a\u0654\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u062a\u0648\u0627\u0644\u064a\u0627\u064b\u060c \u0628\u0639\u062f \u0645\u0633\u064a\u0631\u0629 \u0642\u0648\u064a\u0629 \u0634\u0647\u062f\u062a \u0627\u0655\u0642\u0635\u0627\u0621 \u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627 \u0641\u064a \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u0648\u0627\u0654\u062b\u0628\u062a \u062e\u0644\u0627\u0644\u0647\u0627 \u0627\u0645\u062a\u0644\u0627\u0643\u0647 \u0634\u062e\u0635\u064a\u0629 \u0627\u0644\u0628\u0637\u0644 \u062d\u062a\u0649 \u0641\u064a \u0627\u0654\u0635\u0639\u0628 \u0627\u0644\u0644\u062d\u0638\u0627\u062a.<br /> </p><p>\u0643\u0645\u0627 \u0627\u0654\u0646 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0627\u0655\u062d\u0644\u0627\u0644 \u0628\u062f\u0627\u0654\u062a \u0628\u0627\u0644\u0641\u0639\u0644 \u0642\u0628\u0644 \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644\u060c \u0627\u0655\u0630 \u0628\u0631\u0632\u062a \u0627\u0654\u0633\u0645\u0627\u0621 \u0634\u0627\u0628\u0629 \u0642\u0627\u062f\u0631\u0629 \u0639\u0644\u0649 \u062d\u0645\u0644 \u0627\u0644\u0631\u0627\u064a\u0629 \u0645\u0633\u062a\u0642\u0628\u0644\u0627\u064b\u060c \u0645\u062b\u0644 \u0627\u0655\u0646\u0632\u0648 \u0641\u0631\u0646\u0627\u0646\u062f\u064a\u0632\u060c \u0648\u0627\u0654\u0644\u064a\u062e\u0627\u0646\u062f\u0631\u0648 \u063a\u0627\u0631\u0646\u0627\u062a\u0634\u0648\u060c \u0648\u0641\u0627\u0643\u0648\u0646\u062f\u0648 \u0628\u0648\u0648\u0646\u0627\u0646\u0648\u062a\u064a\u060c \u0648\u062a\u064a\u0627\u062c\u0648 \u0627\u0654\u0644\u0645\u0627\u062f\u0627\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0639\u0646\u0627\u0635\u0631 \u0641\u064a \u0627\u0654\u0648\u062c \u0639\u0637\u0627\u064a\u0654\u0647\u0627 \u0645\u062b\u0644 \u0627\u0654\u0644\u064a\u0643\u0633\u064a\u0633 \u0645\u0627\u0643 \u0627\u0654\u0644\u064a\u0633\u062a\u0631\u060c \u0648\u062e\u0648\u0644\u064a\u0627\u0646 \u0627\u0654\u0644\u0641\u0627\u0631\u064a\u0632\u060c \u0648\u0644\u0627\u0648\u062a\u0627\u0631\u0648 \u0645\u0627\u0631\u062a\u064a\u0646\u064a\u0632.</p><p>\u0648\u064a\u0628\u0642\u0649 \u0627\u0644\u062a\u062d\u062f\u064a \u0627\u0644\u062d\u0642\u064a\u0642\u064a \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0647\u0648 \u0643\u064a\u0641\u064a\u0629 \u0627\u0644\u0627\u0646\u062a\u0642\u0627\u0644 \u0645\u0646 \"\u0645\u0646\u062a\u062e\u0628 \u0645\u064a\u0633\u064a\" \u0627\u0655\u0644\u0649 \"\u0645\u0646\u062a\u062e\u0628 \u0645\u0627 \u0628\u0639\u062f \u0645\u064a\u0633\u064a\"\u060c \u0648\u0647\u064a \u0645\u0631\u062d\u0644\u0629 \u0633\u0628\u0642 \u0627\u0654\u0646 \u0639\u0627\u0634\u062a\u0647\u0627 \u0645\u0646\u062a\u062e\u0628\u0627\u062a \u0643\u0628\u0631\u0649 \u0628\u0639\u062f \u0627\u0639\u062a\u0632\u0627\u0644 \u0646\u062c\u0648\u0645\u0647\u0627 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u064a\u0646. \u0641\u0627\u0644\u062a\u0627\u0631\u064a\u062e \u064a\u0648\u0654\u0643\u062f \u0627\u0654\u0646 \u0627\u0644\u0645\u0646\u062a\u062e\u0628\u0627\u062a \u0627\u0644\u0639\u0638\u064a\u0645\u0629 \u0644\u0627 \u062a\u062a\u0648\u0642\u0641 \u0639\u0646\u062f \u0644\u0627\u0639\u0628 \u0648\u0627\u062d\u062f\u060c \u0644\u0643\u0646\u0647\u0627 \u062a\u062d\u062a\u0627\u062c \u0627\u0655\u0644\u0649 \u0645\u0634\u0631\u0648\u0639 \u0648\u0627\u0636\u062d \u064a\u0645\u0646\u062d \u0627\u0644\u062c\u064a\u0644 \u0627\u0644\u062c\u062f\u064a\u062f \u0627\u0644\u0648\u0642\u062a \u0648\u0627\u0644\u0645\u0633\u0627\u062d\u0629 \u0644\u0643\u062a\u0627\u0628\u0629 \u0641\u0635\u0644\u0647 \u0627\u0644\u062e\u0627\u0635.<br /> </p><p>\u0642\u062f \u062a\u0643\u0648\u0646 \u062e\u0633\u0627\u0631\u0629 \u0646\u0647\u0627\u064a\u0654\u064a 2026 \u0646\u0647\u0627\u064a\u0629 \u0644\u062d\u0642\u0628\u0629 \u0627\u0633\u062a\u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0635\u0646\u0639\u062a\u0647\u0627 \u0645\u0648\u0647\u0628\u0629 \u0644\u064a\u0648\u0646\u064a\u0644 \u0645\u064a\u0633\u064a\u060c \u0644\u0643\u0646\u0647\u0627 \u0644\u0627 \u062a\u0639\u0646\u064a \u0628\u0627\u0644\u0636\u0631\u0648\u0631\u0629 \u0646\u0647\u0627\u064a\u0629 \u0642\u0648\u0629 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646. \u0641\u0640\"\u0627\u0644\u062a\u0627\u0646\u063a\u0648\" \u064a\u0645\u0644\u0643 \u0642\u0627\u0639\u062f\u0629 \u0645\u0646 \u0627\u0644\u0645\u0648\u0627\u0647\u0628 \u0648\u0645\u062f\u0631\u0628\u0627\u064b \u062d\u0627\u0644 \u0627\u0633\u062a\u0645\u0631\u0627\u0631\u064a\u062a\u0647 \u064a\u0639\u0631\u0641 \u0643\u064a\u0641 \u064a\u062c\u062f\u062f \u0627\u0644\u062f\u0645\u0627\u0621\u060c \u063a\u064a\u0631 \u0627\u0654\u0646 \u0627\u0644\u062a\u062d\u062f\u064a \u0627\u0644\u0627\u0654\u0643\u0628\u0631 \u0633\u064a\u0643\u0648\u0646 \u0627\u0655\u062b\u0628\u0627\u062a \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0642\u0627\u062f\u0631\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0646\u0627\u0641\u0633\u0629 \u0639\u0646\u062f\u0645\u0627 \u064a\u063a\u064a\u0628 \u0627\u0644\u0631\u0642\u0645 10 \u0639\u0646 \u0627\u0644\u0645\u0634\u0647\u062f \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629.</p>", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-07-20 11:11:00", "pubDateTZ": "UTC", "fetched_at": "2026-07-20 11:21:42", "image_url": "https://www.alyaum.com/uploads/images/2026/07/20/3054023.jpg", "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "de424bd54c9c3969d66345b74be65b5e", "link": "https://www.tehrantimes.com/news/528350/Iran-edged-by-Japan-at-2026-Asian-Junior-Handball-Championship", "title": "Iran edged by Japan at 2026 Asian Junior Handball Championship", "description": "TEHRAN \u2013 Iran were edged by Japan 28-27 at the 2026 Asian Junior Handball Championship on Monday.", "content": "ONLY AVAILABLE IN PAID PLANS