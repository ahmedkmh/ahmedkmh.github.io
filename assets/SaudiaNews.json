u0633\u0639 \u0646\u0642\u0627\u0637 \u0645\u0648\u0654\u0642\u062a\u064b\u0627 \u0639\u0646 \u062c\u0627\u0631\u0647 \u0648\u0645\u0637\u0627\u0631\u062f\u0647 \u0645\u064a\u0644\u0627\u0646. \u0648\u0627\u0654\u062d\u0631\u0632 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0644\u0627\u0648\u062a\u0627\u0631\u0648 \u0645\u0627\u0631\u062a\u064a\u0646\u064a\u0633 1 \u064852\u060c \u0648\u0627\u0644\u062a\u0631\u0643\u064a \u0647\u0627\u0643\u0627\u0646 \u062a\u0634\u0627\u0644\u0647\u0627\u0646\u0627\u0654\u0648\u062c\u0644\u0648 45+2\u060c \u0648\u0627\u0644\u0641\u0631\u0646\u0633\u064a \u0645\u0627\u0631\u0643\u0648\u0633 \u062a\u0648\u0631\u0627\u0645 55\u060c \u0648\u0646\u064a\u0643\u0648\u0644\u0648 \u0628\u0627\u0631\u064a\u0644\u0627 63\u060c \u0627\u0654\u0647\u062f\u0627\u0641 \u0627\u0655\u0646\u062a\u0631\u060c \u0641\u064a\u0645\u0627 \u0627\u0654\u062d\u0631\u0632 \u062c\u0627\u0646\u0644\u0648\u0643\u0627 \u0645\u0627\u0646\u0634\u064a\u0646\u064a 40\u060c \u0648\u0644\u0648\u0631\u0646\u062a\u0633\u0648 \u0628\u064a\u0644\u064a\u062c\u0631\u064a\u0646\u064a 70\u060c \u0647\u062f\u0641\u064a \u0631\u0648\u0645\u0627. \u0648\u0631\u0641\u0639 \u0627\u0655\u0646\u062a\u0631\u060c \u0627\u0644\u0639\u0627\u064a\u0654\u062f \u0627\u0655\u0644\u0649 \u0633\u0643\u0629 \u0627\u0644\u0627\u0646\u062a\u0635\u0627\u0631\u0627\u062a \u0628\u0639\u062f \u062a\u0639\u0627\u062f\u0644\u064a\u0646 \u0648\u0647\u0632\u064a\u0645\u0629\u060c \u0631\u0635\u064a\u062f\u0647 \u0627\u0655\u0644\u0649 72 \u0646\u0642\u0637\u0629 \u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0627\u0654\u0648\u0644\u060c \u0645\u0628\u062a\u0639\u062f\u064b\u0627 \u0628\u0641\u0627\u0631\u0642 \u062a\u0633\u0639 \u0646\u0642\u0627\u0637 \u0639\u0646 \u0645\u064a\u0644\u0627\u0646 \u0627\u0644\u062b\u0627\u0646\u064a\u060c \u064810 \u0639\u0646 \u0646\u0627\u0628\u0648\u0644\u064a \u0627\u0644\u062b\u0627\u0644\u062b. \u0641\u064a \u0627\u0644\u0645\