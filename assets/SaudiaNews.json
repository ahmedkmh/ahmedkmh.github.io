{"status": "success", "totalResults": 3261, "results": [{"article_id": "76b9b8d9ffa3815d65faffd554cdbcc8", "link": "https://www.alyaum.com/articles/6651800/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D9%86%D9%88%D8%A7%D9%81-%D8%B3%D9%84%D8%A7%D9%85-%D8%A7%D9%84%D8%AD%D8%B1%D8%B3-%D8%A7%D9%84%D8%AB%D9%88%D8%B1%D9%8A-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A-%D9%8A%D8%AF%D9%8A%D8%B1-%D8%B9%D9%85%D9%84%D9%8A%D8%A7%D8%AA-%D8%AD%D8%B2%D8%A8-%D8%A7%D9%84%D9%84%D9%87-%D9%81%D9%8A-%D9%84%D8%A8%D9%86%D8%A7%D9%86", "title": "\u0646\u0648\u0627\u0641 \u0633\u0644\u0627\u0645: \u0627\u0644\u062d\u0631\u0633 \u0627\u0644\u062b\u0648\u0631\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u064a\u062f\u064a\u0631 \u0639\u0645\u0644\u064a\u0627\u062a \u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0641\u064a \u0644\u0628\u0646\u0627\u0646", "description": "\u0642\u0627\u0644 <a href=\"https://www.alyaum.com/articles/6642545/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%B9%D8%A7%D8%AC%D9%84-%D8%AA%D8%B3%D9%84%D9%8A%D9%85-300-%D9%85%D9%88%D9%82%D9%88%D9%81-%D8%B3%D9%88%D8%B1%D9%8A-%D8%AA%D9%81%D8%A7%D8%B5%D9%8A%D9%84-%D8%A7%D9%84%D8%A7%D8%AA%D9%81%D8%A7%D9%82-%D8%A7%D9%84%D9%85%D9%86%D8%AA%D8%B8%D8%B1-%D8%A8%D9%8A%D9%86-%D8%A8%D9%8A%D8%B1%D9%88%D8%AA-%D9%88%D8%AF%D9%85%D8%B4%D9%82\" target=\"_blank\">\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a</a> \u0646\u0648\u0627\u0641 \u0633\u0644\u0627\u0645 \u0627\u0644\u0627\u0654\u062d\u062f \u0627\u0655\u0646 \u0639\u0646\u0627\u0635\u0631 \u0641\u064a <a href=\"https://www.alyaum.com/articles/6651638/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D8%AA%D8%B9%D9%84%D9%86-%D8%A5%D8%B5%D8%A7%D8%A8%D8%A9-%D9%85%D9%82%D8%A7%D8%AA%D9%84%D8%A9-%D8%A5%D8%B3%D8%B1%D8%A7%D8%A6%D9%8A%D9%84%D9%8A%D8%A9-%D9%88%D8%A7%D9%84%D8%A7%D8%AD%D8%AA%D9%84%D8%A7%D9%84-%D9%8A%D8%B6%D8%B1%D8%A8-%D9%85%D9%88%D8%A7%D9%82%D8%B9-%D9%84%D8%A5%D9%86%D8%AA%D8%A7%D8%AC-%D8%A7%D9%84%D8%B5%D9%88%D8%A7%D8%B1%D9%8A%D8%AE\" target=\"_blank\">\u0627\u0644\u062d\u0631\u0633 \u0627\u0644\u062b\u0648\u0631\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a</a> \u064a\u062f\u064a\u0631\u0648\u0646 \u0639\u0645\u0644\u064a\u0627\u062a \u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0641\u064a \u0627\u0644\u062d\u0631\u0628 \u0627\u0644\u062f\u0627\u064a\u0654\u0631\u0629 \u0645\u0639 <a href=\"https://www.alyaum.com/articles/6651787/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%B1%D8%A6%D9%8A%D8%B3-%D9%84%D8%A8%D9%86%D8%A7%D9%86-%D9%82%D8%B5%D9%81-%D8%A5%D8%B3%D8%B1%D8%A7%D8%A6%D9%8A%D9%84-%D9%84%D9%84%D8%A8%D9%86%D9%89-%D8%A7%D9%84%D8%AA%D8%AD%D8%AA%D9%8A%D8%A9-%D9%85%D9%82%D8%AF%D9%85%D8%A9-%D9%84%D8%BA%D8%B2%D9%88-%D8%A8%D8%B1%D9%8A\" target=\"_blank\">\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644</a>.<br /><br />\u0648\u0627\u0646\u062a\u0642\u062f \u0633\u0644\u0627\u0645 \u0641\u064a \u0645\u0642\u0627\u0628\u0644\u0629 \u0645\u0639 \u0634\u0628\u0643\u0629 \u0627\u0644\u062d\u062f\u062b\u060c \u0645\u062c\u062f\u062f\u0627 \u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0644\u062c\u0631\u0651\u0647 \u0644\u0628\u0646\u0627\u0646 \u0627\u0655\u0644\u0649 \u0627\u0644\u062d\u0631\u0628 \u0627\u0644\u062f\u0627\u064a\u0654\u0631\u0629 \u0641\u064a \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0628\u0627\u0655\u0637\u0644\u0627\u0642\u0647 \u0635\u0648\u0627\u0631\u064a\u062e \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0644\u0645\u062d\u062a\u0644\u0629.<br /><br />\u0648\u0642\u0627\u0644 \u0633\u0644\u0627\u0645 \"\u0633\u0645\u0651\u064a\u062a \u0647\u0630\u0647 \u0627\u0644\u062d\u0631\u0628 \u0639\u0644\u0649 \u0627\u0654\u0646\u0647\u0627 \u0644\u0644\u062b\u0627\u0654\u0631 \u0645\u0646 \u0627\u063a\u062a\u064a\u0627\u0644 \u0627\u0644\u062e\u0627\u0645\u0646\u064a\u0654\u064a\"\u060c \u0641\u064a \u0627\u0655\u0634\u0627\u0631\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0631\u0634\u062f \u0627\u0644\u0627\u0654\u0639\u0644\u0649 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0639\u0644\u064a \u062e\u0627\u0645\u0646\u064a\u0654\u064a \u0627\u0644\u0630\u064a \u0642\u064f\u062a\u0644 \u0641\u064a \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u0644\u0647\u062c\u0648\u0645 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a-\u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u0639\u0644\u0649 \u0627\u0655\u064a\u0631\u0627\u0646 \u0641\u064a 28 \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0648\u062a\u0627\u0628\u0639 \"\u0627\u0655\u0630\u0627 \u0647\u0630\u0627 \u064a\u0639\u0646\u064a \u062d\u0631\u0628 \u0641\u064f\u0631\u0636\u062a \u0639\u0644\u064a\u0646\u0627\".<br /> <h2>\u0642\u0627\u0639\u062f\u0629 \u0639\u0633\u0643\u0631\u064a\u0629 \u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0629</h2>\u0648\u0641\u064a \u0627\u0655\u0634\u0627\u0631\u0629 \u0627\u0655\u0644\u0649 \u0636\u0631\u0628\u0629 \u0628\u0645\u0633\u064a\u0651\u0631\u0629 \u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0627\u0654\u0635\u0627\u0628\u062a \u0642\u0627\u0639\u062f\u0629 \u0639\u0633\u0643\u0631\u064a\u0629 \u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0629 \u0641\u064a \u0642\u0628\u0631\u0635 \u0641\u064a \u0648\u0642\u062a \u0633\u0627\u0628\u0642 \u0645\u0646 \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u062d\u0627\u0644\u064a\u060c \u0634\u062f\u0651\u062f \u0633\u0644\u0627\u0645 \u0639\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u062d\u0631\u0633 \u0627\u0644\u062b\u0648\u0631\u064a \u0647\u0648 \u0627\u0644\u0630\u064a \u0627\u0654\u0637\u0644\u0642 \u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0627\u062a \u0645\u0646 \u0644\u0628\u0646\u0627\u0646 \u0639\u0644\u0649 \u0642\u0628\u0631\u0635.<br /><br />\u0648\u0644\u0641\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u062d\u0631\u0633 \u0627\u0644\u062b\u0648\u0631\u064a \"\u0645\u0648\u062c\u0648\u062f (\u0641\u064a \u0644\u0628\u0646\u0627\u0646) \u0648\u064a\u062f\u064a\u0631 \u0644\u0644\u0627\u0654\u0633\u0641 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u062d\u0631\u0628\u064a\u0629\"\u060c \u0648\u0627\u0654\u0636\u0627\u0641 \"\u0647\u0648\u0654\u0644\u0627\u0621 \u0644\u062f\u064a\u0647\u0645 \u062c\u0648\u0627\u0632\u0627\u062a \u0633\u0641\u0631 \u0645\u0632\u0648\u0651\u0631\u0629 \u0648\u062f\u062e\u0644\u0648\u0627 \u0627\u0644\u0628\u0644\u062f \u0628\u0635\u0648\u0631\u0629 \u063a\u064a\u0631 \u0634\u0631\u0639\u064a\u0629\".<br /><br />\u0648\u0643\u0627\u0646\u062a \u0645\u0633\u064a\u0651\u0631\u0629 \u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0627\u0644\u0635\u0646\u0639 \u0627\u0654\u0635\u0627\u0628\u062a \u0642\u0627\u0639\u062f\u0629 \u0639\u0633\u0643\u0631\u064a\u0629 \u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0629 \u0641\u064a \u0642\u0628\u0631\u0635 \u0641\u064a \u0648\u0642\u062a \u0633\u0627\u0628\u0642 \u0645\u0646 \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u062d\u0627\u0644\u064a\u060c \u0648\"\u0631\u062c\u0651\u062d\u062a\" \u0646\u064a\u0642\u0648\u0633\u064a\u0627 \u062d\u064a\u0646\u0647\u0627 \u0627\u0654\u0646 \u064a\u0643\u0648\u0646 \u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0647\u0648 \u0627\u0644\u062c\u0647\u0629 \u0627\u0644\u062a\u064a \u0627\u0654\u0637\u0644\u0642\u062a\u0647\u0627 \u0645\u0646 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a\u0629 \u0648\u0644\u064a\u0633 \u0645\u0646 \u0627\u0655\u064a\u0631\u0627\u0646.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["top", "business", "lifestyle"], "datatype": "news", "pubDate": "2026-03-22 22:12:00", "pubDateTZ": "UTC", "fetched_at": "202