0648\u0644\u062a \u0645\u0634\u0627\u062f\u0629 \u0643\u0644\u0627\u0645\u064a\u0629 \u0628\u064a\u0646 \u0645\u0647\u0646\u062f\u0633 \u0632\u0631\u0627\u0639\u064a \u0648\u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0627\u0654\u0647\u0627\u0644\u064a \u0627\u0655\u0644\u0649 \u0641\u0648\u0636\u0649 \u0645\u0631\u0639\u0628\u0629\u060c \u0643\u0627\u062f\u062a \u0627\u0654\u0646 \u062a\u062a\u062d\u0648\u0644 \u0627\u0655\u0644\u0649 \u0643\u0627\u0631\u062b\u0629 \u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0643\u0628\u0631\u0649 \u0628\u0639\u062f \u0627\u0654\u0646 \u062f\u0647\u0633 \u0639\u062f\u062f\u0627\u064b \u0645\u0646 \u0627\u0644\u0645\u0627\u0631\u0629 \u0648\u0635\u062f\u0645 \u0633\u064a\u0627\u0631\u0627\u062a \u0639\u062f\u0629.\u062a\u0628\u062f\u0627\u0654 \u0627\u0644\u0648\u0627\u0642\u0639\u0629 \u0639\u0646\u062f\u0645\u0627 \u0644\u0627\u062d\u0638 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0645\u0627\u0631\u0629 \u0627\u0654\u0646 \u0627\u0644\u0633\u064a\u0627\u0631\u0629 \u0627\u0644\u062a\u064a \u064a\u0642\u0648\u062f\u0647\u0627 \u0627\u0644\u0645\u0647\u0646\u062f\u0633 \u062a\u062d\u0645\u0644 \u0639\u0644\u0645 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0639\u0644\u0649 \u0632\u062c\u0627\u062c\u0647\u0627\u060c \u0645\u0627 \u0627\u0654\u062b\u0627\u0631 \u063a\u0636\u0628\u0647\u0645 \u0648\u062f\u0641\u0639\u0647\u0645 \u0644\u0644\u062a\u062f\u062e\u0644 \u0628\u0645\u0644\u0627\u062d\u0638\u0627\u062a\u0647\u0645. \u0648\u0627\u0646\u062f\u0644\u0639\u062a \u0645\u0634\u0627\u062f\u0629 \u0643\u0644\u0627\u0645\u064a\u0629 \u062d\u0627\u062f\u0629 \u0633\u0631\u0639\u0627\u0646 \u0645\u0627 \u062a\u0635\u0627\u0639\u062f\u062a\u060c \u0645\u0627 \u062c\u0639\u0644 \u0627\u0644\u0633\u0627\u064a\u0654\u0642 \u064a\u0634\u0639\u0631 \u0628\u0627\u0644\u062a\u0647\u062f\u064a\u062f \u0648\u064a\u0642\u0631\u0631 \u0627\u0644\u0647\u0631\u0648\u0628.\u0648\u0648\u0641\u0642\u0627\u064b \u0644\u0627\u0654\u0