\u0642\u0639\u060c \u0645\u0627 \u0627\u0654\u062b\u0627\u0631 \u0641\u0636\u0648\u0644 \u0627\u0644\u062c\u0645\u0647\u0648\u0631 \u0648\u062a\u0633\u0627\u0648\u0654\u0644\u0627\u062a\u0647\u0645 \u062d\u0648\u0644 \u0637\u0628\u064a\u0639\u0629 \u0627\u0644\u0634\u0631\u0643\u0629 \u0648\u0639\u0644\u0627\u0642\u062a\u0647\u0627 \u0628\u0627\u0644\u0641\u064a\u0644\u0645. \u0648 \u064a\u0636\u0645 \u0641\u064a\u0644\u0645 \u00ab\u0639\u0643\u0633 \u0633\u064a\u0631\u00bb \u0645\u062c\u0645\u0648\u0639\u0629 \u0645\u0646 \u0627\u0644\u0646\u062c\u0648\u0645\u060c \u064a\u062a\u0642\u062f\u0645\u0647\u0645 \u0639\u0628\u062f \u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0644\u0634\u0647\u0631\u064a\u060c \u0648\u0639\u0628\u062f \u0627\u0644\u0645\u062c\u064a\u062f \u0627\u0644\u0643\u0646\u0627\u0646\u064a\u060c \u0648\u0645\u0648\u0654\u064a\u062f \u0627\u0644\u0646\u0641\u064a\u0639\u064a\u060c \u0648\u0645\u0647\u0646\u062f \u0627\u0644\u0635\u0627\u0644\u062d\u060c \u0648\u0627\u0654\u0633\u0645\u0627\u0621 \u0627\u0644\u0633\u064a\u0627\u0631\u064a\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0641\u0648\u0632 \u0639\u0628\u062f \u0627\u0644\u0644\u0647\u060c \u0648\u0645\u0634\u0627\u0631\u064a \u0627\u0644\u0639\u062c\u0627\u062c\u064a\u060c \u0648\u0627\u0644\u0641\u0646\u0627\u0646 \u0627\u0644\u0642\u062f\u064a\u0631 \u062d\u0633\u0646 \u0627\u0644\u0639\u0628\u062f\u064a. \u0643\u0645\u0627 \u064a\u0634\u0627\u0631\u0643 \u0641\u064a \u0627\u0644\u0641\u064a\u0644\u0645 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0648\u062c\u0648\u0647 \u0627\u0644\u062c\u062f\u064a\u062f\u0629\u060c \u0645\u0646 \u0628\u064a\u0646\u0647\u0645 \u0634\u0646\u0627\u0631 \u0627\u0644\u062f\u0648\u0633\u0631\u064a \u0648\u0639\u0628\u062f \u0627\u0644\u0631\u062d\u0645\u0646 \u0627\u0644\u062c\u062f\u0639\u0627\u0646. \u0648\u064a\u064f\u0639\u062f \u00ab\u0639\u0643\u0633 \u0633\u064a\u0631\u00bb \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0627\u0644\u0631\u0