AA%D8%AC%D8%B1%D8%A8%D8%A9-%D8%A5%D9%86%D8%B3%D8%A7%D9%86%D9%8A%D8%A9-%D8%AB%D8%B1%D9%8A%D8%A9-%D8%AD%D8%A7%D8%AC%D8%A9-%D8%A5%D9%86%D8%AF%D9%88%D9%86%D9%8A%D8%B3%D9%8A%D8%A9-%D8%AA%D8%B1%D9%88%D9%8A-%D8%B1%D8%AD%D9%84%D8%A9-%D8%A7%D9%84%D8%AA%D8%B7%D9%84%D8%B9-%D8%A5%D9%84%D9%89-%D8%A7%D9%84%D8%AD%D8%AC", "title": "\u062a\u062c\u0631\u0628\u0629 \u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u062b\u0631\u064a\u0629.. \u062d\u0627\u062c\u0629 \u0627\u0655\u0646\u062f\u0648\u0646\u064a\u0633\u064a\u0629 \u062a\u0631\u0648\u064a \u0631\u062d\u0644\u0629 \u0627\u0644\u062a\u0637\u0644\u0639 \u0627\u0655\u0644\u0649 \u0627\u0644\u062d\u062c", "description": "\u062a\u062d\u0645\u0644 \u0642\u0635\u0629 \u0627\u0644\u062d\u0627\u062c\u0629 \u062e\u064a\u0631\u064a\u0629 \u0628\u0646\u062a \u0645\u062d\u0645\u062f \u0628\u0643\u0631\u064a\u060c \u0627\u0644\u0642\u0627\u062f\u0645\u0629 \u0645\u0646 \u0642\u0631\u064a\u0629 \u0628\u0646\u063a\u0643\u0648\u062a \u062a\u0648\u0628\u0648\u0644\u064a\u0648 \u0641\u064a \u0645\u0642\u0627\u0637\u0639\u0629 \u0645\u0627\u0644\u0648\u0643\u0648 \u0627\u0644\u0634\u0645\u0627\u0644\u064a\u0629 \u0628\u062c\u0645\u0647\u0648\u0631\u064a\u0629 <a href=\"https://www.alyaum.com/articles/6658142/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B5%D9%88%D8%B1-%D8%B3%D9%81%D9%8A%D8%B1-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D9%8A%D8%B7%D9%84%D8%B9-%D8%B9%D9%84%D9%89-%D8%AC%D8%A7%D9%87%D8%B2%D9%8A%D8%A9-%D8%B7%D8%B1%D9%8A%D9%82-%D9%85%D9%83%D8%A9-%D9%84%D8%AE%D8%AF%D9%85%D8%A9-%D8%AD%D8%AC%D8%A7%D8%AC-%D8%A5%D9%86%D8%AF%D9%88%D9%86%D9%8A%D8%B3%D9%8A%D8%A7\">\u0627\u0655\u0646\u062f\u0648\u0646\u064a\u0633\u064a\u0627</a>\u060c \u0645\u0644\u0627\u0645\u062d \u062a\u062c\u0631\u0628\u0629 \u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u062b\u0631\u064a\u0629 \u062a\u0639\u0643\u0633 \u0639\u0645\u0642 \u0627\u0644\u062a\u0639\u0644\u0651\u0642 \u0628\u0628\u064a\u062a \u0627\u0644\u0644\u0647 \u0627\u0644\u062d\u0631\u0627\u0645\u060c \u0648\u0645\u0627 \u064a\u0631\u0627\u0641\u0642\u0647 \u0645\u0646 \u0645\u0634\u0627\u0639\u0631 \u0627\u0644\u0634\u0648\u0642 \u0627\u0644\u0645\u0645\u062a\u062f\u0629 \u0644\u0633\u0646\u0648\u0627\u062a\u060c \u0641\u064a \u0645\u0634\u0647\u062f \u064a\u0628\u0631\u0632 \u0627\u0644\u0642\u064a\u0645 \u0627\u0644\u0627\u0655\u064a\u0645\u0627\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u062a\u0631\u0633\u062e \u0641\u064a \u0648\u062c\u062f\u0627\u0646 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0648\u0647\u0645 \u064a\u062a\u0631\u0642\u0628\u0648\u0646 \u0627\u0654\u062f\u0627\u0621 \u0627\u0644\u0631\u0643\u0646 \u0627\u0644\u062e\u0627\u0645\u0633 \u0645\u0646 \u0627\u0654\u0631\u0643\u0627\u0646 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0654\u0646 \u0627\u0654\u0645\u0646\u064a\u0629 \u0627\u0654\u062f\u0627\u0621 \u0641\u0631\u064a\u0636\u0629 \u0627\u0644\u062d\u062c \u0631\u0627\u0641\u0642\u062a\u0647\u0627 \u0645\u0646\u0630 \u0639\u0627\u0645 2013\u0645\u060c \u0648\u0638\u0644\u062a \u062d\u0627\u0636\u0631\u0629 \u0641\u064a \u062a\u0641\u0627\u0635\u064a\u0644 \u062d\u064a\u0627\u062a\u0647\u0627 \u0627\u0644\u064a\u0648\u0645\u064a\u0629\u060c \u062a\u062a\u062c\u062f\u062f \u0645\u0639 \u0643\u0644 <a href=\"https://www.alyaum.com/articles/6657519/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B5%D9%88%D8%B1-%D9%85%D8%BA%D8%A7%D8%AF%D8%B1%D8%A9-%D8%A3%D9%88%D9%84%D9%89-%D8%B1%D8%AD%D9%84%D8%A7%D8%AA-%D9%85%D8%B3%D8%AA%D9%81%D9%8A%D8%AF%D9%8A-%D9%85%D8%A8%D8%A7%D8%AF%D8%B1%D8%A9-%D8%B7%D8%B1%D9%8A%D9%82-%D9%85%D9%83%D8%A9-%D9%85%D9%86-%D8%B3%D9%88%D8%B1%D8%A7%D8%A8%D8%A7%D9%8A%D8%A7-%D9%81%D9%8A-%D8%A5%D9%86%D8%AF%D9%88%D9%86%D9%8A%D8%B3%D9%8A%D8%A7\">\u0645\u0648\u0633\u0645 \u062d\u062c</a>\u060c \u0648\u0645\