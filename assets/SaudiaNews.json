%D8%A1\">\u0627\u0644\u0633\u0648\u064a\u062f\u0627\u0621</a>\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u0642\u0639 \u0627\u0654\u0646\u062d\u0627\u0621 \u0641\u064a\u0647\u0627 \u062e\u0627\u0631\u062c \u0633\u064a\u0637\u0631\u0629 \u0633\u0644\u0637\u0627\u062a \u062f\u0645\u0634\u0642.<br /><br />\u0648\u0627\u0654\u0648\u0631\u062f \u0627\u0644\u062a\u0644\u0641\u0632\u064a\u0648\u0646 \u0627\u0644\u0631\u0633\u0645\u064a \u0646\u0642\u0644\u0627 \u0639\u0646 \u0645\u0635\u0627\u062f\u0631 \u0645\u062d\u0644\u064a\u0629 \u0642\u0648\u0644\u0647\u0627 \u0627\u0655\u0646 \"\u063a\u0627\u0631\u0627\u062a \u0644\u0637\u0627\u064a\u0654\u0631\u0627\u062a \u062d\u0631\u0628\u064a\u0629 \u064a\u0631\u062c\u062d \u0627\u0654\u0646\u0647\u0627 \u0627\u0654\u0631\u062f\u0646\u064a\u0629 \u062a\u0633\u062a\u0647\u062f\u0641 \u0645\u0642\u0631\u0627 \u064a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u0627\u0654\u0633\u0644\u062d\u0629 \u0648\u0645\u062e\u062f\u0631\u0627\u062a \u062a\u0633\u064a\u0637\u0631 \u0639\u0644\u064a\u0647 \u0627\u0644\u0639\u0635\u0627\u0628\u0627\u062a \u0627\u0644\u0645\u062a\u0645\u0631\u062f\u0629 \u0641\u064a \u0642\u0631\u064a\u0629 \u0634\u0647\u0628\u0627 \u0641\u064a \u0627\u0644\u0633\u0648\u064a\u062f\u0627\u0621\".<br /> <br />\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0645\u0635\u0627\u062f\u0631 \u0645\u062d\u0644\u064a\u0629 \u0645\u0631\u0627\u0633\u0644 \u0648\u0643\u0627\u0644\u0629 \u0641\u0631\u0627\u0646\u0633 \u0628\u0631\u0633 \u0628\u0627\u0654\u0646 \u0633\u0644\u0633\u0644\u0629 \u063a\u0627\u0631\u0627\u062a \u0627\u0633\u062a\u0647\u062f\u0641\u062a \u0645\u0648\u0627\u0642\u0639 \u0639\u062f\u0629 \u0641\u064a \u062e\u0645\u0633 \u0628\u0644\u062f\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0642\u0644\u060c \u0637\u0627\u0644\u062a \u0627\u0655\u062d\u062f\u0627\u0647\u0627 \u0645\u0633\u062a\u0648\u062f\u0639\u0627\u062a \u0641\u064a \u0628\u0644\u062f\u0629 \u0639\u0631\u0645\u0627\u0646.<h2>\u0639\