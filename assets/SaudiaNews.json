0648\u0642\u0639 <a href=\"https://www.alyaum.com/articles/6659617/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A3%D8%B1%D8%B5%D8%A7%D8%AF-%D8%A7%D9%86%D8%AE%D9%81%D8%A7%D8%B6-%D8%AF%D8%B1%D8%AC%D8%A7%D8%AA-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D8%A9-%D8%B9%D9%84%D9%89-%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D8%AD%D8%AF%D9%88%D8%AF-%D8%A7%D9%84%D8%B4%D9%85%D8%A7%D9%84%D9%8A%D8%A9-%D8%BA%D8%AF-%D8%A7%D9%84%D8%A7%D8%AB%D9%86%D9%8A%D9%86\" target=\"_blank\">\u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0644\u0627\u0654\u0631\u0635\u0627\u062f</a> \u0641\u064a \u062a\u0642\u0631\u064a\u0631\u0647 \u0639\u0646 <a href=\"https://www.alyaum.com/articles/6659473/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B7%D9%82%D8%B3-%D8%A7%D9%84%D8%A3%D8%AD%D8%AF-%D8%B9%D9%88%D8%A7%D8%B5%D9%81-%D8%AA%D8%B1%D8%A7%D8%A8%D9%8A%D8%A9-%D9%88%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D8%B1%D8%B9%D8%AF%D9%8A%D8%A9-%D8%AA%D8%B6%D8%B1%D8%A8-6-%D9%85%D9%86%D8%A7%D8%B7%D9%82-%D9%81%D9%8A-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9\" target=\"_blank\">\u062d\u0627\u0644\u0629 \u0627\u0644\u0637\u0642\u0633</a> \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u062b\u0646\u064a\u0646 \u0639\u0644\u0649 \u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0645\u0645\u0644\u0643\u0629\u060c \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u062a\u0627\u0654\u062b\u064a\u0631 <a href=\"https://www.alyaum.com/articles/6659032/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D8%A7%D9%84%D8%B7%D8%A7%D9%82%D8%A9/%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%AA%D8%AA%D8%B5%D8%AF%D8%B1-%D8%A7%D9%84%D8%B4%D8%B1%D9%82-%D8%A7%D9%84%D8%A3%D9%88%D8%B3%D8%B7-%D9%88%D8%A3%D9%81%D8%B1%D9%8A%D9%82%D9%8A%D8%A7-%D9%81%D9%8A-%D8%B7%D8%A7%D9%82%D8%A9-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%AD-%D8%A8%D9%86%D9%85%D9%88-%D8%B3%D9%86%D9%88%D9%8A-287\" target=\"_blank\">\u0627\u0644\u0631\u064a\u0627\u062d</a> \u0627\u0644\u0646\u0634\u0637\u0629 \u0627\u0644\u0645\u062b\u064a\u0631\u0629 \u0644\u0644\u0627\u0654\u062a\u0631\u0628\u0629 \u0648\u0627\u0644\u063a\u0628\u0627\u0631 \u062a\u0648\u0654\u062f\u064a \u0627\u0655\u0644\u0649 \u0634\u0628\u0629 \u0627\u0646\u0639\u062f\u0627\u0645 \u0641\u064a \u0645\u062f\u0649 \u0627\u0644\u0631\u0648\u0654\u064a\u0629 \u0627\u0644\u0627\u0654\u0641\u0642\u064a\u0629 \u0639\u0644\u0649 \u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 \u0645\u0646\u0627\u0637\u0642 \u062a\u0628\u0648\u0643 \u0648\u0627\u0644\u062c\u0648\u0641 \u0648\u062d\u0627\u064a\u0654\u0644 \u0648\u0627\u0644\u062d\u062f\u0648\u062f \u0627\u0644\u0634\u0645\u0627\u0644\u064a\u0629.<br />\u0648\u0644\u0627 \u064a\u064f\u0633\u062a\u0628\u0639\u062f \u0647\u0637\u0648\u0644 \u0627\u0654\u0645\u0637\u0627\u0631 \u0631\u0639\u062f\u064a\u0629 \u0639\u0644\u0649 \u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 \u062a\u0644\u0643 \u0627\u0644\u0645\u0646\u0627\u0637\u0642.<br />\u0641\u064a \u062d\u064a\u0646 \u0644\u0627 \u062a\u0632\u0627\u0644 \u0627\u0644\u0641\u0631\u0635\u0629 \u0645\u0647\u064a\u0627\u0654\u0629 \u0644\u0647\u0637\u0648\u0644 \u0627\u0645\u0637\u0627\u0631 \u0631\u0639\u062f\u064a\u0629 \u0645\u062a\u0648\u0633\u0637\u0629 \u0627\u0655\u0644\u0649 \u063a\u0632\u064a\u0631\u0629 \u062a\u0648\u0654\u062f\u064a \u0627\u0655\u0644\u0649 \u062c\u0631\u064a\u0627\u0646 \u0627\u0644\u0633\u064a\u0648\u0644\u060c \u0645\u0635\u062d\u0648\u0628\u0629 \u0628\u0632\u062e\u0627\u062a \u0645\u0646 \u0627\u0644\u0628\u0631\u062f \u0648\u0631\u064a\u0627\u062d \u0646\u0634\u0637\u0629 \u0639\u0644\u0649 \u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 \u0645\u0646\u0627\u0637\u0642 \u0646\u062c\u0631\u0627\u0646 \u0648\u062c\u0627\u0632\u0627\u0646 \u0648\u0639\u0633\u064a\u0631.<br />\u0643\u0645\u0627 \u062a\u0643\u0648\u0646 \u0627\u0644\u0633\u0645\u0627\u0621 \u063a\u0627\u064a\u0654\u0645\u0629 \u062c\u0632\u064a\u0654\u064a\u0627 \u064a\u062a\u062e\u0644\u0644\u0647\u0627 \u0633\u062d\u0628 \u0631\u0639\u062f\u064a\u0629 \u0645\u0645\u0637\u0631\u0629 \u0639\u0644\u0649 \u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 \u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0628\u0627\u062d\u0629 \u0648\u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629 \u0648\u0627\u0644\u0631\u064a\u0627\u0636 \u0648\u0627\u0644\u0642\u0635\u064a\u0645.</p><h2>\u0627\u0644\u0628\u062d\u0631 \u0627\u0644\u0627\u0654\u062d\u0645\u0631</h2><p>\u0627\u0644\u0631\u064a\u0627\u062d \u0627\u0644\u0633\u0637\u062d\u064a\u0629: \u0634\u0645\u0627\u0644\u064a\u0629 \u0627\u0655\u0644\u0649 \u0634\u0645\u0627\u0644\u064a\u0629 \u063a\u0631\u0628\u064a\u0629 \u0628\u0633\u0631\u0639\u0629 15-45 \u0643\u0645/\u0633\u0627\u0639\u0629 \u0639\u0644\u0649 \u0627\u0644\u062c\u0632\u0627\u0654\u064a\u0646 \u0627\u0644\u0634\u0645\u0627\u0644\u064a \u0648\u0627\u0644\u0627\u0654\u0648\u0633\u0637\u060c \u062a\u0635\u0644 \u0633\u0631\u0639\u062a\u0647\u0627 \u0627\u0655\u0644\u0649 55 \u0643\u0645/\u0633\u0627\u0639\u0629 \u0628\u0627\u062a\u062c\u0627\u0647 \u062e\u0644\u064a\u062c \u0627\u0644\u0639\u0642\u0628\u0629\u060c \u0648\u062c\u0646\u0648\u0628\u064a\u0629 \u0627\u0655\u0644\u0649 \u062c\u0646\u0648\u0628\u064a\u0629 \u0634\u0631\u0642\u064a\u0629 \u062a\u062a\u062d\u0648\u0644 \u0644\u064a\u0644\u064b\u0627 \u0634\u0645\u0627\u0644\u064a\u0629 \u0627\u0655\u0644\u0649 \u0634\u0645\u0627\u0644\u064a\u0629 \u063a\u0631\u0628\u064a\u0629 \u0628\u0633\u0631\u0639\u0629 10-28 \u0643\u0645/\u0633\u0627\u0639\u0629 \u0639\u0644\u0649 \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u062c\u0646\u0648\u0628\u064a.</p><p>\u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0644\u0645\u0648\u062c: \u0645\u0646 \u0645\u062a\u0631 \u0627\u0655\u0644\u0649 \u0645\u062a\u0631\u064a\u0646 \u0639\u0644\u0649 \u0627\u0644\u062c\u0632\u0627\u0654\u064a\u0646 \u0627\u0644\u0634\u0645\u0627\u0644\u064