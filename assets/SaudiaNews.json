64a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u062a\u062e\u0636\u0639 \u0644\u0645\u0631\u0627\u0642\u0628\u0629 \u0645\u0633\u062a\u0645\u0631\u0629 \u0639\u0628\u0631 9 \u0643\u0627\u0645\u064a\u0631\u0627\u062a \u062a\u0639\u0645\u0644 \u0639\u0644\u0649 \u0645\u062f\u0627\u0631 \u0627\u0644\u0633\u0627\u0639\u0629\u060c \u0645\u0639\u062a\u0628\u0631\u0627\u064b \u0627\u0654\u0646 \u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0627\u0644\u0633\u0627\u0628\u0642\u0629 \u0645\u0646\u0639\u062a \u0637\u0647\u0631\u0627\u0646 \u0645\u0646 \u062a\u0637\u0648\u064a\u0631 \u0633\u0644\u0627\u062d \u0646\u0648\u0648\u064a. \u00ab\u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0645\u062a\u0635\u062f\u0639\u0629\u00bb \u0648\u0627\u0654\u0634\u0627\u0631 \u062a\u0631\u0645\u0628 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u00ab\u0645\u0633\u062a\u0648\u064a\u0627\u062a \u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u062b\u0644\u0627\u062b\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646 \u062a\u0645 \u0627\u0644\u0642\u0636\u0627\u0621 \u0639\u0644\u064a\u0647\u0627\u00bb\u060c \u0648\u0627\u0654\u0646 \u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u062d\u0627\u0644\u064a\u0629 \u00ab\u0645\u062a\u0635\u062f\u0639\u0629\u00bb\u060c \u0644\u0643\u0646\u0647 \u0642\u0627\u0644 \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0630\u0627\u062a\u0647 \u0627\u0655\u0646 \u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0646 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u064a\u0646 \u0627\u0644\u062c\u062f\u062f \u0627\u0644\u0630\u064a\u0646 \u062a\u062a\u0639\u0627\u0645\u0644 \u0645\u0639\u0647\u0645 \u0648\u0627\u0634\u0646\u0637\u0646 \u00ab\u0627\u0654\u0643\u062b\u0631 \u0639\u0642\u0644\u0627\u064