4\u0645\u062c\u0644\u0633.<br /><br />\u0648\u0628\u0644\u063a \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0639\u062f\u062f \u0627\u0644\u063a\u0631\u0641 \u0627\u0644\u0641\u0646\u062f\u0642\u064a\u0629 \u0628\u0646\u0647\u0627\u064a\u0629 \u0639\u0627\u0645 2024 \u0646\u062d\u0648 711.5 \u0627\u0654\u0644\u0641 \u063a\u0631\u0641\u0629\u060c \u0628\u0627\u0631\u062a\u0641\u0627\u0639 \u0646\u0633\u0628\u062a\u0647 0.2% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642.<br /><br />\u0648\u0628\u064a\u0651\u0646 \u0627\u0644\u062a\u0642\u0631\u064a\u0631 \u0627\u0654\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0639\u062f\u062f \u0627\u0644\u0633\u064a\u0627\u062d \u0627\u0644\u062f\u0648\u0644\u064a\u064a\u0646 \u0627\u0644\u0642\u0627\u062f\u0645\u064a\u0646 \u0627\u0655\u0644\u0649 \u062f\u0648\u0644 \u0645\u062c\u0644\u0633 \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0628\u0644\u063a \u0646\u062d\u0648 72.2 \u0645\u0644\u064a\u0648\u0646 \u0633\u0627\u064a\u0654\u062d \u062e\u0644\u0627\u0644 \u0639\u0627\u0645 2024\u060c \u0645\u0633\u062c\u0644\u064b\u0627 \u0646\u0645\u0648\u064b\u0627 \u0628\u0646\u0633\u0628\u0629 51.5% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0639\u0627\u0645 2019\u060c \u0648\u0627\u0631\u062a\u0641\u0627\u0639\u064b\u0627 \u0628\u0646\u0633\u0628\u0629 6.1% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0639\u0627\u0645 2023.<br /><br />\u0643\u0645\u0627 \u0627\u0631\u062a\u0641\u0639\u062a \u0639\u0627\u064a\u0654\u062f\u0627\u062a<a href=\"https://www.alyaum.com/articles/6661369/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D9%84%D8%A7%D8%AA%D8%AD%D8%A7%D8%AF-%D8%A7%D9%84%D8%A3%D9%88%D8%B1%D9%88%D8%A8%D9%8A-%D9%8A%D8%A4%D9%83%D8%AF-%D8%A3%D9%87%D9%85%D9%8A%D8%A9-%D8%A7%D9%84%D8%B4%D8%B1%D8%A7%D9%83%D8%A9-%D9%85%D8%B9-%D8%AF%D9%88%D9%84-%D9%85%D8%AC%D9%84%D8%B3-%D8%A7%D9%84%D8%AA%D8%B9%D8%A7%D9%88%D9%86-%D8%A7%D9%84%D8%AE%D9%84%D9%8A%D8%AC%D9%8A\" target=\"_blank\"> \u0627\u0644\u0633\u064a\u0627\u062d\u0629 \u0627\u0644\u062f\u0648\u0644\u064a\u0629</a> \u0641\u064a \u062f\u0648\u0644 \u0627\u0644\u0645\u062c\u0644\u0633 \u0627\u0655\u0644\u0649 \u0646\u062d\u0648 120.2 \u0645\u0644\u064a\u0627\u0631 \u062f\u0648\u0644\u0627\u0631\u060c \u0645\u062d\u0642\u0642\u0629 \u0646\u0645\u0648\u064b\u0627 \u0628\u0646\u0633\u0628\u0629 39.6% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0639\u0627\u0645 2019\u060c \u0648\u0628\u0646\u0633\u0628\u0629 8.9% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0639\u0627\u0645 2023\u060c \u0645\u0627 \u064a\u0639\u0643\u0633 \u062a\u0646\u0627\u0645\u064a \u062c\u0627\u0630\u0628\u064a\u0629 \u0627\u0644\u0648\u062c\u0647\u0627\u062a \u0627\u0644\u062e\u0644\u064a\u062c\u064a\u0629 \u0639\u0644\u0649 \u062e\u0627\u0631\u0637\u0629 \u0627\u0644\u0633\u064a\u0627\u062d\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629.<br /><br />\u0648\u0634\u0643\u0644\u062a <a href=\"https://www.alyaum.com/articles/6642408/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%B3%D9%8A%D8%A7%D8%AD%D8%A9-%D9%88%D8%B3%D9%81%D8%B1/%D8%A7%D9%84%D9%82%D9%8A%D8%B5%D8%B1%D9%8A%D8%A9-%D8%A3%D9%8A%D9%82%D9%88%D9%86%D8%A9-%D8%A7%D9%84%D8%A3%D8%AD%D8%B3%D8%A7%D8%A1-%D8%A7%D9%84%D8%AA%D8%A7%D8%B1%D9%8A%D8%AE%D9%8A%D8%A9-%D8%AA%D8%AA%D8%B5%D8%AF%D8%B1-%D8%AE%D8%A7%D8%B1%D8%B7%D8%A9-%D8%A7%D9%84%D8%B3%D9%8A%D8%A7%D8%AD%D8%A9-%D8%A7%D9%84%D8%AE%D9%84%D9%8A%D8%AC%D9%8A%D8%A9\" target=\"_blank\">\u0627\u0644\u0633\u064a\u0627\u062d\u0629 \u0627\u0644\u0628\u064a\u0646\u064a\u0629</a> \u0627\u0644\u062e\u0644\u064a\u062c\u064a\u0629 \u0646\u062d\u0648 41.3% \u0645\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0633\u064a\u0627\u062d \u0627\u0644\u062f\u0648\u0644\u064a\u064a\u0646\u060c \u0645\u0633\u062c\u0644\u0629 \u0646\u0645\u0648\u064b\u0627 \u0628\u0646\u0633\u0628\u0629 61.2% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0639\u0627\u0645 2019\u060c \u0648\u0627\u0631\u062a\u0641\u