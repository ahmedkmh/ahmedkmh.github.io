0645\u0644\u0643 \u062e\u0627\u0644\u062f \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629.<br /><br />\u0648\u062c\u0627\u0621 \u0647\u062f\u0641 \u0646\u0627\u062f\u064a \u0646\u064a\u0648\u0645 \u0627\u0644\u0648\u062d\u064a\u062f \u0639\u0646 \u0637\u0631\u064a\u0642 \u0633\u0639\u064a\u062f \u0628\u0646 \u0631\u062d\u0645\u0629 (7)\u060c \u0628\u064a\u0646\u0645\u0627 \u062c\u0627\u0621 \u0647\u062f\u0641 \u0646\u0627\u062f\u064a \u0627\u0644\u062d\u0632\u0645\u060c \u0639\u0646 \u0637\u0631\u064a\u0642 \u0644\u0627\u0639\u0628 \u0627\u0644\u0641\u0631\u064a\u0642 \u0639\u0628\u062f\u0627\u0644\u0644\u0647 \u0627\u0644\u0634\u0646\u0642\u064a\u0637\u064a (58).<br /><br />\u0648\u0627\u0631\u062a\u0641\u0639 \u0631\u0635\u064a\u062f \u0646\u0627\u062f\u064a \u0646\u064a\u0648\u0645 \u0627\u0655\u0644\u0649 \u0627\u0644\u0646\u0642\u0637\u0629 (40) \u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0645\u0646 \u0628\u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u0645\u0633\u0627\u0628\u0642\u0629 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0644\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646\u060c \u0628\u064a\u0646\u0645\u0627 \u0627\u0631\u062a\u0641\u0639 \u0631\u0635\u064a\u062f \u0646\u0627\u062f\u064a \u0627\u0644\u062d\u0632\u0645 \u0627\u0655\u0644\u0649 \u0627\u0644\u0646\u0642\u0637\u0629 (38) \u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062a\u0627\u0633\u0639 \u0628\u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629.<br /><br />\u0627\u0644\u0644\u0642\u0627\u0621 \u0628\u062f\u0627\u0654 \u0628\u0636\u063a\u0637 \u0645\u0628\u0643\u0631 \u0645\u0646 \u062c\u0627\u0646\u0628 \u0646\u0627\u062f\u064a \u0646\u064a\u0648\u0645\u060c \u0648\u0630\u0644\u0643 \u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u0627\u0654\u0648\u0644 \u0641\u064a \u0634\u0628\u0627\u0643 \u0627\u0644\u062d\u0632\u0645\u060c \u0648\u062e\u0637\u0641 \u0627\u0644\u0646\u0642\u0627\u0637 \u0627\u0644\u062b\u0644\u0627\u062b \u0645\u0646 \u0627\u0644\u0644\u0642\u0627\u0621\u060c \u0648\u0645\u0648\u0627\u0635\u0644\u0629 \u0627\u0644\u062a\u0642\u062f\u0645 \u0628\u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629.<br /><br />\u0648\u0646\u062c\u062d \u0646\u0627\u062f\u064a \u0646\u064a\u0648\u0645 \u0639\u0646 \u0637\u0631\u064a\u0642 \u0627\u0644\u062c\u0632\u0627\u064a\u0654\u0631\u064a \u0633\u0639\u064a\u062f \u0628\u0646 \u0631\u062d\u0645\u0629\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0646\u0641\u0631\u062f \u0628\u0627\u0644\u0645\u0631\u0645\u0649\u060c \u0648\u0633\u062c\u0644 \u0627\u0644\u0643\u0631\u0629 \u062f\u0627\u062e\u0644 \u0634\u0628\u0627\u0643 \u0646\u0627\u062f\u064a \u0627\u0644\u062d\u0632\u0645\u060c \u0628\u062a\u0635\u0648\u064a\u0628\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0634\u0628\u0627\u0643 (7).<br /><br />\u062d\u0627\u0648\u0644 \u0644\u0627\u0639\u0628\u064a \u0646\u0627\u062f\u064a \u0627\u0644\u062d\u0632\u0645\u060c \u062a\u0639\u062f\u064a\u0644 \u0627\u0644\u0646\u062a\u064a\u062c\u0629\u060c \u0642\u0628\u0644 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u0627\u0654\u0648\u0644\u060c \u0644\u0643\u0646\u0647\u0645 \u0644\u0645 \u064a\u0633\u062c\u0644\u0648\u0627 \u0627\u0654\u064a \u0647\u062f\u0641\u060c \u0644\u064a\u0646\u062a\u0647\u064a \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u0627\u0654\u0648\u0644 \u0628\u062a\u0642\u062f\u0645 \u0646\u064a\u0648\u0645 \u0628\u0647\u062f\u0641 \u0646\u0638\u064a\u0641.<br /><br />\u0648\u0639\u0627\u062f\u0644 \u0646\u0627\u062f\u064a \u0627\u0644\u062d\u0632\u0645\u060c \u0627\u0644\u0646\u062a\u064a\u062c\u0629 \u0639\u0646 \u0637\u0631\u064a\u0642 \u0639\u0628\u062f\u0627\u0644\u0644\u0647 \u0627\u0644\u0634\u0646\u0642\u064a\u0637\u064a\u060c \u0628\u0639\u062f \u0631\u0627\u0654\u0633\u064a\u0629 \u0645\u0646 \u