26\u65bc\u6628\u592903\u670828\u65e5\u5468\u516d\u5169\u6b21\u5411\u4ee5\u8272\u5217\u767c\u5c04\u5c0e\u5f48\u548c\u7121\u4eba\u6a5f\u3002", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u4e9e\u6d32", "\u975e\u6d32", "\u6d77\u7063\u570b\u5bb6", "\u4f0a\u6717", "\u57c3\u585e\u4fc4\u6bd4\u4e9e", "\u4e5f\u9580", "\u5409\u5e03\u63d0", "\u4e2d\u6771"], "creator": ["\u5c3c\u53e4\u62c9"], "language": "chinese", "country": ["libya", "qatar", "somalia", "turkmenistan", "djibouti", "tunisia", "kyrgyzstan", "azerbaijan", "tajikistan", "turkey", "algeria", "syria", "uzbekistan", "oman", "united arab emirates", "lebanon", "iran", "georgia", "morocco", "mauritania", "armenia", "kuwait", "ethiopia", "egypt", "israel", "saudi arabia", "cyprus", "kazakhstan", "sudan", "afghanistan", "bahrain", "iraq", "pakistan", "jordan", "india", "yemen"], "category": ["top", "lifestyle"], "datatype": "news", "pubDate": "2026-03-29 10:48:58", "pubDateTZ": "UTC", "fetched_at": "2026-03-29 11:10:02", "image_url": "https://s.rfi.fr/media/display/435f301e-2b5a-11f1-9d15-005056bf30b7/w:1280/p:16x9/2026-03-29-D-FMM-archive-Yemen-et-Djibouti-x-logo-RFI.jpg", "video_url": null, "source_id": "rfi_fr", "source_name": "Rfi", "source_priority": 8490, "source_url": "https://www.rfi.fr", "source_icon": "https://n.bytvi.com/rfi_fr.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "2b4e9db26ccea618166680137ae599b2", "link": "https://www.alyaum.com/articles/6652895/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D9%83%D8%A9-%D8%A7%D9%84%D9%85%D9%83%D8%B1%D9%85%D8%A9-%D9%81%D8%B1%D9%8A%D9%82-%D8%B7%D8%A8%D9%8A-%D9%8A%D9%86%D8%AC%D8%AD-%D9%81%D9%8A-%D8%A5%D9%86%D9%82%D8%A7%D8%B0-%D8%B3%D8%A7%D9%82-%D8%B7%D9%81%D9%84%D8%A9-%D8%AA%D8%A8%D9%84%D8%BA-4-%D8%A3%D8%B9%D9%88%D8%A7%D9%85-%D9%85%D9%86-%D8%A7%D9%84%D8%A8%D8%AA%D8%B1", "title": "\u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629.. \u0641\u0631\u064a\u0642 \u0637\u0628\u064a \u064a\u0646\u062c\u062d \u0641\u064a \u0627\u0655\u0646\u0642\u0627\u0630 \u0633\u0627\u0642 \u0637\u0641\u0644\u0629 \u062a\u0628\u0644\u063a 4 \u0627\u0654\u0639\u0648\u0627\u0645 \u0645\u0646 \u0627\u0644\u0628\u062a\u0631", "description": "\u0646\u062c\u062d \u0641\u0631\u064a\u0642 \u0637\u0628\u064a \u0645\u062a\u062e\u0635\u0635 \u0628\u0645\u0633\u062a\u0634\u0641\u0649 \u0627\u0644\u0646\u0648\u0631 \u0627\u0644\u062a\u062e\u0635\u0635\u064a\u060c \u0639\u0636\u0648 <a href=\"https://www.alyaum.com/articles/6650848/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AE%D9%84%D8%A7%D9%84-18-%D8%AF%D9%82%D9%8A%D9%82%D8%A9-%D9%81%D8%B1%D9%8A%D9%82-%D8%B7%D8%A8%D9%8A-%D8%A8%D9%85%D9%83%D8%A9-%D9%8A%D9%86%D9%87%D9%8A-%D9%85%D8%B9%D8%A7%D9%86%D8%A7%D8%A9-%D9%85%D9%82%D9%8A%D9%85-%D9%85%D9%86-%D8%AC%D9%84%D8%B7%D8%A9-%D9%82%D9%84%D8%A8%D9%8A%D8%A9-%D8%AD%D8%A7%D8%AF%D8%A9\" target=\"_blank\">\u062a\u062c\u0645\u0639 \u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629 \u0627\u0644\u0635\u062d\u064a</a>\u060c \u0641\u064a \u0627\u0655\u0646\u0642\u0627\u0630 \u0633\u0627\u0642 \u0637\u0641\u0644\u0629 \u062a\u0628\u0644\u063a \u0645\u0646 \u0627\u0644\u0639\u0645\u0631 4 \u0633\u0646\u0648\u0627\u062a \u0645\u0646 \u062e\u0637\u0631 \u0627\u0644\u0628\u062a\u0631 \u0627\u0644\u0645\u062d\u0642\u0642\u060c \u0648\u0630\u0644\u0643 \u0639\u0642\u0628 \u062a\u0639\u0631\u0636\u0647\u0627 \u0644<a href=\"https://www.alyaum.com/articles/6644095/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/30-%D9%82%D8%AA%D9%8A%D9%84%D8%A7-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%A3%D9%82%D9%84-%D9%81%D9%8A-%D8%AD%D8%A7%D8%AF%D8%AB-%D9%85%D8%B1%D9%88%D8%B1%D9%8A-%D9%81%D9%8A-%D9%86%D9%8A%D8%AC%D9%8A%D8%B1%D9%8A%D8%A7-%D8%A7%D9%84%D8%A3%D8%AD%D8%AF\" target=\"_blank\">\u062d\u0627\u062f\u062b \u0645\u0631\u0648\u0631\u064a</a> \u0645\u0631\u0648\u0639 \u062a\u0633\u0628\u0628 \u0641\u064a \u0627\u0655\u0635\u0627\u0628\u0629 \u0628\u0627\u0644\u063a\u0629 \u0648\u0643\u0633\u0631 \u0645\u0636\u0627\u0639\u0641 \u0648\u0645\u0641\u062a\u0648\u062d \u0641\u064a \u0627\u0644\u0633\u0627\u0642 \u0627\u0644\u064a\u0645\u0646\u0649.<br /><br />\u0648\u0627\u0654\u0633\u0647\u0645 \u0646\u0638\u0627\u0645 \u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0639\u0627\u062c\u0644\u0629\u060c \u0627\u0644\u0630\u064a \u064a\u0639\u062f \u0627\u0654\u062d\u062f \u0627\u0644\u0645\u0633\u0627\u0631\u0627\u062a \u0627\u0644\u062c\u0648\u0647\u0631\u064a\u0629 \u0644\u0646\u0645\u0648\u0630\u062c <a href=\"https://www.alyaum.com/articles/6652850/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%84%D8%A3%D9%88%D9%84-%D9%85%D8%B1%D8%A9-%D8%A8%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D8%A6%D8%B5%D8%A7%D9%84-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D9%8A-%D9%8A%D9%86%D9%87%D9%8A-%D9%85%D8%B9%D8%A7%D9%86%D8%A7%D8%A9-%D9%85%D8%B1%D9%8A%D8%B6%D8%A9-%D8%B3%D8%B1%D8%B7%D8%A7%D9%86-%D8%A7%D9%84%D8%AD%D9%88%D8%B6-%D8%A8%D8%A7%D9%84%D8%AF%D9%85%D8%A7%D9%85\" target=\"_blank\">\u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0635\u062d\u064a\u0629</a> \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0627\u0644\u062c\u062f\u064a\u062f\u060c \u0641\u064a \u0633\u0631\u0639\u0629 \u0627\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0644\u062d\u0627\u0644\u0629 \u0627\u0644\u062a\u064a \u0643\u0627\u0646\u062a \u062a\u0639\u0627\u0646\u064a \u0645\u0646 \u062a\u0647\u062a\u0643 \u0634\u062f\u064a\u062f \u0641\u064a \u0627\u0644\u0627\u0654\u0646\u0633\u062c\u0629 \u0648\u0627\u0644\u062c\u0644\u062f \u0627\u0644\u0645\u062d\u064a\u0637 \u0628\u0627\u0644\u0639\u0638\u0627\u0645\u060c \u0645\u0645\u0627 \u062a\u0637\u0644\u0628 \u0627\u0633\u062a\u0646\u0641\u0627\u0631\u0627\u064b \u0637\u0628\u064a\u0627\u064b \u0641\u0648\u0631 \u0648\u0635\u0648\u0644\u0647\u0627 \u0644\u0644\u0645\u0633\u062a\u0634\u0641\u0649 \u0644\u0636\u0645\u0627\u0646 \u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0644\u0637\u0631\u0641 \u0627\u0644\u0645\u0635\u0627\u0628 \u0648\u062a\u062c\u0646\u0628 \u0627\u0644\u0645\u0636\u0627\u0639\u0641\u0627\u062a \u0627\u0644\u062f\u0627\u064a\u0654\u0645\u0629.<h2>\u062a\u0634\u062e\u064a\u0635 \u062f\u0642\u064a\u0642 \u0644\u0644\u062d\u0627\u0644\u0629</h2>\u0627\u0654\u0648\u0636\u062d \u062a\u062c\u0645\u0639 \u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629 \u0627\u0644\u0635\u062d\u064a \u0627\u0654\u0646 \u0627\u0644\u0637\u0648\u0627\u0642\u0645 \u0627\u0644\u0637\u0628\u064a\u0629 \u0628\u0627\u0634\u0631\u062a \u0627\u0655\u062c\u0631\u0627\u0621 \u0627\u0644\u062a\u0642\u064a\u064a\u0645\u0627\u062a \u0648\u0627\u0644\u0641\u062d\u0648\u0635\u0627\u062a \u0627\u0644\u0645\u062e\u0628\u0631\u064a\u0629 \u0648\u0627\u0644\u0627\u0655\u0634\u0639\u0627\u0639\u064a\u0629 \u0628\u0634\u0643\u0644 \u0641\u0648\u0631\u064a\u060c \u062d\u064a\u062b \u0643\u0634\u0641\u062a \u0627\u0644\u0646\u062a\u0627\u064a\u0654\u062c \u0639\u0646 \u0648\u062c\u0648\u062f \u062a\u0644\u0641 \u0648\u0627\u0633\u0639 \u0627\u0644\u0646\u0637\u0627\u0642 \u0641\u064a \u0627\u0644\u0627\u0654\u063a\u0634\u064a\u0629 \u0648\u0627\u0644\u0627\u0654\u0646\u0633\u062c\u0629 \u0627\u0644\u0631\u062e\u0648\u0629 \u0645\u0639 \u0627\u0646\u0643\u0634\u0627\u0641 \u0644\u0644\u0639\u0638\u0645 \u0648\u062a\u0647\u062a\u0643 \u062d\u0627\u062f \u0641\u064a \u0627\u0644\u063a\u0637\u0627\u0621 \u0627\u0644\u062c\u0644\u062f\u064a \u0644\u0644\u0633\u0627\u0642.<br /><br />\u0648\u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0627\u0644\u062a\u0634\u062e\u064a\u0635 \u0627\u0644\u062f\u0642\u064a\u0642\u060c \u0642\u0631\u0631 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0637\u0628\u064a \u0627\u0644\u0628\u062f\u0621 \u0628\u062a\u062f\u062e\u0644\u0627\u062a \u062c\u0631\u0627\u062d\u064a\u0629 \u0645\u062a\u0642\u062f\u0645\u0629 \u0634\u0645\u0644\u062a \u062a\u062b\u0628\u064a\u062a \u0627\u0644\u0643\u0633\u0631 \u0639\u0628\u0631 \u0646\u0638\u0627\u0645 \u062a\u062b\u0628\u064a\u062a \u062e\u0627\u0631\u062c\u064a \u0648\u0627\u0655\u0639\u0627\u062f\u0629 \u0636\u0628\u0637 \u0627\u0644\u0639\u0638\u0627\u0645 \u0644\u0645\u0633\u0627\u0631\u0647\u0627 \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0628\u062f\u0642\u0629 \u0639\u0627\u0644\u064a\u0629\u060c \u0645\u0639 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u062a\u0642\u0646\u064a\u0627\u062a \u0637\u0628\u064a\u0629 \u062d\u062f\u064a\u062b\u0629 \u062a\u0645\u062b\u0644\u062a \u0641\u064a \u062c\u0647\u0627\u0632 \u0627\u0644\u0634\u0641\u0637 \u0627\u0644\u0637\u0628\u064a (VAC) \u0627\u0644\u0630\u064a \u064a\u0639\u0645\u0644 \u0639\u0644\u0649 \u062a\u062d\u0641\u064a\u0632 \u0627\u0644\u062a\u064a\u0654\u0627\u0645 \u0627\u0644\u062c\u0631\u0648\u062d \u0627\u0644\u0639\u0645\u064a\u0642\u0629 \u0648\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0627\u0654\u062c\u0632\u0627\u0621 \u0627\u0644\u0645\u0643\u0634\u0648\u0641\u0629 \u0645\u0646 \u0627\u0644\u062a\u0644\u0648\u062b \u0627\u0654\u0648 \u0627\u0644\u0636\u0645\u0648\u0631.<br /> <h2>\u062c\u0631\u0627\u062d\u0629 \u062a\u062c\u0645\u064a\u0644\u064a\u0629 \u0646\u0627\u062c\u062d\u0629</h2>\u0627\u0633\u062a\u0643\u0645\u0644 \u0641\u0631\u064a\u0642 \u062c\u0631\u0627\u062d\u0629 \u0627\u0644\u062a\u062c\u0645\u064a\u0644 \u0627\u0644\u062e\u0637\u0629 \u0627\u0644\u0639\u0644\u0627\u062c\u064a\u0629 \u0627\u0644\u0645\u0631\u0633\u0648\u0645\u0629 \u0644\u0644\u062d\u0627\u0644\u0629 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0655\u062c\u0631\u0627\u0621 \u0639\u0645\u0644\u064a\u0629 \u062f\u0642\u064a\u0642\u0629 \u0644\u062a\u063a\u0637\u064a\u0629 \u0627\u0644\u0627\u0654\u0646\u0633\u062c\u0629 \u0627\u0644\u0645\u062a\u0636\u0631\u0631\u0629 \u0648\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0639\u0638\u0627\u0645 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0631\u0642\u0639\u0629 \u062c\u0644\u062f\u064a\u0629 \u0645\u062a\u062e\u0635\u0635\u0629\u060c \u0648\u0647\u0648 \u0645\u0627 \u0627\u0654\u062f\u0649 \u0628\u0641\u0636\u0644 \u0627\u0644\u0644\u0647 \u0627\u0655\u0644\u0649 \u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0633\u0627\u0642 \u0648\u0648\u0638\u0627\u064a\u0654\u0641\u0647\u0627 \u0627\u0644\u062d\u064a\u0648\u064a\u0629 \u0628\u0634\u0643\u0644 \u0643\u0627\u0645\u0644.<br /><br />\u0648\u0627\u0654\u0643\u062f\u062a \u0627\u0644\u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0644\u0637\u0628\u064a\u0629 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u062a\u062f\u062e\u0644\u0627\u062a \u0627\u0644\u0646\u0648\u0639\u064a\u0629 \u062d\u0627\u0644\u062a \u062f\u0648\u0646 \u062d\u062f\u0648\u062b \u0645\u0636\u0627\u0639\u0641\u0627\u062a \u062e\u0637\u064a\u0631\u0629 \u0627\u0654\u0648 \u0627\u0644\u062d\u0627\u062c\u0629 \u0644\u0644\u062a\u062f\u062e\u0644 \u0627\u0644\u062c\u0631\u0627\u062d\u064a \u0627\u0644\u0627\u0633\u062a\u064a\u0654\u0635\u0627\u0644\u064a\u060c \u0645\u0645\u0627 \u064a\u0639\u0643\u0633 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u062a\u0646\u0633\u064a\u0642 \u0627\u0644\u0639\u0627\u0644\u064a \u0628\u064a\u0646 \u0627\u0644\u0627\u0654\u0642\u0633\u0627\u0645 \u0627\u0644\u062c\u0631\u0627\u062d\u064a\u0629 \u0627\u0644\u0645\u062e\u062a\u0644\u0641\u0629 \u0641\u064a \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u0649 \u0648\u0642\u062f\u0631\u062a\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0644\u0627\u0655\u0635\u0627\u0628\u0627\u062a \u0627\u0644\u0645\u0639\u0642\u062f\u0629 \u0648\u0627\u0644\u062d\u0627\u0644\u0627\u062a \u0627\u0644\u062d\u0631\u062c\u0629 \u0627\u0644\u062a\u064a \u062a\u0633\u062a\u0648\u062c\u0628 \u0645\u0647\u0627\u0631\u0629 \u0627\u0633\u062a\u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0648\u0633\u0631\u0639\u0629 \u0641\u064a \u0627\u062a\u062e\u0627\u0630 \u0627\u0644\u0642\u0631\u0627\u0631 \u0627\u0644\u0637\u0628\u064a.<h2>\u0643\u0641\u0627\u0621\u0629 \u0627\u0644\u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u0635\u062d\u064a\u0629</h2>\u064a\u0627\u0654\u062a\u064a \u0647\u0630\u0627 \u0627\u0644\u0627\u0655\u0646\u062c\u0627\u0632 \u0627\u0644\u0637\u0628\u064a \u062a\u062c\u0633\u064a\u062f\u0627\u064b \u0644\u0644\u0643\u0641\u0627\u0621\u0629 \u0627\u0644\u0639\u0627\u0644\u064a\u0629 \u0627\u0644\u062a\u064a \u064a\u062a\u0645\u062a\u0639 \u0628\u0647\u0627 \u0645\u0633\u062a\u0634\u0641\u0649 \u0627\u0644\u0646\u0648\u0631 \u0627\u0644\u062a\u062e\u0635\u0635\u064a \u0641\u064a \u0627\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0644\u062d\u0627\u0644\u0627\u062a \u0627\u0644\u0637\u0627\u0631\u064a\u0654\u0629 \u0648\u0627\u0644\u062d\u0631\u062c\u0629\u060c \u0648\u062f\u0648\u0631\u0647 \u0627\u0644\u0645\u062d\u0648\u0631\u064a \u0641\u064a \u0627\u0655\u0646\u0642\u0627\u0630 \u0627\u0644\u0627\u0654\u0631\u0648\u0627\u062d \u0648\u0627\u0644\u0627\u0654\u0637\u0631\u0627\u0641 \u0648\u0641\u0642 \u0627\u0654\u0639\u0644\u0649 \u0627\u0644\u0645\u0639\u0627\u064a\u064a\u0631 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629 \u0627\u0644\u0645\u062a\u0628\u0639\u0629.<br /><br />\u0643\u0645\u0627 \u064a\u0628\u0631\u0632 \u0647\u0630\u0627 \u0627\u0644\u0646\u062c\u0627\u062d \u0627\u0644\u062f\u0648\u0631 \u0627\u0644\u0641\u0639\u0651\u0627\u0644 \u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u062a\u062d\u0648\u0644 \u0641\u064a \u0627\u0644\u0642\u0637\u062