48\u0633\u0637 \u0636\u062f \"\u0627\u0644\u0646\u0638\u0627\u0645 <a href=\"https://www.alyaum.com/articles/6651475/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AD%D8%B1%D8%A8-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%85%D9%82%D8%AA%D9%84-%D8%A7%D9%84%D8%AC%D9%86%D8%B1%D8%A7%D9%84-%D8%A5%D8%B3%D9%85%D8%A7%D8%B9%D9%8A%D9%84-%D8%A3%D8%AD%D9%85%D8%AF%D9%8A-%D9%85%D8%B3%D8%A4%D9%88%D9%84-%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D8%AE%D8%A8%D8%A7%D8%B1%D8%A7%D8%AA-%D9%81%D9%8A-%D8%A7%D9%84%D8%A8%D8%A7%D8%B3%D9%8A%D8%AC\" target=\"_blank\">\u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a</a> \"\u060c \u0648\u0630\u0644\u0643 \u0628\u0639\u062f \u0633\u0627\u0639\u0627\u062a \u0641\u0642\u0637 \u0645\u0646 \u0642\u0648\u0644\u0647 \u0627\u0655\u0646\u0647 \u0644\u0627 \u064a\u0631\u064a\u062f \u0648\u0642\u0641 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631.<br />\u0648\u0643\u062a\u0628 <a href=\"https://www.alyaum.com/articles/6651422/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%8A%D8%AA%D8%A8%D8%B1%D8%A3-%D9%85%D9%86-%D9%82%D8%B5%D9%81-%D8%AD%D9%82%D9%84-%D8%A8%D8%A7%D8%B1%D8%B3-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A-%D9%88%D9%8A%D8%A4%D9%83%D8%AF-%D8%B9%D8%AF%D9%85-%D8%AA%D9%83%D8%B1%D8%A7%D8%B1%D9%87\" target=\"_blank\">\u062a\u0631\u0627\u0645\u0628</a> \u064a\u0648\u0645 \u0627\u0644\u062c\u0645\u0639\u0629 \u0639\u0628\u0631 \u0645\u0646\u0635\u062a\u0647 \"\u062a\u0631\u0648\u062b \u0633\u0648\u0634\u0627\u0644\": \"\u0646\u062d\u0646 \u0646\u0642\u062a\u0631\u0628 \u0645\u0646 \u062a\u062d\u0642\u064a\u0642 \u0627\u0654\u0647\u062f\u0627\u0641\u0646\u0627 \u0641\u064a \u062d\u064a\u0646 \u0646\u062f\u0631\u0633 \u062a\u0642\u0644\u064a\u0635 \u062c\u0647\u0648\u062f\u0646\u0627 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u0627\u0644\u0643\u0628\u064a\u0631\u0629 \u0641\u064a \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654