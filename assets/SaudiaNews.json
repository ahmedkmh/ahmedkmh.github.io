635\u0648\u0627\u0631\u064a\u062e \u0648\u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0627\u062a \u0648\u0627\u0654\u0635\u0648\u0644 \u0627\u0654\u062e\u0631\u0649.<br />\u0648\u0646\u0634\u0631\u062a \u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0645\u0631\u0643\u0632\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 (\u0633\u0646\u062a\u0643\u0648\u0645) \u0628\u064a\u0627\u0646\u064b\u0627 \u0639\u0644\u0649 \u0645\u0646\u0635\u0629 \u0627\u0655\u0643\u0633\u060c \u0627\u0654\u0639\u0644\u0646\u062a \u0641\u064a\u0647 \u0627\u0654\u0646 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0627\u0633\u062a\u0643\u0645\u0644\u062a \u062c\u0648\u0644\u0629 \u0627\u0655\u0636\u0627\u0641\u064a\u0629 \u0645\u0646 \u0627\u0644\u0636\u0631\u0628\u0627\u062a \u0636\u062f <a href=\"https://www.alyaum.com/articles/6671911/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A7%D9%84%D8%AD%D8%B1%D8%B3-%D8%A7%D9%84%D8%AB%D9%88%D8%B1%D9%8A-%D9%8A%D9%87%D8%AF%D8%AF-%D8%A8%D8%A7%D8%B3%D8%AA%D9%87%D8%AF%D8%A7%D9%81-%D8%AC%D8%B3%D8%B1-%D8%A8%D9%85%D8%AF%D9%8A%D9%86%D8%A9-%D8%A2%D9%82-%D9%82%D9%84%D8%A7-%D8%B4%D9%85%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86\" target=\"_blank\">\u0627\u0655\u064a\u0631\u0627\u0646</a> \u0641\u064a 8 \u064a\u0648\u0644\u064a\u0648 \u0644\u062a\u0642\u0648\u064a\u0636 \u0642\u062f\u0631\u0629 \u0627\u0655\u064a\u0631\u0627\u0646 \u0639\u0644\u0649 \u0645\u0647\u0627\u062c\u0645\u0629 \u062d\u0631\u0643\u0629 \u0627\u0644\u0634\u062d\u0646 \u0627\u0644\u062a\u062c\u0627\u0631\u064a \u0648\u0627\u0644\u0628\u062d\u0627\u0631\u0629 \u0627\u0644\u0645\u062f\u0646\u064a\u064a\u0646 \u0627\u0644\u0627\u0654\u0628\u0631\u064a\u0627\u0621 \u0641\u064a \u0645\u0636\u064a\u0642 \u0647\u0631\u0645\u0632\u060c \u0628\u0634\u0643\u0644 \u0627\u0654\u0643\u0628\u0631.<h2>\u0627\u0655\u064a\u0631\u0627\u0646 \u062a\u0633\u062a\u0647\u062f\u0641 \u0642\u0648\u062