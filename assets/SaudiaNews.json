 \u0627\u0644\u062d\u0648\u0627\u062f\u062b \u0641\u064a \u0643\u0644 \u062c\u0648\u0644\u0629 \u0645\u0646 \u0627\u0644\u0645\u0628\u0627\u0631\u064a\u0627\u062a\u060c \u0627\u0654\u0646\u064e\u0651 \u0627\u0644\u062c\u0648\u0644\u0629 \u0646\u0641\u0633\u0647\u0627 \u0645\u0646 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u0645\u0627\u0636\u064a \u0633\u062c\u064e\u0651\u0644\u062a 44 \u062d\u0627\u0644\u0629 \u062a\u062f\u062e\u0644 \u062e\u0627\u0637\u064a\u0654 \u0645\u0646 \u0627\u0644\u0640 VAR \u0627\u0654\u0648 \u0627\u0654\u062e\u0637\u0627\u0621 \u0641\u064a \u0627\u0644\u0645\u0644\u0639\u0628 \u0644\u0645 \u062a\u0633\u062a\u062f\u0639\u0650 \u0645\u0631\u0627\u062c\u0639\u0629 \u0627\u0644\u0641\u064a\u062f\u064a\u0648. \u0648\u0646\u0642\u0644\u062a \u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0627\u0655\u0630\u0627\u0639\u0629 \u0627\u0644\u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0629 \u00ab\u0628\u064a \u0628\u064a \u0633\u064a\u00bb\u060c \u0627\u0644\u062e\u0645\u064a\u0633\u060c \u0639\u0646 \u0627\u062a\u062d\u0627\u062f \u062d\u0643\u0627\u0645 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646 \u0627\u0654\u0646\u064e\u0651 \u0627\u0644\u0627\u062a\u062c\u0627\u0647 \u0627\u0644\u0639\u0627\u0645 \u0627\u0655\u064a\u062c\u0627\u0628\u064a\u060c \u062d\u064a\u062b \u0628\u0644\u063a \u0639\u062f\u062f \u0627\u0644\u0627\u0654\u062e\u0637\u0627\u0621 70 \u0628\u0639\u062f 30 \u0645\u0628\u0627\u0631\u0627\u0629 \u0645\u0646 \u0645\u0648\u0633\u0645 2023\u06402024. \u0644\u0643\u0646 \u0639\u062f\u062f \u0627\u0654\u062e\u0637\u0627\u0621 \u0627\u0644\u0640 VAR \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062c\u0627\u0631\u064a \u00ab18\u00bb \u064a\u0639\u0627\u062f\u0644 \u0628\u0627\u0644\u0641\u0639\u0644 \u0639\u062f\u062f\u0647\u0627 \u0645\u0627 \u0642\u0628\u0644\u0647\u060c \u0645\u0639 \u0627\u0644\u0639\u0644\u0645 \u0627\u0654\u0646\u0647 \u0645\u0639 \u062a\u0628\u0642\u064a