u0627 \u0645\u0644\u0645\u0648\u0633\u064b\u0627 \u0628\u0636\u0645 \u0645\u062f\u0627\u0641\u0639 \u0645\u0646\u062a\u062e\u0628 \u0641\u0631\u0646\u0633\u0627\u060c \u0639\u0642\u0628 \u0627\u0655\u0639\u0644\u0627\u0646 \u0644\u064a\u0641\u0631\u0628\u0648\u0644 \u0631\u062d\u064a\u0644\u0647 \u0631\u0633\u0645\u064a\u064b\u0627 \u0628\u0639\u062f 5 \u0633\u0646\u0648\u0627\u062a \u0642\u0636\u0627\u0647\u0627 \u062f\u0627\u062e\u0644 \u0645\u0644\u0639\u0628 \u201c\u0627\u0654\u0646\u0641\u064a\u0644\u062f\u201d\u060c \u062e\u0627\u0636 \u062e\u0644\u0627\u0644\u0647\u0627 183 \u0645\u0628\u0627\u0631\u0627\u0629 \u0633\u062c\u0644 \u0641\u064a\u0647\u0627 7 \u0627\u0654\u0647\u062f\u0627\u0641\u060c \u0645\u0646\u0630 \u0627\u0646\u062a\u0642\u0627\u0644\u0647 \u0645\u0646 \u0644\u0627\u064a\u0628\u0632\u064a\u063a \u0627\u0644\u0627\u0654\u0644\u0645\u0627\u0646\u064a \u0641\u064a \u0635\u064a\u0641 2021.<br /><br />\u0648\u064a\u063a\u0627\u062f\u0631 \u0627\u0655\u0628\u0631\u0627\u0647\u064a\u0645\u0627 \u0643\u0648\u0646\u0627\u062a\u064a \u0644\u064a\u0641\u0631\u0628\u0648\u0644 \u0648\u0647\u0648 \u0641\u064a \u0633\u0646 27 \u0639\u0627\u0645\u064b\u0627\u060c \u0641\u064a \u0645\u0631\u062d\u0644\u0629 \u064a\u064f\u0646\u0638\u0631 \u0627\u0655\u0644\u064a\u0647\u0627 \u0639\u0644\u0649 \u0627\u0654\u0646\u0647\u0627 \u0630\u0631\u0648\u0629 \u0627\u0644\u0646\u0636\u062c \u0627\u0644\u0643\u0631\u0648\u064a \u0644\u0644\u0645\u062f\u0627\u0641\u0639\u064a\u0646\u060c \u0645\u0627 \u064a\u062c\u0639\u0644\u0647 \u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0627\u0654\u0633\u0645\u0627\u0621 \u0627\u0644\u0645\u0637\u0631\u0648\u062d\u0629 \u0641\u064a \u0633\u0648\u0642 \u0627\u0644\u0627\u0646\u062a\u0642\u0627\u0644\u0627\u062a \u0627\u0644\u062d\u0631\u0629 \u0647\u0630\u0627 \u0627\u0644\u0635\u064a\u0641\u060c \u0648\u0633\u0637 \u0645\u0646\u0627\u0641\u0633\u0629 \u0645\u0646 \u0627\u0654\u0646\u062f\u064a\u0629 \u0627\