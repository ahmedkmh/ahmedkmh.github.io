9%84-%D8%A7%D9%84%D8%B4%D9%83%D9%88%D9%83-%D9%82%D8%A8%D9%84-%D9%86%D8%B5%D9%81-%D9%86%D9%87%D8%A7%D8%A6%D9%8A-%D9%83%D8%A3%D8%B3-%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85", "title": "\u062a\u0639\u064a\u064a\u0646 \u201c\u062d\u0643\u0645 \u0645\u064a\u0633\u064a \u0627\u0644\u0645\u0641\u0636\u0644\u201d \u064a\u0634\u0639\u0644 \u0627\u0644\u0634\u0643\u0648\u0643 \u0642\u0628\u0644 \u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645", "description": "<br /><br />\u0627\u0654\u062b\u0627\u0631 \u0627\u0655\u0639\u0644\u0627\u0646 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u062f\u0648\u0644\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 (\u0641\u064a\u0641\u0627) \u062a\u0639\u064a\u064a\u0646 \u0627\u0644\u062d\u0643\u0645 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u0645\u0646 \u0627\u0654\u0635\u0648\u0644 \u0645\u063a\u0631\u0628\u064a\u0629 \u0627\u0655\u0633\u0645\u0627\u0639\u064a\u0644 \u0627\u0644\u0641\u0627\u062a\u062d \u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627 \u0648\u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0641\u064a \u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026 \u0645\u0648\u062c\u0629 \u0648\u0627\u0633\u0639\u0629 \u0645\u0646 \u0627\u0644\u062c\u062f\u0644\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0654\u0639\u0627\u062f\u062a \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0655\u0639\u0644\u0627\u0645 \u0648\u062c\u0645\u0627\u0647\u064a\u0631 \u0639\u0644\u0649 \u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a \u062a\u062f\u0627\u0648\u0644 \u0648\u0635\u0641\u0647 \u0628\u0640\u201d\u0627\u0644\u062d\u0643\u0645 \u0627\u0644\u0645\u0641\u0636\u0644\u201d \u0644\u0644\u0646\u062c\u0645 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0644\u064a\u0648\u0646\u064a\u0644 \u0645\u064a\u0633\u064a.<br />\u0648\u062c\u0627\u0621\u062a \u0647\u0630\u0647 \u0627\u0644\u0645\u0632\u0627\u0639\u0645 \u0627\u0633\u062a\u0646\u0627\u062f\u064b\u0627 \u0627\u0655\u0644\u0649 \u0633\u062c\u0644 \u0627\u0644\u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u062a\u064a \u0627\u0654\u062f\u0627\u0631\u0647\u0627 \u0627\u0644\u0641\u0627\u062a\u062d \u0644\u0645\u064a\u0633\u064a\u060c \u0627\u0655\u0630 \u0644\u0645 \u064a\u062a\u0639\u0631\u0636 \u0642\u0627\u064a\u0654\u062f \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0644\u0627\u0654\u064a \u062e\u0633\u0627\u0631\u0629 \u0641\u064a \u0627\u0644\u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u062a\u064a \u0627\u0654\u062f\u0627\u0631\u0647\u0627 \u0627\u0644\u062d\u0643\u0645 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u060c \u0633\u0648\u0627\u0621 \u0645\u0639 \u0645\u0646\u062a\u062e\u0628 \u0628\u0644\u0627\u062f\u0647 \u0627\u0654\u0648 \u0645\u0639 \u0641\u0631\u064a\u0642\u0647 \u0627\u0655\u0646\u062a\u0631 \u0645\u064a\u0627\u0645\u064a\u060c \u0648\u0647\u0648 \u0645\u0627 \u062f\u0641\u0639 \u0627\u0644\u0628\u0639\u0636 \u0627\u0655\u0644\u0649 \u0631\u0628\u0637 \u062a\u0639\u064a\u064a\u0646\u0647 \u0628\u0645\u0628\u0627\u0631\u0627\u0629 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0648\u0637\u0631\u062d \u062a\u0633\u0627\u0648\u0654\u0644\u0627\u062a \u062d\u0648\u0644 \u062d\u064a\u0627\u062f\u064a\u0629 \u0627\u0644\u062a\u062d\u0643\u064a\u0645. <br />\u0648\u064a\u0639\u062f \u0627\u0655\u0633\u0645\u0627\u0639\u064a\u0644 \u0627\u0644\u0641\u0627\u062a\u062d \u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u062d\u0643\u0627\u0645 \u0641\u064a \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629\u060c \u0648\u064a\u062d\u0645\u0644 \u0627\u0644\u0