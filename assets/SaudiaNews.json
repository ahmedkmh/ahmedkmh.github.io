\u0627\u0644\u0627\u0654\u062d\u0633\u0627\u0621</a>\u060c \u0628\u0645\u0643\u062a\u0628 \u0633\u0645\u0648\u0651\u0647 \u0628\u0645\u0642\u0631 \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629\u060c \u0627\u0644\u064a\u0648\u0645 \u00ab\u0627\u0644\u0627\u0654\u062d\u062f\u00bb\u060c \u0627\u0644\u0639\u0642\u064a\u062f \u062e\u0627\u0644\u062f \u0628\u0646 \u062c\u0628\u0631\u0627\u0646 \u0627\u0644\u0641\u064a\u0641\u064a \u0628\u0645\u0646\u0627\u0633\u0628\u0629 \u062a\u0639\u064a\u064a\u0646\u0647 \u0645\u062f\u064a\u0631\u064b\u0627 \u0644\u0645\u0631\u0648\u0631 \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629.<br /><br />\u0648\u0647\u0646\u0627\u0654 \u0645\u062d\u0627\u0641\u0638 \u0627\u0644\u0627\u0654\u062d\u0633\u0627\u0621 \u0627\u0644\u0639\u0642\u064a\u062f \u0627\u0644\u0641\u064a\u0641\u064a \u0628\u0647\u0630\u0647 \u0627\u0644\u062b\u0642\u0629\u060c \u0645\u062a\u0645\u0646\u064a\u064b\u0627 \u0644\u0647 \u0627\u0644\u062a\u0648\u0641\u064a\u0642 \u0648\u0627\u0644\u0633\u062f\u0627\u062f \u0641\u064a \u0645\u0647\u0627\u0645 \u0639\u0645\u0644\u0647 \u0627\u0644\u062c\u062f\u064a\u062f\u0629\u060c \u0645\u0648\u0654\u0643\u062f\u064b\u0627 \u0627\u0654\u0647\u0645\u064a\u0629 \u0645\u0648\u0627\u0635\u0644\u0629 \u0627\u0644\u062c\u0647\u0648\u062f \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u062a\u0643\u0627\u0645\u0644 \u0648\u0627\u0644\u062a\u0646\u0633\u064a\u0642 \u0628\u064a\u0646 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0628\u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629\u060c \u0628\u0645\u0627 \u064a\u0633\u0647\u0645 \u0641\u064a \u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 <a href=\"https://www.alyaum.com/articles/6665396/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%83%D8%AA%D9%85%D8%A7%D9%84-%D8%AA%D8%A3%D9%87%D9%8A%D9%84-%D9%86%D9%81%D9%82-%D8%A7%D9%84%D9%85%D9%84%D9%83-%D9%81%D9%87%D8%AF-