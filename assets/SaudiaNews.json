1\u0648\u0644\u0627\u0646 \u062c\u0627\u0631\u0648\u0633 \u0639\u0627\u0645 2024\u060c \u0648\u0631\u0628\u0639 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0645\u0627\u0636\u064a. \u0648\u0628\u0627\u062a\u062a \u0627\u0654\u0646\u062f\u0631\u064a\u064a\u0641\u0627 \u0627\u0654\u0635\u063a\u0631 \u0644\u0627\u0639\u0628\u0629 \u062a\u062a\u0648\u062c \u0628\u0644\u0642\u0628 \u0631\u0648\u0644\u0627\u0646 \u062c\u0627\u0631\u0648\u0633 \u0645\u0646\u0630 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0645\u0648\u0646\u064a\u0643\u0627 \u0633\u064a\u0644\u064a\u062a\u0634 \u0639\u0627\u0645 1992 \u062d\u064a\u0646 \u062a\u0648\u062c\u062a \u0628\u0637\u0644\u0629 \u0644\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062b\u0627\u0644\u062b \u062a\u0648\u0627\u0644\u064a\u064b\u0627 \u0639\u0646 18 \u0639\u0627\u0645\u064b\u0627. \u0643\u0645\u0627 \u0627\u0654\u0635\u0628\u062d\u062a \u0627\u0644\u0631\u0648\u0633\u064a\u0629 \u0627\u0654\u0648\u0644 \u0644\u0627\u0639\u0628\u0629 \u0627\u0654\u0648 \u0644\u0627\u0639\u0628 \u0645\u0646 \u0645\u0648\u0627\u0644\u064a\u062f 2005 \u0648\u0645\u0627 \u0628\u0639\u062f \u064a\u062a\u0648\u062c \u0628\u0644\u0642\u0628 \u0643\u0628\u064a\u0631. \u0648\u0642\u0627\u0644\u062a \u0645\u064a\u0631\u0627 \u0628\u0639\u062f \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629: \u00ab\u0643\u0646\u062a \u0627\u0654\u0634\u0627\u0647\u062f \u0631\u0648\u0644\u0627\u0646 \u062c\u0627\u0631\u0648\u0633 \u0639\u0644\u0649 \u0627\u0644\u062a\u0644\u0641\u0632\u064a\u0648\u0646 \u0645\u0646\u0630 \u0643\u0646\u062a \u0635\u063a\u064a\u0631\u0629 \u062c\u062f\u064b\u0627\u060c \u0628\u0627\u0644\u062a\u0627\u0644\u064a \u0627\u0644\u0641\u0648\u0632 \u0628\u0647\u0630\u0647 \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0643\u0627\u0646 \u062d\u0644\u0645\u064b\u0627 \u0643\u0628\u064a\u0631\u064b\u0627 \u0628\u0627\u0644\u0646\u0633\u0628\u0629 \u0644\u064a\u060c \u0648\u0644\u0627 \u0627\u0654\u0633\u062a\u0637\u064a\u0639 \u0628\u0635\u0631\u0627\u062d\u0629 \u0627\u0654\u0646 \u0627\u0654\u0635\u062f\u0642 \u0627\u0654\u0646\u064a \u0627\u0654\u062d\u0645\u0644 \u0647\u0630\u0647 \u0627\u0644\u0643\u0627\u0654\u0633 \u0627\u0644\u0627\u0653\u0646\u00bb. \u0648\u062a\u0648\u062c\u0647\u062a \u0627\u0655\u0644\u0649 \u0645\u0646\u0627\u0641\u0633\u062a\u0647\u0627 \u0628\u0627\u0644\u0642\u0648\u0644: \u00ab\u062a\u0647\u0627\u0646\u064a\u0646\u0627 \u0644\u0645\u0627\u064a\u0627 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0627\u0654\u0633\u0627\u0628\u064a\u0639 \u0627\u0644\u062b\u0644\u0627\u062b\u0629 \u0627\u0644\u0631\u0627\u064a\u0654\u0639\u0629\u060c \u0628\u0639\u062f \u0627\u0644\u0645\u0631\u0648\u0631 \u0639\u0628\u0631 \u0627\u0644\u062a\u0635\u0641\u064a\u0627\u062a \u0648\u0627\u0644\u0641\u0648\u0632 \u0628\u0639\u062f\u062f \u0643\u0628\u064a\u0631 \u0645\u0646 \u0627\u0644\u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0648\u0627\u0644\u062a\u063a\u0644\u0628 \u0639\u0644\u0649 \u0627\u0644\u0639\u062f\u064a\u062f \u0645\u0646 \u0627\u0644\u0644\u0627\u0639\u0628\u0627\u062a \u0627\u0644\u0631\u0627\u064a\u0654\u0639\u0627\u062a\u00bb. \u0648\u0627\u062e\u062a\u062a\u0645\u062a \u0647\u0630\u0647 \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u062a\u064a \u0644\u0645 \u062a\u0643\u0646 \u0641\u064a \u0627\u0644\u062d\u0633\u0628\u0627\u0646 \u0627\u0654\u0633\u0628\u0648\u0639\u064a\u0646 \u062d\u0627\u0641\u0644\u064a\u0646 \u0628\u0627\u0644\u0645\u0641\u0627\u062c\u0627\u0653\u062a \u0627\u0646\u0642\u0644\u0628\u062a \u062e\u0644\u0627\u0644\u0647\u0645\u0627 \u0627\u0644\u0645\u0648\u0627\u0632\u064a\u0646 \u0628\u0641\u0639\u0644 \u0645\u0648\u062c\u0629 \u0627\u0644\u062d\u0631 \u0627\u0644\u062a\u064a \u0627\u0654\u0644\u0642\u062a \u0628\u0638\u0644\u0627\u0644\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0627\u0644\u0627\u0654\u0648\u0644 \u0645\u0646 \u0