u063a\u0631\u0628 \u00d7 \u0643\u0646\u062f\u0627.<br /><br /> \u0627\u0644\u0628\u0631\u062a\u063a\u0627\u0644 \u00d7 \u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627.<br /><br />\u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627 \u00d7 \u0627\u0644\u0645\u0643\u0633\u064a\u0643.<br /><br /> \u0627\u0644\u0628\u0631\u0627\u0632\u064a\u0644 \u00d7 \u0627\u0644\u0646\u0631\u0648\u064a\u062c.<br /><br /> \u0641\u0631\u0646\u0633\u0627 \u00d7 \u0628\u0627\u0631\u0627\u063a\u0648\u0627\u064a. <br /><br /><br />\u0648\u062a\u0628\u0631\u0632 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0628\u0631\u062a\u063a\u0627\u0644 \u0648\u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627 \u0628\u0627\u0639\u062a\u0628\u0627\u0631\u0647\u0627 \u0627\u0655\u062d\u062f\u0649 \u0627\u0654\u0642\u0648\u0649 \u0642\u0645\u0645 \u062b\u0645\u0646 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u0641\u064a \u0638\u0644 \u0627\u0644\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0643\u0628\u064a\u0631 \u0644\u0644\u0645\u0646\u062a\u062e\u0628\u064a\u0646 \u0648\u0627\u0644\u0646\u062c\u0648\u0645 \u0627\u0644\u0630\u064a\u0646 \u064a\u0636\u0645\u0627\u0646\u0647\u0645\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0646\u062a\u0638\u0631 \u0639\u0634\u0627\u0642 \u0627\u0644\u0643\u0631\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0645\u063a\u0631\u0628 \u0648\u0643\u0646\u062f\u0627\u060c \u0628\u0639\u062f\u0645\u0627 \u0648\u0627\u0635\u0644 \"\u0627\u0654\u0633\u0648\u062f \u0627\u0644\u0627\u0654\u0637\u0644\u0633\" \u0639\u0631\u0648\u0636\u0647\u0645 \u0627\u0644\u0645\u0645\u064a\u0632\u0629 \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629.<br /><br />\u0643\u0645\u0627 \u062a\u0634\u0647\u062f \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0635\u062f\u0627\u0645\u064b\u0627 \u0642\u0648\u064a\u064b\u0627 \u0628\u064a\u0646 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u06