4\u0648\u0637\u0646\u064a\u0629 \u0644\u062a\u0635\u0646\u064a\u0639 \u0648\u0633\u0628\u0643 \u0627\u0644\u0645\u0639\u0627\u062f\u0646 \"\u0645\u0639\u062f\u0646\u064a\u0629\"\u060c \u0646\u062a\u0627\u064a\u0654\u062c \u0627\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0627\u0644\u0639\u0627\u062f\u064a\u0629 (\u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u0627\u0654\u0648\u0644) \u0648\u0627\u0644\u0630\u064a \u0627\u0646\u0639\u0642\u062f \u0628\u062a\u0627\u0631\u064a\u062e 21 \u0645\u0627\u064a\u0648 \u0627\u0644\u062d\u0627\u0644\u064a.<br /><br />\u0648\u0642\u0627\u0644\u062a \u0627\u0644\u0634\u0631\u0643\u0629 \u0641\u064a \u0628\u064a\u0627\u0646 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\": \u0627\u0655\u0646 \u0646\u062a\u0627\u064a\u0654\u062c \u0627\u0644\u062a\u0635\u0648\u064a\u062a \u0639\u0644\u0649 \u062c\u062f\u0648\u0644 \u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u062a\u0636\u0645\u0646\u062a:<br /><br />- \u0627\u0644\u0627\u0637\u0644\u0627\u0639 \u0639\u0644\u0649 \u062a\u0642\u0631\u064a\u0631 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0644\u0644\u0633\u0646\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0641\u064a 31 \u062f\u064a\u0633\u0645\u0628\u0631 2025 \u0648\u0645\u0646\u0627\u0642\u0634\u062a\u0647.<br /><br />- \u0627\u0644\u0627\u0637\u0644\u0627\u0639 \u0639\u0644\u0649 \u0627\u0644\u0642\u0648\u0627\u064a\u0654\u0645 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0644\u0644\u0633\u0646\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0641\u064a 31 \u062f\u064a\u0633\u0645\u0628\u0631 2025 \u0648\u0645\u0646\u0627\u0642\u0634\u062a\u0647\u0627.<br /><br />- \u0627\u0644\u0645\u0648\u0627\u0641\u0642\u0629 \u0639\u0644\u0649 \u062a\u0642\u0631\u064a\u0631 \u0645\u0631\u0627\u062c\u0639 \u062d\u0633\u0627\u0628\u0627\u062a \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0627\u0644\u0633\u0646\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0641\u064a 31 \u062f\u064a\u0633\u0645\u0628\u0631 2025 \u0628\u0639\u062f \u0645\u0646\u0627\u0642\u0634\u062a\u0647.<br /><br />- \u0627\u0644\u0645\u0648\u0627\u0641\u0642\u0629 \u0639\u0644\u0649 \u0635\u0631\u0641 \u0645\u0643\u0627\u0641\u0627\u0654\u0629 \u0644\u0627\u0654\u0639\u0636\u0627\u0621 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0628\u0645\u0628\u0644\u063a 1.2 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0639\u0646 \u0627\u0644\u0633\u0646\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0641\u064a 31 \u062f\u064a\u0633\u0645\u0628\u0631 2025.<br /><br />- \u0627\u0644\u0645\u0648\u0627\u0641\u0642\u0629 \u0639\u0644\u0649 \u0627\u0655\u0628\u0631\u0627\u0621 \u0630\u0645\u0629 \u0627\u0654\u0639\u0636\u0627\u0621 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0639\u0646 \u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0627\u0644\u0633\u0646\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0641\u064a 31 \u062f\u064a\u0633\u0645\u0628\u0631 2025.<br /><br />- \u0627\u0644\u0645\u0648\u0627\u0641\u0642\u0629 \u0639\u0644\u0649 \u062a\u0639\u064a\u064a\u0646 \u0645\u0643\u062a\u0628 \u0627\u0655\u0628\u0631\u0627\u0647\u064a\u0645 \u0627\u0654\u062d\u0645\u062f \u0627\u0644\u0628\u0633\u0627\u0645 \u0648\u0634\u0631\u0643\u0627\u0647 \u0645\u0631\u0627\u062c\u0639 \u062d\u0633\u0627\u0628\u0627\u062a \u0627\u0644\u0634\u0631\u0643\u0629 \u0645\u0646 \u0628\u064a\u0646 \u0627\u0644\u0645\u0631\u0634\u062d\u064a\u0646 \u0628\u0646\u0627\u062