 "title": "\u0627\u0644\u062e\u0644\u064a\u062c \u064a\u0642\u0644\u0628 \u0627\u0644\u0637\u0627\u0648\u0644\u0629 \u0639\u0644\u0649 \u0627\u0644\u062d\u0632\u0645 \u0628\u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0645\u062b\u064a\u0631\u0629 \u0641\u064a \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0627\u0644\u0633\u0639\u0648\u062f\u064a", "description": "\u062d\u0642\u0642 \u0641\u0631\u064a\u0642 \u0646\u0627\u062f\u064a \u0627\u0644\u062e\u0644\u064a\u062c \u0641\u0648\u0632\u064b\u0627 \u0645\u0647\u0645\u064b\u0627 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0646\u0627\u062f\u064a \u0627\u0644\u062d\u0632\u0645 \u0628\u0646\u062a\u064a\u062c\u0629 2-1\u060c \u0641\u064a \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u062a\u064a \u062c\u0645\u0639\u062a\u0647\u0645\u0627 \u0636\u0645\u0646 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u064025 \u0645\u0646 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0627\u0644\u0633\u0639\u0648\u062f\u064a.\u0648\u0628\u0647\u0630\u0627 \u0627\u0644\u0627\u0646\u062a\u0635\u0627\u0631 \u0631\u0641\u0639 \u0627\u0644\u062e\u0644\u064a\u062c \u0631\u0635\u064a\u062f\u0647 \u0627\u0655\u0644\u0649 30 \u0646\u0642\u0637\u0629 \u0644\u064a\u062a\u0642\u062f\u0645 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062a\u0627\u0633\u0639 \u0641\u064a \u062c\u062f\u0648\u0644 \u0627\u0644\u062a\u0631\u062a\u064a\u0628\u060c \u0628\u064a\u0646\u0645\u0627 \u062a\u062c\u0645\u062f \u0631\u0635\u064a\u062f \u0627\u0644\u062d\u0632\u0645 \u0639\u0646\u062f 28 \u0646\u0642\u0637\u0629 \u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062d\u0627\u062f\u064a \u0639\u0634\u0631.\u0628\u062f\u0627\u0654\u062a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0628\u0645\u062d\u0627\u0648\u0644\u0627\u062a \u0647\u062c\u0648\u0645\u064a\u0629 \u0645\u0628\u0643\u0631\u0629 \u0645\u0646 \u062c\u0627\u0646\u0628 \u0627\u0644\u062e\u0644\u064a\u062c\u060c \u062d\u064a\u062b \u0643\u0627\u062f \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0654\u0646 \u064a\u0641\u062a\u062a\u062d \u0627\u0644\u062a\u0633\u062c\u064a\u0644 \u0641\u064a \u0627\u0644\u062f\u0642\u064a\u0642\u0629 (7) \u0628\u0639\u062f\u0645\u0627 \u0633\u062f\u062f \u0641\u0648\u0631\u062a\u0648\u0646\u064a\u0633 \u0643\u0631\u0629 \u0642\u0648\u064a\u0629 \u0628\u0642\u062f\u0645\u0647 \u0627\u0644\u064a\u0633\u0631\u0649 \u0645\u0646 \u062f\u0627\u062e\u0644 \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u062c\u0632\u0627\u0621\u060c \u0644\u0643\u0646 \u062d\u0627\u0631\u0633 \u0627\u0644\u062d\u0632\u0645 \u0627\u0655\u0628\u0631\u0627\u0647\u064a\u0645 \u0632\u0627\u064a\u062f \u062a\u0635\u062f\u0649 \u0644\u0647\u0627 \u0628\u0628\u0631\u0627\u0639\u0629 \u0648\u0627\u0654\u0646\u0642\u0630 \u0645\u0631\u0645\u0627\u0647 \u0645\u0646 \u0647\u062f\u0641 \u0645\u062d\u0642\u0642\u060c \u0628\u0639\u062f \u062a\u0645\u0631\u064a\u0631\u0629 \u0645\u0646 \u062d\u0633\u064a\u0646 \u0627\u0644\u0639\u064a\u0633\u0649.\u0648\u0641\u064a \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u062b\u0627\u0646\u064a \u0646\u062c\u062d \u0627\u0644\u062d\u0632\u0645 \u0641\u064a \u0643\u0633\u0631 \u0627\u0644\u062a\u0639\u0627\u062f\u0644\u060c \u0639\u0646\u062f\u0645\u0627 \u0633\u062c\u0644 \u0646\u0648\u0627\u0641 \u0627\u0644\u062d\u0628\u0634\u064a \u0647\u062f\u0641 \u0627\u0644\u062a\u0642\u062f\u0645 \u0641\u064a \u0627\u0644\u062f\u0642\u064a\u0642\u0629 (54)\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0633\u062a\u063a\u0644 \u0647\u062c\u0645\u0629 \u0645\u0631\u062a\u062f\u0629 \u0633\u0631\u064a\u0639\u0629 \u0642\u0627\u062f\u0647\u0627 Aboubacar Bah\u060c \u0644\u064a\u0633\u062f\u062f \u0643\u0631\u0629 \u0628\u0642\u062f\u0645\u0647 \u0627\u0644\u064a\u0645\u0646\u0649 \u0645\u0646 \u062f\u0627\u062e\u0644 \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0633\u062a \u064a\u0627\u0631\u062f\u0627\u062a \u0627\u0655\u0644\u0649 \u0648\u0633\u0637 \u0627\u0644\u0645\u0631\u0645\u0649.\u0648\u0644\u0645 \u064a\u062a\u0627\u0654\u062e\u0631 \u0631\u062f \u0627\u0644\u062e\u0644\u064a\u062c \u0643\u062b\u064a\u0631\u064b\u0627\u060c \u062d\u064a\u062b \u062d\u0635\u0644 \u0627\u0644\u0641\u0631\u064a\u0642 \u0639\u0644\u0649 \u0631\u0643\u0644\u0629 \u062c\u0632\u0627\u0621 \u0641\u064a \u0627\u0644\u062f\u0642\u064a\u0642\u0629 (57) \u0628\u0639\u062f \u062a\u0639\u0631\u0636 \u0628\u0627\u0648\u0644\u0648 \u0641\u064a\u0631\u0646\u0627\u0646\u062f\u064a\u0632 \u0644\u0639\u0631\u0642\u0644\u0629 \u062f\u0627\u062e\u0644 \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u062c\u0632\u0627\u0621.\u0648\u0646\u062c\u062d \u0641\u0648\u0631\u062a\u0648\u0646\u064a\u0633 \u0641\u064a \u062a\u0631\u062c\u0645\u0629 \u0627\u0644\u0631\u0643\u0644\u0629 \u0627\u0655\u0644\u0649 \u0647\u062f\u0641 \u0627\u0644\u062a\u0639\u0627\u062f\u0644 \u0641\u064a \u0627\u0644\u062f\u0642\u064a\u0642\u0629 (60)\u060c \u0628\u0639\u062f\u0645\u0627 \u0633\u062f\u062f \u0627\u0644\u0643\u0631\u0629 \u0628\u0642\u062f\u0645\u0647 \u0627\u0644\u064a\u0645\u0646\u0649 \u0642\u0648\u064a\u0629 \u0646\u062d\u0648 \u0627\u0644\u0632\u0627\u0648\u064a\u0629 \u0627\u0644\u064a\u0645\u0646\u0649 \u0627\u0644\u0633\u0641\u0644\u064a\u0629 \u0644\u0644\u0645\u0631\u0645\u0649.\u0648\u0627\u0633\u062a\u0645\u0631 \u0636\u063a\u0637 \u0627\u0644\u062e\u0644\u064a\u062c \u062d\u062a\u0649 \u062a\u0645\u0643\u0646 \u0645\u0646 \u0642\u0644\u0628 \u0627\u0644\u0646\u062a\u064a\u062c\u0629 \u0641\u064a \u0627\u0644\u062f\u0642\u064a\u0642\u0629 (72)\u060c \u062d\u064a\u0646 \u0633\u062c\u0644 \u0645\u0627\u0633\u0648\u0631\u0627\u0633 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u062b\u0627\u0646\u064a \u0628\u0639\u062f \u062a\u0633\u062f\u064a\u062f\u0629 \u0642\u0648\u064a\u0629 \u0628\u0642\u062f\u0645\u0647 \u0627\u0644\u064a\u0645\u0646\u0649 \u0645\u0646 \u0627\u0644\u062c\u0647\u0629 \u0627\u0644\u064a\u0633\u0631\u0649 \u0644\u0645\