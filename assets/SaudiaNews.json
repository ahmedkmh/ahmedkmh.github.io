29 \u0627\u0644\u062c\u0628\u064a\u0644 \u064a\u062a\u0648\u062c \"\u0627\u0654\u0643\u0627\u062f\u064a\u0645\u064a\u0629 \u0627\u0644\u0641\u0647\u062f\" \u0628\u0637\u0644\u0627\u064b \u0644\u0631\u0645\u0636\u0627\u0646\u064a\u0629 \u0627\u0644\u062c\u0628\u064a\u0644 \u0627\u0644\u062b\u0627\u0646\u064a\u0629", "description": "\u062a\u0648\u062c \u0631\u064a\u0654\u064a\u0633 \u0628\u0644\u062f\u064a\u0629 \u0645\u062d\u0627\u0641\u0638\u0629 \u0627\u0644\u062c\u0628\u064a\u0644 \u0627\u0644\u0645\u0647\u0646\u062f\u0633 \u0628\u0627\u062f\u064a \u0628\u0646 \u0641\u0647\u064a\u062f \u0627\u0644\u0642\u062d\u0637\u0627\u0646\u064a \u0641\u0631\u064a\u0642 \"\u0627\u0654\u0643\u0627\u062f\u064a\u0645\u064a\u0629 \u0627\u0644\u0641\u0647\u062f\" \u0628\u0643\u0627\u0654\u0633 \u0628\u0637\u0648\u0644\u0629 \u0628\u0644\u062f\u064a\u0629 \u0627\u0644\u062c\u0628\u064a\u0644 \u0627\u0644\u0631\u0645\u0636\u0627\u0646\u064a\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0648\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0640 40 \u0627\u0654\u0644\u0641 \u0631\u064a\u0627\u0644\u060c \u0628\u0639\u062f \u0641\u0648\u0632\u0647 \u0639\u0644\u0649 \u0641\u0631\u064a\u0642 \"\u0643\u0648\u0641\u064a \u063a\u0628\u0648\u0642\" \u0628\u0631\u0643\u0644\u0627\u062a \u0627\u0644\u062a\u0631\u062c\u064a\u062d (4 - 3) \u0627\u0655\u062b\u0631 \u062a\u0639\u0627\u062f\u0644\u0647\u0645\u0627 \u0628\u0646\u062a\u064a\u062c\u0629 1 - 1.\u0648\u062d\u0635\u0644 \u0641\u0631\u064a\u0642 \"\u0643\u0648\u0641\u064a \u063a\u0628\u0648\u0642\" \u0639\u0644\u0649 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0646\u064a \u0648\u062c\u0627\u064a\u0654\u0632\u0629 10 \u0627\u0653\u0644\u0627\u0641 \u0631\u064a\u0627\u0644\u060c \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0627\u0644\u062a\u064a \u0634\u0647\u062f\u062a \u0645\u0634\u0627\u0631\u0643\u0629 \u0646\u062e\u0628\u0629 \u0641\u0631\u0642 \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u064