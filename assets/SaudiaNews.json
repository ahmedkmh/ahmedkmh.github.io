A7%D9%86-%D9%84%D9%84%D9%85%D8%AD%D8%A7%D8%AF%D8%AB%D8%A7%D8%AA-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9-%D8%A7%D9%84%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D9%8A%D8%A9\">\u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0627\u062a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629</a>\u060c \u0627\u0655\u0630 \u062a\u0648\u062c\u0647 \u0648\u0641\u062f \u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0627\u0644\u0649 <a href=\"https://www.alyaum.com/articles/6588549/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D9%84%D8%A8%D8%AF%D9%8A%D9%88%D9%8A-%D9%8A%D8%B1%D8%AD%D8%A8-%D8%A8%D8%A7%D8%B3%D8%AA%D8%B6%D8%A7%D9%81%D8%A9-%D8%B3%D9%84%D8%B7%D9%86%D8%A9-%D8%B9%D9%85%D8%A7%D9%86-%D9%84%D9%84%D9%85%D8%AD%D8%A7%D8%AF%D8%AB%D8%A7%D8%AA-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9-%D8%A7%D9%84%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D9%8A%D8%A9\">\u0633\u0648\u064a\u0633\u0631\u0627</a> \u0627\u0644\u0633\u0628\u062a \u0644\u0644\u0628\u062d\u062b \u0641\u064a \u062a\u0637\u0628\u064a\u0642 \u0645\u0630\u0643\u0631\u0629 \u0627\u0644\u062a\u0641\u0627\u0647\u0645 \u0627\u0644\u0645\u0648\u0642\u0639\u0629 \u0645\u0639 <a href=\"https://www.alyaum.com/articles/6588528/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%AA%D8%B1%D8%AD%D8%A8-%D8%A8%D8%A7%D8%B3%D8%AA%D8%B6%D8%A7%D9%81%D8%A9-%D8%B3%D9%84%D8%B7%D9%86%D8%A9-%D8%B9%D9%85%D8%A7%D9%86-%D9%84%D9%84%D9%85%D8%AD%D8%A7%D8%AF%D8%AB%D8%A7%D8%AA-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9-%D8%A7%D9%84%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D9%8A%D8%A9\">\u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629</a>.<br /><br />\u064a\u0627\u0654\u062a\u064a \u0647\u0630\u0627 \u0641\u064a\u0645\u0627 \u062a\u062d\u0630\u0631 \u0637\u0647\u0631\u0627\u0646 \u0645\u0646 \u0627\u0654\u0646 \u0647\u0630\u0627 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0633\u064a\u0643\u0648\u0646 \u0641\u064a \u062e\u0637\u0631 \u0645\u0627 \u0644\u0645 \u062a\u0646\u0641\u0630 \u0648\u0627\u0634\u0646\u0637\u0646 \u062a\u0639\u0647\u062f\u0627\u062a\u0647\u0627.<h2>\u0627\u062a\u0641\u0627\u0642 \u0627\u0655\u064a\u0631\u0627\u0646 \u0648\u0627\u0654\u0645\u0631\u064a\u0643\u0627</h2>\u0648\u0642\u0627\u0644 \u0627\u0644\u0645\u062a\u062d\u062f\u062b \u0628\u0627\u0633\u0645 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0655\u0633\u0645\u0627\u0639\u064a\u0644 \u0628\u0642\u0627\u064a\u0654\u064a \u0627\u0655\u0646 \u0627\u0644\u0648\u0641\u062f \u0633\u064a\u062a\u0627\u0628\u0639 \u0648\u064a\u0637\u0627\u0644\u0628 \u0628\u062a\u0646\u0641\u064a\u0630 \u0627\u0644\u062a\u0632\u0627\u0645\u0627\u062a \u0627\u0644\u0637\u0631\u0641 \u0627\u0644\u0627\u0653\u062e\u0631 \u0628\u0645\u0648\u062c\u0628 \u0647\u0630\u0627 \u0627\u0644\u062a\u0641\u0627\u0647\u0645.<br /><br /> <br /><br />\u0648\u062d\u0630\u0651\u0631 \"\u0628\u0642\u0627\u064a\u0654\u064a\" \u0645\u0646 \u0627\u0654\u0646 \"\u0639\u0644\u0649 \u0627\u0644\u0637\u0631\u0641 \u0627\u0644\u0627\u0653\u062e\u0631 \u0627\u062a\u062e\u0627\u0630 \u0627\u0644\u062a\u062f\u0627\u0628\u064a\u0631 \u0627\u0644\u0644\u0627\u0632\u0645\u0629 \u0644\u062a\u0646\u0641\u064a\u0630 \u062a\u0639\u0647\u062f\u0627\u062a\u0647 \u0641\u064a \u0627\u0654\u0633\u0631\u0639 \u0648\u0642\u062a \u0645\u0645\u0643\u0646. \u0645\u0627 \u062f\u0648\u0646 \u0630\u0644\u0643\u060c \u0633\u064a\u0643\u0648\u0646 \u0627\u0644\u062a\u0641\u0627\u0647\u0645 \u0628\u0627\u0654\u0643\u0645\u0644\u0647 \u0641\u064a \u062e\u0637\u0631\".<br /><br />\u0648\u0630\u0643\u0631 \u0627\u0644\u062a\u0644\u0641\u0632\u064a\u0648\u0646 \u0627\u0644\u0631\u0633\u0645\u064a \u0627\u0644\u0627\u064a\u0631\u0627\u0646\u064a\u060c \u0627\u0654\u0646 \u0627\u0644\u0648\u0641\u062f \u0627\u0644\u0630\u064a