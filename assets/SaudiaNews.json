{"status": "success", "totalResults": 4463, "results": [{"article_id": "6af6e0d5f1b962524fdb7afc4351c1c6", "link": "https://www.rfi.fr/cn/%E4%B8%AD%E4%B8%9C/20260329-rfi%E6%B3%95%E5%B9%BF-%E5%B0%BC%E5%8F%A4%E6%8B%89-%E9%9D%9E%E6%B4%B2%E5%81%B7%E6%B8%A1%E5%AE%A2%E5%B0%9D%E8%AF%95%E6%BD%9C%E5%85%A5%E4%B8%AD%E4%B8%9C%E9%81%AD%E6%B5%B7%E9%9A%BE", "title": "\u975e\u6d32\u5077\u6e21\u5ba2\u5c1d\u8bd5\u6f5c\u5165\u4e2d\u4e1c\u906d\u6d77\u96be", "description": "\u5728\u4e16\u754c\u5404\u56fd\u6c11\u4f17\u7eb7\u7eb7\u56e0\u4f0a\u6717\u6218\u4e8b\u800c\u8fdc\u79bb\u4e2d\u4e1c\u53ca\u6d77\u6e7e\u5730\u533a\u4e4b\u9645,\u5728\u4e9a\u975e\u4e24\u5927\u6d32\u7684\u4ea4\u754c\u5730\u5e26,\u4e34\u8fd1\u51fa\u5165\u82cf\u4f0a\u58eb\u8fd0\u6cb3\u6d77\u4e0a\u822a\u9053\u7ea2\u6d77\u8981\u51b2\u66fc\u5fb7\u6d77\u5ce1(le de\u0301troit de Bab el-Mandeb)\u9644\u8fd1,\u4e00\u8258\u642d\u8f7d\u4e86\u8d85\u8fc7320\u4eba\u7684\u8239\u53ea,\u9006\u4eba\u6f6e\u800c\u884c,\u4ece\u4e1c\u975e\u51fa\u53d1\u8bd5\u56fe\u6f5c\u5165\u963f\u62c9\u4f2f\u534a\u5c9b\u4e0a\u7684\u4e2d\u4e1c\u56fd\u5bb6\u4e5f\u95e8,\u4f46\u4e0d\u5e78\u4e8e2026\u5e7403\u670824\u65e5\u5468\u4e8c\u81f325\u65e5\u5468\u4e09\u591c\u95f4\u5728\u5409\u5e03\u63d0\u6c34\u57df\u53d1\u751f\u6d77\u96be\u3002\u81f3\u5c11\u6709\u8fd110\u6b7b\u4ea1\u548c45\u4eba\u5931\u8e2a\u3002\u8fd9\u662f\u672c\u53f0\u6cd5\u5e7f\u975e\u6d32\u7ec4(RFI Afrique)2026\u5e7403\u670828\u65e5\u661f\u671f\u516d\u4e0a\u7f51\u7684\u6cd5\u6587\u6d88\u606f\u4e4b\u4e00\u3002\u672c\u53f0\u6cd5\u5e7f(RFI)\u975e\u6d32\u901a\u8baf\u5458\u53d1\u81ea\u5185\u7f57\u6bd5(Nairobi)\u7684\u6cd5\u6587\u62a5\u9053\u8bf4,\u56fd\u9645\u79fb\u6c11\u7ec4\u7ec7(OIM-Organisation internationale des migration)\u5728\u4e00\u4efd\u65b0\u95fb\u901a\u62a5\u4e2d\u8868\u793a,\u8fd9\u662f\u4e00\u6279\u8bd5\u56fe\u8fdb\u5165\u897f\u4e9a\u7684\u79fb\u6c11\u3002\u53e6\u5916,\u672c\u53f0\u6cd5\u5e7f(RFI)\u4eca\u592903\u670829\u53f7\u5468\u65e5\u66f4\u65b0\u7684\u6cd5\u6587\u62a5\u9053\u663e\u793a,\u53cd\u5bf9\u7f8e\u4ee5\u4e24\u56fd\u6253\u51fb\u4f0a\u6717\u7684\u4e5f\u95e8\u80e1\u585e\u6b66\u88c5\u5df2\u5f00\u59cb\u5377\u5165\u4e2d\u4e1c\u5730\u533a\u5f53\u524d\u6218\u4e8b,\u5e76\u4e8e\u6628\u592903\u670828\u65e5\u5468\u516d\u4e24\u6b21\u5411\u4ee5\u8272\u5217\u53d1\u5c04\u5bfc\u5f39\u548c\u65e0\u4eba\u673a\u3002", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u975e\u6d32", "\u4e2d\u4e1c", "\u4e5f\u95e8", "\u6d77\u6e7e\u56fd\u5bb6", "\u4f0a\u6717", "\u4e9a\u6d32", "\u57c3\u585e\u4fc4\u6bd4\u4e9a", "\u5409\u5e03\u63d0"], "creator": ["\u5c3c\u53e4\u62c9"], "language": "chinese", "country": ["libya", "qatar", "somalia", "turkmenistan", "djibouti", "tunisia", "kyrgyzstan", "azerbaijan", "tajikistan", "turkey", "algeria", "syria", "uzbekistan", "oman", "united arab emirates", "lebanon", "iran", "georgia", "morocco", "mauritania", "armenia", "kuwait", "ethiopia", "egypt", "israel", "saudi arabia", "cyprus", "kazakhstan", "sudan", "afghanistan", "bahrain", "iraq", "pakistan", "jordan", "india", "yemen"], "category": ["top", "lifestyle"], "datatype": "news", "pubDate": "2026-03-29 10:48:58", "pubDateTZ": "UTC", "fetched_at": "2026-03-29 11:10:07", "image_url": "https://s.rfi.fr/media/display/435f301e-2b5a-11f1-9d15-005056bf30b7/w:1280/p:16x9/2026-03-29-D-FMM-archive-Yemen-et-Djibouti-x-logo-RFI.jpg", "video_url": null, "source_id": "rfi_fr", "source_name": "Rfi", "source_priority": 8490, "source_url": "https://www.rfi.fr", "source_icon": "https://n.bytvi.com/rfi_fr.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "3e505ab63db183ff725e8ccfc758af65", "link": "https://www.rfi.fr/tw/%E4%B8%AD%E6%9D%B1/20260329-rfi%E6%B3%95%E5%