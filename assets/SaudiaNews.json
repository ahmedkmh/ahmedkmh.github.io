3\u0631\u0628\u0648\u0646\u060c \u0644\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u0644\u0648\u062c\u0633\u062a\u064a\u0629 \u0648\u062a\u062e\u0641\u064a\u0641 \u0627\u0644\u0627\u0654\u0639\u0628\u0627\u0621 \u0627\u0644\u0628\u064a\u064a\u0654\u064a\u0629 \u0628\u0627\u0644\u0645\u0645\u0644\u0643\u0629.<br /><br />\u0648\u0628\u064a\u0646 \u0627\u0644\u062a\u0642\u0631\u064a\u0631 \u0627\u0644\u0630\u064a \u062d\u0645\u0644 \u0634\u0639\u0627\u0631 \u00ab\u062e\u0637\u0649 \u062b\u0627\u0628\u062a\u0629 \u0639\u0644\u0649 \u0645\u0633\u0627\u0631 \u0627\u0644\u0627\u0633\u062a\u062f\u0627\u0645\u0629\u00bb \u0627\u062a\u0633\u0627\u0639 <a href=\"https://www.alyaum.com/articles/6664113/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B3%D8%A7%D8%B1-%D8%AA%D9%81%D9%88%D9%8A%D8%AC-%D9%82%D8%B7%D8%A7%D8%B1-%D8%A7%D9%84%D9%85%D8%B4%D8%A7%D8%B9%D8%B1-%D9%84290-%D8%A3%D9%84%D9%81-%D8%AD%D8%A7%D8%AC-%D9%85%D9%86-%D8%B9%D8%B1%D9%81%D8%A7%D8%AA-%D8%A5%D9%84%D9%89-%D9%85%D8%B2%D8%AF%D9%84%D9%81%D8%A9\" target=\"_blank\">\u0627\u0644\u0634\u0628\u0643\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629</a> \u0644\u0627\u0654\u0643\u062b\u0631 \u0645\u0646 5500 \u0643\u064a\u0644\u0648\u0645\u062a\u0631. \u0648\u062a\u0631\u0628\u0637 \u0647\u0630\u0647 \u0627\u0644\u0645\u0633\u0627\u0631\u0627\u062a 14 \u0645\u062f\u064a\u0646\u0629 \u0639\u0628\u0631 \u0627\u0654\u0631\u0628\u0639 \u0634\u0628\u0643\u0627\u062a \u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629\u060c \u062a\u0634\u0645\u0644 \u0642\u0637\u0627\u0631\u0627\u062a \u0627\u0644\u0634\u0631\u0642 \u0648\u0627\u0644\u0634\u0645\u0627\u0644 \u0648\u0627\u0644\u062d\u0631\u0645\u064a\u0646 \u0648\u0627\u0644\u0645\u0634\u0627\u0639\u0631\u060c \u0644\u062f\u0639\u0645 \u0627\u0644\u062d\u0631\u0627\u0643 \u0627\u0644\u062a\u062c\u0627\u0631\u064a \u0648\u062a\u0633\u0647\u064a\u0644 \u062a\u0646\u0642\u0644\u0627\u062a \u0627\u0644\u0645\u0633\u0627\u0641\u0631\u064a\u0646.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0627\u0655\u062d\u0635\u0627\u064a\u0654\u064a\u0629 \u062a\u0633\u062c\u064a\u0644 \u0645\u0639\u062f\u0644\u0627\u062a \u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0642\u064a\u0627\u0633\u064a\u0629 \u0628\u0646\u0642\u0644 1,8 \u0645\u0644\u064a\u0648\u0646 \u062d\u0627\u062c \u062e\u0644\u0627\u0644 \u0645\u0648\u0633\u0645 \u062d\u062c 1446 \u0647\u0640 \u0639\u0628\u0631 \u0642\u0637\u0627\u0631 \u0627\u0644\u0645\u0634\u0627\u0639\u0631 \u0627\u0644\u0645\u0642\u062f\u0633\u0629. \u0648\u0633\u062c\u0644 \u0642\u0637\u0627\u0631 \u0627\u0644\u062d\u0631\u0645\u064a\u0646 \u0627\u0644\u0633\u0631\u064a\u0639 \u0627\u0646\u0636\u0628\u0627\u0637\u0627\u064b \u0632\u0645\u0646\u064a\u064b\u0627 \u0628\u0644\u063a 99,5% \u062e\u0644\u0627\u0644 \u0634\u0647\u0631 \u0631\u0645\u0636\u0627\u0646\u060c \u0646\u0627\u0642\u0644\u064b\u0627 1,2 \u0645\u0644\u064a\u0648\u0646 \u0645\u0633\u0627\u0641\u0631 \u0628\u0632\u064a\u0627\u062f\u0629 \u0633\u0646\u0648\u064a\u0629 \u0642\u062f\u0631\u0647\u0627 12%\u060c \u0648\u0628\u0645\u0639\u062f\u0644 \u064a\u0648\u0645\u064a \u062a\u062c\u0627\u0648\u0632 48 \u0627\u0654\u0644\u0641 \u0631\u0627\u0643\u0628.</div><h2 style=\"text-align:justify\"> <br />\u0646\u0645\u0648 \u0627\u0654\u062d\u062c\u0627\u0645 \u0627\u0644\u0634\u062d\u0646</h2><div style=\"text-align: justify;\"><br />\u0648\u0639\u0644\u0649 \u0627\u0644\u0635\u0639\u064a\u062f \u0627\u0644\u0644\u0648\u062c\u0633\u062a\u064a\u060c \u0627\u0654\u0638\u0647\u0631\u062a \u0627\u0644\u0627\u0654\u0631\u0642\u0627\u0645 \u0646\u0645\u0648\u0627\u064b \u0641\u064a \u0627\u0654\u062d\u062c\u0627\u0645 \u0627\u0644\u0634\u062d\u0646 \u0628\u0646\u0633\u0628\u0629 \u062a\u062c\u0627\u0648\u0632\u062a 3% \u0639\u0628\u0631 \u0646\u0642\u0644 30 \u0645\u0644\u064a\u0648\u0646 \u0637\u0646 \u0645\u0646 \u0627\u0644\u0628\u0636\u0627\u064a\u0654\u0639.<br /><br />\u0648\u0627\u0654\u0633\u0647\u0645 \u0647\u0630\u0627 \u0627\u0644\u062a\u062d\u0648\u0644 \u0641\u064a \u062f\u0639\u0645 \u0633\u0644\u0627\u0633\u0644 \u0627\u0644\u0627\u0655\u0645\u062f\u0627\u062f\u060c \u062a\u0632\u0627\u0645\u0646\u064b\u0627 \u0645\u0639 \u0627\u0655\u0628\u0631\u0627\u0645 \u0635\u0641\u0642\u0627\u062a \u062a\u062e\u0637\u062a \u0642\u064a\u0645\u062a\u0647\u0627 \u0633\u062a\u0629 \u0645\u0644\u064a\u0627\u0631\u0627\u062a \u062f\u0648\u0644\u0627\u0631 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0648\u0654\u062a\u0645\u0631 \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0627\u0644\u062f\u0648\u0644\u064a \u0644\u0644\u062e\u0637\u0648\u0637 \u0627\u0644\u062d\u062f\u064a\u062f\u064a\u0629.<br /><br />\u0628\u064a\u064a\u0654\u064a\u064b\u0627\u060c \u0644\u0641\u062a <a href=\"https://www.alyaum.com/articles/6664068/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B3%D8%A7%D8%B1-%D9%86%D9%82%D9%84-%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-314-%D8%A3%D9%84%D9%81-%D8%B1%D8%A7%D9%83%D8%A8-%D8%A8%D9%82%D8%B7%D8%A7%D8%B1-%D8%A7%D9%84%D9%85%D8%B4%D8%A7%D8%B9%D8%B1-%D8%A7%D9%84%D9%85%D9%82%D8%AF%D8%B3%D8%A9\" target=\"_blank\">\u0627\u0644\u062a\u0642\u0631\u064a\u0631 </a>\u0627\u0644\u0627\u0646\u062a\u0628\u0627\u0647 \u0627\u0655\u0644\u0649 \u062a\u0648\u0641\u064a\u0631 139,4 \u0645\u0644\u064a\u0648\u0646 \u0644\u062a\u0631 \u0645\u0646 \u0627\u0644\u0648\u0642\u0648\u062f \u0633\u0646\u0648\u064a\u064b\u0627\u060c \u0648\u0627\u0655\u0632\u0627\u062d\u0629 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0645\u0644\u064a\u0648\u0646\u064a \u0645\u0631\u0643\u0628\u0629 \u0639\u0646 \u0627\u0644\u0637\u0631\u0642 \u0627\u0644\u0628\u0631\u064a\u0629. \u0648\u0639\u0632\u0632\u062a \u0627\u0644\u062e\u0637\u0648\u0637 \u0627\u0644\u062d\u062f\u064a\u062f\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0639\u062a\u0645\u0627\u062f\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0646\u0638\u064a\u0641\u0629 \u0628\u062a\u0634\u063a\u064a\u0644 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 50% \u0645\u0646 \u0627\u0654\u0646\u0638\u0645\u0629 \u0627\u0644\u0627\u0655\u0634\u0627\u0631\u0627\u062a \u0648\u0627\u0644\u0627\u062a\u0635\u0627\u0644\u0627\u062a \u0639\u0628\u0631 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0634\u0645\u0633\u064a\u0629\u060c \u0628\u062a\u0631\u0643\u064a\u0628 96 \u0644\u0648\u062d\u064b\u0627 \u0634\u0645\u0633\u064a\u064b\u0627 \u0641\u064a 62 \u0628\u0631\u062c\u064b\u0627\u060c \u0645\u0645\u0627 \u062e\u0641\u0636 \u0627\u0644\u0627\u0646\u0628\u0639\u0627\u062b\u0627\u062a \u0641\u064a \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u0646\u0627\u064a\u0654\u064a\u0629 \u0628\u0646\u0633\u0628\u0629 99,9%.<br /><br />\u0648\u0627\u0654\u0643\u062f\u062a \u0627\u0644\u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u062a\u0632\u0627\u0645\u0647\u0627 \u0628\u0645\u0628\u0627\u062f\u064a\u0654 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f \u0627\u0644\u062f\u0627\u064a\u0654\u0631\u064a \u0639\u0628\u0631 \u062a\u062f\u0648\u064a\u0631 10,216 \u0637\u0646\u064b\u0627 \u0645\u0646 \u0627\u0644\u0646\u0641\u0627\u064a\u0627\u062a \u0627\u0644\u0635\u0646\u0627\u0639\u064a\u0629 \u0627\u0644\u0645\u062e\u062a\u0644\u0641\u0629 \u0648\u0627\u0655\u0639\u0627\u062f\u062a\u0647\u0627 \u0644\u0633\u0644\u0627\u0633\u0644 \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u0645\u062d\u0644\u064a\u0629. \u0648\u062a\u0631\u0627\u0641\u0642 \u0630\u0644\u0643 \u0645\u0639 \u0631\u0641\u0639 \u0646\u0633\u0628\u0629 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0645\u062d\u0644\u064a \u0627\u0655\u0644\u0649 55% \u0628\u062f\u0644\u0627\u064b \u0645\u0646 36,8% \u0627\u0644\u0645\u0633\u062c\u0644\u0629 \u0641\u064a \u0639\u0627\u0645 2021\u060c \u0645\u0639 \u062a\u0648\u062c\u064a\u0647 95% \u0645\u0646 \u0627\u0644\u0627\u0655\u0646\u0641\u0627\u0642 \u0646\u062d\u0648 \u0627\u0644\u0645\u0648\u0631\u062f\u064a\u0646 \u0627\u0644\u0645\u062d\u0644\u064a\u064a\u0646\u060c \u0645\u0645\u0627 \u0648\u0641\u0631 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 10 \u0645\u0644\u0627\u064a\u064a\u0646 \u062f\u0648\u0644\u0627\u0631 \u0648\u062f\u0645\u062c 33 \u0645\u0646\u0634\u0627\u0654\u0629 \u0635\u063a\u064a\u0631\u0629 \u0648\u0645\u062a\u0648\u0633\u0637\u0629.</div><h2 style=\"text-align:justify\">\u0645\u0639\u062f\u0644 \u062a\u0648\u0637\u064a\u0646</h2><div style=\"text-align: justify;\">\u0648\u0641\u064a \u0645\u0633\u0627\u0631 \u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u0642\u062f\u0631\u0627\u062a\u060c \u062d\u0627\u0641\u0638\u062a \u0627\u0644\u062c\u0647\u0629 \u0639\u0644\u0649 \u0645\u0639\u062f\u0644 \u062a\u0648\u0637\u064a\u0646 \u0628\u0644\u063a 89% \u0644\u0644\u0643\u0648\u0627\u062f\u0631 \u0627\u0644\u0628\u0634\u0631\u064a\u0629\u060c \u0645\u0639 \u062a\u0642\u062f\u064a\u0645 104 \u0627\u0653\u0644\u0627\u0641 \u0633\u0627\u0639\u0629 \u062a\u062f\u0631\u064a\u0628\u064a\u0629 \u0627\u0633\u062a\u0641\u0627\u062f \u0645\u0646\u0647\u0627 3129 \u0645\u0648\u0638\u0641\u064b\u0627. \u0643\u0645\u0627 \u062c\u0631\u0649 \u062a\u0627\u0654\u0647\u064a\u0644 2421 \u0645\u0648\u0638\u0641\u064b\u0627 \u0641\u064a \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0633\u0627\u0631\u0627\u062a\u060c \u0648\u062a\u0633\u062c\u064a\u0644 4400 \u0633\u0627\u0639\u0629 \u062a\u0637\u0648\u0639\u064a\u0629 \u0644\u062e\u062f\u0645\u0629 \u0636\u064a\u0648\u0641 \u0627\u0644\u0631\u062d\u0645\u0646.<br /><br />\u062a\u0642\u0646\u064a\u064b\u0627\u060c \u0643\u0634\u0641\u062a \u0627\u0644\u0627\u0655\u062d\u0635\u0627\u0621\u0627\u062a \u0639\u0646 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0654\u0648\u0644 \u0646\u0645\u0648\u0630\u062c \u0630\u0643\u0627\u0621 \u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0648\u0634\u0645\u0627\u0644 \u0627\u0654\u0641\u0631\u064a\u0642\u064a\u0627 \u0644\u0644\u062a\u0646\u0628\u0648\u0654 \u0628\u0627\u0644\u062d\u0648\u0627\u062f\u062b \u0628\u062f\u0642\u0629 \u0628\u0644\u063a\u062a 75%\u060c \u0644\u0631\u0641\u0639 \u0627\u0644\u0645\u0648\u062b\u0648\u0642\u064a\u0629 \u0648\u062a\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u0627\u0654\u0635\u0648\u0644. \u0648\u062a\u0648\u062c\u062a \u0647\u0630\u0647 \u0627\u0644\u0645\u0645\u0627\u0631\u0633\u0627\u062a \u0628\u062d\u0635\u0648\u0644 \u0627\u0644\u062e\u0637\u0648\u0637 \u0627\u0644\u062d\u062f\u064a\u062f\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0639\u0644\u0649 \u062a\u0635\u0646\u064a\u0641 \u0627\u0654\u0631\u0628\u0639 \u0646\u062c\u0648\u0645 \u0645\u0646 \u0627\u0644\u0645\u0648\u0654\u0633\u0633\u0629 \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a\u0629 \u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u062c\u0648\u062f\u0629 \u0643\u0627\u0654\u0648\u0644 \u062c\u0647\u0629 \u0646\u0642\u0644 \u0627\u0655\u0642\u0644\u064a\u0645\u064a\u0629 \u062a\u062d\u0635\u062f \u0647\u0630\u0627 \u0627\u0644\u062a\u0642\u064a\u064a\u0645\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0646\u064a\u0644 \u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0645\u0644\u0643 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0644\u0644\u062c\u0648\u062f\u0629.<br /><br />\u0648\u062a\u0645\u0636\u064a \u0627\u0644\u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u0642\u0628\u0644\u064a\u0629 \u0644\u0639\u0627\u0645 2035\u0645 \u0646\u062d\u0648 \u062a\u0648\u0633\u064a\u0639 \u0627\u0644\u0634\u0628\u0643\u0629 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0648\u0631\u0641\u0639 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0627