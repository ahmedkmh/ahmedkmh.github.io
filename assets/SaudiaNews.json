46\u064a\u0629 \u0628\u0645\u0627 \u064a\u0633\u0647\u0645 \u0641\u064a \u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0654\u0645\u0646 \u0648\u0633\u0644\u0627\u0645\u0629 \u0636\u064a\u0648\u0641 \u0627\u0644\u0631\u062d\u0645\u0646\u060c \u0645\u0634\u062f\u062f\u0629 \u0639\u0644\u0649 \u0627\u0654\u0646 \u0645\u062e\u0627\u0644\u0641\u0629 \u0627\u0644\u0627\u0654\u0646\u0638\u0645\u0629 \u062a\u0639\u0631\u0636 \u0645\u0631\u062a\u0643\u0628\u064a\u0647\u0627 \u0644\u0644\u0639\u0642\u0648\u0628\u0627\u062a \u0627\u0644\u0646\u0638\u0627\u0645\u064a\u0629.<br /><br />\u0643\u0645\u0627 \u062f\u0639\u062a \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0655\u0628\u0644\u0627\u063a \u0639\u0646 \u0627\u0644\u0645\u062e\u0627\u0644\u0641\u064a\u0646 \u0639\u0628\u0631 \u0627\u0644\u0631\u0642\u0645 (911) \u0641\u064a \u0645\u0646\u0627\u0637\u0642 \u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629 \u0648\u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629 \u0648\u0627\u0644\u0631\u064a\u0627\u0636 \u0648\u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629\u060c \u0648\u0627\u0644\u0631\u0642\u0645 (999) \u0641\u064a \u0628\u0642\u064a\u0629 \u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0645\u0645\u0644\u0643\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["top", "politics"], "datatype": "news", "pubDate": "2026-05-25 16:30:00", "pubDateTZ": "UTC", "fetched_at": "2026-05-25 16:47:20", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE