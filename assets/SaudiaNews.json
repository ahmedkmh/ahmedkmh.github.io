\u0634\u0631\u0629 \u0627\u0644\u0634\u0647\u0631\u064a\u0629 \u0644\u0645\u062a\u0648\u0633\u0637\u0627\u062a <a href=\"https://www.alyaum.com/articles/6650920/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D8%B3%D8%AA%D9%82%D8%B1%D8%A7%D8%B1-%D8%A3%D8%B3%D8%B9%D8%A7%D8%B1-%D8%A7%D9%84%D9%84%D8%AD%D9%88%D9%85-%D9%88%D8%A7%D9%84%D8%AF%D8%AC%D8%A7%D8%AC-%D9%88%D8%A7%D8%B1%D8%AA%D9%81%D8%A7%D8%B9-%D8%A7%D9%84%D8%A3%D8%B3%D9%85%D8%A7%D9%83-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%AE%D9%84%D8%A7%D9%84-%D9%81%D8%A8%D8%B1%D8%A7%D9%8A%D8%B1\" target=\"_blank\">\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0633\u0644\u0639</a> \u0644\u0634\u0647\u0631 \u0641\u0628\u0631\u0627\u064a\u0631 2026 \u0627\u0631\u062a\u0641\u0627\u0639\u064b\u0627 \u0645\u0644\u062d\u0648\u0638\u064b\u0627 \u0641\u064a \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u062d\u062f\u064a\u062f \u0641\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\u060c \u062d\u064a\u062b \u0634\u0647\u062f\u062a \u0627\u0654\u0633\u0639\u0627\u0631 \u062d\u062f\u064a\u062f \u0627\u0644\u062a\u0633\u0644\u064a\u062d (\u0648\u0637\u0646\u064a) \u0632\u064a\u0627\u062f\u0627\u062a \u0634\u0627\u0645\u0644\u0629 \u0641\u064a \u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u0642\u0627\u0633\u0627\u062a\u060c \u0628\u064a\u0646\u0645\u0627 \u0648\u0627\u0635\u0644\u062a \u0627\u0644\u0627\u0654\u0633\u0644\u0627\u0643 \u0648\u0627\u0644\u0643\u064a\u0627\u0628\u0644 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u064a\u0654\u064a\u0629 \u0642\u0641\u0632\u0627\u062a\u0647\u0627 \u0627\u0644\u0642\u064a\u0627\u0633\u064a\u0629 \u0645\u0633\u062c\u0644\u0629 \u0627\u0654\u0639\u0644\u0649 \u0646\u0633\u0628 \u0627\u0631\u062a\u0641\u0627\u0639 \u0628\u064a\u0646 \u0627\u0644\u0645\u0648\u0627\u062f \u0627\u0644\u0627\u0655\u0646\u0634\u0627\u064a\u0654\u064a\u0629.<h2>\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u062d\u062f\u064a\u062f \u0641\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629</h2>\u0648\u0641\u0642\u064b\u0627 \u0644\u0628\u064a\u0627\u0646\u0627\u062a <a href=\"https://www.alyaum.com/articles/6650628/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D9%84%D8%A5%D8%AD%D8%B5%D8%A7%D8%A1-%D8%A7%D9%84%D8%AA%D8%B6%D8%AE%D9%85-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D9%8A%D8%B3%D8%AC%D9%84-17-%D8%AE%D9%84%D8%A7%D9%84-%D9%81%D8%A8%D8%B1%D8%A7%D9%8A%D8%B1-%D8%A7%D9%84%D9%85%D8%A7%D8%B6%D9%8A\" target=\"_blank\">\u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u0627\u0655\u062d\u0635\u0627\u0621</a>\u060c \u0634\u0647\u062f\u062a \u0627\u0654\u0633\u0639\u0627\u0631 \u062d\u062f\u064a\u062f \u0627\u0644\u062a\u0633\u0644\u064a\u062d \u062e\u0644\u0627\u0644 \u0634\u0647\u0631 \u0641\u0628\u0631\u0627\u064a\u0631 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0634\u0647\u0631 \u064a\u0646\u0627\u064a\u0631 \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0628\u0627\u0633\u062a\u062b\u0646\u0627\u0621 \u0627\u0631\u062a\u0641\u0639 \u062d\u062f\u064a\u062f \u0627\u0644\u062a\u0633\u0644\u064a\u062d (6 \u0645\u0645 \u0648\u0637\u0646\u064a) \u0627\u0644\u0630\u064a \u0627\u0646\u062e\u0641\u0636 \u0628\u0646\u0633\u0628\u0629 0.3% \u0644\u064a\u0633\u062c\u0644 3958 \u0631\u064a\u0627\u0644\u0627\u064b \u0644\u0644\u0637\u0646\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0640 3969.1 \u0631\u064a\u0627\u0644 \u0641\u064a \u064a\u0646\u0627\u064a\u0631.<br /> <br />\u0648\u0633\u062c\u0644 \u062d\u062f\u064a\u062f (8 \u0645\u0645 \u0648\u0637\u0646\u064a) \u0627\u0631\u062a\u0641\u0627\u0639\u064b\u0627 \u0628\u0646\u0633\u0628\u0629 0.7% \u0644\u064a\u0635\u0644 \u0627\u0655\u0644\u0649 2651 \u0631\u064a\u0627\u0644\u0627\u064b \u0644\u0644\u0637\u0646\u060c \u0648\u0632\u0627\u062f \u062d\u062f\u064a\u062f (10 \u0645\u0645 \u0648\u0637\u0646\u064a) \u0628\u0646\u0633\u0628\u0629 0.7% \u0627\u0655\u0644\u0649 2696.3 \u0631\u064a\u0627\u0644 \u0644\u0644\u0637\u0646.<br /><br />\u0648\u0634\u0647\u062f\u062a \u0627\u0644\u0645\u0642\u0627\u0633\u0627\u062a \u0627\u0644\u0627\u0654\u0643\u0628\u0631 \u0627\u0631\u062a\u0641\u0627\u0639\u064b\u0627 \u0627\u0654\u0643\u062b\u0631 \u0648\u0636\u0648\u062d\u064b\u0627\u060c \u062d\u064a\u062b \u0642\u0641\u0632 \u062d\u062f\u064a\u062f (12 \u0645\u0645 \u0648\u0637\u0646\u064a) \u0628\u0646\u0633\u0628\u0629 3% \u0627\u0655\u0644\u0649 2626.5 \u0631\u064a\u0627\u0644 \u0644\u0644\u0637\u0646\u060c \u0643\u0645\u0627 \u0627\u0631\u062a\u0641\u0639 \u062d\u062f\u064a\u062f (14 \u0645\u0645 \u0648\u0637\u0646\u064a) \u0628\u0646\u0633\u0628\u0629 2.9% \u0644\u064a\u0628\u0644\u063a 2629.2 \u0631\u064a\u0627\u0644 \u0644\u0644\u0637\u0646\u060c \u0648\u0635\u0639\u062f \u062d\u062f\u064a\u062f (16 \u0645\u0645 \u0648\u0637\u0646\u064a) \u0628\u0646\u0633\u0628\u0629 3% \u0644\u064a\u0633\u062c\u0644 2628.3 \u0631\u064a\u0627\u0644 \u0644\u0644\u0637\u0646\u060c \u0641\u064a \u062d\u064a\u0646 \u0632\u0627\u062f \u062d\u062f\u064a\u062f (18 \u0645\u0645 \u0648\u0637\u0646\u064a) \u0628\u0646\u0633\u0628\u0629 2.9% \u0627\u0655\u0644\u0649 2634.6 \u0631\u064a\u0627\u0644 \u0644\u0644\u0637\u0646.<h2>\u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0627\u0654\u0633\u0644\u0627\u0643</h2> <br />\u0648\u0627\u0635\u0644\u062a <a href=\"https://www.alyaum.com/articles/6650825/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D8%B1%D8%AA%D9%81%D8%A7%D8%B9-%D8%B3%D8%B9%D8%B1-%D8%A7%D9%84%D8%A8%D9%8A%D8%B6-%D9%88%D8%A7%D8%B3%D8%AA%D9%82%D8%B1%D8%A7%D8%B1-%D8%A7%D9%84%D8%AD%D9%84%D9%8A%D8%A8-%D9%88%D8%A7%D9%84%D8%A3%D8%AC%D8%A8%D8%A7%D9%86-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%AE%D9%84%D8%A7%D9%84-%D8%B4%D9%87%D8%B1\" target=\"_blank\">\u0627\u0654\u0633\u0639\u0627\u0631 </a>\u0627\u0644\u0627\u0654\u0633\u0644\u0627\u0643 \u0648\u0627\u0644\u0643\u064a\u0627\u0628\u0644 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u064a\u0654\u064a\u0629 \u0641\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0631\u062a\u0641\u0627\u0639\u0647\u0627 \u062e\u0644\u0627\u0644 \u0634\u0647\u0631 \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u062d\u064a\u062b \u0627\u0631\u062a\u0641\u0639 \u0627\u0644\u0633\u0644\u0643 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u064a\u0654\u064a 2.5 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 1.5% \u0644\u064a\u0633\u062c\u0644 1.4 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0643\u0645\u0627 \u0627\u0631\u062a\u0641\u0639 \u0627\u0644\u0633\u0644\u0643 4 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 2.5% \u0644\u064a\u0635\u0644 \u0627\u0655\u0644\u0649 \u0631\u064a\u0627\u0644\u064a\u0646 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0648\u0635\u0639\u062f \u0627\u0644\u0633\u0644\u0643 6 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 3.7% \u0645\u0633\u062c\u0644\u0627\u064b 3.1 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0640 2.8 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631.<h2>\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0643\u064a\u0627\u0628\u0644 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u064a\u0654\u064a\u0629</h2>\u0648\u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0643\u064a\u0627\u0628\u0644\u060c \u0627\u0631\u062a\u0641\u0639 \u0633\u0639\u0631 \u0627\u0644\u0643\u0627\u0628\u0644 10 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 1.7% \u0627\u0655\u0644\u0649 24.5 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0628\u0644 21.6 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631\u060c \u0648\u0627\u0631\u062a\u0641\u0639 \u0627\u0644\u0643\u0627\u0628\u0644 25 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 2.5% \u0644\u064a\u0628\u0644\u063a 54.5 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0640 47.7 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631\u060c \u0648\u0632\u0627\u062f \u0627\u0644\u0643\u0627\u0628\u0644 35 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 2.8% \u0644\u064a\u0633\u062c\u0644 73.4 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0628\u0644 71.5 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631. \u0643\u0645\u0627 \u0627\u0631\u062a\u0641\u0639 \u0627\u0644\u0643\u0627\u0628\u0644 50 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 3.0% \u0627\u0655\u0644\u0649 103.2 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0640 100.1 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631\u060c \u0648\u0635\u0639\u062f \u0627\u0644\u0643\u0627\u0628\u0644 70 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 1.8% \u0645\u0633\u062c\u0644\u0627\u064b 150.1 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0628\u0644 147.4 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631.<br /><br />\u0648\u0632\u0627\u062f \u0633\u0639\u0631 \u0627\u0644\u0643\u0627\u0628\u0644 95 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 1.2% \u0644\u064a\u0635\u0644 \u0627\u0655\u0644\u0649 200.2 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0640 197.9 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631\u060c \u0643\u0645\u0627 \u0627\u0631\u062a\u0641\u0639 \u0627\u0644\u0643\u0627\u0628\u0644 120 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 1.1% \u0627\u0655\u0644\u0649 245.4 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0628\u0644 242.6 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631\u060c \u0648\u0642\u0641\u0632 \u0627\u0644\u0643\u0627\u0628\u0644 300 \u0645\u0645 \u0648\u0637\u0646\u064a \u0628\u0646\u0633\u0628\u0629 1.9% \u0644\u064a\u0628\u0644\u063a 614.3 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0640 602.8 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u064a\u0646\u0627\u064a\u0631.<h2>\u0627\u0644\u0627\u0654\u0644\u0645\u0648\u0646\u064a\u0648\u0645 \u0648\u0627\u0644\u0627\u0654\u062e\u0634\u0627\u0628</h2> <br />\u0627\u0631\u062a\u0641\u0639 \u0633\u0639\u0631 \u0627\u0644\u0627\u0654\u0644\u0645\u0646\u064a\u0648\u0645 (\u062d\u0644\u0642 \u062c\u0646\u0628 \u0633\u0639\u0648\u062f\u064a) \u0628\u0646\u0633\u0628\u0629 2.3% \u0645\u0633\u062c\u0644\u0627\u064b 94.5 \u0631\u064a\u0627\u0644 \u0644\u0644\u0645\u062a\u0631 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0640 92.3 \u0631\u064a\u0627\u0644 \