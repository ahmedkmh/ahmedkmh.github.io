9-%D8%A7%D9%84%D9%85%D9%84%D9%83%D9%8A%D8%A9-%D9%84%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D8%AA%D8%AD%D9%85%D9%8A-3-%D8%A3%D8%B4%D8%AC%D8%A7%D8%B1-%D8%A3%D9%83%D8%A7%D8%B3%D9%8A%D8%A7-%D9%85%D8%B9%D9%85%D8%B1%D8%A9\"> \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0631\u064a\u0627\u0636</a> \u062a\u0646\u0641\u064a\u0630 \u0627\u0654\u0639\u0645\u0627\u0644 \u0645\u0634\u0631\u0648\u0639 <a href=\"https://www.alyaum.com/articles/6656340/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D8%A8%D8%AF%D8%A1-%D9%85%D8%B4%D8%B1%D9%88%D8%B9-%D8%AA%D8%B7%D9%88%D9%8A%D8%B1-%D8%AA%D9%82%D8%A7%D8%B7%D8%B9-%D8%B7%D8%B1%D9%8A%D9%82%D9%8A-%D8%A7%D9%84%D8%AB%D9%85%D8%A7%D9%85%D8%A9-%D9%88%D8%B9%D8%AB%D9%85%D8%A7%D9%86-%D8%A8%D9%86-%D8%B9%D9%81%D8%A7%D9%86\">\u062a\u0637\u0648\u064a\u0631 \u0637\u0631\u064a\u0642</a> \u0627\u0644\u0627\u0655\u0645\u0627\u0645 \u0645\u0633\u0644\u0645\u060c \u0636\u0645\u0646 \u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0645\u0646 \u0628\u0631\u0646\u0627\u0645\u062c \u062a\u0637\u0648\u064a\u0631 \u0645\u062d\u0627\u0648\u0631 \u0627\u0644\u0637\u0631\u0642 \u0627\u0644\u062f\u0627\u064a\u0654\u0631\u064a\u0629 \u0648\u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a\u0629 \u0628\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u060c \u0648\u0630\u0644\u0643 \u0639\u0628\u0631 \u062a\u0641\u0639\u064a\u0644 \u0645\u0631\u062d\u0644\u0629 \u062c\u062f\u064a\u062f\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644 \u0628\u0627\u062a\u062c\u0627\u0647 \u0637\u0631\u064a\u0642 \u062f\u064a\u0631\u0627\u0628 \u0634\u0645\u0627\u0644\u064b\u0627\u060c \u0641\u064a \u0627\u0645\u062a\u062f\u0627\u062f \u0644\u0644\u062c\u0647\u0648\u062f \u0627\u0644\u0631\u0627\u0645\u064a\u0629 \u0627\u0655\u0644\u0649 \u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u0629 \u0634\u0628\u0643\u0629 \u0627\u0644\u0637\u0631\u0642 \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0646\u0633\u064a\u0627\u0628\u064a\u0629 \u0627\u0644\u062d\u0631\u0643\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629 \u0641\u064a \u0627\u0644\u0639\u0627\u0635\u0645\u0629.<br /><br />\u0648\u064a\u0633\u062a\u0647\u062f\u0641 \u0627\u0644\u0645\u0634\u0631\u0648\u0639\u060c \u0639\u0646\u062f \u0627\u0643\u062a\u0645\u0627\u0644\u0647\u060c \u062a\u0637\u0648\u064a\u0631<a href=\"https://www.alyaum.com/articles/6195606/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A3%D9%85%D9%8A%D8%B1-%D8%A7%D9%84%D9%85%D8%AF%D9%8A%D9%86%D8%A9-%D9%8A%D9%88%D8%AC%D9%87-%D8%A8%D8%A7%D9%81%D8%AA%D8%AA%D8%A7%D8%AD-%D8%A7%D9%85%D8%AA%D8%AF%D8%A7%D8%AF-%D8%B7%D8%B1%D9%8A%D9%82-%D8%A7%D9%84%D8%A5%D9%85%D8%A7%D9%85-%D9%85%D8%B3%D9%84%D9%85-%D8%AC%D8%B2%D8%A6%D9%8A%D8%A7\"> \u0637\u0631\u064a\u0642 \u0627\u0644\u0627\u0655\u0645\u0627\u0645 \u0645\u0633\u0644\u0645 </a>\u0628\u0637\u0648\u0644 12 \u0643\u064a\u0644\u0648\u0645\u062a\u0631\u064b\u0627\u060c \u0628\u0645\u0627 \u064a\u0634\u0645\u0644 \u0627\u0655\u0646\u0634\u0627\u0621 4 \u062c\u0633\u0648\u0631 \u0631\u064a\u0654\u064a\u0633\u0629 \u0628\u0637\u0648\u0644 150 \u0645\u062a\u0631\u064b\u0627 \u0644\u0643\u0644 \u062c\u0633\u0631\u060c \u0648\u0631\u0641\u0639 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0627\u0633\u062a\u064a\u0639\u0627\u0628\u064a\u0629 \u0644\u0644\u0637\u0631\u064a\u0642 \u0644\u062a\u0635\u0644 \u0627\u0655\u0644\u0649 200 \u0627\u0654\u0644\u0641 \u0645\u0631\u0643\u0628\u0629 \u064a\u0648\u0645\u064a\u064b\u0627\u060c \u0645\u0646 \u062e\u0644\u0627\u0644 \u062a\u0635\u0645\u064a\u0645 \u062d\u062f\u064a\u062b \u064a\u0636\u0645 3 \u0645\u0633\u0627\u0631\u0627\u062a \u0644\u0644\u0637\u0631\u064a\u0642 \u0627\u