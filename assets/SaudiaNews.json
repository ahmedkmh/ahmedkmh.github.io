0642 <a href=\"https://www.alyaum.com/articles/6652552/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A8%D8%B7%D9%84%D8%A8-%D9%85%D9%86-%D8%B1%D9%88%D8%B3%D9%8A%D8%A7-%D9%85%D8%AC%D9%84%D8%B3-%D8%A7%D9%84%D8%A3%D9%85%D9%86-%D9%8A%D8%B9%D9%82%D8%AF-%D8%AC%D9%84%D8%B3%D8%A9-%D9%85%D8%BA%D9%84%D9%82%D8%A9-%D8%A8%D8%B4%D8%A3%D9%86-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86\">\u0627\u0644\u0627\u0654\u0645\u0645 \u0627\u0644\u0645\u062a\u062d\u062f\u0629</a>\u060c \u0648\u062a\u0647\u062f\u064a\u062f\u064b\u0627 \u0645\u0628\u0627\u0634\u0631\u064b\u0627 \u0644\u0627\u0654\u0645\u0646 \u0648\u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0627\u0644\u0645\u0646\u0637\u0642\u0629.<br /><br />\u0648\u0627\u0654\u0636\u0627\u0641 \u0641\u064a \u0628\u064a\u0627\u0646 \u0627\u0644\u064a\u0648\u0645 \u0627\u0654\u0646 \u0627\u0644\u0627\u0639\u062a\u062f\u0627\u0621\u0627\u062a \u0627\u0644\u062a\u064a \u0646\u0641\u0630\u062a\u0647\u0627 \u0627\u0655\u064a\u0631\u0627\u0646 \u0645\u0646\u0630 \u0628\u062f\u0621 \u0627\u0644\u062d\u0631\u0628 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0635\u0648\u0627\u0631\u064a\u062e \u0648\u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0627\u062a \u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0629 \u062a\u0639\u0643\u0633 \u0646\u0647\u062c\u064b\u0627 \u0639\u062f\u0627\u064a\u0654\u064a\u064b\u0627 \u0645\u062a\u0643\u0631\u0631\u064b\u0627 \u0644\u0627 \u064a\u0631\u0627\u0639\u064a \u0633\u064a\u0627\u062f\u0629 \u0627\u0644\u062f\u0648\u0644 \u0627\u0654\u0648 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u062f\u0646\u064a\u064a\u0646.<h2>\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u0628\u0646\u064a\u0629 \u0627\u0644\u062a\u062d\u062a\u064a\u0629</h2>\u0648\u0627\u0654\u0643\u062f \u0627\u0654\u0646 \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u0628\u0646\u064a\u0629 \u0627\u0644\u062a\u062d\u062a\u064a\u0629\u060c \u0648\u0645\u0627 \u0627\u0