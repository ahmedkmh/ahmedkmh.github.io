{"status": "success", "totalResults": 4839, "results": [{"article_id": "7df1c170164ec505cfa340d15360999e", "link": "https://www.alyaum.com/articles/6656802/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B6%D8%A8%D8%B7-%D9%85%D9%82%D9%8A%D9%85-%D8%A8%D9%85%D9%83%D8%A9-%D8%A7%D9%84%D9%85%D9%83%D8%B1%D9%85%D8%A9-%D9%84%D8%AA%D8%B1%D9%88%D9%8A%D8%AC%D9%87-%D8%AA%D8%B5%D8%A7%D8%B1%D9%8A%D8%AD-%D9%88%D9%87%D9%85%D9%8A%D8%A9-%D9%84%D8%AF%D8%AE%D9%88%D9%84-%D8%A7%D9%84%D8%B9%D8%A7%D8%B5%D9%85%D8%A9-%D8%A7%D9%84%D9%85%D9%82%D8%AF%D8%B3%D8%A9", "title": "\u0636\u0628\u0637 \u0645\u0642\u064a\u0645 \u0628\u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629 \u0644\u062a\u0631\u0648\u064a\u062c\u0647 \u062a\u0635\u0627\u0631\u064a\u062d \u0648\u0647\u0645\u064a\u0629 \u0644\u062f\u062e\u0648\u0644 \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0627\u0644\u0645\u0642\u062f\u0633\u0629", "description": "\u0642\u0628\u0636\u062a \u0634\u0631\u0637\u0629 \u0645\u0646\u0637\u0642\u0629 <a href=\"https://www.alyaum.com/articles/6656200/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AE%D8%B7%D9%88%D8%A7%D8%AA-%D8%A5%D8%B5%D8%AF%D8%A7%D8%B1-%D8%AA%D8%B5%D8%B1%D9%8A%D8%AD-%D8%A7%D9%84%D8%AF%D8%AE%D9%88%D9%84-%D8%A5%D9%84%D9%89-%D9%85%D9%83%D8%A9-%D8%A7%D9%84%D9%85%D9%83%D8%B1%D9%85%D8%A9-%D9%84%D9%84%D8%B9%D9%85%D8%A7%D9%84%D8%A9-%D8%A7%D9%84%D9%85%D9%86%D8%B2%D9%84%D9%8A%D8%A9\">\u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629</a> \u0639\u0644\u0649 \u0645\u0642\u064a\u0645 \u0645\u0646 \u0627\u0644\u062c\u0646\u0633\u064a\u0629 \u0627\u0644\u0633\u0648\u062f\u0627\u0646\u064a\u0629\u061b \u0644\u0627\u0631\u062a\u0643\u0627\u0628\u0647 \u0639\u0645\u0644\u064a\u0627\u062a <a href=\"https://www.alyaum.com/articles/6655755/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D9%86-%D8%A7%D9%84%D9%8A%D9%88%D9%85-%D8%A8%D8%AF%D8%A1-%D8%AD%D8%B5%D9%88%D9%84-%D8%A7%D9%84%D9%85%D9%82%D9%8A%D9%85%D9%8A%D9%86-%D8%A7%D9%84%D8%B1%D8%A7%D8%BA%D8%A8%D9%8A%D9%86-%D9%81%D9%8A-%D8%AF%D8%AE%D9%88%D9%84-%D9%85%D8%AF%D9%8A%D9%86%D8%A9-%D9%85%D9%83%D8%A9-%D8%A7%D9%84%D9%85%D9%83%D8%B1%D9%85%D8%A9-%D8%B9%D9%84%D9%89-%D8%AA%D8%B5%D8%B1%D9%8A%D8%AD\">\u0646\u0635\u0628 \u0648\u0627\u062d\u062a\u064a\u0627\u0644</a> \u0628\u0646\u0634\u0631 \u0627\u0655\u0639\u0644\u0627\u0646\u0627\u062a<a href=\"https://www.alyaum.com/articles/6656008/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AE%D8%B7%D9%88%D8%A7%D8%AA-%D8%A5%D8%B5%D8%AF%D8%A7%D8%B1%D8%AA%D8%B5%D8%B1%D9%8A%D8%AD-%D8%AF%D8%AE%D9%88%D9%84-%D9%85%D9%83%D8%A9-%D9%84%D8%A3%D9%81%D8%B1%D8%A7%D8%AF-%D8%A7%D9%84%D8%A3%D8%B3%D8%B1%D8%A9-%D8%A7%D9%84%D9%85%D9%82%D9%8A%D9%85%D9%8A%D9%86-%D8%AE%D9%84%D8%A7%D9%84-%D9%85%D9%88%D8%B3%D9%85-%D8%A7%D9%84%D8%AD%D8%AC\"> \u062a\u0635\u0627\u0631\u064a\u062d \u062f\u062e\u0648\u0644 \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0627\u0644\u0645\u0642\u062f\u0633\u0629</a> \u0644\u0644\u0645\u0642\u064a\u0645\u064a\u0646 \u0628\u0637\u0631\u0642 \u063a\u064a\u0631 \u0646\u0638\u0627\u0645\u064a\u0629 \u0648\u0645\u0636\u0644\u0644\u0629 \u0639\u0628\u0631 \u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a.<br /><br />\u0648\u062c\u0631\u0649 \u0627\u0655\u064a\u0642\u0627\u0641\u0647 \u0648\u0627\u062a\u062e\u0627\u0630 \u0627\u0644\u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0646\u0638\u0627\u0645\u064a\u0629 \u0628\u062d\u0642\u0647\u060c \u0648\u0627\u0655\u062d\u0627\u0644\u062a\u0647 \u0627\u0655\u0644\u0649 \u0627\u0644\u0646\u064a\u0627\u0628\u0629 \u0627\u0644\u0639\u0627\u0645\u0629.<br /><br /> <br /><br />\u0648\u0627\u0654\u0647\u0627\u0628 \u0627\u0644\u0627\u0654\u0645\