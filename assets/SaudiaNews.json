get=\"_blank\">\u0641\u0646\u0632\u0648\u064a\u0644\u0627</a> \u0641\u064a 24 \u064a\u0648\u0646\u064a\u0648 4500 \u0642\u062a\u064a\u0644\u060c \u0648\u0641\u0642 \u0627\u0654\u0631\u0642\u0627\u0645 \u0631\u0633\u0645\u064a\u0629 \u0646\u064f\u0634\u0631\u062a \u064a\u0648\u0645 \u0627\u0644\u0627\u062b\u0646\u064a\u0646.<br />\u0648\u062c\u0627\u0621 \u0641\u064a \u0627\u0644\u062a\u0642\u0631\u064a\u0631 \u0627\u0644\u0631\u0633\u0645\u064a \u0627\u0644\u0630\u064a \u0646\u0634\u0631\u0647 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u062e\u0648\u0631\u062e\u064a \u0631\u0648\u062f\u0631\u064a\u062c\u064a\u0632 \u0641\u064a \u062d\u0633\u0627\u0628\u0647 \u0639\u0644\u0649 \u0645\u0646\u0635\u0629 \u062a\u0644\u064a\u062c\u0631\u0627\u0645\u060c \u0627\u0654\u0646 \u062d\u0635\u064a\u0644\u0629 <a href=\"https://www.alyaum.com/articles/6672358/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/19-%D8%A3%D9%84%D9%81-%D9%85%D9%86%D9%83%D9%88%D8%A8-%D8%AD%D8%B5%D9%8A%D9%84%D8%A9-%D8%B6%D8%AD%D8%A7%D9%8A%D8%A7-%D8%B2%D9%84%D8%B2%D8%A7%D9%84%D9%8A-%D9%81%D9%86%D8%B2%D9%88%D9%8A%D9%84%D8%A7-%D8%AA%D8%AA%D8%AE%D8%B7%D9%89-4300-%D9%82%D8%AA%D9%8A%D9%84\" target=\"_blank\">\u0627\u0644\u0636\u062d\u0627\u064a\u0627</a> \u0628\u0644\u063a\u062a \u0627\u0644\u0627\u062b\u0646\u064a\u0646 4561 \u0642\u062a\u064a\u0644\u064b\u0627\u060c \u0645\u0639 \u0628\u0642\u0627\u0621 \u062d\u0635\u064a\u0644\u0629 \u0627\u0644\u0645\u0635\u0627\u0628\u064a\u0646 \u0639\u0644\u0649 \u062d\u0627\u0644\u0647\u0627 \u0639\u0646\u062f 16 \u0627\u0654\u0644\u0641\u064b\u0627 \u0648740 \u062c\u0631\u064a\u062d\u064b\u0627.<br />\u0648\u0643\u0627\u0646\u062a \u0627\u0644\u062d\u0635\u064a\u0644\u0629 \u0627\u0644\u0633\u0627\u0628\u0642\u0629 \u062a\u0641\u064a\u062f \u0628\u0645\u0642\u062a\u0644 4490 \u0634\u062e\u0635\u064b\u0627.<br />\u0648\u0644\u0627 \u062a\u062a\u0637\u0631\u0651\u06