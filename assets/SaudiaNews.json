0627\u0644\u0633\u0627\u0628\u0642\u060c \u062d\u064a\u062b \u0633\u062c\u0644\u062a \u0645\u0639\u0638\u0645 \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0641\u0627\u0643\u0647\u0629 \u0627\u0631\u062a\u0641\u0627\u0639\u0627\u062a \u0645\u062a\u0628\u0627\u064a\u0646\u0629\u060c \u0628\u064a\u0646\u0645\u0627 \u0627\u0633\u062a\u0642\u0631 \u0639\u062f\u062f \u0627\u0654\u0642\u0644 \u0639\u0646\u062f \u0645\u0633\u062a\u0648\u064a\u0627\u062a\u0647 \u0627\u0644\u0645\u0633\u062c\u0644\u0629 \u0641\u064a \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0628\u062d\u0633\u0628 \u0628\u064a\u0627\u0646\u0627\u062a <a href=\"https://www.alyaum.com/articles/6662455/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D9%86%D8%AE%D9%81%D8%A7%D8%B6-%D8%A3%D8%B3%D8%B9%D8%A7%D8%B1-%D8%A7%D9%84%D8%A3%D8%BA%D9%86%D8%A7%D9%85-%D8%A8%D8%A7%D8%B3%D8%AA%D8%AB%D9%86%D8%A7%D8%A1-%D8%A7%D9%84%D9%86%D8%B9%D9%8A%D9%85%D9%8A-%D9%88%D8%A7%D9%84%D8%A8%D8%B1%D8%A8%D8%B1%D9%8A-%D9%88%D8%AA%D8%A8%D8%A7%D9%8A%D9%86-%D8%A7%D9%84%D8%A3%D8%B9%D9%84%D8%A7%D9%81\" target=\"_blank\">\u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u0627\u0655\u062d\u0635\u0627\u0621</a>.<h2>\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0641\u0648\u0627\u0643\u0647 \u0641\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629.. \u0627\u0644\u0644\u064a\u0645\u0648\u0646 \u0627\u0644\u0627\u0654\u0641\u0631\u064a\u0642\u064a \u064a\u0642\u0641\u0632 22.4%</h2> <br />\u0648\u0641\u0642\u064b\u0627 \u0644\u0646\u0634\u0631\u0629 \u0645\u062a\u0648\u0633\u0637\u0627\u062a <a href=\"https://www.alyaum.com/articles/6662422/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D9%86%D8%AE%D9%81%D8%A7%D8%B6-%D8%B3%D8%B9%D8%B1-%D8%A7%D9%84%D8%A3%D8%B1%D8%B2-%D8%A7%D9%84%D8%A8%D8%B3%D9%85%D8%AA%D9%8A-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%AE%D9%84%D8%A7%D9%84-%D8%B4%D9%87%D8%B1-%D9%88%D8%AA%D8%A8%D8%A7%D9%8A%D9%86-%D8%A7%D9%84%D8%AF%D9%82%D9%8A%D9%82\" target=\"_blank\">\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0633\u0644\u0639 \u0648\u0627\u0644\u062e\u062f\u0645\u0627\u062a</a> \u0644\u0634\u0647\u0631 \u0627\u0654\u0628\u0631\u064a\u0644\u060c \u062a\u0635\u062f\u0651\u0631 \u0627\u0644\u0644\u064a\u0645\u0648\u0646 \u0627\u0644\u0627\u0654\u0641\u0631\u064a\u0642\u064a \u0627\u0644\u0645\u062a\u0648\u0633\u0637 \u0642\u0627\u064a\u0654\u0645\u0629 \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u0627\u0631\u062a\u0641\u0627\u0639\u064b\u0627\u060c \u062d\u064a\u062b \u0628\u0644\u063a \u0633\u0639\u0631\u0647 12.9 \u0631\u064a\u0627\u0644 \u0644\u0644\u0643\u064a\u0644\u0648 \u0641\u064a \u0627\u0654\u0628\u0631\u064a\u0644 2026 \u0645\u0642\u0627\u0628\u0644 10.6 \u0631\u064a\u0627\u0644 \u0641\u064a \u0645\u0627\u0631\u0633\u060c \u0645\u0633\u062c\u0644\u064b\u0627 \u0632\u064a\u0627\u062f\u0629 \u0634\u0647\u0631\u064a\u0629 \u062d\u0627\u062f\u0629 \u0628\u0644\u063a\u062a 22.4%\u060c \u0648\u062c\u0627\u0621 \u0627\u0644\u0628\u0631\u0642\u0648\u0642 \u0627\u0644\u062a\u0631\u0643\u064a \u062b\u0627\u0646\u064a\u064b\u0627 \u0628\u0640 17 \u0631\u064a\u0627\u0644\u0627\u064b \u0645\u0642\u0627\u0628\u0644 15 \u0631\u064a\u0627\u0644\u0627\u064b \u0641\u064a \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0633\u0627\u0628\u0642 \u0628\u0627\u0631\u062a\u0641\u0627\u0639 13.5%\u060c \u064a\u0644\u064a\u0647 \u0627\u0644\u0631\u0645\u0627\u0646 \u0627\u0644\u0647\u0646\u062f\u064a \u0628\u0640 17.9 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 15.9 \u0631\u064a\u0627\u0644 \u0645\u0631\u062a\u0641\u0639\u064b\u0627 12.8%\u060c \u062b\u0645 \u0627\u0644\u0628\u0631\u062a\u0642\u0627\u0644 \u0627\u0654\u0628\u0648 \u0635\u0631\u0629 \u0627\u0644\u0645\u0635\u0631\u064a \u0628\u0640 6.3 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 5.6 \u0631\u064a\u0627\u0644 \u0628\u0627\u0631\u062a\u0641\u0627\u0639 12.4%\u060c \u0648\u062d\u0644 \u0627\u0644\u0639\u0646\u0628 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a \u062e\u0627\u0645\u0633\u064b\u0627 \u0628\u0640 20.2 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 18.4 \u0631\u064a\u0627\u0644 \u0645\u0631\u062a\u0641\u0639\u064b\u0627 9.8%.<h2>\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0641\u0648\u0627\u0643\u0647 \u0641\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629</h2> <br />\u0633\u062c\u0644\u062a \u0627\u0654\u0635\u0646\u0627\u0641 \u0627\u0654\u062e\u0631\u0649 \u0632\u064a\u0627\u062f\u0627\u062a \u0645\u0644\u062d\u0648\u0638\u0629\u060c \u0627\u0655\u0630\u0627 \u0628\u0644\u063a \u0633\u0639\u0631 \u0627\u0644\u0639\u0646\u0628 \u0627\u0644\u0645\u062d\u0644\u064a 18.8 \u0631\u064a\u0627\u0644 \u0641\u064a \u0627\u0654\u0628\u0631\u064a\u0644 \u0645\u0642\u0627\u0628\u0644 17.5 \u0631\u064a\u0627\u0644 \u0641\u064a \u0645\u0627\u0631\u0633 \u0628\u0627\u0631\u062a\u0641\u0627\u0639 7.7%\u060c \u062b\u0645 \u0627\u0644\u062a\u064a\u0646 \u0627\u0644\u0645\u062d\u0644\u064a \u0628\u0633\u0639\u0631 18.7 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 17.5 \u0631\u064a\u0627\u0644 \u0628\u0627\u0631\u062a\u0641\u0627\u0639 6.9%\u060c \u062b\u0645 \u0627\u0644\u0643\u0645\u062b\u0631\u0649 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a \u0627\u0644\u0645\u062a\u0648\u0633\u0637 \u0628\u0640 12.9 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 12.3 \u0631\u064a\u0627\u0644 \u0645\u0631\u062a\u0641\u0639\u064b\u0627 5.1%.<br /><br />\u0648\u0628\u0644\u063a \u0627\u0644\u064a\u0648\u0633\u0641\u064a \u0627\u0644\u0628\u0627\u0643\u0633\u062a\u0627\u0646\u064a7.1 \u0631\u064a\u0627\u0644 \u0641\u064a \u0627\u0654\u0628\u0631\u064a\u0644 \u0645\u0642\u0627\u0628\u0644 6.9 \u0631\u064a\u0627\u0644 \u0641\u064a \u0645\u0627\u0631\u0633 \u0628\u0627\u0631\u062a\u0641\u0627\u0639 3.2%\u060c \u0628\u064a\u0646\u0645\u0627 \u0633\u062c\u0644 \u0627\u0644\u062e\u0648\u062e \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a19.0 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 18.6 \u0631\u064a\u0627\u0644 \u0645\u0631\u062a\u0641\u0639\u064b\u0627 1.9%\u060c \u0648\u0628\u0644\u063a \u0627\u0644\u062a\u0641\u0627\u062d \u0627\u0644\u0627\u0654\u062d\u0645\u0631 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a 9.3 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 9.2 \u0631\u064a\u0627\u0644 \u0628\u0627\u0631\u062a\u0641\u0627\u0639 1.5%.<h2>\u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0627\u0644\u062a\u0645\u0631 \u0627\u0644\u0645\u062d\u0644\u064a \u0648\u062a\u0631\u0627\u062c\u0639 \u0627\u0644\u0645\u0648\u0632 \u0648\u0627\u0644\u0645\u0627\u0646\u062c\u0648</h2> <br />\u0633\u062c\u0644 \u0627\u0644\u062a\u0645\u0631 \u0627\u0644\u0631\u0637\u0628 \u0627\u0633\u062a\u0642\u0631\u0627\u0631\u064b\u0627 \u0639\u0646\u062f 14.9 \u0631\u064a\u0627\u0644 \u0644\u0644\u0643\u064a\u0644\u0648 \u0641\u064a \u0627\u0654\u0628\u0631\u064a\u0644 (\u0628\u062f\u0648\u0646 \u062a\u063a\u064a\u0631 \u0639\u0646 \u0645\u0627\u0631\u0633)\u060c \u0641\u064a \u062d\u064a\u0646 \u0634\u0647\u062f\u062a \u0628\u0642\u064a\u0629 \u0627\u0644\u0627\u0654\u0635\u0646\u0627\u0641 \u062a\u0631\u0627\u062c\u0639\u0627\u062a \u0645\u062a\u0641\u0627\u0648\u062a\u0629\u060c \u0627\u0655\u0630 \u0627\u0646\u062e\u0641\u0636 \u0627\u0644\u062a\u0641\u0627\u062d \u0627\u0644\u0627\u0654\u0635\u0641\u0631 \u0627\u0655\u0644\u0649 9 \u0631\u064a\u0627\u0644\u0627\u062a \u0645\u0642\u0627\u0628\u0644 9.1 \u0631\u064a\u0627\u0644 \u0628\u0646\u0633\u0628\u0629 -1.3%\u060c \u0648\u062a\u0631\u0627\u062c\u0639 \u062a\u0645\u0631 \u0627\u0644\u0645\u0643\u0646\u0648\u0632 \u0627\u0655\u062e\u0644\u0627\u0635 \u0627\u0655\u0644\u0649 15.6 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 15.8 \u0631\u064a\u0627\u0644 \u0628\u0627\u0646\u062e\u0641\u0627\u0636 -1.5%\u060c \u0643\u0645\u0627 \u0647\u0628\u0637 \u0627\u0644\u0628\u0637\u064a\u062e \u0627\u0644\u0645\u062d\u0644\u064a \u0627\u0655\u0644\u0649 3.7 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 3.8 \u0631\u064a\u0627\u0644 \u0628\u0646\u0633\u0628\u0629 -1.6%\u060c \u0648\u0627\u0646\u062e\u0641\u0636 <a href=\"https://www.alyaum.com/articles/6660577/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D9%85%D9%86%D9%88%D8%B9%D8%A7%D8%AA/%D9%85%D9%88%D8%B3%D9%85-%D8%A7%D9%84%D9%85%D8%A7%D9%86%D8%AC%D9%88-%D8%AA%D8%AC%D8%B1%D8%A8%D8%A9-%D8%B5%D9%8A%D9%81%D9%8A%D8%A9-%D8%AA%D8%AC%D8%B0%D8%A8-%D8%B9%D8%B4%D8%A7%D9%82-%D8%A7%D9%84%D8%B3%D9%8A%D8%A7%D8%AD%D8%A9-%D8%A7%D9%84%D8%B1%D9%8A%D9%81%D9%8A%D8%A9-%D9%81%D9%8A-%D8%AC%D8%A7%D8%B2%D8%A7%D9%86\" target=\"_blank\">\u0627\u0644\u0645\u0627\u0646\u062c\u0648 </a>\u0627\u0644\u0628\u0627\u0643\u0633\u062a\u0627\u0646\u064a \u0627\u0655\u0644\u0649 13.2 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 13.5 \u0631\u064a\u0627\u0644 \u0628\u0646\u0633\u0628\u0629 -2.1%.<br /><br />\u0648\u062a\u0630\u064a\u0644 \u0627\u0644\u0645\u0648\u0632 \u0627\u0644\u0641\u0644\u0628\u064a\u0646\u064a \u0627\u0644\u0642\u0627\u064a\u0654\u0645\u0629 \u0628\u0640 6.8 \u0631\u064a\u0627\u0644 \u0641\u064a \u0627\u0654\u0628\u0631\u064a\u0644 \u0645\u0642\u0627\u0628\u0644 7 \u0631\u064a\u0627\u0644 \u0645\u0646\u062e\u0641\u0636\u064b\u0627 -2.7% \u0639\u0646 \u0645\u0627\u0631\u0633 \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0628\u064a\u0646\u0645\u0627 \u0633\u062c\u0644 \u0627\u0644\u0634\u0645\u0627\u0645 \u0627\u0644\u0645\u062d\u0644\u064a 5.2 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0628\u0644 5.3 \u0631\u064a\u0627\u0644 \u0628\u0627\u0646\u062e\u0641\u0627\u0636 1.1%.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["business"], "datatype": "news", "pubDate": "2026-05-17 11:05:00", "pubDateTZ": "UTC", "fetched_at": "2026-05-17 11:18:11", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "3d02bc9c038903d61fa1da19c60ff04e", "link": "https://saudigazette.com.sa/article/661405/saudi-arabia/sar-launches-naming-rights-project-for-haramain-high-speed-railway-stations", "title": "SAR launches naming rights project for Haramain High Speed Railway stations", "description": "RIYADH \u2014 Saudi Arabia Railways (SAR) on Saturday launched its naming rights and sponsorship project for the Haramain High Speed Railway stations. The project specifically covers the stations in Makkah, Madinah, Jeddah (Sulaimaniyah), and King Abdullah Economic City (KAEC). The initiative \u2014 focused on elevating the passenger experience by developing the stations and activating new commercial services \u2014 is designed to open new investment opportunities in partnership with the private sector and enhance asset utilization. Operating at speeds of up to 300 km/h, the Haramain High Speed Railway ranks among the 10 fastest electric trains globally. Utilizing a fleet of 35 trains, the network connects Makkah and Madinah via stations at Jeddah (Sulaimaniyah), King Abdulaziz International Airport, and King Abdullah Economic City, serving millions of passengers, pilgrims, and Umrah performers annually. These assets will give brands the chance to reach a massive segment of passengers across one of the Kingdom's most vital transport networks. The project offers strategic marketing opportunities that boost brand visibility while supporting overall integration with private enterprises by utilizing high-density operational sites. Interested investors can apply for these naming rights and sponsorship opportunities through SAR's official channels.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["naming rights", "jeddah", "sponsorship projects", "makkah", "haramain high speed railway", "railway", "saudi arabia", "kaec", "private sector", "madinha"], "creator": ["saudi gazette"], "language": "english", "country": ["saudi arabia"], "category": ["business", "top"], "datatype": "news", "pubDate": "2026-05-17 11:04:52", "pubDateTZ": "UTC", "fetched_at": "2026-05-17 11:42:13", "image_url": "https://saudigazette.com.sa/saudigazette/uploads/images/2026/05/17/2709004.webp", "video_url": null, "source_id": "saudigazette", "source_name": "Saudi Gazette", "source_priority": 356263, "source_url": "https://saudigazette.com.sa", "source_icon": "https://n.bytvi.com/saudigazette.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "86319b9363b675e2a7c5671a14d74241", "link": "https://news.google.?oc=5", "title": "\u0645\u062d\u0637\u0629 \u0639\u0645\u0644 \u0645\u062a\u0646\u0642\u0644\u0629 \u0645\u0646 \"\u0644\u064a\u0646\u0648\u0641\u0648\" \u0644\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646 \u0648\u0635\u0646\u0627\u0639 \u0627\u0644\u0645\u062d\u062a\u0648\u0649.. \u062a\u0639\u0631\u0641 \u0639\u0644\u064a\u0647\u0627\u061f - \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f \u0627\u0644\u064a\u0648\u0645", "description": "\u0645\u062d\u0637\u0629 \u0639\u0645\u0644 \u0645\u062a\u0646\u0642\u0644\u0629 \u0645\u0646 \"\u0644\u064a\u0646\u0648\u0641\u