0627\u0644\u062a\u0627\u0628\u0639 \u0644\u062a\u062c\u0645\u0639 \u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u0627\u0644\u0635\u062d\u064a\u060c \u062d\u0632\u0645\u0629 \u0628\u0631\u0627\u0645\u062c \u0648\u0642\u0627\u064a\u0654\u064a\u0629 \u0648\u062a\u0648\u0639\u0648\u064a\u0629 \u062a\u0632\u0627\u0645\u0646\u0627\u064b \u0645\u0639 \u0648\u0635\u0648\u0644 \u0639\u0631\u0628\u0629 \"<a href=\"https://www.alyaum.com/articles/6490328/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%B5%D8%AD%D8%A9-%D9%88%D8%AA%D8%BA%D8%B0%D9%8A%D8%A9/3-%D8%A3%D8%B3%D8%A8%D8%A7%D8%A8-%D9%88%D8%B1%D8%A7%D8%A1-%D8%A5%D8%AC%D8%B1%D8%A7%D8%A1-%D8%A3%D8%B4%D8%B9%D8%A9-%D8%A7%D9%84%D9%85%D8%A7%D9%85%D9%88%D8%AC%D8%B1%D8%A7%D9%85-%D8%A3%D9%87%D9%85%D9%87%D8%A7-%D8%A7%D9%84%D9%83%D8%B4%D9%81-%D8%A7%D9%84%D9%85%D8%A8%D9%83%D8%B1\" target=\"_blank\">\u0627\u0644\u0645\u0627\u0645\u0648\u062c\u0631\u0627\u0645</a>\" \u0627\u0644\u0645\u062a\u0646\u0642\u0644\u0629\u060c \u0628\u0647\u062f\u0641 \u062a\u0639\u0632\u064a\u0632 \u062b\u0642\u0627\u0641\u0629 \u0627\u0644\u0643\u0634\u0641 \u0627\u0644\u0645\u0628\u0643\u0631 \u0639\u0646 \u0633\u0631\u0637\u0627\u0646 \u0627\u0644\u062b\u062f\u064a \u0648\u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0648\u0639\u064a \u0627\u0644\u0635\u062d\u064a \u0644\u0644\u0645\u062c\u062a\u0645\u0639.<br /><br />\u0648\u0627\u0654\u0643\u062f\u062a \u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u0649 \u0627\u0654\u0646 <a href=\"https://www.alyaum.com/articles/6490328/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%B5%D8%AD%D8%A9-%D9%88%D8%AA%D8%BA%D8%B0%D9%8A%D8%A9/3-%D8%A3%D8%B3%D8%A8%D8%A7%D8%A8-%D9%88%D8%B1%D8%A7%D8%A1-%D8%A5%D8%AC%D8%B1%D8%A7%D8%A1-%D8%A3%D8%B4%D8%B9%D8%A9-%D8%A7%D9%84%D9%85%D8%A7%D9%85%D9%88%D8%AC%D8%B1%D8%A7%D9%85-%D8%A3%D9%87%D9%85%D9%87%D8%A7-%D8%A7%D9%84%D9%83%D8%B4%D9%81-%D8%A7%D9%84%D9%85%D8%A8%D9%83%D8%B1\">\u0627\u0644\u0639\u0631\u0628\u0629 \u0627\u0644\u0637\u0628\u064a\u0629</a> \u062c\u064f\u0647\u0632\u062a \u0628\u0627\u0654\u062d\u062f\u062b \u0627\u0644\u062a\u0642\u0646\u064a\u0627\u062a\u060c \u0648\u062a\u0639\u0645\u0644 \u0628\u0627\u0655\u0634\u0631\u0627\u0641 \u0643\u0648\u0627\u062f\u0631 \u0635\u062d\u064a\u0629 \u0645\u062a\u062e\u0635\u0635\u0629\u060c \u0644\u0636\u0645\u0627\u0646 \u062a\u0642\u062f\u064a\u0645 \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0641\u062d\u0635 \u0628\u062c\u0648\u062f\u0629 \u0648\u0643\u0641\u0627\u0621\u0629 \u0639\u0627\u0644\u064a\u0629\u060c \u0648\u0633\u0637 \u0627\u0644\u062a\u0632\u0627\u0645 \u062a\u0627\u0645 \u0628\u062e\u0635\u0648\u0635\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u0627\u062a.</div><h2 style=\"text-align:justify\"><br />\u0631\u0641\u0639 \u0646\u0633\u0628 \u0627\u0644\u0634\u0641\u0627\u0621</h2><div style=\"text-align: justify;\"><br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0654\u0646 \u0627\u0644\u0641\u062d\u0635 \u0627\u0644\u0645\u0628\u0643\u0631 \u064a\u064f\u0639\u062f \u0631\u0643\u064a\u0632\u0629 \u0627\u0654\u0633\u0627\u0633\u064a\u0629 \u0644\u0631\u0641\u0639 \u0646\u0633\u0628 \u0627\u0644\u0634\u0641\u0627\u0621 \u0648\u062a\u0642\u0644\u064a\u0644 \u0627\u0644\u0645\u0636\u0627\u0639\u0641\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0629 \u0627\u0644\u0645\u062d\u062a\u0645\u0644\u0629\u060c \u0644\u0627\u0641\u062a\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0655\u062c\u0631\u0627\u0621 \u0627\u0644\u0641\u062d\u0635 \u064a\u0633\u062a\u063a\u0631\u0642 \"\u062f\u0642\u0627\u064a\u0654\u0642 \u0628\u0633\u064a\u0637\u0629 \u0642\u062f \u062a\u0635\u0646\u0639 \u0641\u0627\u0631\u0642\u0627\u064b \u0643\u0628\u064a\u0631\u0627\u064b \u0641\u064a \u0627\u0644\u062d\u064a\u0627\u0629 \u0627\u0644\u0635\u062d\u064a\u0629 \u0644\u0644\u0645\u0631\u0627\u0654\u0629\".<br /><br />\u0648\u0648\u062c\u0647\u062a \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u062f\u0639\u0648\u0629 \u0645\u0641\u062a\u0648\u062d\u0629 \u0644\u062c\u0645\u064a\u0639 \u0627\u0644\u0633\u064a\u062f\u0627\u062a \u0644\u0644\u0645\u0628\u0627\u062f\u0631\u0629 \u0628\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u062a\u0648\u0627\u062c\u062f \u0627\u0644\u0639\u0631\u0628\u0629 \u0627\u0644\u0645\u062a\u0646\u0642\u0644\u0629\u060c \u0645\u0634\u062f\u062f\u0629 \u0639\u0644\u0649 \u0627\u0654\u0647\u0645\u064a\u0629 \u0647\u0630\u0647 \u0627\u0644\u062e\u0637\u0648\u0629 \u0643\u0627\u0654\u062f\u0627\u0629 \u0641\u0639\u0627\u0644\u0629 \u0644\u0644\u0627\u0637\u0645\u064a\u0654\u0646\u0627\u0646 \u0627\u0644\u062f\u0648\u0631\u064a \u0639\u0644\u0649 \u0635\u062d\u062a\u0647\u0646.<br /><br />\u0648\u0639\u0644\u0649 \u0627\u0644\u0635\u0639\u064a\u062f \u0627\u0644\u062a\u0648\u0639\u0648\u064a\u060c \u0628\u064a\u0651\u0646\u062a \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0654\u0646 \u0627\u0644\u0645\u0628\u0627\u062f\u0631\u0629 \u0627\u0645\u062a\u062f\u062a \u0644\u062a\u0634\u0645\u0644 \u062a\u0646\u0638\u064a\u0645 \u0633\u0644\u0633\u0644\u0629 \u0645\u062d\u0627\u0636\u0631\u0627\u062a \u062a\u062b\u0642\u064a\u0641\u064a\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0645\u0631\u0627\u0643\u0632 \u0627\u0644\u0635\u062d\u064a\u0629 \u0648\u0627\u0644\u0645\u062c\u0645\u0639\u0627\u062a \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u0646\u0637\u0642\u0629.<br /><br />\u0648\u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u0628\u0631\u0627\u0645\u062c \u0627\u0644\u0631\u062f\u064a\u0641\u0629 \u062a\u0633\u062a\u0647\u062f\u0641 \u0646\u0634\u0631 \u0627\u0644\u062b\u0642\u0627\u0641\u0629 \u0627\u0644\u0635\u062d\u064a\u0629\u060c \u0648\u062a\u0633\u0644\u064a\u0637 \u0627\u0644\u0636\u0648\u0621 \u0639\u0644\u0649 \u0639\u0648\u0627\u0645\u0644 \u0627\u0644\u062e\u0637\u0648\u0631\u0629\u060c \u0648\u0628\u062b \u0631\u0633\u0627\u064a\u0654\u0644 \u062a\u0648\u06