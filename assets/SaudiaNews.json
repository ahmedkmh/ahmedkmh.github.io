85/%D9%85%D8%AD%D9%85%D8%AF-%D9%87%D9%86%D9%8A%D8%AF%D9%8A-%D9%8A%D9%83%D8%B4%D9%81-%D9%85%D9%88%D8%A7%D8%B7%D9%86-%D8%A7%D9%84%D8%A5%D9%84%D9%87%D8%A7%D9%85-%D9%81%D9%8A-%D8%AE%D9%81%D8%A9-%D8%A7%D9%84%D8%B8%D9%84-%D8%AE%D9%84%D8%A7%D9%84-%D9%85%D9%84%D8%AA%D9%82%D9%89-%D8%B5%D9%86%D8%A7%D8%B9-%D8%A7%D9%84%D8%AA%D8%A3%D8%AB%D9%8A%D8%B1\" target=\"_blank\">\u0645\u062d\u0645\u062f \u0647\u0646\u064a\u062f\u064a</a> \u0648\u0645\u0646\u0649 \u0632\u0643\u064a\u060c \u0627\u0644\u0644\u0630\u0627\u0646 \u064a\u062c\u0645\u0639\u0647\u0645\u0627 \u0641\u064a\u0644\u0645 \u0627\u0644\u0643\u0648\u0645\u064a\u062f\u064a\u0627 \u0627\u0644\u062c\u062f\u064a\u062f \u00ab\u0627\u0644\u062c\u0648\u0627\u0647\u0631\u062c\u064a\u00bb.<br /><br />\u0648\u0627\u0654\u0637\u0644\u0642\u062a \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0646\u062a\u062c\u0629 \u0627\u0644\u0628\u0631\u0648\u0645\u0648 \u0627\u0644\u0631\u0633\u0645\u064a \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u0641\u064a\u0644\u0645 \u00ab\u0627\u0644\u062c\u0648\u0627\u0647\u0631\u062c\u064a\u00bb\u060c \u0627\u0655\u064a\u0630\u0627\u0646\u064b\u0627 \u0628\u0627\u0642\u062a\u0631\u0627\u0628 \u0639\u0631\u0636\u0647 \u0641\u064a \u062f\u0648\u0631 \u0627\u0644\u0633\u064a\u0646\u0645\u0627\u060c \u0643\u0627\u0634\u0641\u064b\u0627 \u0639\u0646 \u0639\u0648\u062f\u0629 \u0645\u062d\u0645\u062f \u0647\u0646\u064a\u062f\u064a \u0648<a href=\"https://www.alyaum.com/articles/6470319/%D8%A7%D9%84%D8%AB%D9%82%D8%A7%D9%81%D8%A9-%D9%88%D8%A7%D9%84%D9%81%D9%86/%D8%AF%D8%B1%D8%A7%D9%85%D8%A7/%D8%A8%D8%B9%D8%AF-19-%D8%B9%D8%A7%D9%85%D8%A7-%D9%85%D9%86-%D8%A7%D9%84%D8%BA%D9%8A%D8%A7%D8%A8-%D8%A3%D8%AD%D9%85%D8%AF-%D8%AD%D9%84%D9%85%D9%8A-%D9%88%D9%85%D9%86%D9%89-%D8%B2%D9%83%D9%8A-%D9%81%D9%8A-%D9%81%D9%8A%D9%84%D9%85-%D9%88%D8%A7%D8%AD%D8%AF\" target=\"_blank\">\u0645\u0646\u0649 \u0632\u0643\u064a</a> \u0643\u062b\u0646\u0627\u064a\u0654\u064a \u0627\u0655\u0644\u0649 \u0627\u0644\u0634\u0627\u0634\u0629 \u0627\u0644\u0643\u0628\u064a\u0631\u0629 \u0628\u0639\u062f \u063a\u064a\u0627\u0628 \u064a\u0642\u0627\u0631\u0628 30 \u0639\u0627\u0645\u064b\u0627.<br /><br />\u0648\u064a\u064f\u0637\u0631\u062d \u0627\u0644\u0641\u064a\u0644\u0645 \u0641\u064a \u062f\u0648\u0631 \u0627\u0644\u0639\u0631\u0636 \u0627\u0639\u062a\u0628\u0627\u0631\u064b\u0627 \u0645\u0646 5 \u0627\u0654\u063a\u0633\u0637\u0633 2026\u060c \u0628\u0639\u062f \u0633\u0644\u0633\u0644\u0629 \u0645\u0646 \u0627\u0644\u062a\u0627\u0654\u062c\u064a\u0644\u0627\u062a \u0627\u0645\u062a\u062f\u062a \u0644\u0639\u062f\u0629 \u0633\u0646\u0648\u0627\u062a\u060c \u0644\u064a\u0639\u0648\u062f \u0627\u0654\u062e\u064a\u0631\u064b\u0627 \u0627\u0655\u0644\u0649 \u0633\u0628\u0627\u0642 \u0627\u0644\u0633\u064a\u0646\u0645\u0627.<br /> <h2>\u0627\u0655\u064a\u0642\u0627\u0639 \u0643\u0648\u0645\u064a\u062f\u064a \u0633\u0631\u064a\u0639</h2>\u0648\u064a\u0643\u0634\u0641 \u0627\u0644\u0628\u0631\u0648\u0645\u0648 \u0639\u0646 \u0627\u0654\u062d\u062f\u0627\u062b \u0633\u0631\u064a\u0639\u0629 \u0627\u0644\u0627\u0655\u064a\u0642\u0627\u0639 \u062a\u0639\u062a\u0645\u062f \u0639\u0644\u0649 \u0627\u0644\u0645\u0641\u0627\u0631\u0642\u0627\u062a \u0627\u0644\u0643\u0648\u0645\u064a\u062f\u064a\u0629\u060c \u0627\u0655\u0630 \u062a\u062f\u0648\u0631 \u0627\u0644\u0642\u0635\u0629 \u062d\u0648\u0644 \u062a\u0627\u062c\u0631 \u0645\u062c\u0648\u0647\u0631\u0627\u062a \u064a\u062c\u0633\u062f\u0647 \u0645\u062d\u0645\u062f \u0647\u0646\u064a\u062f\u064a\u060c \u064a\u062c\u062f \u0646\u0641\u0633\u0647 \u0641\u064a \u062f\u0648\u0627\u0645\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0632\u0645\u0627\u062a \u0628\u0633\u0628\u0628 \u0627\u0644\u062e\u0644\u0627\u0641\u0627\u062a \u0627\u0644\u0645\u062a\u0643\u0631\u0631\u0629 \u0645\u0639 \u0632\u0648\u062c\u062a\u0647\u060c \u0627\u0644\u062a\u064a \u062a\u0648\u0654\u062f\u064a \u062f\u0648\u0631\u0647\u0627 \u0645\u0646\u0649 \u0632\u0643\u064a\u060c \u0644\u062a\u062a\u0637\u0648\u0631 \u0627\u0644\u0627\u0654\u062d\u062f\u0627\u062b \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0646\u0641\u0635\u0627\u0644 \u0628\u064a\u0646\u0647\u0645\u0627 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0645\u0631\u0629\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0644\u062c\u0627\u0653 \u0627\u0655\u0644\u0649 \u0645\u0633\u062a\u0634\u0627\u0631 \u0644\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u0632\u0648\u062c\u064a\u0629 \u0641\u064a \u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0627\u0655\u0646\u0642\u0627\u0630 \u0632\u0648\u0627\u062c\u0647\u0645\u0627\u060c \u0648\u0633\u0637 \u0633\u0644\u0633\u0644\u0629 \u0645\u0646 \u0627\u0644\u0645\u0648\u0627\u0642\u0641 \u0627\u0644\u0643\u0648\u0645\u064a\u062f\u064a\u0629 \u063a\u064a\u0631 \u0627\u0644\u0645\u062a\u0648\u0642\u0639\u0629.<br /><br />\u0648\u064a\u0634\u0627\u0631\u0643 \u0641\u064a \u0628\u0637\u0648\u0644\u0629 \u0627\u0644\u0641\u064a\u0644\u0645\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0645\u062d\u0645\u062f \u0647\u0646\u064a\u062f\u064a \u0648\u0645\u0646\u0649 \u0632\u0643\u064a\u060c \u0643\u0644 \u0645\u0646 \u0644\u0628\u0644\u0628\u0629\u060c \u0648\u0627\u0654\u062d\u0645\u062f \u0635\u0644\u0627\u062d \u0627\u0644\u0633\u0639\u062f\u0646\u064a \u0627\u0644\u0630\u064a \u064a\u062c\u0633\u062f \u0634\u062e\u0635\u064a\u0629 \u0645\u0633\u062a\u0634\u0627\u0631 \u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u0632\u0648\u062c\u064a\u0629\u060c \u0648\u062a\u0627\u0631\u0627 \u0639\u0645\u0627\u062f\u060c \u0648\u0628\u0627\u0633\u0645 \u0633\u0645\u0631\u0629\u060c \u0648\u0631\u064a\u0645 \u0645\u0635\u0637\u0641\u0649\u060c \u0648\u0627\u0654\u062d\u0645\u062f \u0635\u0644\u0627\u062d \u062d\u0633\u0646\u064a\u060c \u0648\u0639\u0627\u0631\u0641\u0629 \u0639\u0628\u062f \u0627\u0644\u0631\u0633\u0648\u0644.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["entertainment"], "datatype": "news", "pubDate": "2026-06-28 07:38:00", "pubDateTZ": "UTC", "fetched_at": "2026-06-28 07:47:51", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "ebea6f7634902b5aa9564e71219c6b00", "link": "https://www.alyaum.com/articles/6669603/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%AA%D9%83%D9%86%D9%88%D9%84%D9%88%D8%AC%D9%8A%D8%A7/GTA-6-%D9%84%D9%86-%D8%AA%D8%B5%D8%AF%D8%B1-%D8%B9%D9%84%D9%89-%D9%82%D8%B1%D8%B5-%D9%85%D8%A7%D8%AF%D9%8A-%D8%B9%D9%86%D8%AF-%D8%A7%D9%84%D8%A5%D8%B7%D9%84%D8%A7%D9%82", "title": "GTA 6 \u0644\u0646 \u062a\u0635\u062f\u0631 \u0639\u0644\u0649 \u0642\u0631\u0635 \u0645\u0627\u062f\u064a \u0639\u0646\u062f \u0627\u0644\u0627\u0655\u0637\u0644\u0627\u0642", "description": "\u0634\u0647\u062f\u062a \u0627\u0644\u0641\u062a\u0631\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629 \u062a\u062f\u0627\u0648\u0644 \u062a\u0642\u0627\u0631\u064a\u0631 \u0648\u0645\u0646\u0634\u0648\u0631\u0627\u062a \u0639\u0628\u0631 \u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a \u0632\u0639\u0645\u062a \u0627\u0654\u0646 \u0644\u0639\u0628\u0629 GTA 6 \u0633\u062a\u062a\u0648\u0641\u0631 \u0639\u0644\u0649 \u0642\u0631\u0635 \u0641\u0639\u0644\u064a \u0642\u0628\u0644 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u062c\u0627\u0631\u064a\u060c \u0648\u0630\u0644\u0643 \u0628\u0639\u062f \u0627\u0646\u062a\u0634\u0627\u0631 \u0635\u0648\u0631\u0629 \u0644\u0631\u0633\u0627\u0644\u0629 \u0645\u0646\u0633\u0648\u0628\u0629 \u0627\u0655\u0644\u0649 \u0641\u0631\u064a\u0642 \u062f\u0639\u0645 Rockstar.<br /><br />\u0648\u062c\u0627\u0621 \u0641\u064a \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0627\u0644\u0645\u062a\u062f\u0627\u0648\u0644\u0629: \"\u0633\u062a\u062a\u0645\u0643\u0646 \u0645\u0646 \u0627\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0646\u0633\u062e\u0629 \u0645\u0627\u062f\u064a\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u0634\u0647\u0631 \u0627\u0644\u062a\u0627\u0644\u064a\u0629\"\u060c \u0648\u0647\u0648 \u0645\u0627 \u062f\u0641\u0639 \u0643\u062b\u064a\u0631\u064a\u0646 \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0639\u062a\u0642\u0627\u062f \u0628\u0627\u0654\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u062a\u0633\u062a\u0639\u062f \u0644\u0627\u0655\u0637\u0644\u0627\u0642 \u0646\u0633\u062e\u0629 \u0642\u0631\u0635\u064a\u0629 \u0645\u0646 \u0627\u0644\u0644\u0639\u0628\u0629.<h2>\u0644\u0627 \u0646\u0633\u062e\u0629 \u0642\u0631\u0635\u064a\u0629</h2>\u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u0645\u062c\u0644\u0629 The Hollywood Reporter \u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0654\u0646 \u0627\u0644\u0628\u0631\u064a\u062f \u0627\u0644\u0627\u0655\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u0627\u0644\u0645\u062a\u062f\u0627\u0648\u0644 \u0643\u0627\u0646 \u0631\u062f\u064b\u0627 \u062d\u0642\u064a\u0642\u064a\u064b\u0627 \u0639\u0644\u0649 \u0627\u0633\u062a\u0641\u0633\u0627\u0631 \u0648\u064f\u062c\u0647 \u0627\u0655\u0644\u0649 \u0641\u0631\u064a\u0642 \u062f\u0639\u0645 Rockstar \u0628\u0634\u0627\u0654\u0646 \u0627\u0655\u0645\u0643\u0627\u0646\u064a\u0629 \u0627\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0646\u0633\u062e\u0629 \u0642\u0631\u0635\u064a\u0629 \u0645\u0646 GTA 6\u060c \u0645\u0648\u0654\u0643\u062f\u0629 \u0627\u0654\u0646 \u0635\u064a\u0627\u063a\u0629 \u0627\u0644\u0631\u062f \u0643\u0627\u0646\u062a \u063a\u064a\u0631 \u0648\u0627\u0636\u062d\u0629\u060c \u0644\u0643\u0646\u0647\u0627 \u0644\u0627 \u062a\u062a\u0636\u0645\u0646 \u0627\u0654\u064a \u0627\u0655\u0639\u0644\u0627\u0646 \u0639\u0646 \u062a\u063a\u064a\u064a\u0631 \u0641\u064a \u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0654\u0648 \u062a\u0627\u0654\u0643\u064a\u062f\u064b\u0627 \u0639\u0644\u0649 \u062a\u0637\u0648\u064a\u0631 \u0627\u0655\u0635\u062f\u0627\u0631 \u064a\u0639\u0645\u0644 \u0628\u0627\u0644\u0627\u0654\u0642\u0631\u0627\u0635.<br /> <br />\u0648\u0627\u0654\u0636\u0627\u0641\u062a \u0627\u0644\u0645\u062c\u0644\u0629\u060c \u0646\u0642\u0644\u064b\u0627 \u0639\u0646 \u0645\u0635\u062f\u0631 \u0645\u0637\u0644\u0639 \u0639\u0644\u0649 \u062e\u0637\u0629 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0644\u0639\u0628\u0629\u060c \u0627\u0654\u0646 Rockstar \u0644\u0627 \u062a\u0639\u062a\u0632\u0645 \u0627\u0655\u0635\u062f\u0627\u0631 \u0646\u0633\u062e\u0629 \u0642\u0631\u0635\u064a\u0629 \u0645\u0646 GTA 6\u060c \u0633\u0648\u0627\u0621 \u0639\u0646\u062f \u0627\u0644\u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0654\u0648 \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u0634\u0647\u0631 \u0627\u0644\u062a\u064a \u062a\u0644\u064a\u0647.<br /><br />\u0648\u0628\u064a\u0651\u0646\u062a \u0627\u0654\u0646 \u0627\u0644\u0645\u0642\u0635\u0648\u062f \u0628\u0639\u0628\u0627\u0631\u0629 \"\u0646\u0633\u062e\u0629 \u0645\u0627\u062f\u064a\u0629\" \u0641\u064a \u0631\u062f \u0641\u0631\u064a\u0642 \u0627\u0644\u062f\u0639\u0645 \u0647\u0648 \u0627\u0644\u0646\u0633\u062e\u0629 \u0627\u0644\u062a\u064a \u0627\u0654\u0639\u0644\u0646\u062a \u0639\u0646\u0647\u0627 \u0627\u0644\u0634\u0631\u0643\u0629 \u0645\u0633\u0628\u0642\u064b\u0627\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u0627\u0654\u062a\u064a \u062f\u0627\u062e\u0644 \u0639\u0644\u0628\u0629 \u062a\u062d\u062a\u0648\u064a \u0639\u0644\u064