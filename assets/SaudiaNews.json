%AF%D9%88%D8%B1%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A/%D8%A7%D9%84%D8%A3%D8%AE%D8%B6%D8%B1-%D9%8A%D9%88%D8%A7%D8%B5%D9%84-%D8%AA%D8%AD%D8%B6%D9%8A%D8%B1%D8%A7%D8%AA%D9%87-%D9%84%D9%85%D9%88%D8%A7%D8%AC%D9%87%D8%A9-%D9%85%D8%B5%D8%B1-%D9%88%D8%B1%D9%8A%D9%86%D8%A7%D8%B1%D8%AF-%D9%8A%D8%B1%D9%83%D8%B2-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%AC%D9%88%D8%A7%D9%86%D8%A8-%D8%A7%D9%84%D8%AA%D9%83%D8%AA%D9%8A%D9%83%D9%8A%D8%A9\" target=\"_blank\">\u0645\u0635\u0631</a> \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0628\u062d\u0645\u064a\u0639 \u0627\u0644\u0645\u0648\u0627\u0637\u0646\u064a\u0646 \u0627\u0644\u0643\u0631\u0627\u0645 \u062a\u0648\u062e\u064a \u0627\u0644\u062d\u064a\u0637\u0629 \u0648\u0627\u0644\u062d\u0630\u0631\u060c \u0641\u064a \u0638\u0644 \u0645\u0627 \u062a\u0634\u0647\u062f\u0647 \u0627\u0644\u0628\u0644\u0627\u062f \u0645\u0646 \u062d\u0627\u0644\u0629 <a href=\"https://www.alyaum.com/articles/1085587/%D9%82%D8%A8%D9%84-%D8%A7%D9%84%D8%A7%D8%AE%D9%8A%D8%B1%D8%A9/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%B9%D8%AF%D9%85-%D8%A7%D8%B3%D8%AA%D9%82%D8%B1%D8%A7%D8%B1-%D8%AC%D9%88%D9%8A-%D8%AD%D8%AA%D9%89-%D9%86%D9%87%D8%A7%D9%8A%D8%A9-%D8%A7%D9%84%D8%A3%D8%B3%D8%A8%D9%88%D8%B9\" target=\"_blank\">\u0639\u062f\u0645 \u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u062c\u0648\u064a</a> \u0642\u0648\u064a\u0629 \u0645\u062a\u0648\u0642\u0639\u0629 \u064a\u0648\u0645\u064a \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 \u0648\u0627\u0644\u062e\u0645\u064a\u0633 25 \u064826 \u0645\u0627\u0631\u0633 2026\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0631\u0633\u0645\u064a\u0629.<br />\u0648\u062f\u0639\u062a \u0627\u0644\u0633\u0641\u0627\u0631\u0629 \u0645\u0646 \u062e\u0644\u0627\u0644 \u062d\u0633\u0627\u0628\u0647\u0627 \u0627\u0644\u0631\u0633\u0645\u064a \u0639\u0644\u0649 \u0645\u0646\u0635\u0629 \u0627\u0655\u0643\u0633 \u0627\u0655\u0644\u0649:<br />- \u0