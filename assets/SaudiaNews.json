 \u0642\u0631\u0627\u0631\u064b\u0627 \u062a\u0627\u0631\u064a\u062e\u064a\u064b\u0651\u0627\u060c \u064a\u0642\u0636\u064a \u0628\u0627\u0639\u062a\u0628\u0627\u0631 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0646\u063a\u0627\u0644\u064a \u0627\u0644\u0627\u0654\u0648\u0644 \u062e\u0627\u0633\u0631\u064b\u0627 \u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0627\u0654\u0645\u0645 \u0627\u0644\u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0629 2025 \u0628\u0646\u062a\u064a\u062c\u0629 0\u06403 \u0644\u0635\u0627\u0644\u062d \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0644\u0645\u0633\u062a\u0636\u064a\u0641\u060c \u0627\u0633\u062a\u0646\u0627\u062f\u064b\u0627 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0627\u062f\u0629 84 \u0645\u0646 \u0644\u0627\u064a\u0654\u062d\u0629 \u0627\u0644\u0628\u0637\u0648\u0644\u0629. \u0648\u062d\u0633\u0628\u064e \u0627\u0644\u0645\u0648\u0642\u0639 \u0627\u0644\u0631\u0633\u0645\u064a \u0644\u0643\u0627\u0641\u060c \u062c\u0627\u0621 \u0642\u0631\u0627\u0631 \u0627\u0644\u0644\u062c\u0646\u0629 \u0628\u0639\u062f \u0642\u0628\u0648\u0644 \u0627\u0644\u0627\u0633\u062a\u064a\u0654\u0646\u0627\u0641 \u0627\u0644\u0645\u0642\u062f\u064e\u0651\u0645 \u0645\u0646 \u0627\u0644\u062c\u0627\u0645\u0639\u0629 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629 \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u0634\u0643\u0644\u064b\u0627 \u0648\u0645\u0648\u0636\u0648\u0639\u064b\u0627\u060c \u0648\u0627\u0655\u0644\u063a\u0627\u0621 \u0642\u0631\u0627\u0631 \u0627\u0644\u0644\u062c\u0646\u0629 \u0627\u0644\u062a\u0627\u0654\u062f\u064a\u0628\u064a\u0629 \u0627\u0644\u0633\u0627\u0628\u0642. \u0648\u0627\u0654\u0643\u062f\u062a \u0644\u062c\u0646\u0629 \u0627\u0644\u0627\u0633\u062a\u064a\u0654\u0646\u0627\u0641 \u0648\u0642\u0648\u0639 \u0633\u0644\u0648\u0643 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0646\u063a\u0627\u