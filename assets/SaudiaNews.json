644\u0643\u0629 \u0627\u0644\u0642\u0627\u0628\u0636\u0629\u00bb \u062a\u0633\u062a\u062d\u0648\u0630 \u0639\u0644\u0649 \u062d\u0635\u0629 \u0645\u0646 \u00abBEV\u00bb \u0645\u0642\u0627\u0628\u0644 225 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644", "description": "\u0648\u0642\u0639\u062a \u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0642\u0627\u0628\u0636\u0629\u060c \u0627\u0654\u0645\u0633\u060c \u062a\u0648\u0642\u064a\u0639 \u0627\u062a\u0641\u0627\u0642\u064a\u0629 \u0634\u0631\u0627\u0621 \u0627\u0654\u0633\u0647\u0645 \u0644\u0644\u0627\u0633\u062a\u062d\u0648\u0627\u0630 \u0639\u0644\u0649 \u062d\u0635\u0629 \u0641\u064a \u0634\u0631\u0643\u0629 \u0628\u0631\u064a\u0643\u062b\u0631\u0648 \u0627\u0655\u0646\u0631\u062c\u064a \u0641\u0646\u062a\u0634\u0631\u0632 \u201cBEV\u201d \u0645\u0646 \u0635\u0627\u062d\u0628 \u0627\u0644\u0633\u0645\u0648 \u0627\u0644\u0645\u0644\u0643\u064a \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0627\u0644\u0648\u0644\u064a\u062f \u0628\u0646 \u0637\u0644\u0627\u0644 \u0628\u0646 \u0639\u0628\u062f \u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0653\u0644 \u0633\u0639\u0648\u062f\u060c \u0645\u0642\u0627\u0628\u0644 \u0645\u0628\u0644\u063a \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0642\u062f\u0631\u0647 225 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0628\u0645\u0627 \u064a\u0639\u0627\u062f\u0644 68 \u0645\u0644\u064a\u0648\u0646 \u062f\u0648\u0644\u0627\u0631.<br /><br />\u0648\u0648\u0641\u0642\u0627 \u0644\u0628\u064a\u0627\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\"\u060c \u0628\u0644\u063a\u062a \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u062a\u0642\u062f\u064a\u0631\u064a\u0629 \u0644\u0644\u062d\u0635\u0629 \u0627\u0644\u0645\u0633\u062a\u062d\u0648\u0630 \u0639\u0644\u064a\u0647\u0627 \u0646\u062d\u0648 98 \u0645\u0644\u064a\u0648\u0646 \u062f\u0648\u0644\u0627\u0631 (367.5 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644)\u060c \u0648\u0630\u0644\u0643 \u0627\u0633\u062a\u0646\u0627\u062f\u064b\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u062d\u062f\u062b \u0627\u0644\u0642\u0648\u0627\u064a\u0654\u0645 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u062f\u0642\u0642\u0629 \u0644\u0634\u0631\u0643\u0629 \"BEV\". \u0641\u064a\u0645\u0627 \u062a\u0645 \u062a\u0646\u0641\u064a\u0630 \u0627\u0644\u0635\u0641\u0642\u0629 \u0628\u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0645\u0628\u0644\u063a \u0642\u062f\u0631\u0647 68 \u0645\u0644\u064a\u0648\u0646 \u062f\u0648\u0644\u0627\u0631 (255 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644)\u060c \u0628\u0645\u0627 \u064a\u0639\u0643\u0633 \u0633\u0639\u0631\u0627\u064b \u0634\u0631\u0627\u064a\u0654\u064a\u0627\u064b \u064a\u062a\u0636\u0645\u0646 \u062e\u0635\u0645\u0627\u064b \u0628\u0646\u0633\u0628\u0629 30% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u062a\u0642\u062f\u064a\u0631\u064a\u0629.<br /><br />\u0648\u0628\u062d\u0633\u0628 \u0627\u0644\u0628\u064a\u0627\u0646\u060c \u0633\u062a\u0645\u0648\u0644 \u0627\u0644\u0635\u0641\u0642\u0629 \u0645\u0646 \u0645\u0635\u0627\u062f\u0631 \u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0642\u0627\u0628\u0636\u0629 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629.<br /><br />\u0648\"BEV\" \u0647\u064a \u0639\u0628\u0627\u0631\u0629 \u0639\u0646 \u0634\u0631\u0643\u0629 \u062a\u0633\u062a\u062b\u0645\u0631 \u0641\u064a \u062a\u0642\u0646\u064a\u0627\u062a \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0646\u0638\u064a\u0641\u0629 \u0648\u0627\u0644\u0627\u0633\u062a\u062f\u0627\u0645\u0629 \u0627\u0644\u0645\u0628\u062a\u0643\u0631\u0629\u060c \u0628\u0647\u062f\u0641 \u062a\u0645\u0643\u064a\u0646 \u0627\u0642\u062a\u0635\u0627\u062f \u0645\u0646\u062e\u0641\u0636 \u0627\u0644\u0643\u0631\u0628\u0648\u0646\u060c \u0641\u064a\u0645\u0627 \u0627\u0654\u0633\u0633\u0647\u0627 \u0628\u064a\u0644 \u063a\u064a\u062a\u0633\u060c \u0648\u062a\u0633\u062a\u062b\u0645\u0631 \u0641\u064a \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u064f\u0637\u0648\u0651\u0631 \u062d\u0644\u0648\u0644\u0627\u064b \u0631\u0627\u064a\u0654\u062f\u0629 \u0641\u064a \u0645\u062c\u0627\u0644\u0627\u062a \u0627\u0644\u0632\u0631\u0627\u0639\u0629\u060c \u0648\u0627\u0644\u0628\u0646\u0627\u0621\u060c \u0648\u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621\u060c \u0648\u0627\u0644\u062a\u0635\u0646\u064a\u0639\u060c \u0648\u0627\u0644\u0646\u0642\u0644.<br /><br />\u0648\u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u062f\u0642\u0642\u0629 \u0644\u0640\u0634\u0631\u0643\u0629 \"BEV\" \u0643\u0645\u0627 \u0641\u064a 31 \u062f\u064a\u0633\u0645\u0628\u0631 2024 \u06482023 \u06482022\u060c \u062a\u0628\u0644\u063a \u0642\u064a\u0645\u0629 \u0627\u0644\u062d\u0635\u0629 \u0627\u0644\u0645\u0633\u062a\u062d\u0648\u0630 \u0639\u0644\u064a\u0647\u0627 \u0645\u0646 \u0642\u0628\u0644 \u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0642\u0627\u0628\u0636\u0629 98 \u0645\u0644\u064a\u0648\u0646 \u062f\u0648\u0644\u0627\u0631 \u064891.4 \u0645\u0644\u064a\u0648\u0646 \u062f\u0648\u0644\u0627\u0631 \u064896.6 \u0645\u0644\u064a\u0648\u0646 \u062f\u0648\u0644\u0627 \u0639\u0644\u0649 \u0627\u0644\u062a\u0648\u0627\u0644\u064a.<br /><br />\u0648\u0642\u0627\u0644\u062a \u0627\u0644\u0634\u0631\u0643\u0629: \u0627\u0655\u0646 \u0627\u0644\u0635\u0641\u0642\u0629 \u062a\u062a\u0645\u0627\u0634\u0649 \u0645\u0639 \u0641\u0644\u0633\u0641\u0629 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0644\u062f\u0649 \u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0642\u0627\u0628\u0