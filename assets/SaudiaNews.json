a \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0645\u0628\u060c \u0627\u0654\u0645\u0633 (\u0627\u0644\u062c\u0645\u0639\u0629)\u060c \u0627\u0655\u0646 \u062d\u0635\u0627\u0631 \u0627\u0644\u0645\u0648\u0627\u0646\u064a\u0654 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0633\u064a\u0633\u062a\u0645\u0631 \u0627\u0655\u0644\u0649 \u063a\u0627\u064a\u0629 \u0627\u0644\u062a\u0648\u0635\u0644 \u0627\u0655\u0644\u0649 \u0627\u062a\u0641\u0627\u0642 \u0645\u0639 \u0637\u0647\u0631\u0627\u0646. \u0637\u0647\u0631\u0627\u0646 \u063a\u064a\u0631 \u0645\u0633\u062a\u0639\u062f\u0629 \u0644\u062c\u0648\u0644\u0629 \u062a\u0641\u0627\u0648\u0636\u0645\u0646 \u062c\u0627\u0646\u0628\u0647\u060c \u0642\u0627\u0644 \u0646\u0627\u064a\u0654\u0628 \u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0633\u0639\u064a\u062f \u062e\u0637\u064a\u0628 \u0632\u0627\u062f\u0647 \u0641\u064a \u0645\u0642\u0627\u0628\u0644\u0629 \u0645\u0639 \u0648\u0643\u0627\u0644\u0629 \"\u0627\u0654\u0633\u0648\u0634\u064a\u062a\u062f \u0628\u0631\u0633\"\u060c \u0627\u0655\u0646 \u0637\u0647\u0631\u0627\u0646 \"\u063a\u064a\u0631 \u0645\u0633\u062a\u0639\u062f\u0629 \u0644\u062c\u0648\u0644\u0629 \u062c\u062f\u064a\u062f\u0629 \u0645\u0646 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0627\u062a \u0627\u0644\u0645\u0628\u0627\u0634\u0631\u0629 \u0645\u0639 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629\u060c \u0644\u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0645\u064a\u0643\u064a\u064a\u064a\u0646 \u0644\u0645 \u064a\u062a\u062e\u0644\u0648\u0627 \u0639\u0646 \u0645\u0648\u0627\u0642\u0641\u0647\u0645 \u0627\u0644\u0645\u062a\u0634\u062f\u062f\u0629\"\u060c \u0648\u0641\u0642 \u0642\u0648\u0644\u0647 .\u0648\u0627\u0654\u0636\u0627\u0641 \u062e\u0644\u0627\u0644 \u062d\u0636\u0648\u0631\u0647 \u0645\u0646\u062a\u062f\u0649 \u0627\u0654\u0646\u0637\u0627\u0644\u064a\u0627 \u0627\u0644\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a \u0641\u064a \u062a\u0631\u0643\u064a\u0627\u060c \u0627\u0644\u064a\u0648\u0645 \u060c \u0627\u0654\u0646 \"\u0627\u0655\u064a\u0631\u0627\u0646 \u0644\u0646 \u062a\u0633\u0644\u0645 \u0627\u0644\u064a\u0648\u0631\u0627\u0646\u064a\u0648\u0645 \u0627\u0644\u0645\u062e\u0635\u0651\u0628 \u0644\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629\u060c \u0646\u0627\u0641\u064a\u0627\u064b \u062a\u0635\u0631\u064a\u062d\u0627\u062a \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0645\u0628 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0634\u0627\u0654\u0646.\u0648\u0643\u0627\u0646 \u0645\u0635\u062f\u0631 \u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0645\u0637\u0644\u0639\u060c \u0643\u0634\u0641 \u0644\u0648\u0643\u0627\u0644\u0629 \u00ab\u062a\u0633\u0646\u064a\u0645\u00bb\u060c \u0627\u0644\u0633\u0628\u062a\u060c \u0627\u0654\u0646 \u0637\u0647\u0631\u0627\u0646 \u0644\u0645 \u062a\u0648\u0627\u0641\u0642 \u062d\u062a\u0649 \u0627\u0644\u0627\u0653\u0646 \u0639\u0644\u0649 \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0645\u0646 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a \u0645\u0639 \u0648\u0627\u0634\u0646\u0637\u0646.\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0644\u0645\u0635\u062f\u0631\u060c \u0627\u0654\u0646 \u0637\u0647\u0631\u0627\u0646 \u062a\u0631\u0649 \u0627\u0654\u0646 \u0648\u0627\u0634\u0646\u0637\u0646 \u0648\u0636\u0639\u062a \u0645\u0637\u0627\u0644\u0628 \u0645\u0641\u0631\u0637\u0629 \u062e\u0644\u0627\u0644 \u0639\u0645\u0644\u064a\u0629 \u062a\u0628\u0627\u062f\u0644 \u0627\u0644\u0631\u0633\u0627\u064a\u0654\u0644\u060c \u0644\u0627\u0641\u062a\u0627\u064b \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0634\u0631\u0637 \u0627\u0655\u064a\u0631\u0627\u0646 \u0644\u0645\u0648\u0627\u0635\u