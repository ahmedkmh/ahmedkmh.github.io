B9-%D8%A7%D9%84%D9%85%D9%8A%D8%A7%D9%87-%D9%81%D9%8A-%D9%85%D8%A3%D8%B1%D8%A8", "title": "\u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629 \u064a\u0636\u0639 \u062d\u062c\u0631 \u0627\u0644\u0627\u0654\u0633\u0627\u0633 \u0644\u062b\u0644\u0627\u062b\u0629 \u0645\u0634\u0627\u0631\u064a\u0639 \u062d\u064a\u0648\u064a\u0629 \u0628\u0642\u0637\u0627\u0639 \u0627\u0644\u0645\u064a\u0627\u0647 \u0641\u064a \u0645\u0627\u0654\u0631\u0628", "description": "\u0648\u0636\u0639 \u0645\u0631\u0643\u0632 <a href=\"https://www.alyaum.com/articles/6658010/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%B5%D9%88%D8%B1-%D8%BA%D8%B2%D8%A9-%D8%A7%D8%B3%D8%AA%D9%81%D8%A7%D8%AF%D8%A9-%D8%A7%D9%84%D8%A2%D9%84%D8%A7%D9%81-%D9%85%D9%86-%D9%88%D8%AC%D8%A8%D8%A7%D8%AA-%D9%88%D9%85%D8%B3%D8%A7%D8%B9%D8%AF%D8%A7%D8%AA-%D9%85%D8%B1%D9%83%D8%B2-%D8%A7%D9%84%D9%85%D9%84%D9%83-%D8%B3%D9%84%D9%85%D8%A7%D9%86-%D9%84%D9%84%D8%A5%D8%BA%D8%A7%D8%AB%D8%A9\" target=\"_blank\">\u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629</a> \u0648\u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u062d\u062c\u0631 \u0627\u0644\u0627\u0654\u0633\u0627\u0633 \u0644\u062b\u0644\u0627\u062b\u0629 \u0645\u0634\u0627\u0631\u064a\u0639 \u062d\u064a\u0648\u064a\u0629 <a href=\"https://www.alyaum.com/articles/6655870/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%82%D8%B7%D8%A7%D8%B9-%D8%A7%D9%84%D9%85%D9%8A%D8%A7%D9%87-%D9%8A%D8%AA%D8%AC%D8%A7%D9%88%D8%B2-%D9%85%D8%B3%D8%AA%D9%87%D8%AF%D9%81-%D8%A7%D9%84%D9%85%D8%AD%D8%AA%D9%88%D9%89-%D8%A7%D9%84%D9%85%D8%AD%D9%84%D9%8A-%D9%85%D8%B3%D8%AC%D9%84%D8%A7-6610-%D8%A8%D9%86%D9%87%D8%A7%D9%8A%D8%A9-2025\" target=\"_blank\">\u0628\u0642\u0637\u0627\u0639 \u0627\u0644\u0645\u064a\u0627\u0647</a> \u0641\u064a \u0645\u062f\u064a\u0646\u0629 <a href=\"https://www.alyaum.com/articles/6656177/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AA%D8%B3%D8%AA%D9%87%D8%AF%D9%81-553-%D8%A3%D9%84%D9%81%D8%A7-%D8%AD%D9%85%D9%84%D8%A9-%D9%84%D9%85%D9%83%D8%A7%D9%81%D8%AD%D8%A9-%D8%A7%D9%84%D9%85%D9%84%D8%A7%D8%B1%D9%8A%D8%A7-%D9%81%D9%8A-%D9%85%D8%AE%D9%8A%D9%85%D8%A7%D8%AA-%D8%A7%D9%84%D9%86%D8%A7%D8%B2%D8%AD%D9%8A%D9%86-%D8%A8%D8%B9%D8%AF%D9%86-%D9%88%D9%85%D8%A3%D8%B1%D8%A8\" target=\"_blank\">\u0645\u0627\u0654\u0631\u0628</a>\u060c \u0628\u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0645\u0639 \u0627\u0644\u0645\u0646\u0638\u0645\u0629 \u0627\u0644\u062f\u0648\u0644\u064a\u0629 \u0644\u0644\u0647\u062c\u0631\u0629\u060c \u0636\u0645\u0646 \u0628\u0631\u0646\u0627\u0645\u062c \u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0648\u0635\u0648\u0644 \u0627\u0655\u0644\u0649 \u0627\u0655\u0645\u062f\u0627\u062f\u0627\u062a \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u064a\u0627\u0647 \u0627\u0644\u0627\u0653\u0645\u0646\u0629 \u0648\u0627\u0644\u0646\u0638\u064a\u0641\u0629 \u0628\u0627\u0644\u064a\u0645\u0646.<br />\u0648\u062a\u062a\u0648\u0632\u0639 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0639\u0644\u0649 3 \u0642\u0637\u0627\u0639\u0627\u062a \u0631\u064a\u0654\u064a\u0633\u0629\u060c \u0627\u0644\u0627\u0654\u0648\u0644 \u062a\u0648\u0633\u0639\u0629 \u0645\u0634\u0631\u0648\u0639 \u0645\u064a\u0627\u0647 \u0627\u0644\u0633\u0648\u064a\u062f\u0627\u0621 \u0634\u0645\u0627\u0644 \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0628\u062d\u0641\u0631 \u0628\u064a\u0654\u0631 \u062c\u062f\u064a\u062f\u0629 \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \"\u0627\u0644\u0645\u064a\u0644\"\u060c \u0648\u0627\u0655\u0646\u0634\u0627\u0621 \u062e\u0632\u0627\u0646 \u062e\u0631\u0633\u0627\u0646\u064a \u0627\u0654\u0631\u0636\u064a \u0628\u0633\u0639\u0629 500 \u0645\u062a\u063