0654\u0646 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0627\u062a \u0645\u0639 \u0627\u0644\u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629 \u062a\u062c\u0631\u064a \u0639\u0644\u0649 \u0646\u062d\u0648 \u062c\u064a\u062f \u062c\u062f\u064b\u0627.<br />\u0648\u062c\u0627\u0621 \u0641\u064a \u0645\u0646\u0634\u0648\u0631 \u0644\u062a\u0631\u0627\u0645\u0628 \u0639\u0644\u0649 \u0645\u0646\u0635\u062a\u0647 \u062a\u0631\u0648\u062b \u0633\u0648\u0634\u0627\u0644 \u064a\u0648\u0645 \u0627\u0644\u062e\u0645\u064a\u0633: \"\u062a\u0644\u0628\u064a\u0629 \u0644\u0645\u0637\u0644\u0628 \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629\u060c \u064a\u0631\u062c\u0649 \u0627\u0639\u062a\u0628\u0627\u0631 \u0647\u0630\u0627 \u0627\u0644\u0628\u064a\u0627\u0646 \u0627\u0655\u0639\u0644\u0627\u0646\u064b\u0627 \u0645\u0641\u0627\u062f\u0647 \u0627\u0654\u0646\u0646\u064a \u0627\u0654\u0645\u062f\u0651\u062f \u0645\u0647\u0644\u0629 \u0627\u0646\u0642\u0636\u0627\u0621 \u0627\u0644\u0627\u0655\u0646\u0630\u0627\u0631 \u0628\u062a\u062f\u0645\u064a\u0631 \u0645\u062d\u0637\u0627\u062a \u0627\u0644\u0637\u0627\u0642\u0629 10 \u0627\u0654\u064a\u0627\u0645\u060c \u0648\u0630\u0644\u0643 \u062d\u062a\u0649 \u0627\u0644\u0627\u062b\u0646\u064a\u0646 6 \u0627\u0654\u0628\u0631\u064a\u0644 2026 \u0627\u0644\u0633\u0627\u0639\u0629 8 \u0645\u0633\u0627\u0621 \u0628\u062a\u0648\u0642\u064a\u062a \u0627\u0644\u0633\u0627\u062d\u0644 \u0627\u0644\u0634\u0631\u0642\u064a \u0644\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629\".<br />\u0648\u0627\u0654\u0636\u0627\u0641: \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0627\u062a \u062a\u062c\u0631\u064a \u0639\u0644\u0649 \u0646\u062d\u0648 \u062c\u064a\u0651\u062f \u062e\u0644\u0627\u0641\u064b\u0627 \u0644\u0645\u0627 \u062a\u0648\u0631\u062f\u0647 \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0655\u0639\u0644\u0627\u0645 \u0627\u0644\u0627\u0654\u062e\u0628\u0627\u0631 \u0627\u0644\u0643\u0627\u0630\u0628\u0629 \u0648\u063a\u064a\u0631\u0647\u0627 \u0645\u0646 \u0627\u0644\u062c\u0647\u0627\u062a.<h2>\u0627\u0644\u062d\u0631\u0628 \u0645\u062a\u0642\u062f\u0645\u0629 \u0639\u0646 \u062c\u062f\u0648\u0644\u0647\u0627 \u0627\u0644\u0632\u0645\u0646\u064a</h2><p>\u0648\u0641\u064a \u0648\u0642\u062a \u0633\u0627\u0628\u0642 \u0642\u0627\u0644 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a <a href=\"https://www.alyaum.com/articles/6652302/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D8%A7%D9%84%D9%85%D9%81%D8%A7%D9%88%D8%B6%D8%A7%D8%AA-%D8%AC%D8%A7%D8%B1%D9%8A%D8%A9-%D9%85%D8%B9-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%84%D9%83%D9%86%D9%87%D9%85-%D9%8A%D8%AE%D8%B4%D9%88%D9%86-%D8%A7%D9%84%D9%82%D8%AA%D9%84-%D8%B9%D9%84%D9%89-%D8%A3%D9%8A%D8%AF%D9%8A-%D8%B4%D8%B9%D8%A8%D9%87%D9%85\" target=\"_blank\">\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u0628</a> \u0627\u0644\u062e\u0645\u064a\u0633 \u0627\u0655\u0646 <a href=\"https://www.alyaum.com/articles/6652442/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D9%86%D8%AA%D8%B8%D8%B1-%D8%A7%D9%84%D8%B1%D8%AF-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%82%D8%AF%D9%85%D8%AA-%D9%84%D9%84%D9%88%D8%B3%D8%B7%D8%A7%D8%A1-%D8%B1%D8%AF%D9%87%D8%A7-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D9%85%D9%82%D8%AA%D8%B1%D8%AD-%D8%A7%D9%84%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D9%8A-%D9%84%D8%A5%D9%86%D9%87%D8%A7%D8%A1-%D8%A7%D9%84%D8%AD%D8%B1%D8%A8\" target=\"_blank\">\u0627\u0644\u062d\u0631\u0628</a> \u0639\u0644\u0649 <a href=\"https://www.alyaum.com/articles/6652386/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%8A%D8%AD%D8%B6-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%AA%D8%B9%D8%A7%D9%85%D9%84-%D8%A8%D8%A