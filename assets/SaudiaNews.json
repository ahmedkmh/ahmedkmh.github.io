{"status": "success", "totalResults": 3569, "results": [{"article_id": "c465476c74eb95e2f787ef61b8245dea", "link": "https://menafn.com/1111033236/Three-Killed-Two-Injured-as-Ukraine-Strikes-Luhansk", "title": "Three Killed, Two Injured as Ukraine Strikes Luhansk", "description": "(MENAFN) Three civilians were killed and two others injured after Ukrainian drones pounded the Luhansk region overnight, Leonid Pasechnik, the Moscow-appointed head of the region, announced ...", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "english", "country": ["saudi arabia", "syria", "qatar", "kuwait", "turkey", "united arab emirates", "lebanon", "bahrain", "egypt", "iraq", "iran", "jordan", "israel"], "category": ["politics"], "datatype": "news", "pubDate": "2026-04-26 07:52:19", "pubDateTZ": "UTC", "fetched_at": "2026-04-26 14:36:15", "image_url": "https://menafn.com/updates/pr/Menafn_News_Images/local_politics_1042.jpg", "video_url": null, "source_id": "menafn", "source_name": "Menafn", "source_priority": 28392, "source_url": "https://menafn.com", "source_icon": "https://n.bytvi.com/menafn.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "08fc793337fe7345d0a869a7b25b9fd0", "link": "https://www.okaz.com.sa/variety/na/2245847", "title": "\u0630\u0647\u0628 \u0644\u064a\u062d\u0645\u064a\u0647 \u0645\u0646 \u0627\u0644\u0635\u064a\u0627\u062f\u064a\u0646 \u0641\u0642\u062a\u0644\u0647.. \u00ab\u0648\u062d\u064a\u062f \u0627\u0644\u0642\u0631\u0646\u00bb \u064a\u0637\u0639\u0646 \u062d\u0627\u0631\u0633\u0647 \u062d\u062a\u0649 \u0627\u0644\u0645\u0648\u062a", "description": "\u0641\u064a \u0645\u062d\u0645\u064a\u0629 \u00ab\u0633\u0627\u0647\u0627\u0631\u0627 \u0643\u0627\u0631\u0648\u00bb \u0628\u062c\u0646\u0648\u0628 \u0627\u0654\u0641\u0631\u064a\u0642\u064a\u0627\u060c \u0644\u0645 \u064a\u0643\u0646 \u0641\u062c\u0631 \u064a\u0648\u0645 \u0627\u0644\u062c\u0645\u0639\u0629 \u064a\u0646\u0630\u0631 \u0628\u0643\u0627\u0631\u062b\u0629. \u0634\u0648\u0645\u0627\u0646 \u0641\u0627\u0646 \u064a\u0627\u0631\u0633\u0641\u064a\u0644\u062f (58 \u0639\u0627\u0645\u0627\u064b)\u060c \u0627\u0644\u0631\u062c\u0644 \u0627\u0644\u0630\u064a \u0643\u0631\u0651\u0633 \u062d\u064a\u0627\u062a\u0647 \u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0641\u0635\u0627\u064a\u0654\u0644 \u0627\u0644\u0645\u0647\u062f\u062f\u0629 \u0628\u0627\u0644\u0627\u0646\u0642\u0631\u0627\u0636 \u0645\u0646 \u0628\u0637\u0634 \u0627\u0644\u0635\u064a\u0627\u062f\u064a\u0646 \u0627\u0644\u062c\u0627\u064a\u0654\u0631\u064a\u0646\u060c \u0627\u0646\u0637\u0644\u0642 \u0641\u064a \u062f\u0648\u0631\u064a\u062a\u0647 \u0627\u0644\u0635\u0628\u0627\u062d\u064a\u0629 \u0627\u0644\u0645\u0639\u062a\u0627\u062f\u0629. \u0643\u0627\u0646 \u064a\u062d\u0645\u0644 \u062c\u0647\u0627\u0632 \u062a\u062a\u0628\u0639 (GPS) \u0644\u0645\u0631\u0627\u0642\u0628\u0629 \u0648\u062d\u064a\u062f \u0642\u0631\u0646 \u0627\u0654\u0633\u0648\u062f \u0646\u0627\u062f\u0631\u060c \u0627\u0653\u0645\u0644\u0627\u064b \u0627\u0654\u0646 \u064a\u0636\u0645\u0646 \u0644\u0647 \u064a\u0648\u0645\u0627\u064b \u0627\u0653\u062e\u0631 \u0645\u0646 \u0627\u0644\u0627\u0654\u0645\u0627\u0646. \u0644\u0643\u0646 \u0641\u064a \u0644\u062d\u0638\u0629 \u062e\u0627\u0637\u0641\u0629\u060c \u0627\u0646\u0642\u0644\u0628\u062a \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0644\u064a\u062c\u062f \u00ab\u0627\u0644\u062d\u0627\u0645\u064a\u00bb \u0646\u0641\u0633\u0647 \u0636\u062d\u064a\u0629 \u0644\u0644\u062d\u064a\u0648\u0627\u0646 \u0627\u0644\u0630\u064a \u0646\u0630\u0631 \u062d\u064a\u0627\u062a\u0647 \u0644\u0627\u0655\u0646\u0642\u0627\u0630\u0647.\u0628\u064a\u0646\u0645\u0627 \u0643\u0627\u0646 \u0634\u0648\u0645\u0627\u0646 \u064a\u062a\u062a\u0628\u0639 \u062d\u0631\u0643\u0629 \u0627\u0644\u062d\u064a\u0648\u0627\u0646\u060c \u0627\u0646\u062f\u0641\u0639 \u0648\u062d\u064a\u062f \u0627\u0644\u0642\u0631\u0646 \u0627\u0644\u0630\u064a \u064a\u0632\u0646 1,300 \u0643\u064a\u0644\u0648\u063a\u0631\u0627\u0645 \u0645\u0646 \u0628\u064a\u0646 \u0627\u0644\u0627\u0654\u0634\u062c\u0627\u0631 \u0643\u0627\u0644\u0627\u0655\u0639\u0635\u0627\u0631. \u0644\u0645 \u064a\u0643\u0646 \u0647\u0646\u0627\u0643 \u0645\u062a\u0633\u0639 \u0645\u0646 \u0627\u0644\u0648\u0642\u062a \u0644\u0644\u0647\u0631\u0648\u0628 \u0627\u0654\u0648 \u062d\u062a\u0649 \u0627\u0644\u062a\u0641\u0627\u0639\u0644. \u0648\u0628\u0642\u0631\u0646\u064a\u0647 \u0627\u0644\u0644\u0630\u064a\u0646 \u064a\u0634\u0628\u0647\u0627\u0646 \u0627\u0644\u0631\u0645\u0627\u062d\u060c \u0648\u062c\u0651\u0647 \u0627\u0644\u062d\u064a\u0648\u0627\u0646 \u0637\u0639\u0646\u0629 \u0627\u062e\u062a\u0631\u0642\u062a \u062c\u0633\u062f \u00ab\u0634\u0648\u0645\u0627\u0646\u00bb \u0641\u064a \u062b\u0648\u0627\u0646\u064d \u0645\u0639\u062f\u0648\u062f\u0629. \u0648\u0639\u0644\u0649 \u0627\u0644\u0631\u063a\u0645 \u0645\u0646 \u0635\u0631\u0627\u062e \u0627\u0654\u0639\u0636\u0627\u0621 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0630\u064a \u062f\u0641\u0639 \u0627\u0644\u062d\u064a\u0648\u0627\u0646 \u0644\u0644\u062a\u0631\u0627\u062c\u0639 \u0641\u0648\u0631\u0627\u064b\u060c \u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u0627\u0644\u0636\u0631\u0631 \u0643\u0627\u0646 \u0642\u062f \u0648\u0642\u0639\u060c \u0627\u0655\u0630 \u0644\u0641\u0638 \u0634\u0648\u0645\u0627\u0646 \u0627\u0654\u0646\u0641\u0627\u0633\u0647 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0641\u064a \u062a\u0645\u0627\u0645 \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u064010:30 \u0635\u0628\u0627\u062d\u0627\u064b\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u062a\u0635\u0644 \u0641\u0631\u0642 \u0627\u0644\u0627\u0655\u0633\u0639\u0627\u0641.\u0634\u0648\u0645\u0627\u0646 \u0644\u0645 \u064a\u0643\u0646 \u0645\u062c\u0631\u062f \u0645\u0648\u0638\u0641 \u0641\u064a \u0627\u0644\u0645\u062d\u0645\u064a\u0629\u060c \u0628\u0644 \u0643\u0627\u0646 \u0645\u0648\u0654\u0633\u0633 \u0634\u0631\u0643\u0629 \u0627\u0654\u0645\u0646\u064a\u0629 \u0645\u0633\u0644\u062d\u0629 \u0645\u0643\u0631\u0633\u0629 \u0644\u0645\u0637\u0627\u0631\u062f\u0629 \u0639\u0635\u0627\u0628\u0627\u062a \u0627\u0644\u0635\u064a\u062f \u0627\u0644\u062c\u0627\u064a\u0654\u0631 \u0627\u0644\u062a\u064a \u062a\u062a\u0631\u0628\u062d \u0645\u0646 \u062a\u062c\u0627\u0631\u0629 \u0642\u0631\u0648\u0646 \u0648\u062d\u064a\u062f \u0627\u0644\u0642\u0631\u0646\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u064f\u0639\u062f \u0627\u0654\u062b\u0645\u0646 \u0645\u0646 \u0627\u0644\u0630\u0647\u0628 \u0648\u0627\u0644\u0643\u0648\u0643\u0627\u064a\u064a\u0646 \u0641\u064a \u0627\u0644\u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0644\u0633\u0648\u062f\u0627\u0621. \u0632\u0645\u0644\u0627\u0648\u0654\u0647 \u064a\u0635\u0641\u0648\u0646\u0647 \u0628\u0627\u0654\u0646\u0647 \u00ab\u0645\u062d\u062a\u0631\u0641 \u062a\u0641\u0627\u0646\u0649 \u062d\u062a\u0649 \u0627\u0644\u0631\u0645\u0642 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u00bb. \u0641\u0642\u062f \u0643\u0627\u0646 \u064a\u0642\u0636\u064a \u0644\u064a\u0627\u0644\u064a\u0647 \u0648\u0627\u0654\u064a\u0627\u0645\u0647 \u064a\u0637\u0627\u0631\u062f \u0627\u0644\u0645\u062c\u0631\u0645\u064a\u0646 \u0641\u064a \u0627\u0654\u062f\u063a\u0627\u0644 \u00ab\u062c\u0631\u0627\u0641 \u0631\u064a\u0646\u064a\u062a\u00bb\u060c \u0644\u064a\u0635\u0628\u062d \u0631\u062d\u064a\u0644\u0647 \u0635\u062f\u0645\u0629 \u0644\u0645\u062c\u062a\u0645\u0639 \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u064a\u0646 \u0639\u0644\u0649 \u0627\u0644\u0628\u064a\u064a\u0654\u0629\u060c \u0644\u0627 \u06