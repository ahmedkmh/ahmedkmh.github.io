%D8%B1%D9%8A-%D8%A8%D8%A7%D9%84%D8%AE%D8%B1%D8%AC\" target=\"_blank\">\u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0645\u0634\u0647\u062f \u0627\u0644\u062d\u0636\u0631\u064a </a>\u0644\u062a\u0639\u0632\u064a\u0632 \u062c\u0648\u062f\u0629 \u0627\u0644\u062d\u064a\u0627\u0629 \u0641\u064a \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629 \u0627\u0654\u0646 \u0627\u0644\u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0627\u0654\u062b\u0645\u0631\u062a \u0639\u0646 \u0635\u064a\u0627\u0646\u0629 \u0645\u0633\u0637\u062d\u0627\u062a \u062e\u0636\u0631\u0627\u0621 \u062a\u062c\u0627\u0648\u0632\u062a \u0645\u0633\u0627\u062d\u062a\u0647\u0627 1,3 \u0645\u0644\u064a\u0648\u0646 \u0645\u062a\u0631 \u0645\u0631\u0628\u0639\u060c \u0641\u0636\u0644\u0627\u064b \u0639\u0646 \u0632\u0631\u0627\u0639\u0629 73,097 \u0634\u062c\u0631\u0629 \u0648\u0632\u0647\u0631\u0629 \u0644\u062a\u0639\u0632\u064a\u0632 <a href=\"https://www.alyaum.com/articles/6652395/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A3%D8%AE%D8%B6%D8%B1-%D9%8A%D9%84%D9%8A%D9%82-%D8%A8%D9%85%D9%83%D8%A9-%D8%AD%D9%85%D9%84%D8%A9-%D8%AA%D8%B4%D8%AC%D9%8A%D8%B1-%D9%83%D8%A8%D8%B1%D9%89-%D9%84%D8%AA%D8%B9%D8%B2%D9%8A%D8%B2-%D8%A7%D9%84%D8%BA%D8%B7%D8%A7%D8%A1-%D8%A7%D9%84%D9%86%D8%A8%D8%A7%D8%AA%D9%8A-%D8%A8%D8%A7%D9%84%D9%85%D9%86%D8%B7%D9%82%D8%A9\" target=\"_blank\">\u0627\u0644\u063a\u0637\u0627\u0621 \u0627\u0644\u0646\u0628\u0627\u062a\u064a</a>.<br /><br /> <h2>\u0627\u0654\u0639\u0645\u0627\u0644 \u0645\u064a\u062f\u0627\u0646\u064a\u0629</h2><br />\u0628\u064a\u0651\u0646\u062a \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u0634\u0645\u0644\u062a \u0627\u0655\u0635\u0644\u0627\u062d 780 \u0645\u062a\u0631\u0627\u064b \u0645\u0631\u0628\u0639\u0627\u064b \u0645\u0646 \u062d\u0641\u0631 \u0627\u0644\u0634\u0648\u0627\u0631\u0639\u060c \u0648\u062a\u0646\u0641\u064a\u0630 \u062f\u0647\u0627\u0646\u0627\u062a \u0644\u0644\u0627\u0654\u0631\u0635\u0641\u0629 \u0628\u0637\u0648\u0644 1,440 \u0645\u062a\u0631\u0627\u064b\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0635\u064a\u0627\u0646\u0629 \u0648\u0627\u0655\u0635\u0644\u0627\u062d 2,305 \u0627\u0654\u0639\u0645\u062f\u0629 \u0627\u0655\u0646\u0627\u0631\u0629 \u0644\u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u0629 \u0627\u0644\u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629.<br /><br />\u0648\u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0645\u062e\u062a\u0635\u0629 \u0627\u0655\u0644\u0649 \u0627\u0655\u0632\u0627\u0644\u0629 410 \u0627\u0654\u0645\u062a\u0627\u0631 \u0645\u0631\u0628\u0639\u0629 \u0645\u0646 \u0627\u0644\u0643\u062a\u0627\u0628\u0627\u062a \u0627\u0644\u0645\u0634\u0648\u0647\u0629\u060c \u0648\u0631\u0641\u0639 \u0645\u062e\u0644\u0641\u0627\u062a \u0628\u0646\u0627\u0621 \u0648\u0647\u062f\u0645 \u0646\u0627\u0647\u0632\u062a 14,521 \u0645\u062a\u0631\u0627\u064b \u0645\u0643\u0639\u0628\u0627\u064b\u060c \u0645\u0639 \u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0654\u0648\u0636\u0627\u0639 2,490 \u062d\u0627\u0648\u064a\u0629 \u0646\u0641\u0627\u064a\u0627\u062a \u062f\u0627\u062e\u0644 \u0627\u0644\u0627\u0654\u062d\u064a\u0627\u0621.<br /><br />\u0648\u0644\u0641\u062a\u062a \u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u0627\u0655\u0644\u0649 \u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u062a\u0634\u0648\u0647 \u0627\u0644\u0628\u0635\u0631\u064a \u0628\u0627\u0655\u0632\u0627\u0644\u0629 311 \u0645\u0646 \u0627\u0644\u062a\u062d\u0648\u064a\u0644\u0627\u062a \u0648\u0627\u0644\u062d\u0648\u0627\u062c\u0632 \u0627\u0644\u062e\u0631\u0633\u0627\u0646\u064a\u0629\u060c \u0648\u0627\u0655\u0633\u0642\u0627\u0637 \u0644\u0648\u062d\u062a\u064a\u0646 \u0627\u0655\u0639\u0644\u0627\u0646\u064a\u062a\u064a\u0646 \u0645\u062e\u0627\u0644\u0641\u062a\u064a\u0646\u060c \u0648\u062a\u0641\u0643\u064a\u0643 \u0645\u0648\u0642\u0639 \u0639\u0634\u0648\u0627\u064a\u0654\u064a \u0645\u062a\u0643\u0627\u0645\u0644 \u0644\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0627\u0646\u0636\u0628\u0627\u0637 \u0627\u0644\u0645\u0643\u0627\u0646\u064a.<br /><br /> <h2>\u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a</h2><br />\u0627\u0654\u0636\u0627\u0641\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629 \u0627\u0654\u0646\u0647\u0627 \u0627\u0654\u0647\u0644\u062a 5,459 \u0645\u0646 \u0645\u0644\u0627\u0639\u0628 \u0627\u0644\u0627\u0654\u0637\u0641\u0627\u0644 \u0644\u0631\u0641\u0639 \u062c\u0627\u0647\u0632\u064a\u062a\u0647\u0627\u060c \u0641\u064a\u0645\u0627 \u0646\u0641\u0630\u062a 4,655 \u062c\u0648\u0644\u0629 \u0631\u0642\u0627\u0628\u064a\u0629 \u0627\u0654\u0633\u0641\u0631\u062a \u0639\u0646 \u0627\u0655\u0635\u062f\u0627\u0631 12,856 \u0634\u0647\u0627\u062f\u0629 \u0635\u062d\u064a\u0629 \u0644\u0636\u0645\u0627\u0646 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a\u0629 \u0648\u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629.<br /><br />\u0648\u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0633\u064a\u0627\u0642\u060c \u0627\u0654\u0643\u062f \u0631\u064a\u0654\u064a\u0633 \u0628\u0644\u062f\u064a\u0629 \u0645\u062d\u0627\u0641\u0638\u0629 \u0627\u0644\u0642\u0637\u064a\u0641\u060c \u0627\u0644\u0645\u0647\u0646\u062f\u0633 \u0635\u0627\u0644\u062d \u0627\u0644\u0642\u0631\u0646\u064a\u060c \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u0645\u0643\u062a\u0633\u0628\u0627\u062a \u062a\u0627\u0654\u062a\u064a \u062b\u0645\u0631\u0629 \u0644\u0646\u0647\u062c \u062a\u0634\u063a\u064a\u0644\u064a \u064a\u0631\u062a\u0643\u0632 