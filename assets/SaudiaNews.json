4%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B6%D8%A8%D8%B7-%D9%85%D8%AE%D8%A7%D9%84%D9%81-%D9%84%D9%86%D8%B8%D8%A7%D9%85-%D8%A7%D9%84%D8%A8%D9%8A%D8%A6%D8%A9-%D8%A8%D8%A7%D9%84%D8%B1%D8%B9%D9%8A-%D9%81%D9%8A-%D9%85%D8%AD%D9%85%D9%8A%D8%A9-%D8%A7%D9%84%D9%85%D9%84%D9%83-%D8%B9%D8%A8%D8%AF%D8%A7%D9%84%D8%B9%D8%B2%D9%8A%D8%B2-%D8%A7%D9%84%D9%85%D9%84%D9%83%D9%8A%D8%A9\">\u0645\u062d\u0645\u064a\u0629 \u0627\u0644\u0645\u0644\u0643 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632</a> \u0627\u0644\u0645\u0644\u0643\u064a\u0629\u060c \u0648\u0637\u0628\u0651\u0642\u062a \u0628\u062d\u0642\u0647 \u0627\u0644\u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0646\u0638\u0627\u0645\u064a\u0629.<br /><br />\u0648\u0627\u0654\u0643\u062f\u062a \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0654\u0646 \u0639\u0642\u0648\u0628\u0629 \u0631\u0639\u064a \u0627\u0644\u0627\u0655\u0628\u0644 \u063a\u0631\u0627\u0645\u0629 (500) \u0631\u064a\u0627\u0644 \u0644\u0643\u0644 \u0645\u062a\u0646.<div data-oembed-url=\"https://x.com/SFES_KSA/status/2073407919358398944\"><blockquote align=\"center\" class=\"twitter-tweet\" data-dnt=\"true\"><p dir=\"rtl\" lang=\"ar\"><a href=\"https://x.com/hashtag/%D8%A7%D9%84%D8%A3%D9%85%D9%86_%D8%A7%D9%84%D8%A8%D9%8A%D8%A6%D9%8A?src=hash&ref_src=twsrc%5Etfw\">#\u0627\u0644\u0627\u0654\u0645\u0646_\u0627\u0644\u0628\u064a\u064a\u0654\u064a</a> \u064a\u0636\u0628\u0637 \u0645\u0648\u0627\u0637\u0646\u064b\u0627 \u0645\u062e\u0627\u0644\u0641\u064b\u0627 \u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0628\u064a\u064a\u0654\u0629 \u0644\u0627\u0631\u062a\u0643\u0627\u0628\u0647 \u0645\u062e\u0627\u0644\u0641\u0629 \u0631\u0639\u064a \u0641\u064a \u0645\u062d\u0645\u064a\u0629 \u0627\u0644\u0645\u0644\u0643 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0644\u0645\u0644\u0643\u064a\u0629. <a href=\"https://t.co/97jgBa0Th0\">pic.twitter.com/97jgBa0Th0</a></p>\u2014 \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u062e\u0627\u0635\u0629 \u0644\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u0628\u064a\u064a\u0654\u064a (@SFES_KSA) <a href=\"https://x.com/SFES_KSA/status/2073407919358398944?ref_src=twsrc%5Etfw\">July 4, 2026</a></blockquote> </div><h2>\u0645\u062e\u0627\u0644\u0641\u0629 \u0627\u0644\u062a\u062e\u064a\u064a\u0645 \u0641\u064a \u0639\u0633\u064a\u0631</h2>\u0643\u0645\u0627 \u0636\u0628\u0637\u062a \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u062e\u0627\u0635\u0629 \u0644\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u0628\u064a\u064a\u0654\u064a \u0645\u0648\u0627\u0637\u0646\u064b\u0627 \u0645\u062e\u0627\u0644\u0641\u064b\u0627 \u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0628\u064a\u064a\u0654\u0629\u060c \u0644\u0627\u0631\u062a\u0643\u0627\u0628\u0647 \u0645\u062e\u0627\u0644\u0641\u0629 \u0627\u0644\u062a\u062e\u064a\u064a\u0645 \u062f\u0648\u0646 \u062a\u0631\u062e\u064a\u0635 \u0641\u064a \u0645\u0646\u0637\u0642\u0629 <a href=\"https://www.alyaum.com/articles/6670517/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B9%D8%B3%D9%8A%D8%B1-%D8%B6%D8%A8%D8%B7-%D9%85%D8%AE%D8%A7%D9%84%D9%81-%D9%84%D9%84%D8%A8%D9%8A%D8%A6%D8%A9-%D8%A8%D8%A5%D8%B4%D8%B9%D8%A7%D9%84-%D8%A7%D9%84%D9%86%D8%A7%D8%B1-%D9%81%D9%8A-%D8%A7%D9%84%D8%A3%D9%85%D8%A7%D9%83%D9%86-%D8%BA%D9%8A%D8%B1-%D8%A7%D9%84%D9%85%D8%AE%D8%B5%D8%B5%D8%A9-%D9%84%D9%87%D8%A7\">\u0639\u0633\u064a\u0631</a>\u060c \u0648\u0637\u0628\u0651\u0642\u062a \u0628\u062d\u0642\u0647 \u0627\u0644\u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0646\u0638\u0627\u0645\u064a\u0629.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0654\u0646 \u0639\u0642\u0648\u0628\u0629 \u0645\u062e\u0627\u0644\u0641\u0629 \u0627\u0644\u062a\u062e\u064a\u064a\u0645 \u0641\u064a \u0627\u0644\u063a\u0627\u0628\u0627\u062a \u0627\u0654\u0648 \u0627\u0644\u0645\u062a\u0646\u0632\u0647\u0627\u062a \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u062f\u0648\u0646 \u062a\u0631\u062e\u064a\u0635 \u063a\u0631\u0627\u0645\u0629 \u062a\u0635\u0644 \u0627\u0655\u0644\u0649 (3,000) \u0631\u064a\u0627\u0644.<div data-oembed-url=\"https://x.com/SFES_KSA/status/2073400180083130788\"><blockquote align=\"center\" class=\"twitter-tweet\" data-dnt=\"true\"><p dir=\"rtl\" lang=\"ar\"><a href=\"https://x.com/hashtag/%D8%A7%D9%84%D8%A3%D9%85%D9%86_%D8%A7%D9%84%D8%A8%D9%8A%D8%A6%D9%8A?src=hash&ref_src=twsrc%5Etfw\">#\u0627\u0644\u0627\u0654\u0645\u0646_\u0627\u0644\u0628\u064a\u064a\u0654\u064a</a> \u064a\u0636\u0628\u0637 \u0645\u0648\u0627\u0637\u0646\u064b\u0627 \u0645\u062e\u0627\u0644\u0641\u064b\u0627 \u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0628\u064a\u064a\u0654\u0629 \u0644\u0627\u0631\u062a\u0643\u0627\u0628\u0647 \u0645\u062e\u0627\u0644\u0641\u0629 \u0627\u0644\u062a\u062e\u064a\u064a\u0645 \u062f\u0648\u0646 \u062a\u0631\u062e\u064a\u0635 \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u0639\u0633\u064a\u0631. <a href=\"https://t.co/YJMSC0qzWt\">pic.twitter.com/YJMSC0qzWt</a></p>\u2014 \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u062e\u0627\u0635\u0629 \u0644\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u0628\u064a\u064a\u0654\u064a (@SFES_KSA) <a href=\"https://x.com/SFES_KSA/status/2073400180083130788?ref_src=twsrc%5Etfw\">July 4, 2026</a></blockquote> </div><br />\u0648\u062d\u062b\u062a \u0639\u0644\u0649 \u0627\u0644\u0627\u0655\u0628\u0644\u0627\u063a \u0639\u0646 \u0627\u0654\u064a \u062d\u0627\u0644\u0627\u062a \u062a\u0645\u062b\u0644 \u0627\u0639\u062a\u062f\u0627\u0621\u064b \u0639\u0644\u0649 \u0627\u0644\u0628\u064a\u064a\u0654\u0629 \u0627\u0654\u0648 \u0627\u0644\u062d\u064a\u0627\u0629 \u0627\u0644\u0641\u0637\u0631\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0631\u0642\u0645 (911) \u0628\u0645\u0646\u0627\u0637\u0642 \u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629 \u0648\u0627\u0644\u0645\u0