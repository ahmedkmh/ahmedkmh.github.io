 \u0636\u062f \u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0627\u062a \u0627\u0644\u0645\u0633\u064a\u0631\u0629.\u0648\u0627\u0654\u0641\u0627\u062f \u0628\u0627\u0654\u0646 \u062e\u0628\u0631\u0627\u0621 \u0627\u0654\u0648\u0643\u0631\u0627\u0646\u064a\u064a\u0646 \u0641\u064a \u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0627\u062a \u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0629 \u0633\u064a\u0635\u0644\u0648\u0646 \u0627\u0655\u0644\u0649 \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637\u060c \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0627\u0644\u0642\u0627\u062f\u0645\u060c \u0644\u0644\u0645\u0633\u0627\u0639\u062f\u0629 \u0641\u064a \u0627\u0644\u062a\u0635\u062f\u064a \u0644\u0644\u0645\u0633\u064a\u0651\u0631\u0627\u062a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629\u060c \u0641\u064a\u0645\u0627 \u064a\u0627\u0654\u0645\u0644 \u0641\u064a \u0627\u0644\u062d\u0635\u0648\u0644 \u0628\u0627\u0644\u0645\u0642\u0627\u0628\u0644 \u0639\u0644\u0649 \u0635\u0648\u0627\u0631\u064a\u062e \u062f\u0641\u0627\u0639 \u062c\u0648\u064a \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0627\u0644\u0635\u0646\u0639.\u0648\u0627\u0654\u0636\u0627\u0641 \u0641\u064a \u0645\u0648\u0654\u062a\u0645\u0631 \u0635\u062d\u0641\u064a \u0628\u0639\u062f \u0627\u062c\u062a\u0645\u0627\u0639 \u0645\u0639 \u0636\u064a\u0641\u0647 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0647\u0648\u0644\u0646\u062f\u064a \u0631\u0648\u0628 \u064a\u062a\u0646: \u00ab\u0627\u0654\u0639\u062a\u0642\u062f \u0627\u0654\u0646\u0647 \u0641\u064a \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0627\u0644\u0642\u0627\u062f\u0645\u060c \u0639\u0646\u062f\u0645\u0627 \u064a\u0643\u0648\u0646 \u0627\u0644\u062e\u0628\u0631\u0627\u0621 \u0641\u064a \u0627\u0644\u0645\u0648\u0642\u0639\u060c \u0633\u064a\u0646\u0638\u0631\u0648\u0646 \u0641\u064a \u0627\u0644\u0648\u0636\u0639 \u0648\u064a\u0642\u062f\u0645\u0648\u0646 \