654\u0639\u0644\u0646 <a href=\"https://www.alyaum.com/articles/6665631/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AA%D9%86%D8%A8%D9%8A%D9%87-%D8%A8%D8%A7%D9%84%D8%A5%D9%86%D8%B0%D8%A7%D8%B1-%D8%A7%D9%84%D8%A3%D8%B5%D9%81%D8%B1-%D9%85%D9%88%D8%AC%D8%A9-%D8%AD%D8%A7%D8%B1%D8%A9-%D8%AA%D8%B6%D8%B1%D8%A8-4-%D9%85%D8%AD%D8%A7%D9%81%D8%B8%D8%A7%D8%AA-%D9%81%D9%8A-%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9\">\u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0644\u0627\u0654\u0631\u0635\u0627\u062f</a>\u060c \u062a\u0641\u0627\u0635\u064a\u0644 \u062d\u0627\u0644\u0629 \u0627\u0644\u0637\u0642\u0633 \u0627\u0644\u0645\u062a\u0648\u0642\u0639\u0629 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u062d\u062f \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629\u060c \u0645\u0646\u0628\u0647\u0627 \u0645\u0646 \u0627\u0631\u062a\u0641\u0627\u0639 \u0641\u064a \u062f\u0631\u062c\u0627\u062a \u0627\u0644\u062d\u0631\u0627\u0631\u0629\u060c \u0648\u0647\u0637\u0648\u0644 \u0627\u0654\u0645\u0637\u0627\u0631 \u0631\u0639\u062f\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0639\u062f\u064a\u062f \u0645\u0646 \u0627\u0644\u0645\u0646\u0627\u0637\u0642.<br /><br />\u062d\u0633\u0628 \u0628\u064a\u0627\u0646 <a href=\"https://www.alyaum.com/articles/6665494/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A3%D8%AD%D8%B3%D8%A7%D8%A1-%D8%A7%D9%84%D8%A3%D8%B9%D9%84%D9%89-%D8%A847-%D9%85%D8%A6%D9%88%D9%8A%D8%A9-%D8%A8%D9%8A%D8%A7%D9%86%D8%AF%D8%B1%D8%AC%D8%A7%D8%AA-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9\">\u0627\u0644\u0627\u0654\u0631\u0635\u0627\u062f</a>\u061b \u062a\u062a\u0627\u0654\u062b\u0631 \u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u