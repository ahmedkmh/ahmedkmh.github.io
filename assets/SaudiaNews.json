D8%A7%D9%86-%D8%AA%D9%86%D8%B9%D8%B4-%D8%A7%D9%84%D9%85%D8%B9%D8%A7%D8%AF%D9%86-%D8%A7%D9%84%D8%B0%D9%87%D8%A8-%D9%8A%D8%B3%D8%AA%D9%82%D8%B1-%D9%82%D8%B1%D8%A8-4800-%D8%AF%D9%88%D9%84%D8%A7%D8%B1-%D9%88%D8%A7%D9%84%D9%81%D8%B6%D8%A9-%D8%AA%D9%82%D9%81%D8%B2-6", "title": "\u0647\u062f\u0646\u0629 \u0627\u0655\u064a\u0631\u0627\u0646 \u062a\u0646\u0639\u0634 \u0627\u0644\u0645\u0639\u0627\u062f\u0646.. \u0627\u0644\u0630\u0647\u0628 \u064a\u0633\u062a\u0642\u0631 \u0642\u0631\u0628 4800 \u062f\u0648\u0644\u0627\u0631 \u0648\u0627\u0644\u0641\u0636\u0629 \u062a\u0642\u0641\u0632 6%", "description": "\u0627\u0633\u062a\u0642\u0631\u062a \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0630\u0647\u0628\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u0642\u0631\u0628 \u0627\u0654\u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0644\u0647\u0627 \u0645\u0646\u0630 \u0646\u062d\u0648 3 \u0627\u0654\u0633\u0627\u0628\u064a\u0639\u060c \u0648\u0633\u0637 \u0627\u0646\u062e\u0641\u0627\u0636 \u062d\u0627\u062f \u0641\u064a \u0627\u0654\u0633\u0639\u0627\u0631 <a href=\"https://www.alyaum.com/articles/6654960/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D8%A7%D9%84%D8%B7%D8%A7%D9%82%D8%A9/%D8%AD%D8%AF%D8%AB-%D9%86%D8%A7%D8%AF%D8%B1-%D9%81%D9%8A-%D8%B3%D9%88%D9%82-%D8%A7%D9%84%D9%86%D9%81%D8%B7-%D9%83%D9%8A%D9%81-%D9%8A%D8%AA%D8%AF%D8%A7%D9%88%D9%84-%D8%A7%D9%84%D8%AE%D8%A7%D9%85-%D8%A7%D9%84%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D9%8A-%D8%A8%D8%B3%D8%B9%D8%B1-%D8%A3%D8%B9%D9%84%D9%89-%D9%85%D9%86-%D8%A8%D8%B1%D9%86%D8%AA\" target=\"_blank\">\u0627\u0644\u0646\u0641\u0637 </a>\u0648\u0627\u0644\u062f\u0648\u0644\u0627\u0631 \u0628\u0639\u062f \u0627\u062a\u0641\u0627\u0642 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0648\u0627\u0655\u064a\u0631\u0627\u0646 \u0639\u0644\u0649 \u0648\u0642\u0641 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631 \u0644\u0645\u062f\u0629 \u0627\u0654\u0633\u0628\u0648\u0639\u064a\u0646.<br /><br />\u0648\u0628\u0644\u063a <a href=\"https://www.alyaum.com/articles/6654926/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A3%D8%B3%D8%B9%D8%A7%D8%B1-%D8%A7%D9%84%D8%B0%D9%87%D8%A8-%D9%81%D9%8A-%D9%85%D8%B5%D8%B1-%D8%A7%D9%84%D9%8A%D9%88%D9%85-%D8%A7%D9%84%D8%A3%D8%B1%D8%A8%D8%B9%D8%A7%D8%A1-%D8%A7%D8%B1%D8%AA%D9%81%D8%A7%D8%B9-%D8%AC%D8%AF%D9%8A%D8%AF-%D9%81%D9%8A-%D8%A7%D9%84%D8%A3%D8%B3%D9%88%D8%A7%D9%82\" target=\"_blank\">\u0633\u0639\u0631 \u0627\u0644\u0630\u0647\u0628</a> \u0641\u064a \u0627\u0644\u0645\u0639\u0627\u0645\u0644\u0627\u062a \u0627\u0644\u0641\u0648\u0631\u064a\u0629 4795.28 \u062f\u0648\u0644\u0627\u0631 \u0644\u0644\u0627\u0654\u0648\u0642\u064a\u0629\u060c \u0628\u062d\u0644\u0648\u0644 \u0627\u0644\u0633\u0627\u0639\u0629 11:23 \u0628\u062a\u0648\u0642\u064a\u062a \u062c\u0631\u064a\u0646\u062a\u0634\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0631\u062a\u0641\u0639 \u0628\u0627\u0654\u0643\u062b\u0631 \u0645\u0646 3% \u0641\u064a \u0648\u0642\u062a \u0633\u0627\u0628\u0642 \u0645\u0646 \u0627\u0644\u062c\u0644\u0633\u0629 \u0644\u064a\u0633\u062c\u0644 \u0627\u0654\u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0644\u0647 \u0645\u0646\u0630 19 \u0645\u0627\u0631\u0633 \u0627\u0644\u0645\u0627\u0636\u064a.<br /><br />\u0648\u0641\u064a \u0633\u064a\u0627\u0642 \u0645\u062a\u0635\u0644\u060c \u0635\u0639\u062f\u062a \u0627\u0644\u0639\u0642\u0648\u062f \u0627\u0644\u0627\u0653\u062c\u0644\u0629 \u0644\u0644\u0630\u0647\u0628 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a (\u062a\u0633\u0644\u064a\u0645 \u064a\u0648\u0646\u064a\u0648) \u0628\u0646\u0633\u0628\u0629 3% \u0644\u062a\u0635\u0644 \u0627\u0655\u0644\u0649 4822.70 \u062f\u0648\u0644\u0627\u0631 \u0644\u0644\u0627\u0654\u0648\u0642\u064a\u0629.<br /><br />\u0648\u0641\u064a <a href=\"https://www.alyaum.com/articles/6654923/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85-%D9%8A%D8%AA%D9%86%D9%81%D8%B3-%D8%A7%D9%84%D8%B5%D8%B9%D8%AF%D8%A7%D8%A1-%D8%AA%D8%AD%D8%B1%D9%83%D8%A7%D8%AA-%D8%AD%D8%A7%D8%AF%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%A3%D8%B3%D9%88%D8%A7%D9%82-%D8%A8%D8%B9%D8%AF-%D8%A5%D8%B9%D9%84%D8%A7%D9%86-%D8%A7%D9%84%D9%87%D8%AF%D9%86%D8%A9-%D9%81%D9%8A-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86\" target=\"_blank\">\u0627\u0644\u0645\u0639\u0627\u062f\u0646 \u0627\u0644\u0646\u0641\u064a\u0633\u0629</a> \u0627\u0644\u0627\u0654\u062e\u0631\u0649\u060c \u0642\u0641\u0632 \u0633\u0639\u0631 \u0627\u0644\u0641\u0636\u0629 \u0627\u0644\u0641\u0648\u0631\u064a \u0628\u0646\u0633\u0628\u0629 5.9% \u0627\u0655\u0644\u0649 77.22 \u062f\u0648\u0644\u0627\u0631 \u0644\u0644\u0627\u0654\u0648\u0642\u064a\u0629\u060c \u0648\u0627\u0631\u062a\u0641\u0639 \u0633\u0639\u0631 \u0627\u0644\u0628\u0644\u0627\u062a\u064a\u0646 \u0628\u0646\u0633\u0628\u0629 5.4% \u0644\u064a\u0635\u0644 \u0627\u0655\u0644\u0649 2063.50 \u062f\u0648\u0644\u0627\u0631\u060c \u0648\u0642\u0641\u0632 \u0633\u0639\u0631 \u0627\u0644\u0628\u0644\u0627\u062f\u064a\u0648\u0645 \u0628\u0646\u0633\u0628\u0629 8.3% \u0644\u064a\u0635\u0644 \u0627\u0655\u0644\u0649 1592.40 \u062f\u0648\u0644\u0627\u0631.<br /><br />\u0627\u0646\u062e\u0641\u0636 \u0633\u0639\u0631 \u0627\u0644\u0630\u0647\u0628 \u0628\u0646\u0633\u0628\u0629 10% \u0645\u0646\u0630 \u0627\u0654\u0646 \u0634\u0646\u062a \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0648\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0647\u062c\u0645\u0627\u062a \u0639\u0644\u0649 \u0627\u0655\u064a\u0631\u0627\u0646 \u0641\u064a 28 \u0641\u0628\u0631\u0627\u064a\u0631. \u0648\u0631\u063a\u0645 \u0627\u0654\u0646 \u0627\u0644\u0645\u0639\u062f\u0646 \u064a\u064f\u0646\u0638\u0631 \u0627\u0655\u0644\u064a\u0647 \u0643\u0627\u0654\u062f\u0627\u0629 \u0644\u0644\u062a\u062d\u0648\u0637 \u0636\u062f \u0627\u0644\u062a\u0636\u062e\u0645\u060c \u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0641\u0627\u064a\u0654\u062f\u0629 \u064a\u064f\u0648\u0654\u062b\u0631 \u0633\u0644\u0628\u064b\u0627 \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0627\u0654\u0635\u0644 \u0627\u0644\u0630\u064a \u0644\u0627 \u064a\u064f\u062f\u0631\u0651 \u0639\u0627\u064a\u0654\u062f\u064b\u0627.<br /><br />\u0648\u064a\u0636\u0639 \u0627\u0644\u0645\u0633\u062a\u062b\u0645\u0631\u0648\u0646 \u062d\u0627\u0644\u064a\u064b\u0627 \u0627\u062d\u062a\u0645\u0627\u0644\u064b\u0627 \u0628\u0646\u0633\u0628\u0629 43% \u0644\u062e\u0641\u0636 \u0633\u0639\u0631 \u0627\u0644\u0641\u0627\u064a\u0654\u062f\u0629 \u0645\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0642\u0644 \u0628\u062d\u0644\u0648\u0644 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u060c \u0645\u0642\u0627\u0631\u0646\u0629\u064b \u0628\u0646\u0633\u0628\u0629 14% \u0641\u064a \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u0627\u0654\u062f\u0627\u0629 FedWatch \u0627\u0644\u062a\u0627\u0628\u0639\u0629 \u0644\u0628\u0648\u0631\u0635\u0629 \u0634\u064a\u0643\u0627\u063a\u0648 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629.<br /><br />\u0643\u0645\u0627 \u064a\u0646\u062a\u0638\u0631 \u0627\u0644\u0645\u062a\u062f\u0627\u0648\u0644\u0646 \u0645\u062d\u0636\u0631 \u0627\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u0633\u064a\u0627\u0633\u0629 \u0627\u0644\u0646\u0642\u062f\u064a\u0629 \u0644\u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062d\u062a\u064a\u0627\u0637\u064a \u0627\u0644\u0641\u064a\u062f\u0631\u0627\u0644\u064a \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u0644\u0634\u0647\u0631 \u0645\u0627\u0631\u0633\u060c \u0648\u0627\u0644\u0630\u064a \u0633\u064a\u0635\u062f\u06