64a \u0627\u0644\u062e\u0644\u064a\u062c \u0627\u0644\u0644\u0642\u0628 \u0631\u0633\u0645\u064a\u064b\u0627 \u0642\u0628\u0644 \u0627\u0644\u0646\u0647\u0627\u064a\u0629 \u0628\u0639\u062f\u0629 \u062c\u0648\u0644\u0627\u062a\u060c \u0645\u0642\u062f\u0645\u064b\u0627 \u0648\u0627\u062d\u062f\u064b\u0627 \u0645\u0646 \u0627\u0654\u0642\u0648\u0649 \u0627\u0644\u0645\u0648\u0627\u0633\u0645 \u0641\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629.<br /><br /><strong>\u0627\u0644\u062e\u0644\u064a\u062c \u0628\u0637\u0644\u064b\u0627 \u0639\u0646 \u062c\u062f\u0627\u0631\u0629.. \u0645\u0648\u0633\u0645 \u0627\u0644\u0643\u0645\u0627\u0644 \u064a\u0643\u062a\u0645\u0644</strong><br /><br />\u064a\u062f\u062e\u0644 \u0646\u0627\u062f\u064a \u0627\u0644\u062e\u0644\u064a\u062c \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062e\u062a\u0627\u0645\u064a\u0629 \u0648\u0647\u0648 \u0645\u062a\u0631\u0628\u0639 \u0639\u0644\u0649 \u0627\u0644\u0635\u062f\u0627\u0631\u0629 \u0628\u0627\u0644\u0639\u0644\u0627\u0645\u0629 \u0627\u0644\u0643\u0627\u0645\u0644\u0629 (38 \u0646\u0642\u0637\u0629 \u0645\u0646 19 \u0641\u0648\u0632\u064b\u0627)\u060c \u0641\u064a \u0645\u0634\u0647\u062f \u064a\u0639\u0643\u0633 \u0627\u0644\u0647\u064a\u0645\u0646\u0629 \u0627\u0644\u0645\u0637\u0644\u0642\u0629 \u0644\u0644\u0641\u0631\u064a\u0642 \u0637\u0648\u0627\u0644 \u0627\u0644\u0645\u0648\u0633\u0645\u060c \u0633\u0648\u0627\u0621 \u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0646\u062a\u0627\u064a\u0654\u062c \u0627\u0654\u0648 \u0627\u0644\u0627\u0654\u0631\u0642\u0627\u0645 \u0627\u0644\u0647\u062c\u0648\u0645\u064a\u0629 \u0648\u0627\u0644\u062f\u0641\u0627\u0639\u064a\u0629\u060c \u062d\u064a\u062b \u0633\u062c\u0644 611 \u0647\u062f\u0641\u064b\u0627 \u0648\u0627\u0633\u062a\u0642\u0628\u0644 413 \u0641\u0642\u0637\u060c \u0628\u0641\u0627\u0631\u0642 \u062a\u0647\u062f\u064a\u0641\u064a \u0636\u062e\u0645 \u0628\u0644\u063a +198.<br /><br />\u062a\u062a\u062c\u0647 \u0627\u0644\u0627\u0654\u0646\u0638\u0627\u0631 \u0627\u0655\u0644\u0649 \u0635\u0627\u0644\u0629 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u0629 \u0628\u0627\u0644\u062f\u0645\u0627\u0645\u060c \u062d\u064a\u062b \u064a\u0648\u0627\u062c\u0647 \u0627\u0644\u062e\u0644\u064a\u062c \u0646\u0638\u064a\u0631\u0647 \u0645\u0636\u0631 \u0641\u064a \u0644\u0642\u0627\u0621 \u0633\u064a\u0643\u0648\u0646 \u0627\u0654\u0642\u0631\u0628 \u0627\u0655\u0644\u0649 \u201c\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062a\u062a\u0648\u064a\u062c\u201d\u060c \u0627\u0655\u0630 \u0645\u0646 \u0627\u0644\u0645\u0646\u062a\u0638\u0631 \u0627\u0654\u0646 \u064a\u062d\u062a\u0641\u0644 \u0627\u0644\u0641\u0631\u064a\u0642 \u0628\u0627\u0644\u0644\u0642\u0628 \u0648\u0633\u0637 \u062c\u0645\u0627\u0647\u064a\u0631\u0647\u060c \u0641\u064a \u062e\u062a\u0627\u0645 \u0645\u0648\u0633\u0645 \u062a\u0627\u0631\u064a\u062e\u064a \u0628\u0644\u0627 \u0627\u0654\u064a \u062e\u0633\u0627\u0631\u0629.<br /><br /><strong>\u0645\u0636\u0631 \u0648\u0627\u0644\u0646\u0648\u0631.. \u0635\u0631\u0627\u0639 \u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0645\u0631\u0627\u0643\u0632</strong><br /><br />\u064a\u062d\u062a\u0644 \u0645\u0636\u0631 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0631\u0627\u0628\u0639 \u0628\u064026 \u0646\u0642\u0637\u0629\u060c \u0648\u064a\u0635\u0637\u062f\u0645 \u0628\u0627\u0644\u0628\u0637\u0644 \u0627\u0644\u062e\u0644\u064a\u062c \u0641\u064a \u0627\u062e\u062a\u0628\u0627\u0631 \u0635\u0639\u0628\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0633\u0639\u0649 \u0627\u0644\u0646\u0648\u0631 (23 \u0646\u0642\u0637\u0629) \u0644\u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0641\u0648\u0632 \u0639\u0644\u0649 \u0627\u0644\u0648\u062d\u062f\u0629 \u0645\u0646 \u0627\u0654\u062c\u0644 \u062a\u062b\u0628\u064a\u062a \u0645\u0648\u0642\u0639\u0647 \u0641\u064a \u0627\u0644\u0645\u0631\u0628\u0639 \u0627\u0644\u0630\u0647\u0628\u064a \u0627\u0654\u0648 \u0627\u0644\u062a\u0642\u062f\u0645 \u062e\u0637\u0648\u0629 \u0627\u0655\u0636\u0627\u0641\u064a\u0629 \u0641\u064a \u0633\u0644\u0645 \u0627\u0644\u062a\u0631\u062a\u064a\u0628.<br /><br /><strong>\u0645\u0639\u0631\u0643\u0629 \u0627\u0644\u0642\u0627\u0639.. \u062d\u0633\u0627\u0628\u0627\u062a \u0627\u0644\u0628\u0642\u0627\u0621 \u0648\u0627\u0644\u0643\u0631\u0627\u0645\u0629</strong><br /><br />\u0641\u064a \u0627\u0654\u0633\u0641\u0644 \u0627\u0644\u062c\u062f\u0648\u0644\u060c \u062a\u062a\u0648\u0627\u0635\u0644 \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0627\u062a \u0628\u064a\u0646 \u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u062a\u064a \u0639\u0627\u0646\u062a \u0637\u0648\u0627\u0644 \u0627\u0644\u0645\u0648\u0633\u0645\u060c \u062d\u064a\u062b \u064a\u0644\u062a\u0642\u064a \u0627\u0644\u0639\u062f\u0627\u0644\u0629 \u0645\u0639 \u0627\u0644\u0645\u062d\u064a\u0637 \u0641\u064a \u0635\u0627\u0644\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0639\u0628\u062f\u0627\u0644\u0644\u0647 \u0628\u0646 \u062c\u0644\u0648\u064a \u0628\u0627\u0644\u0627\u0654\u062d\u0633\u0627\u0621\u060c \u0641\u064a \u0645\u0648\u0627\u062c\u0647\u0629 \u0644\u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0635\u0648\u0631\u0629 \u0642\u0628\u0644 \u0627\u0655\u0633\u062f\u0627\u0644 \u0627\u0644\u0633\u062a\u0627\u0631.<br /><br />\u0643\u0645\u0627 \u064a\u0633\u062a\u0636\u064a\u0641 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0646\u0638\u064a\u0631\u0647 \u0627\u0644\u0641\u062a\u062d\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0635\u0637\u062f\u0645 \u0627\u0644\u0648\u062d\u062f\u0629 \u0628\u0627\u0644\u0646\u0648\u0631\u060c \u0641\u064a \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u062a\u062d\u0645\u0644 \u0637\u0627\u0628\u0639\u064b\u0627 \u0645\u0639\u0646\u0648\u064a\u064b\u0627 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0643\u0648\u0646\u0647\u0627 \u0645\u0648\u0654\u062b\u0631\u0629 \u0641\u064a \u0645\u0635\u064a\u0631 \u0627\u0644\u0644\u0642\u0628.<br /><br /><strong>\u0645\u0628\u0627\u0631\u064a\u0627\u062a</strong><br />\u0627\u0644\u062c\u0648\u0644\u0629 22 (\u0627\u0644\u062e\u062a\u0627\u0645\u064a\u0629)<br />\u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0645\u0645\u062a\u0627\u0632 \u0644\u0643\u0631\u0629 \u0627\u0644\u064a\u062f<br /><br />\u0627\u0644\u0635\u0641\u0627 \u00d7 \u0627\u0644\u0647\u062f\u0649 \u2014 \u0635\u0627\u0644\u0629 \u0646\u0627\u062f\u064a \u0627\u0644\u0635\u0641\u0627 (4:00 \u0645)<br />\u0627\u0644\u0646\u0648\u0631 \u00d7 \u0627\u0644\u0648\u062d\u062f\u0629 \u2014 \u0635\u0627\u0644\u0629 \u0646\u0627\u062f\u064a \u0627\u0644\u0646\u0648\u0631 (4:00 \u0645)<br />\u0627\u0644\u0639\u062f\u0627\u0644\u0629 \u00d7 \u0627\u0644\u0645\u062d\u064a\u0637 \u2014 \u0635\u0627\u0644\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0639\u0628\u062f\u0627\u0644\u0644\u0647 \u0628\u0646 \u062c\u0644\u0648\u064a \u0628\u0627\u0644\u0627\u0654\u062d\u0633\u0627\u0621 (4:00 \u0645)<br />\u0627\u0644\u062e\u0644\u064a\u062c \u00d7 \u0645\u0636\u0631 \u2014 \u0635\u0627\u0644\u0629 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u0629 \u0628\u0627\u0644\u062f\u0645\u0627\u0645 (4:00 \u0645)<br />\u0627\u0644\u0627\u0654\u0647\u0644\u064a \u00d7 \u0627\u0644\u0641\u062a\u062d \u2014 \u0635\u0627\u0644\u0629 \u0646\u0627\u062f\u064a \u0627\u0644\u0627\u0654\u0647\u0644\u064a (4:00 \u0645)<br /><br /><br /><strong>\u062a\u0631\u062a\u064a\u0628 \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0627\u0644\u0645\u0645\u062a\u0627\u0632 \u0644\u0643\u0631\u0629 \u0627\u0644\u064a\u062f: </strong><br /><br />1. \u0627\u0644\u062e\u0644\u064a\u062c \u2014 38 \u0646\u0642\u0637\u0629<br />2. \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u2014 32 \u0646\u0642\u0637\u0629<br />3. \u0627\u0644\u0647\u062f\u0649 \u2014 27 \u0646\u0642\u0637\u0629<br />4. \u0645\u0636\u0631 \u20