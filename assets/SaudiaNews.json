\u0627\u0644\u0631\u064a\u0627\u0636.<br /><br />\u0648\u0642\u062f\u0645 \u0627\u0644\u0646\u0635\u0631 \u0645\u0634\u0648\u0627\u0631\u064b\u0627 \u0645\u062b\u0627\u0644\u064a\u064b\u0627 \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629\u060c \u0628\u062f\u0627\u0654\u0647 \u0628\u0642\u0648\u0629 \u0641\u064a \u062f\u0648\u0631 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a\u060c \u062d\u064a\u062b \u0627\u0641\u062a\u062a\u062d \u0645\u0646\u0627\u0641\u0633\u0627\u062a\u0647 \u0628\u0641\u0648\u0632 \u0643\u0628\u064a\u0631 \u0639\u0644\u0649 \u0627\u0633\u062a\u0642\u0644\u0627\u0644 \u062f\u0648\u0634\u0646\u0628\u0647 (5-0)\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u062a\u063a\u0644\u0628 \u0639\u0644\u0649 \u0627\u0644\u0632\u0648\u0631\u0627\u0621 (2-0) \u0648\u063a\u0648\u0627 (2-1)\u060c \u062b\u0645 \u0643\u0631\u0631 \u062a\u0641\u0648\u0642\u0647 \u0639\u0644\u0649 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0647\u0646\u062f\u064a (4-0)\u060c \u0648\u0639\u0627\u062f \u0644\u064a\u0647\u0632\u0645 \u0627\u0633\u062a\u0642\u0644\u0627\u0644 (4-0)\u060c \u0648\u0627\u062e\u062a\u062a\u0645 \u0627\u0644\u062f\u0648\u0631 \u0628\u0627\u0646\u062a\u0635\u0627\u0631 \u0639\u0631\u064a\u0636 \u0639\u0644\u0649 \u0627\u0644\u0632\u0648\u0631\u0627\u0621 (5-1).<br /><br />\u0648\u0641\u064a \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0627\u0644\u0627\u0655\u0642\u0635\u0627\u064a\u0654\u064a\u0629\u060c \u0648\u0627\u0635\u0644 \u0627\u0644\u0641\u0631\u064a\u0642 \u062a\u0627\u0654\u0644\u0642\u0647\u060c \u0627\u0655\u0630 \u062a\u062c\u0627\u0648\u0632 \u0639\u0642\u0628\u0629 \u0627\u0654\u0631\u0643\u0627\u062f\u0627\u063a \u0641\u064a \u062f\u0648\u0631 \u0627\u0644\u064016 \u0628\u0641\u0648\u0632\u064a\u0646 \u0645\u062a\u062a\u0627\u0644\u064a\u064a\u0646 (1-0) \u0630\u0647\u0627\u0628\u064b\u0627 \u0648\u0627\u0655\u064a\u0627\u0628\u064b\u0627\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0643\u062a\u0633\u062d \u0627\u0644\u0648\u0635\u0644 (4-0) \u0641\u064a \u0631\u0628\u0639 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u0648\u064a\u0648\u0654\u0643\u062f \u0642\u0648\u062a\u0647 \u0627\u0644\u0647\u062c\u0648\u0645\u064a\u0629 \u0641\u064a \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0628\u062e\u0645\u0627\u0633\u064a\u0629 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0627\u0654\u0647\u0644\u064a.<br /><br />\u0648\u062a\u0639\u0643\u0633 \u0627\u0654\u0631\u0642\u0627\u0645 \u0627\u0644\u0646\u0635\u0631 \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u062d\u062c\u0645 \u0627\u0644\u062a\u0641\u0648\u0642 \u0627\u0644\u0630\u064a \u0642\u062f\u0645\u0647\u060c \u062d\u064a\u062b \u062e\u0627\u0636 10 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u062d\u0642\u0642 \u062e\u0644\u0627\u0644\u0647\u0627 \u0627\u0644\u0639\u0644\u0627\u0645\u0629 \u0627\u0644\u0643\u0627\u0645\u0644\u0629 \u0628\u064010 \u0627\u0646\u062a\u0635\u0627\u0631\u0627\u062a\u060c \u0645\u0633\u062c\u0644\u064b\u0627 33 \u0647\u062f\u0641\u064b\u0627 \u0645\u0642\u0627\u0628\u0644 \u0627\u0633\u062a\u0642\u0628\u0627\u0644 3 \u0627\u0654\u0647\u062f\u0627\u0641 \u0641\u0642\u0637\u060c \u0644\u064a\u062c\u0645\u0639 \u0628\u064a\u0646 \u0627\u0644\u0642\u0648\u0629 \u0627\u0644\u0647\u062c\u0648\u0645\u064a\u0629 \u0648\u0627\u0644\u0635\u0644\u0627\u0628\u0629 \u0627\u0644\u062f\u0641\u0627\u0639\u064a\u0629 \u062f\u0648\u0646 \u0627\u0654\u064a \u062e\u0633\u0627\u0631\u0629.<br /><br />\u0648\u0628\u0627\u062a \u0627\u0644\u0646\u0635\u0631 \u0639\u0644\u0649 \u0628\u0639\u062f \u062e\u0637\u0648\u0629 \u0648\u0627\u062d\u062f\u0629 \u0645\u0646 \u0627\u0644\u062a\u062a\u0648\u064a\u062c\u060c \u0641\u064a \u0638\u0644 \u0633\u0639\u064a\u0647 \u0644\u0645\u0648\u0627\u0635\u0644\u0629 \u0633\u0644\u0633\u0644\u0629 \u0627\u0646\u062a\u0635\u0627\u0631\u0627\u062a\u0647 \u0648\u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0644\u0642\u0628 \u0627\