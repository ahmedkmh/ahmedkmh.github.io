1-%D8%A7%D9%84%D8%AD%D8%B5%D8%A7%D8%B1-%D8%A7%D9%84%D8%A8%D8%AD%D8%B1%D9%8A\" target=\"_blank\">\u0627\u0644\u062d\u0635\u0627\u0631</a> \u0627\u0644\u0628\u062d\u0631\u064a \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0627\u0646\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629.<br />\u0648\u0646\u0642\u0644\u062a \u0642\u0646\u0627\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0639\u0628\u0631 \u062d\u0633\u0627\u0628\u0647\u0627 \u0639\u0644\u0649 \u062a\u0637\u0628\u064a\u0642 \u0627\u0655\u0643\u0633 \u0639\u0646 <a href=\"https://www.alyaum.com/articles/6656124/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A7%D9%84%D8%AC%D9%8A%D8%B4-%D8%A7%D9%84%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D9%8A-%D9%8A%D8%B9%D9%84%D9%86-%D9%85%D9%86%D8%B9-6-%D8%B3%D9%81%D9%86-%D9%85%D9%86-%D9%85%D8%BA%D8%A7%D8%AF%D8%B1%D8%A9-%D9%85%D9%88%D8%A7%D9%86%D8%A6-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9\" target=\"_blank\">\u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a</a> \u0627\u0654\u0646\u0647 \u0644\u0645 \u062a\u062a\u0645\u0643\u0646 \u0627\u0654\u064a \u0633\u0641\u064a\u0646\u0629 \u0645\u0646 \u0627\u062e\u062a\u0631\u0627\u0642 \u0627\u0644\u062d\u0635\u0627\u0631.<br />\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646 \u0633\u0641\u064a\u0646\u0629 \u062a\u0631\u0641\u0639 \u0639\u0644\u0645 <a href=\"https://www.alyaum.com/articles/6656311/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D8%AA%D8%B3%D8%AA%D9%82%D8%A8%D9%84-%D9%88%D9%81%D8%AF%D8%A7-%D8%A8%D8%A7%D9%83%D8%B3%D8%AA%D8%A7%D9%86%D9%8A%D8%A7-%D8%A8%D8%B1%D8%A6%D8%A7%D8%B3%D8%A9-%D9%82%D8%A7%D8%A6%D8%AF-%D8%A7%D9%84%D8%AC%D9%8A%D8%B4\" target=\"_blank\">\u0627\u0655\u064a\u0631\u0627\u0646</a> \u062d\u0627\u0648\u0644\u062a \u0627\u0644\u0627\u0644\u062a\u0641\u0627\u0641 \u0639\u0644\u0649 \u0627\u0644\u062d\u0635\u0627\u0631 \u0628\u0639\u062f \u0645\u063a\u0627\u062f\u0631\u0629 \u0628\u0646\u062f\u0631 \u0639\u0628\u0627\u0633\u060c \u0644\u0643\u0646\u0647 \u0646\u062c\u062d \u0641\u064a \u062a\u063a\u064a\u064a\u0631 \u0645\u0633\u0627\u0631\u0647\u0627.<h2>\u062a\u0647\u062f\u064a\u062f\u0627\u062a \u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629</h2><p>\u0647\u062f\u062f\u062a <a href=\"https://www.alyaum.com/articles/6656285/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D8%A7%D9%84%D8%B5%D9%8A%D9%86-%D9%88%D8%A7%D9%81%D9%82%D8%AA-%D8%B9%D9%84%D9%89-%D8%B9%D8%AF%D9%85-%D8%AA%D8%B2%D9%88%D9%8A%D8%AF-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D8%A8%D8%A7%D9%84%D8%A3%D8%B3%D9%84%D8%AD%D8%A9\" target=\"_blank\">\u0627\u0655\u064a\u0631\u0627\u0646 </a>\u0628\u0641\u0631\u0636 \u062d\u0635\u0627\u0631 \u0628\u062d\u0631\u064a \u0639\u0644\u0649 \u0627\u0644\u0628\u062d\u0631 \u0627\u0644\u0627\u0654\u062d\u0645\u0631 \u0627\u0644\u0630\u064a \u0644\u0627 \u062a\u0645\u0644\u0643 \u062d\u062f\u0648\u062f\u0627 \u0645\u0628\u0627\u0634\u0631\u0629 \u0645\u0639\u0647\u060c \u0641\u064a \u062d\u0627\u0644 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062d\u0635\u0627\u0631 \u0627\u0644\u0645\u0641\u0631\u0648\u0636 \u0645\u0646 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0639\u0644\u0649 \u0645\u0648\u0627\u0646\u064a\u0654\u0647\u0627\u060c \u0648\u0627\u0644\u0630\u064a \u0642\u0627\u0644\u062a \u0637\u0647\u0631\u0627\u0646 \u0627\u0655\u0646\u0647 \u0642\u062f \u064a\u0648\u0654\u062f\u064a \u0644\u062e\u0631\u0642 <a href=\"https://www.alyaum.com/articles/6656172/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%81%D8%A7%D9%86%D8%B3-%D9%88%D9%82%D9%81-%D8%A5%D8%B7%D9%84%D8%A7%D9%82-%D8%A7%D9%84%D9%86%D8%A7%D8%B1-%D9%85%D8%B9-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%85%D8%AA%D9%85%D8%A7%D8%B3%D9%83-%D9%88%D8%A7%D9%84%D9%88%D8%B6%D8%B9-%D8%AC%D9%8A%D8%AF-%D8%AD%D8%A7%D9%84%D9%8A%D8%A7\" target=\"_blank\">\u0648\u0642\u0641 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631</a>.</p><p>\u0648\u0642\u0627\u0644 \u0642\u0627\u064a\u0654\u062f \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u0645\u0633\u0644\u062d\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0627\u0644\u062c\u0646\u0631\u0627\u0644 \u0639\u0644\u064a \u0639\u0628\u062f \u0627\u0644\u0644\u0647\u060c \u0627\u0655\u0646 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0641\u064a \u062d\u0635\u0627\u0631\u0647\u0627 \u0627\u0644\u0628\u062d\u0631\u064a \u0648\"\u062e\u0644\u0642 \u062d\u0627\u0644\u0629 \u0645\u0646 \u0639\u062f\u0645 \u0627\u0644\u064a\u0642\u064a\u0646 \u0628\u0634\u0627\u0654\u0646 \u0627\u0654\u0645\u0646 \u0627\u0644\u0633\u0641\u0646 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0648\u0646\u0627\u0642\u0644\u0627\u062a \u0627\u0644\u0646\u0641\u0637\"\u060c \u0633\u064a\u0634\u0643\u0644 \"\u0645\u0642\u062f\u0645\u0629\" \u0644\u062e\u0631\u0642 \u0648\u0642\u0641 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631 \u0627\u0644\u0633\u0627\u0631\u064a \u0645\u0646\u0630 8 \u0627\u0654\u0628\u0631\u064a\u0644.<br /> </p><div data-oembed-url=\"https://x.com/AlArabiya_Brk/status/2044515359022104862\"><blockquote align=\"center\" class=\"twitter-tweet\" data-dnt=\"true\"><p dir=\"rtl\" lang=\"ar\">\u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a: \u062a\u0645 \u062a\u063a\u064a\u064a\u0631 \u0645\u0633\u0627\u0631 10 \u0633\u0641\u0646 \u0645\u0646\u0630 \u0628\u062f\u0621 \u0627\u0644\u062d\u0635\u0627\u0631 <a href=\"https://twitter.com/hashtag/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8%D9%8A%D8%A9_%D8%B9%D8%A7%D8%AC%D9%84?src=hash&ref_src=twsrc%5Etfw\">#\u0627\u0644\u0639\u0631\u0628\u064a\u0629_\u0639\u0627\u062c\u0644</a><