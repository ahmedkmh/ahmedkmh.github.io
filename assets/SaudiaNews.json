a \u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0644\u0646\u0627\u062a\u062c\u0629 \u0639\u0646 <a href=\"https://www.alyaum.com/articles/6667631/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%B4%D9%87%D8%A7%D8%AF%D8%A9-%D8%A7%D9%84%D8%AB%D8%A7%D9%84%D8%AB%D8%A9-%D9%85%D9%86-%D8%BA%D9%8A%D9%86%D9%8A%D8%B3-%D8%A3%D9%85%D9%8A%D8%B1-%D8%A7%D9%84%D8%AC%D9%88%D9%81-%D9%8A%D8%AA%D8%B3%D9%84%D9%85-%D8%A3%D8%AD%D8%AF%D8%AB-%D8%A7%D9%84%D8%A5%D9%86%D8%AC%D8%A7%D8%B2%D8%A7%D8%AA-%D9%81%D9%8A-%D9%85%D9%83%D8%A7%D9%81%D8%AD%D8%A9-%D8%A7%D9%84%D8%AA%D8%B5%D8%AD%D8%B1\" target=\"_blank\">\u0627\u0644\u062a\u0635\u062d\u0631</a> \u0648<a href=\"https://www.alyaum.com/articles/6667642/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%AE%D8%AA%D8%B5%D9%88%D9%86-%D9%84%D8%A7%D9%84%D9%8A%D9%88%D9%85-%D8%B3%D9%88%D8%A1-%D8%A5%D8%AF%D8%A7%D8%B1%D8%A9-%D8%A7%D9%84%D8%A3%D8%B1%D8%B6-%D9%88%D8%A7%D9%84%D9%85%D9%8A%D8%A7%D9%87-%D9%85%D9%86-%D8%A3%D8%A8%D8%B1%D8%B2-%D8%A3%D8%B3%D8%A8%D8%A7%D8%A8-%D8%AA%D9%81%D8%A7%D9%82%D9%85-%D8%A7%D9%84%D8%AA%D8%B5%D8%AD%D8%B1-%D9%88%D8%A7%D9%84%D8%AC%D9%81%D8%A7%D9%81\" target=\"_blank\">\u0627\u0644\u062c\u0641\u0627\u0641</a> \u0648<a href=\"https://www.alyaum.com/articles/6652568/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%81%D9%8A-%D8%A5%D9%86%D8%AC%D8%A7%D8%B2-%D8%A8%D9%8A%D8%A6%D9%8A-%D9%86%D9%88%D8%B9%D9%8A-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%AA%D8%B9%D9%8A%D8%AF-%D8%AA%D8%A3%D9%87%D9%8A%D9%84-%D8%A3%D9%88%D9%84-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D9%87%D9%83%D8%AA%D8%A7%D8%B1-%D9%85%D9%86-%D8%A7%D9%84%D8%A3%D8%B1%D8%A7%D8%B6%D9%8A-%D8%A7%D9%84%D9%85%D8%AA%D8%AF%D9%87%D9%88%D8%B1%D8%A9-%D8%A8%D9%85%D8%A8%D8%A7%D8%AF%D8%B1%D8%A9-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%A7%D9%84%D8%AE%D8%B6%D8%B1%D8%A7%D8%A1\" target=\"_blank\">\u062a\u062f\u0647\u0648\u0631 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a</a>.<br />\u0648\u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0641\u064a \u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0648\u0627\u0644\u0645\u0631\u0627\u0639\u064a \u064a\u0633\u0647\u0645 \u0641\u064a \u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a \u0648\u0627\u0644\u0645\u0627\u064a\u0654\u064a\u060c \u0648\u062f\u0639\u0645 \u0627\u0644\u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u062f\u0627\u0645\u0629\u060c \u0648\u0628\u0646\u0627\u0621 \u0645\u062c\u062a\u0645\u0639\u0627\u062a \u0627\u0654\u0643\u062b\u0631 \u0642\u062f\u0631\u0629 \u0639\u0644\u0649 \u0627\u0644\u0635\u0645\u0648\u062f.<br />\u062c\u0627\u0621 \u0630\u0644\u0643 \u0641\u064a \u0628\u064a\u0627\u0646 \u0628\u0645\u0646\u0627\u0633\u0628\u0629 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0639\u0627\u0644\u0645\u064a \u0644\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u062a\u0635\u062d\u0631 \u0648\u0627\u0644\u062c\u0641\u0627\u0641\u060c \u0627\u0644\u0630\u064a \u064a\u0648\u0627\u0641\u0642 17 \u064a\u0648\u0646\u064a\u0648 \u0645\u0646 \u0643\u0644 \u0639\u0627\u0645\u060c \u0648\u064a\u0642\u0627\u0645 \u0647\u0630\u0627 \u0627\u0644\u0639\u0627\u0645 \u062a\u062d\u062a \u0634\u0639\u0627\u0631 \"\u0627\u0644\u0645\u0631\u0627\u0639\u064a: \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0641 \u0628\u0642\u064a\u0645\u062a\u0647\u0627\u060c \u0627\u062d\u062a\u0631\u0627\u0645\u0647\u0627\u060c \u0648\u0627\u0633\u062a\u0639\u0627\u062f\u062a\u0647\u0627\"\u060c \u062a\u0627\u0654\u0643\u064a\u062f\u064b\u0627 \u0644\u0644\u062f\u0648\u0631 \u0627\u0644\u062d\u064a\u0648\u064a \u0644\u0644\u0645\u0631\u0627\u0639\u064a \u0641\u064a \u062f\u0639\u0645 \u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a \u0648\u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0644\u062a\u0646\u0648\u0639 \u0627\u0644\u0628\u064a\u0648\u0644\u0648\u062c\u064a \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u062a\u0643\u064a\u0641 \u0645\u0639 \u0627\u0653\u062b\u0627\u0631 \u062a\u063a\u064a\u0631 \u0627\u0644\u0645\u0646\u0627\u062e \u0648\u0627\u0644\u062c\u0641\u0627\u0641.<h2>\u062a\u063a\u064a\u0631 \u0627\u0644\u0645\u0646\u0627\u062e \u0648\u0646\u062f\u0631\u0629 \u0627\u0644\u0645\u064a\u0627\u0647</h2>\u0648\u0627\u0654\u0648\u0636\u062d \u0627\u0644\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0645\u0633\u0627\u0639\u062f \u0631\u064a\u0654\u064a\u0633 \u0642\u0637\u0627\u0639 \u0627\u0644\u0634\u0648\u0654\u0648\u0646 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629 \u0628\u0627\u0644\u062c\u0627\u0645\u0639\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0641\u064a\u0631 \u062f. \u0639\u0644\u064a \u0628\u0646 \u0627\u0655\u0628\u0631\u0627\u0647\u064a\u0645 \u0627\u0644\u0645\u0627\u0644\u0643\u064a\u060c \u0627\u0654\u0646 \u0642\u0636\u0627\u064a\u0627 \u0627\u0644\u062a\u0635\u062d\u0631 \u0648\u0627\u0644\u062c\u0641\u0627\u0641 \u0648\u062a\u062f\u0647\u0648\u0631 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u062a\u0645\u062b\u0644 \u0627\u0654\u0648\u0644\u0648\u064a\u0629 \u0639\u0644\u0649 \u0627\u0654\u062c\u0646\u062f\u0629 \u0627\u0644\u062c\u0627\u0645\u0639\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629\u060c \u0641\u064a \u0638\u0644 \u0627\u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u0632\u0627\u064a\u062f\u0629 \u0627\u0644\u062a\u064a \u062a\u0648\u0627\u062c\u0647\u0647\u0627 \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0646\u062a\u064a\u062c\u0629 \u062a\u063a\u064a\u0631 \u0627\u0644\u0645\u0646\u0627\u062e \u0648\u0646\u062f\u0631\u0629 \u0627\u0644\u0645\u064a\u0627\u0647 \u0648\u062a\u062f\u0647\u0648\u0631 \u0627\u0644\u0646\u0638\u0645 \u0627\u0644\u0628\u064a\u064a\u0654\u064a\u0629 \u0648\u0627\u0646\u0639\u0643\u0627\u0633\u0627\u062a\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a \u0648\u0627\u0644\u0645\u0627\u064a\u0654\u064a.<br /> <br />\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0645\u0627\u0646\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0646\u0638\u0645\u062a \u0628\u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0645\u0639 \u0627\u0644\u0645\u0643\u062a\u0628 \u0627\u0644\u0627\u0655\u0642\u0644\u064a\u0645\u064a \u0644\u0645\u0646\u0638\u0645\u0629 \u0627\u0644\u0627\u0654\u063a\u0630\u064a\u0629 \u0648\u0627\u0644\u0632\u0631\u0627\u0639\u0629 \u0644\u0644\u0627\u0654\u0645\u0645 \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \"\u0627\u0644\u0641\u0627\u0648\"\u060c \u0646\u062f\u0648\u0629 \u0627\u0655\u0642\u0644\u064a\u0645\u064a\u0629 \u0627\u0641\u062a\u0631\u0627\u0636\u064a\u0629 \u0639\u0646 \u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0631\u0627\u0639\u064a \u0648\u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0644\u0645\u062a\u062f\u0647\u0648\u0631\u0629 \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0642\u062f\u0631\u0629 \u0639\u0644\u0649 \u0627\u0644\u0635\u0645\u0648\u062f \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u062c\u0641\u0627\u0641\u060c \u0648\u0630\u0644\u0643 \u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u0627\u0644\u062a\u062d\u0636\u064a\u0631 \u0644\u0644\u062f\u0648\u0631\u0629 \u0627\u0644\u0633\u0627\u0628\u0639\u0629 \u0639\u0634\u0631\u0629 \u0644\u0645\u0648\u0654\u062a\u0645\u0631 \u0627\u0654\u0637\u0631\u0627\u0641 \u0627\u062a\u0641\u0627\u0642\u064a\u0629 \u0627\u0644\u0627\u065