a\u0648\u0632\u064a\u0639 \u0627\u0654\u0631\u0628\u0627\u062d \u0648\u0632\u064a\u0627\u062f\u0629 \u0631\u0627\u0654\u0633 \u0627\u0644\u0645\u0627\u0644 50%", "description": "\u0627\u0654\u0648\u0635\u0649 \u0645\u062c\u0644\u0633 \u0627\u0655\u062f\u0627\u0631\u0629 \u0634\u0631\u0643\u0629 \u0645\u0635\u0627\u0639\u062f \u0627\u0654\u0637\u0644\u0633 \u0644\u0644\u062a\u062c\u0627\u0631\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0648\u0627\u0644\u0645\u0642\u0627\u0648\u0644\u0627\u062a\u060c \u0627\u0654\u0645\u0633\u060c \u0628\u062a\u0648\u0632\u064a\u0639 \u0627\u0654\u0631\u0628\u0627\u062d \u0646\u0642\u062f\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646 \u0639\u0646 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0645\u0627\u0644\u064a \u0627\u0644\u0645\u0646\u062a\u0647\u064a \u0641\u064a 31/12/2025\u0645,\u0648\u0642\u0627\u0644\u062a \u0627\u0644\u0634\u0631\u0643\u0629 \u0641\u064a \u0628\u064a\u0627\u0646 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\": \u0627\u0655\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0645\u0628\u0644\u063a \u0627\u0644\u0645\u0648\u0632\u0639 \u064a\u0642\u062f\u0631 \u0628\u06405.84 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0641\u064a\u0645\u0627 \u062a\u0628\u0644\u063a \u062d\u0635\u0629 \u0627\u0644\u0633\u0647\u0645 \u0645\u0646 \u0627\u0644\u062a\u0648\u0632\u064a\u0639 1 \u0631\u064a\u0627\u0644.\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0654\u0646 \u0628\u0639\u062f \u0645\u0648\u0627\u0641\u0642\u0629 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u062a\u0648\u0635\u064a\u0629 \u062a\u0643\u0648\u0646 \u0627\u0654\u062d\u0642\u064a\u0629 \u0627\u0644\u0627\u0654\u0631\u0628\u0627\u062d \u0644\u0645\u0633\u0627\u0647\u0645\u064a \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0627\u0644\u0643\u064a\u0646 \u0644\u0644\u0627\u0654\u0633\u0647\u0645 \u0628\u0646\u0647\u0627\u064a\u0629 \u062a\u062f\u0627\u0648\u0644 \u064a\u0648\u0645 \u0627\u0646\u0639\u0642\u0627\u062f \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u0634\u0631\u0643\u0629 \u0648\u0627\u0644\u0645\u0642\u064a\u062f\u064a\u0646 \u0628\u0633\u062c\u0644\u0627\u062a \u0627\u0644\u0634\u0631\u0643\u0629 \u0644\u062f\u0649 \u0634\u0631\u0643\u0629 \u0645\u0631\u0643\u0632 \u0627\u0655\u064a\u062f\u0627\u0639 \u0627\u0644\u0627\u0654\u0648\u0631\u0627\u0642 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 (\u0627\u0655\u064a\u062f\u0627\u0639) \u0628\u0646\u0647\u0627\u064a\u0629 \u062b\u0627\u0646\u064a \u064a\u0648\u0645 \u062a\u062f\u0627\u0648\u0644 \u064a\u0644\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0646\u0639\u0642\u0627\u062f \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0648\u0627\u0644\u062a\u064a \u0633\u064a\u0639\u0644\u0646 \u0639\u0646 \u0645\u0648\u0639\u062f \u0627\u0646\u0639\u0642\u0627\u062f\u0647\u0627 \u0644\u0627\u062d\u0642\u0627\u064b \u0628\u0639\u062f \u0627\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0627\u0641\u0642\u0627\u062a \u0627\u0644\u0631\u0633\u0645\u064a\u0629 \u0627\u0644\u0644\u0627\u0632\u0645\u0629\u060c \u0641\u064a\u0645\u0627 \u0633\u064a\u062d\u062f\u062f \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062a\u0648\u0632\u064a\u0639 \u0644\u0627\u062d\u0642\u0627.\u0632\u064a\u0627\u062f\u0629 \u0631\u0627\u0654\u0633 \u0645\u0627\u0644 \u0645\u0635\u0627\u0639\u062f \u0627\u0654\u0637\u0644\u0633\u0627\u0654\u0648\u0635\u0649 \u0645\u062c\u0644\u0633 \u0627\u0655\u062f\u0627\u0631\u0629 \u0634\u0631\u0643\u0629 \u0645\u0635\u0627\u0639\u062f \u0627\u0654\u0637\u0644\u0633 \u0644\u0644\u062a\u062c\u0627\u0631\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0648\u0627\u0644\u0645\u0642\u0627\u0648\u0644\u0627\u062a