u0627\u0644\u0644\u0647 \u0627\u0644\u062d\u0631\u0627\u0645\u060c \u0645\u0634\u064a\u0631\u0627\u064b \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0645\u0628\u0627\u062f\u0631\u0629 \u062d\u0642\u0642\u062a \u0627\u0655\u0646\u062c\u0627\u0632\u0627\u062a \u0646\u0648\u0639\u064a\u0629 \u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u062a\u0643\u0644\u0644\u062a \u0645\u0648\u0654\u062e\u0631\u0627\u064b \u0628\u0641\u0648\u0632\u0647\u0627 \u0628\u062c\u0627\u064a\u0654\u0632\u0629 \u00ab\u063a\u0627\u0632\u064a \u0627\u0644\u0642\u0635\u064a\u0628\u064a\u00bb \u0639\u0646 \u0645\u0633\u0627\u0631 \u0627\u0644\u062a\u0637\u0648\u0639.\u0648\u0627\u0654\u0648\u0636\u062d \u0627\u0644\u062d\u0631\u064a\u0642\u064a \u0627\u0654\u0646\u0647 \u0631\u0648\u0639\u064a \u062e\u0644\u0627\u0644 \u0648\u0631\u0634 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u062a\u0627\u0654\u0647\u064a\u0644\u064a\u0629\u060c \u0627\u0644\u062a\u0631\u0643\u064a\u0632 \u0639\u0644\u0649 \u0627\u0653\u0644\u064a\u0629 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a \u0648\u0627\u0644\u062a\u0643\u0627\u0645\u0644 \u0645\u0639 \u062d\u0645\u0644\u0629 (\u062d\u062c \u0628\u0635\u062d\u0629)\u060c \u0644\u0636\u0645\u0627\u0646 \u0627\u0633\u062a\u0645\u0631\u0627\u0631\u064a\u0629 \u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0648\u0642\u0627\u064a\u0654\u064a\u0629 \u0644\u0644\u062d\u062c\u0627\u062c \u0627\u0644\u0630\u064a\u0646 \u0628\u062f\u0627\u0654\u062a \u0631\u062d\u0644\u062a\u0647\u0645 \u0627\u0644\u0635\u062d\u064a\u0629 \u0648\u0627\u0644\u062a\u0648\u0639\u0648\u064a\u0629 \u0645\u0646 \u062c\u0645\u064a\u0639 \u0645\u062f\u0646 \u0627\u0644\u0645\u0645\u0644\u0643\u0629\u060c \u0648\u0635\u0648\u0644\u0627\u064b \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0634\u0627\u0639\u0631 \u0627\u0644\u0645\u0642\u062f\u0633\u0629 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062d\u0648\u0635\u0627\u062a \u0627\u0644\u0