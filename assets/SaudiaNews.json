654\u0646 \u062d\u0642\u0647 \u0641\u064a \u062d\u0631\u064a\u0629 \u0627\u0644\u062a\u0639\u0628\u064a\u0631 \u0642\u062f \u0627\u0646\u062a\u064f\u0647\u0643 \u062e\u0644\u0627\u0644 \u0641\u062a\u0631\u0629 \u062a\u0648\u0644\u064a\u0647 \u062a\u062f\u0631\u064a\u0628 \u0646\u0627\u062f\u064a \u0641\u0646\u0631\u0628\u0647\u062a\u0634\u0647 \u0627\u0644\u062a\u0631\u0643\u064a.<br /><br />\u0648\u0643\u0627\u0646\u062a \u0627\u0644\u062f\u0639\u0648\u0649 \u0642\u062f \u0642\u064f\u062f\u0645\u062a \u0641\u064a \u0645\u0627\u0631\u0633 2025\u060c \u0627\u0654\u064a \u0642\u0628\u0644 \u0646\u062d\u0648 \u0633\u062a\u0629 \u0627\u0654\u0634\u0647\u0631 \u0645\u0646 \u0627\u0655\u0642\u0627\u0644\u062a\u0647 \u0645\u0646 \u062a\u062f\u0631\u064a\u0628 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0645\u0646\u0627\u0641\u0633 \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u062a\u0631\u0643\u064a \u0627\u0644\u0645\u0645\u062a\u0627\u0632 \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0654\u062e\u0641\u0642 \u0641\u064a \u0642\u064a\u0627\u062f\u062a\u0647 \u0627\u0655\u0644\u0649 \u0627\u0644\u062a\u0627\u0654\u0647\u0644 \u0644\u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0654\u0648\u0631\u0648\u0628\u0627.<br /><br />\u0648\u0627\u0654\u0638\u0647\u0631\u062a \u0648\u062b\u0627\u064a\u0654\u0642 \u0642\u0636\u0627\u064a\u0654\u064a\u0629 \u0627\u0637\u0644\u0639\u062a \u0639\u0644\u064a\u0647\u0627 \u0648\u0643\u0627\u0644\u0629 \u0641\u0631\u0627\u0646\u0633 \u0628\u0631\u0633\u060c \u0627\u0644\u062e\u0645\u064a\u0633\u060c \u0627\u0654\u0646 \u0645\u0648\u0631\u064a\u0646\u064a\u0648 \u0637\u0639\u0646 \u0641\u064a \"\u0627\u0644\u0639\u0642\u0648\u0628\u0627\u062a \u0627\u0644\u062a\u0627\u0654\u062f\u064a\u0628\u064a\u0629\" \u0627\u0644\u062a\u064a \u0641\u0631\u0636\u0647\u0627 \u0639\u0644\u064a\u0647 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0