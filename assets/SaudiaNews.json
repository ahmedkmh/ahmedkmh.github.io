9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D8%AD%D8%AA%D9%89-%D8%B5%D8%A8%D8%A7%D8%AD-%D8%A7%D9%84%D8%AB%D9%84%D8%A7%D8%AB%D8%A7%D8%A1\" target=\"_blank\">\u0627\u0654\u0645\u0637\u0627\u0631 \u063a\u0632\u064a\u0631\u0629</a> \u0639\u0644\u0649 \u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 4 \u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u0648\u0647\u064a: \u0627\u0644\u0631\u064a\u0627\u0636 \u0648\u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629 \u0648\u0639\u0633\u064a\u0631 \u0648\u0646\u062c\u0631\u0627\u0646<br />\u0648\u062a\u062a\u0645\u062b\u0644 \u0627\u0644\u062a\u0627\u0654\u062b\u064a\u0631\u0627\u062a \u0627\u0644\u0645\u0635\u0627\u062d\u0628\u0629 \u0641\u064a: \u0631\u064a\u0627\u062d \u0634\u062f\u064a\u062f\u0629 \u0627\u0644\u0633\u0631\u0639\u0629\u060c \u0648\u0627\u0646\u0639\u062f\u0627\u0645 \u0641\u064a \u0645\u062f\u0649 \u0627\u0644\u0631\u0648\u0654\u064a\u0629 \u0627\u0644\u0627\u0654\u0641\u0642\u064a\u0629\u060c \u0648\u062a\u0633\u0627\u0642\u0637 \u0627\u0644\u0628\u0631\u062f\u060c \u0648\u062c\u0631\u064a\u0627\u0646 \u0627\u0644\u0633\u064a\u0648\u0644\u060c \u0648\u0635\u0648\u0627\u0639\u0642 \u0631\u0639\u062f\u064a\u0629.<br />\u0627\u0654\u0645\u0627\u0643\u0646 \u0647\u0637\u0648\u0644 \u0627\u0644\u0627\u0654\u0645\u0637\u0627\u0631<br />\u0627\u0644\u0631\u064a\u0627\u0636: \u062b\u0627\u062f\u0642 \u0648\u062d\u0631\u064a\u0645\u0644\u0627\u0621 \u0648\u0634\u0642\u0631\u0627\u0621 \u0648\u0636\u0631\u0645\u0627 \u0648\u0645\u0631\u0627\u062a \u0648\u0627\u0644\u0631\u064a\u0646 \u0648\u0627\u0644\u0642\u0648\u064a\u0639\u064a\u0629 \u0648\u0627\u0644\u0633\u0644\u064a\u0644 \u0648\u0648\u0627\u062f\u064a \u0627\u0644\u062f\u0648\u0627\u0633\u0631.<br />\u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629: \u0627\u0644\u062e\u0631\u0645\u0629 \u0648\u062a\u0631\u0628\u0629 \u0648\u0631\u0646\u064a\u0629.<br />\u0639\u0633\u064a\u0631: \u0627\u0644\u0627\u0654\u0645\u0648\u0627\u0647 \u0648\u0627\u0644\u0639\u0631\u064a\u0646 \u0648\u0628\u064a\u0634\u0629 \u0648\u062a\u062b\u0644\u064a\u062b \u0648\u0637\u0631\u064a\u0628 \u0648\u0627\u0644\u0646\u0645\u0627\u0635 \u0648\u0628\u0644\u0642\u0631\u0646 \u0648\u062a\u0646\u0648\u0645\u0629 \u0648\u0627\u0644\u062d\u0631\u062c\u0629 \u0648\u0627\u0644\u0631\u0628\u0648\u0639\u0629 \u0648\u0627\u0644\u0641\u0631\u0634\u0629 \u0648\u0633\u0631\u0627\u0629 \u0639\u0628\u064a\u062f\u0629 \u0648\u0638\u0647\u0631\u0627\u0646 \u0627\u0644\u062c\u0646\u0648\u0628.<br />\u0646\u062c\u0631\u0627\u0646: \u0628\u062f\u0631 \u0627\u0644\u062c\u0646\u0648\u0628 \u0648\u062b\u0627\u0631 \u0648\u062d\u0628\u0648\u0646\u0627 \u0648\u062e\u0628\u0627\u0634 \u0648\u0646\u062c\u0631\u0627\u0646 \u0648\u064a\u062f\u0645\u0629.</p><h2>\u0627\u0654\u062a\u0631\u0628\u0629 \u0648\u0627\u0654\u0645\u0637\u0627\u0631 \u0639\u0644\u0649 \u0627\u0644\u0634\u0631\u0642\u064a\u0629</h2><p>\u0646\u0628\u0647 <a href=\"https://www.alyaum.com/articles/6658619/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A3%D8%B1%D8%B5%D8%A7%D8%AF-%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D9%85%D8%AA%D9%88%D8%B3%D8%B7%D8%A9-%D8%B9%D9%84%D9%89-%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D8%A8%D8%A7%D8%AD%D8%A9-%D9%88%D8%B1%D9%8A%D8%A7%D8%AD-%D9%88%D8%A3%D8%AA%D8%B1%D8%A8%D8%A9-%D8%B9%D9%84%D9%89-%D8%AD%D8%A7%D8%A6%D9%84\" target=\"_blank\">\u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0644\u0627\u0654\u0631\u0635\u0627\u062f</a> \u0641\u064a \u062a\u0642\u0631\u064a\u0631\u0647 \u0639\u0646 <a href=\"https://www.alyaum.com/articles/6658545/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AD%D8%A7%D9%84%D8%A9-%D8%A7%D9%84%D8%B7%D9%82%D8%B3-%D8%A7%D8%B3%D8%AA%D9%85%D8%B1%D8%A7%D8%B1-%D9%87%D8%B7%D9%88%D9%84-%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D8%B1%D8%B9%D8%AF%D9%8A%D8%A9-%D8%B2%D8%AE%D8%A7%D8%AA-%D9%85%D9%86-%D8%A7%D9%84%D8%A8%D8%B1%D8%AF-%D8%B9%D9%84%D9%89-8-%D9%85%D9%86%D8%A7%D8%B7%D9%82\" target=\"_blank\">\u062d\u0627\u0644\u0629 \u0627\u0644\u0637\u0642\u0633</a> \u0645\u0646 <a href=\"https://www.alyaum.com/articles/6658683/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A3%D8%B1%D8%B5%D8%A7%D8%AF-%D8%A3%D8%AA%D8%B1%D8%A8%D8%A9-%D9%85%D8%AB%D8%A7%D8%B1%D8%A9-%D8%B9%D9%84%D9%89-%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D8%AD%D8%AA%D9%89-%D8%A7%D9%84%D8%B3%D8%A7%D8%B9%D8%A9-9-%D9%85%D8%B3%D8%A7%D8%A1\" target=\"_blank\">\u0627\u0654\u062a\u0631\u0628\u0629 \u0645\u062b\u0627\u0631\u0629</a> \u0648<a href=\"https://www.alyaum.com/articles/6658512/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D8%AE%D9%81%D9%8A%D9%81%D8%A9-%D8%B9%D9%84%D9%89-%D8%A3%D8%AC%D8%B2%D8%A7%D8%A1-%D9%85%D9%86-%D8%A7%D9%84%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85-%D8%A7%D9%84%D8%AB%D9%84%D8%A7%D8%AB%D8%A7%D8%A1\" target=\"_blank\">\u0627\u0654\u0645\u0637\u0627\u0631 \u062e\u0641\u064a\u0641\u0629</a> \u0639\u0644\u0649 \u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u062e\u0644\u0627\u0644 \u0633\u0627\u0639\u0627\u062a \u0627\u0644\u0635\u0628\u0627\u062d \u0627\u0644\u0628\u0627\u0643\u0631 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621.<br />\u062a\u0628\u062f\u0627\u0654 \u0627\u0644\u0627\u0654\u062a\u0631\u0628\u0629 \u0627\u0644\u0633\u0627\u0639\u0629 1 \u0635\u0628\u0627\u062d\u064b\u0627\u060c \u0648\u062a\u0633\u062a\u0645\u0631 \u062d\u062a\u0649 \u0627\u0644\u0633\u0627\u0639\u0629 11 \u0635\u0628\u0627\u062d\u064b\u0627 \u0639\u0644\u0649 \u0628\u0639\u0636 \u0627\u0644\u0627\u0654\u0645\u0627\u0643\u0646\u060c \u0648\u062d\u062a\u0649 \u0627\u0644\u0633\u0627\u0639\u0629 1 \u0628\u0639\u062f \u0627\u0644\u0638\u0647\u0631 \u0639\u0644\u0649 \u0627\u0654\u0645\u0627\u0643\u0646 \u0627\u0654\u062e\u0631\u0649.<br />\u064a\u0634\u0645\u0644 \u0627\u0644\u062a\u0646\u0628\u064a\u0647: \u0627\u0644\u062c\u0628\u064a\u0644 \u0648\u0627\u0644\u062e\u0628\u0631 \u0648\u0627\u0644\u062f\u0645\u0627\u0645 \u0648\u0627\u0644\u0642\u0637\u064a\u0641 \u0648\u0631\u0627\u0654\u0633 \u062a\u0646\u0648\u0631\u0629 \u0648\u0627\u0644\u0627\u0654\u062d\u0633\u0627\u0621 \u0648\u0627\u0644\u0639\u062f\u064a\u062f \u0648\u0628\u0642\u064a\u0642 \u0648\u062d\u0641\u0631 \u0627\u0644\u0628\u0627\u0637\u0646 \u0648\u0627\u0644\u062e\u0641\u062c\u064a \u0648\u0627\u0644\u0646\u0639\u064a\u0631\u064a\u0629 \u0648\u0642\u0631\u064a\u0629 \u0627\u0644\u0639\u0644\u064a\u0627.</p><div data-oembed-url=\"https://x.com/NCMAlert/status/2049205463640633779\"><blockquote align=\"center\" class=\"twitter-tweet\" data-dnt=\"true\"><p dir=\"rtl\" lang=\"ar\">\u0627\u0644\u0627\u0655\u0646\u0630\u0627\u0631 \u0627\u0644\u0627\u0654\u062d\u0645\u0631 - <a href=\"https://twitter.com/hashtag/%D9%85%D9%86%D8%B7%D9%82%D8%A9_%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6?src=hash&ref_src=twsrc%5Etfw\">#\u0645\u0646\u0637\u0642\u0629_\u0627\u0644\u0631\u064a\u0627\u0636</a> - <a href=\"https://twitter.com/hashtag/%D8%AB%D8%A7%D8%AF%D9%82?src=hash&ref_src=twsrc%5Etfw\">#\u062b\u0627\u062f\u0642</a> <a href=\"https://twitter.com/hashtag/%D8%AD%D8%B1%D9%8A%D9%85%D9%84%D8%A7%D8%A1?src=hash&ref_src=twsrc%5Etfw\">#\u062d\u0631\u064a\u0645\u0644\u0627\u0621</a> <a href=\"https://twitter.com/hashtag/%D8%B4%D9%82%D8%B1%D8%A7%D8%A1?src=hash&ref_src=twsrc%5Etfw\">#\u0634\u0642\u0631\u0627\u0621</a> <a href=\"https://twitter.com/hashtag/%D8%B6%D8%B1%D9%85%D8%A7?src=hash&ref_src=tws