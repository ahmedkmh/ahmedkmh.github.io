ription": "\u0643\u0634\u0641\u062a \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0655\u0639\u0644\u0627\u0645 \u063a\u0631\u0628\u064a\u0629 \u0627\u0644\u064a\u0648\u0645 (\u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621) \u0639\u0646 \u0645\u0636\u0627\u0645\u064a\u0646 \u062e\u0637\u0627\u0628 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0645\u0628 \u0627\u0644\u0645\u0642\u0631\u0631 \u0627\u0655\u0644\u0642\u0627\u0648\u0654\u0647 \u062e\u0644\u0627\u0644 \u0627\u0644\u0633\u0627\u0639\u0627\u062a \u0627\u0644\u0642\u0627\u062f\u0645\u0629. \u0648\u0642\u0627\u0644 \u2060\u0645\u0633\u0648\u0654\u0648\u0644 \u200c\u0641\u064a \u200b\u0627\u0644\u0628\u064a\u062a \u0627\u0644\u0627\u0654\u0628\u064a\u0636 \u2060\u0644\u0648\u0643\u0627\u0644\u0629 \u00ab\u0631\u0648\u064a\u062a\u0631\u0632\u00bb: \u0645\u0646 \u0627\u0644\u0645\u062a\u0648\u0642\u0639 \u2060\u0627\u0654\u0646 \u064a\u0648\u0654\u0643\u062f \u200b\u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0645\u0628 \u2060\u0639\u0644\u0649 \u200b\u0627\u0644\u062c\u062f\u0648\u0644 \u0627\u0644\u0632\u0645\u0646\u064a \u200b\u0627\u0644\u0630\u064a \u200c\u064a\u062a\u0631\u0627\u0648\u062d \u0628\u064a\u0646 \u200b\u0627\u0654\u0633\u0628\u0648\u0639\u064a\u0646 \u2060\u0648\u062b\u0644\u0627\u062b\u0629 \u0627\u0654\u0633\u0627\u0628\u064a\u0639 \u2060\u0644\u0627\u0655\u0646\u0647\u0627\u0621 \u0627\u0644\u062d\u0631\u0628 \u200c\u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646 \u062e\u0644\u0627\u0644 \u200c\u062e\u0637\u0627\u0628 \u064a\u0644\u0642\u064a\u0647 \u0641\u064a \u0648\u0642\u062a \u0645\u062a\u0627\u0654\u062e\u0631 \u0645\u0633\u0627\u0621 \u0627\u0644\u064a\u0648\u0645.\u0628\u062f\u0648\u0631\u0647\u0627\u060c \u0646\u0642\u0644\u062a \u0634\u0628\u0643\u0629 \u00ab\u0633\u064a \