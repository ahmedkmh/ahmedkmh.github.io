3%D8%AE%D8%A8%D8%A7%D8%B1/%D9%85%D9%86%D9%88%D8%B9%D8%A7%D8%AA/%D8%AA%D9%88%D9%82%D8%B9%D8%A7%D8%AA-%D8%A8%D9%85%D8%B4%D8%A7%D9%87%D8%AF%D8%AA%D9%87-%D8%A8%D8%A7%D9%84%D8%B9%D9%8A%D9%86-%D8%A7%D9%84%D9%85%D8%AC%D8%B1%D8%AF%D8%A9-%D8%B1%D8%B5%D8%AF-%D9%85%D8%B0%D9%86%D8%A8-C-2025-R3-%D9%81%D9%8A-%D8%B3%D9%85%D8%A7%D8%A1-%D8%A7%D9%84%D9%82%D8%B5%D9%8A%D9%85", "title": "\u062a\u0648\u0642\u0639\u0627\u062a \u0628\u0645\u0634\u0627\u0647\u062f\u062a\u0647 \u0628\u0627\u0644\u0639\u064a\u0646 \u0627\u0644\u0645\u062c\u0631\u062f\u0629.. \u0631\u0635\u062f \u0645\u0630\u0646\u0628 \"C/2025 R3\" \u0641\u064a \u0633\u0645\u0627\u0621 \u0627\u0644\u0642\u0635\u064a\u0645", "description": "\u0627\u0654\u0639\u0644\u0646\u062a \u062c\u0645\u0639\u064a\u0629 \"<a href=\"https://www.alyaum.com/articles/6653695/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D9%85%D9%86%D9%88%D8%B9%D8%A7%D8%AA/%D8%AA%D8%AA%D8%B3%D8%A8%D8%A8-%D9%81%D9%8A-%D8%A7%D8%B6%D8%B7%D8%B1%D8%A7%D8%A8%D8%A7%D8%AA-%D8%B1%D8%B5%D8%AF-%D9%86%D8%B4%D8%A7%D8%B7-%D8%B4%D9%85%D8%B3%D9%8A-%D9%8A%D9%86%D8%B0%D8%B1-%D8%A8%D8%B9%D8%A7%D8%B5%D9%81%D8%A9-%D8%AC%D9%8A%D9%88%D9%85%D8%BA%D9%86%D8%A7%D8%B7%D9%8A%D8%B3%D9%8A%D8%A9-%D8%A7%D9%84%D9%84%D9%8A%D9%84%D8%A9\">\u0646\u0648\u0631 \u0627\u0644\u0641\u0644\u0643</a>\" \u0628\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0642\u0635\u064a\u0645 \u0631\u0635\u062f <a href=\"https://www.alyaum.com/articles/6623616/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D9%85%D9%86%D9%88%D8%B9%D8%A7%D8%AA/%D8%A8%D9%84%D9%88%D9%86-%D9%85%D9%85%D9%8A%D8%B2-%D9%88%D8%B0%D9%8A%D9%84-%D9%82%D8%B5%D9%8A%D8%B1-%D8%B1%D8%B5%D8%AF-%D9%85%D8%B0%D9%86%D8%A8-%D9%84%D9%8A%D9%85%D9%88%D9%86-%D9%81%D9%8A-%D8%B3%D9%85%D8%A7%D8%A1-%D8%A7%D9%84%D9%82%D8%B5%D9%8A%D9%85\">\u0627\u0644\u0645\u0630\u0646\u0628 </a>(C/2025 R3)\u060c \u0627\u0644\u0630\u064a \u0628\u062f\u0627\u0654 \u064a\u0632\u062f\u0627\u062f \u0633\u0637\u0648\u0639\u064b\u0627 \u0645\u0639 \u0627\u0642\u062a\u0631\u0627\u0628\u0647 \u0645\u0646 \u0627\u0644\u062d\u0636\u064a\u0636 \u0627\u0644\u0634\u0645\u0633\u064a\u060c \u0648\u0633\u0637 \u062a\u0648\u0642\u0639\u0627\u062a \u0628\u0627\u0655\u0645\u0643\u0627\u0646\u064a\u0629 \u0645\u0634\u0627\u0647\u062f\u062a\u0647 \u0628\u0627\u0644\u0639\u064a\u0646 \u0627\u0644\u0645\u062c\u0631\u062f\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u064a\u0627\u0645 \u0627\u0644\u0642\u0644\u064a\u0644\u0629 \u0627\u0644\u0645\u0642\u0628\u0644\u0629.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0639\u064a\u0633\u0649 \u0627\u0644\u063a\u0641\u064a\u0644\u064a \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0631\u0635\u0627\u062f \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0627\u0654\u0638\u0647\u0631\u062a \u0648\u0635\u0648\u0644 \u0644\u0645\u0639\u0627\u0646 \u0627\u0644\u0645\u0630\u0646\u0628 \u0627\u0655\u0644\u0649 \u0627\u0644\u0642\u062f\u0631 (5)\u061b \u0645\u0645\u0627 \u064a\u062c\u0639\u0644\u0647 \u0647\u062f\u0641\u064b\u0627 \u0645\u0646\u0627\u0633\u0628\u064b\u0627 \u0644\u0644\u0631\u0635\u062f \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u0646\u0627\u0638\u064a\u0631 \u0648\u0627\u0644\u062a\u0644\u0633\u0643\u0648\u0628\u0627\u062a \u0627\u0644\u0635\u063a\u064a\u0631\u0629\u060c \u0645\u0634\u064a\u0631\u064b\u0627 \u0627\u0655\u0644\u0649 \u0638\u0647\u0648\u0631\u0647 \u0636\u0645\u0646 \u0645\u062c\u0645\u0648\u0639\u0629 \u0646\u062c\u0648\u0645 \u0627\u0644\u0641\u0631\u0633 \u0627\u0644\u0627\u0654\u0639\u0638\u0645\u060c \u0645\u0639 \u0628\u062f\u0621 \u0627\u0645\u062a\u062f\u0627\u062f \u0630\u064a\u0644\u0647 \u0627\u0644\u063a\u0627\u0632\u064a \u0628\u0635\u0648\u0631\u0629 \u062a\u0639\u0643\u0633 \u0646\u0634\u0627\u0637 \u0646\u0648\u0627\u062a\u0647 \u0645\u0639 \u0627\u0642\u062a\u0631\u0627\u0628\u0647\u0627 \u0645\u0646 \u0627\u0644\u0634\u0645\u0633.<h2>\u0645\u0630\u0646\u0628 \"C/2025 R3\"</h2>\u0648\u0627\u0654\u0641\u0627\u062f \u0627\u0654\u0646 \u0627\u0644\u0645\u0630\u0646\u0628 \u0633\u064a\u0635\u0644 \u0627\u0655\u0644\u0649 \u0646\u0642\u0637\u0629 \u0627\u0644\u062d\u0636\u064a\u0636 \u0627\u0644\u0634\u0645\u0633\u064a -\u0627\u0654\u0642\u0631\u0628 \u0646\u0642\u0637\u0629 \u0644\u0647 \u0645\u0646 \u0627\u0644\u0634\u0645\u0633- \u0645\u0639 \u0628\u062f\u0627\u064a\u0629 \u0634\u0647\u0631 \u0630\u064a \u0627\u0644\u0642\u0639\u062f\u0629 \u0627\u0644\u0642\u0627\u062f\u0645\u060c \u0639\u0644\u0649 \u0645\u0633\u0627\u0641\u0629 \u062a\u064f\u0642\u062f\u0651\u0631 \u0628\u0646\u062d\u0648 75 \u0645\u0644\u064a\u0648\u0646 \u0643\u064a\u0644\u0648\u0645\u062a\u0631.<div data-oembed-url=\"https://x.com/alyaum/status/1982151199022252268\"><blockquote align=\"center\" class=\"twitter-tweet\" data-dnt=\"true\"><p dir=\"rtl\" lang=\"ar\">\u0628\u0644\u0648\u0646 \u0645\u0645\u064a\u0632 \u0648\u0630\u064a\u0644 \u0642\u0635\u064a\u0631.. \u0631\u0635\u062f \u0645\u0630\u0646\u0628 \"\u0644\u064a\u0645\u0648\u0646\" \u0641\u064a \u0633\u0645\u0627\u0621 <a href=\"https://twitter.com/hashtag/%D8%A7%D9%84%D9%82%D8%B5%D9%8A%D9%85?src=hash&ref_src=twsrc%5Etfw\">#\u0627\u0644\u0642\u0635\u064a\u0645</a><a href=\"https://twitter.com/hashtag/%D8%A7%D9%84%D9%8A%D9%88%D9%85?src=hash&ref_src=twsrc%5Etfw\">#\u0627\u0644\u064a\u0648\u0645</a><a href=\"https://t.co/kSVuSGq42m\">https://t.co/kSVuSGq42m</a> <a href=\"https://t.co/MAHE26nb9O\">pic.twitter.com/MAHE26nb9O</a></p>\u2014 \u0635\u062d\u064a\u0641\u0629 \u0627\u0644\u064a\u0648\u0645 (@alyaum) <a href=\"https://twitter.com/alyaum/status/1982151199022252268?ref_src=twsrc%5Etfw\">October 25, 2025</a></blockquote> </div><br />\u0648\u0628\u064a\u0646 \u0627\u0654\u0646 \u0627\u0644\u0641\u062a\u0631\u0629 \u0627\u0644\u062d\u0627\u0644\u064a\u0629 \u062a\u064f\u0639\u062f \u0627\u0644\u0627\u0654\u0646\u0633\u0628 \u0644\u0644\u0631\u0635\u062f \u0645\u0646 \u0627\u0644\u0646\u0635\u0641 \u0627\u0644\u0634\u0