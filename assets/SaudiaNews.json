8\u0629 \u062a\u0633\u062a\u0647\u062f\u0641 \u062a\u062e\u0641\u064a\u0641 \u0627\u0644\u0627\u0654\u0639\u0628\u0627\u0621 \u0627\u0644\u0645\u0639\u064a\u0634\u064a\u0629 \u0639\u0646 \u0627\u0644\u0627\u0654\u0633\u0631 \u0627\u0644\u0627\u0654\u0634\u062f \u0627\u062d\u062a\u064a\u0627\u062c\u064b\u0627 \u0648\u0630\u0648\u064a \u0627\u0644\u062f\u062e\u0644 \u0627\u0644\u0645\u062d\u062f\u0648\u062f.\u0648\u062c\u0631\u0649 \u0627\u0644\u062a\u062f\u0634\u064a\u0646 \u0628\u062d\u0636\u0648\u0631 \u0645\u062f\u064a\u0631 \u0639\u0627\u0645 \u0645\u062f\u064a\u0631\u064a\u0629 \u0648\u0627\u062f\u064a \u0627\u0644\u0639\u064a\u0646 \u0648\u062d\u0648\u0631\u0629 \u0627\u0644\u0634\u064a\u062e \u0633\u0627\u0644\u0645 \u0639\u0628\u0627\u062f\u064a\u0646 \u0628\u0627\u0648\u0632\u064a\u0631\u060c \u0648\u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0642\u064a\u0627\u062f\u0627\u062a \u0627\u0644\u0645\u062d\u0644\u064a\u0629 \u0648\u0627\u0644\u0634\u062e\u0635\u064a\u0627\u062a \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0648\u0639\u0642\u0627\u0644 \u0627\u0644\u062d\u0627\u0631\u0627\u062a\u060c \u062d\u064a\u062b \u0627\u0654\u0643\u062f \u0627\u0644\u0645\u062f\u064a\u0631 \u0627\u0644\u0639\u0627\u0645 \u0627\u0654\u0646 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u062a\u0648\u0632\u064a\u0639 \u062a\u0634\u0645\u0644 \u0645\u062e\u062a\u0644\u0641 \u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0645\u062f\u064a\u0631\u064a\u0629\u060c \u0645\u0646 \u0648\u0627\u062f\u064a \u0627\u0644\u0639\u064a\u0646 \u0627\u0655\u0644\u0649 \u062d\u0648\u0631\u0629\u060c \u0648\u0641\u0642 \u0627\u0653\u0644\u064a\u0629 \u0645\u0646\u0638\u0645\u0629 \u062a\u0636\u0645\u0646 \u0639\u062f\u0627\u0644\u0629 \u0627\u0644\u062a\u0648\u0632\u064a\u0639 \u0648\u0648\u0635\u0648\u0644 \u0627\u0644\u0645\u0633\u0627\u0639\u062f\u0627\u062a \u0627\u0655\u0644\u0649 \u0645\u0633\u062a\u062d\u0642\u064a\u0647\u0627 \u062f\u0648\u0646 \u0627\u0633\u062a\u062b\u0646\