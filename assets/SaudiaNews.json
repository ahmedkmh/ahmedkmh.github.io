62f\u0629 \u0627\u0654\u0647\u0627\u0644\u064a \u0645\u062f\u064a\u0646\u0629 <a href=\"https://www.alyaum.com/articles/6599215/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A3%D8%AD%D8%B3%D8%A7%D8%A1-%D8%AA%D8%B7%D9%88%D9%8A%D8%B1-%D8%B7%D8%B1%D9%8A%D9%82-%D8%AC%D9%88%D8%A7%D8%AB%D8%A7-%D8%A7%D9%84%D8%AA%D8%A7%D8%B1%D9%8A%D8%AE%D9%8A-%D9%88%D8%A5%D9%86%D8%B4%D8%A7%D8%A1-%D8%AD%D8%AF%D8%A7%D8%A6%D9%82-%D8%B9%D8%A7%D9%85%D8%A9-%D8%B9%D9%84%D9%89-%D8%B7%D8%A7%D9%88%D9%84%D8%A9-%D8%A8%D9%84%D8%AF%D9%8A%D8%A9-%D8%A7%D9%84%D8%B9%D9%85%D8%B1%D8%A7%D9%86\" target=\"_blank\">\u062c\u0648\u0627\u062b\u0627</a>\u060c \u0648\u0627\u0644\u0630\u064a \u064a\u0636\u0645 \u0628\u0644\u062f\u0627\u062a (\u0627\u0644\u0643\u0644\u0627\u0628\u064a\u0629 \u0648\u0627\u0644\u0645\u0642\u062f\u0627\u0645 \u0648\u0627\u0644\u062d\u0644\u064a\u0644\u0629).<br />\u0648\u0634\u0647\u062f \u0627\u0644\u062d\u0641\u0644 \u062a\u0642\u062f\u064a\u0645 <a href=\"https://www.alyaum.com/articles/6651864/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/50-%D8%B9%D8%A7%D9%85%D8%A7-%D9%85%D9%86-%D8%A7%D9%84%D8%B9%D8%B1%D8%B6%D8%A9-%D9%88%D8%A7%D9%84%D8%B3%D8%A7%D9%85%D8%B1%D9%8A-%D8%AA%D8%AC%D8%B0%D8%A8-%D8%B2%D9%88%D8%A7%D8%B1-%D8%A7%D8%AD%D8%AA%D9%81%D8%A7%D9%84%D8%A7%D8%AA-%D8%A7%D9%84%D8%B9%D9%8A%D8%AF-%D9%81%D9%8A-%D8%A7%D9%84%D8%A3%D8%AD%D8%B3%D8%A7%D8%A1\" target=\"_blank\">\u0627\u0644\u0639\u0631\u0636\u0629</a> \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0648\u0627\u0644\u0628\u0631\u0627\u0645\u062c \u0627\u0644\u0645\u0635\u0627\u062d\u0628\u0629 \u0627\u0644\u062a\u064a \u0639\u0643\u0633\u062a \u0627\u0654\u0635\u0627\u0644\u0629 \u0627\u0644\u062a\u0631\u0627\u062b \u0627\u0644\u0627\u0654\u062d\u0633\u0627\u064a\u0654\u064a \u0648\u0627\u0644\u0645\u0648\u0631\u0648\u062b \u0627\u0644\u0634\u0639\u0628\u064a\u060c \u0648\u0633\u0637 \u062a\u0641\u0627\u0639\u0644 \u0648\u0627\u0633\u0639 \u0645\u0646 \u0627\u0644\u062d\u0636\u0648\u0631 \u0627\u0644\u0630\u064a\u0646 \u0627\u0633\u062a\u0645\u062a\u0639\u0648\u0627 \u0628\u0627\u0644\u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0644\u064a\u0629 \u0627\u0644\u062a\u064a \u0627\u0645\u062a\u0632\u062c\u062a \u0641\u064a\u0647\u0627 \u0627\u0644\u0641\u0631\u062d\u0629 \u0628\u0627\u0644\u0639\u0627\u062f\u0627\u062a \u0648\u0627\u0644\u062a\u0642\u0627\u0644\u064a\u062f \u0627\u0644\u0627\u0654\u0635\u064a\u0644\u0629.<br />\u064a\u0627\u0654\u062a\u064a \u0630\u0644\u0643 \u0636\u0645\u0646 \u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0621 <a href=\"https://www.alyaum.com/articles/6664259/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%B5%D8%AD%D8%A9-%D9%88%D8%AA%D8%BA%D8%B0%D9%8A%D8%A9/%D8%A7%D8%B3%D8%AA%D8%B4%D8%A7%D8%B1%D9%8A-%D9%84%D8%A7%D9%84%D9%8A%D9%88%D9%85-9-%D9%86%D8%B5%D8%A7%D8%A6%D8%AD-%D9%84%D9%84%D8%B3%D9%83%D8%B1%D9%8A%D9%8A%D9%86-%D9%81%D9%8A-%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D8%A3%D8%B6%D8%AD%D9%89\" target=\"_blank\">\u0628\u0639\u064a\u062f \u0627\u0644\u0627\u0654\u0636\u062d\u0649</a> \u0627\u0644\u0645\u0628\u0627\u0631\u0643\u060c \u0641\u064a \u0641\u0639\u0627\u0644\u064a\u0629 \u0627\u064f\u0654\u0642\u064a\u0645\u062a \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0648\u0633\u0637 \u062d\u0636\u0648\u0631 \u0645\u0646 \u0627\u0644\u0627\u0654\u0647\u0627\u0644\u064a \u0648\u0627\u0644\u0645\u0642\u064a\u0645\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u062d\u0631\u0635\u0648\u0627 \u0639\u0644\u0649 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0629 \u0641\u064a \u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0648\u062a\u0631\u0627\u062b\u064a\u0629 \u0645\u0645\u064a\u0632\u0629 \u062c\u0633\u062f\u062a \u0641\u0631\u062d\u0629 \u0627\u0644\u0639\u064a\u062f \u0648\u0631\u0648\u062d \u0627\u0644\u0627\u0654\u0644\u0641\u0629 \u0648\u0627\u0644\u0645\u062d\u0628\u0629 \u0628\u064a\u0646 \u0627\u0644\u062c\u0645\u064a\u0639.</p><h2>\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0631\u0648\u0627\u0628\u0637 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629</h2><p>\u0648\u0627\u0654\u0648\u0636\u062d \u062c\u0644\u0627\u0644 \u0627\u0644\u0631\u0634\u064a\u062f \u0631\u064a\u0654\u064a\u0633 \u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0646\u062c\u0627\u062d \u0627\u0644\u0634\u0628\u0627\u0628\u064a\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629\u060c \u0627\u0654\u0646 \u0627\u0655\u0642\u0627\u0645\u0629 \u062d\u0641\u0644 \u0627\u0644\u0645\u0639\u0627\u064a\u062f\u0629 \u062a\u0627\u0654\u062a\u064a \u0628\u0647\u062f\u0641 \u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0631\u0648\u0627\u0628\u0637 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0628\u064a\u0646 \u0627\u0644\u0627\u0654\u0647\u0627\u0644\u064a \u0648\u062a\u0631\u0633\u064a\u062e \u0642\u064a\u0645 \u0627\u0644\u0645\u062d\u0628\u0629 \u0648\u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0628\u064a\u0646 \u0627\u0654\u0641\u0631\u0627\u062f \u0627\u0644\u0645\u062c\u062a\u0645\u0639\u060c \u0645\u0634\u064a\u0631\u064b\u0627 \u0627\u0655\u0644\u0649 \u062d\u0631\u0635 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0639\u0644\u0649 \u062a\u0646\u0638\u064a\u0645 \u0645\u062b\u0644 \u0647\u0630\u0647 \u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u062c\u0645\u0639 \u0627\u0654\u0628\u0646\u0627\u0621 \u0627\u0644\u0645\u062c\u062a\u0645\u0639 \u0641\u064a \u0627\u0654\u062c\u0648\u0627\u0621 \u064a\u0633\u0648\u062f\u0647\u0627 \u0627\u0644\u0648\u062f \u0648\u0627\u0644\u062a\u0644\u0627\u062d\u0645.</p><p>\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646 \u0627\u0644\u062d\u0641\u0644 \u0627\u0634\u062a\u0645\u0644 \u0639\u0644\u0649 \u0627\u0644\u0639\u062f\u064a\u062f \u0645\u0646 \u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0648\u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0627\u062a \u0627\u0644\u0645\u062a\u0646\u0648\u0639\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0644\u0639\u0631\u0636\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0639\u062f \u0645\u0646 \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0641\u0646\u0648\u0646 \u0627\u0644\u0634\u0639\u0628\u064a\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0648\u062a\u0639\u0643\u0633 \u0627\u0644\u0645\u0648\u0631\u0648\u062b \u0627\u0644\u0627\u0654\u0635\u064a\u0644.<br /> <br />\u0648\u0627\u0654\u0643\u062f \u0627\u0654\u0646 \u0627\u0644\u062d\u0636\u0648\u0631 \u0648\u0627\u0644\u062a\u0641\u0627\u0639\u0644 \u0627\u0644\u0645\u0645\u064a\u0632 \u0645\u0646 \u0627\u0644\u0627\u0654\u0647\u0627\u0644\u064a \u0627\u0654\u0633\u0647\u0645\u0627 \u0641\u064a \u0646\u062c\u0627\u062d \u0627\u0644\u062d\u0641\u0644 \u0648\u0627\u0655\u0628\u0631\u0627\u0632 \u0631\u0648\u062d \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0648\u0627\u0644\u0645\u062d\u0628\u0629 \u0628\u064a\u0646 \u0627\u0644\u062c\u0645\u064a\u0639.</p><p>\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u0645\u0628\u0627\u062f\u0631\u0627\u062a \u062a\u0627\u0654\u062a\u064a \u0636\u0645\u0646 \u0628\u0631\u0627\u0645\u062c \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0647\u0627\u062f\u0641\u0629 \u0627\u0655\u0644\u0649 \u062e\u062f\u0645\u0629 \u0627\u0644\u0645\u062c\u062a\u0645\u0639 \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u062a\u0644\u0627\u062d\u0645 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u060c \u0633\u0627\u064a\u0654\u0644\u064b\u0627 \u0627\u0644\u