u0639\u062f\u0627\u0645 \u0641\u064a \u0645\u062f\u0649 \u0627\u0644\u0631\u0648\u0654\u064a\u0629 \u0643\u064a\u0644\u0648\u0645\u062a\u0631 \u0648\u0627\u062d\u062f \u0627\u0654\u0648 \u0627\u0654\u0642\u0644 \u0639\u0644\u0649 \u0627\u0654\u0645\u0627\u0643\u0646 \u0627\u0644\u0636\u0628\u0627\u0628 \u0627\u0644\u0643\u062b\u064a\u0641.\u0627\u0654\u0645\u0627\u0643\u0646 \u0627\u0646\u062a\u0634\u0627\u0631 \u0627\u0644\u0636\u0628\u0627\u0628\u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629: \u0627\u0644\u062c\u0628\u064a\u0644 \u0648\u0627\u0644\u062e\u0628\u0631 \u0648\u0627\u0644\u062e\u0641\u062c\u064a \u0648\u0627\u0644\u062f\u0645\u0627\u0645 \u0648\u0627\u0644\u0638\u0647\u0631\u0627\u0646 \u0648\u0627\u0644\u0642\u0637\u064a\u0641 \u0648\u0631\u0627\u0654\u0633 \u062a\u0646\u0648\u0631\u0629 \u0648\u0627\u0644\u0627\u0654\u062d\u0633\u0627\u0621 \u0648\u0627\u0644\u0639\u062f\u064a\u062f \u0648\u0628\u0642\u064a\u0642.\u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629: \u0645\u064a\u0633\u0627\u0646.\u0627\u0644\u0628\u0627\u062d\u0629: \u0627\u0644\u0642\u0631\u0649 \u0648\u0627\u0644\u0645\u0646\u062f\u0642 \u0648\u0627\u0644\u0628\u0627\u062d\u0629 \u0648\u0628\u0644\u062c\u0631\u0634\u064a \u0648\u0628\u0646\u064a \u062d\u0633\u0646.\u0639\u0633\u064a\u0631: \u0627\u0644\u0646\u0645\u0627\u0635 \u0648\u0628\u0644\u0642\u0631\u0646 \u0648\u062a\u0646\u0648\u0645\u0629 \u0648\u0627\u0654\u0628\u0647\u0627 \u0648\u0627\u0654\u062d\u062f \u0631\u0641\u064a\u062f\u0629 \u0648\u062e\u0645\u064a\u0633 \u0645\u0634\u064a\u0637 \u0648\u0627\u0644\u062d\u0631\u062c\u0629 \u0648\u0627\u0644\u0631\u0628\u0648\u0639\u0629 \u0648\u0627\u0644\u0641\u0631\u0636\u0629 \u0648\u0633\u0631\u0627\u0629 \u0639\u0628\u064a\u062f\u0629 \u0648\u0638\u0647\u0631\u0627\u0646 \u0627\u0644\u062c\u0646\u0648\u0628.\u0627\u0644\u0627\u0655\u0646\u0630\u0627\u0631 \u0627\u0644\u0627\u0654\u062d\u0645\u0631 - #\u0645\u0646\u0637\u0642\