-%D9%81%D8%B1%D8%B5\" target=\"_blank\">\u0644\u0627\u064a\u0654\u062d\u0629 \u0627\u0644\u062a\u0635\u0631\u0641</a> \u0628\u0627\u0644\u0639\u0642\u0627\u0631\u0627\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629 \u0627\u0644\u0645\u062d\u062f\u062b\u0629.<br /><br />\u0648\u064a\u0627\u0654\u062a\u064a \u0630\u0644\u0643 \u062a\u0646\u0641\u064a\u0630\u064b\u0627 \u0644\u0644\u0627\u0654\u0645\u0631 \u0627\u0644\u0633\u0627\u0645\u064a \u0627\u0644\u0643\u0631\u064a\u0645 \u0627\u0644\u0645\u062a\u0636\u0645\u0646 \u062a\u0645\u0643\u064a\u0646 \u0627\u0644\u062a\u062c\u062f\u064a\u062f \u0627\u0644\u0645\u0628\u0643\u0631 \u0644\u0644\u0639\u0642\u0648\u062f \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u064a\u0629 \u0628\u0639\u062f \u0627\u0646\u0642\u0636\u0627\u0621 \u0646\u0635\u0641 \u0645\u062f\u0629 \u0627\u0644\u0639\u0642\u062f\u060c \u0648\u0648\u0636\u0639 \u0627\u0644\u0636\u0648\u0627\u0628\u0637 \u0648\u0627\u0644\u0645\u0639\u0627\u064a\u064a\u0631 \u0627\u0644\u0645\u0646\u0638\u0645\u0629 \u0644\u0630\u0644\u0643\u060c \u0628\u0645\u0627 \u064a\u0639\u0632\u0632 \u0627\u0644\u0628\u064a\u064a\u0654\u0629 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u064a\u0629\u060c \u0648\u064a\u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u0629 \u0627\u0633\u062a\u062b\u0645\u0627\u0631 <a href=\"https://www.alyaum.com/articles/6672307/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D8%B9%D9%82%D8%A7%D8%B1%D8%A7%D8%AA/%D8%AC%D8%A7%D9%87%D8%B2%D9%8A%D8%A9-49-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D8%B9%D9%82%D8%A7%D8%B1-%D9%84%D9%84%D8%AA%D8%B3%D8%AC%D9%8A%D9%84-%D8%A7%D9%84%D8%B9%D9%8A%D9%86%D9%8A-%D9%88%D8%A5%D8%B5%D8%AF%D8%A7%D8%B1-18-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D8%B5%D9%83\" target=\"_blank\">\u0627\u0644\u0639\u0642\u0627\u0631\u0627\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629</a>\u060c \u0648\u064a\u062f\u0639\u0645 \u062a\u0646\u0641\u064a\u0630 \u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a \u062a\u0637\u0648\u064a\u0631\u0