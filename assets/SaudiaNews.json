55\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u062a\u0642\u064a\u064a\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0648\u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0639\u0627\u062c\u0644\u0629 \u0641\u064a \u0627\u0644\u0645\u0648\u0642\u0639\u060c \u0648\u0627\u0644\u062a\u0627\u0654\u0643\u062f \u0627\u0644\u0641\u0648\u0631\u064a \u0645\u0646 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0648\u0644\u0648\u062f\u0629 \u0648\u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0643\u0627\u0641\u0629 \u0639\u0644\u0627\u0645\u0627\u062a\u0647\u0627 \u0627\u0644\u062d\u064a\u0648\u064a\u0629\u061b \u062d\u064a\u062b \u062a\u0628\u064a\u0646 \u0627\u0654\u0646\u0647\u0627 \u062a\u0633\u062a\u062c\u064a\u0628 \u0628\u0634\u0643\u0644 \u0637\u0628\u064a\u0639\u064a \u0645\u0639 \u0628\u0643\u0627\u0621 \u0648\u062a\u0646\u0641\u0633 \u0645\u0646\u062a\u0638\u0645\u064a\u0646 \u062f\u0648\u0646 \u0648\u062c\u0648\u062f \u0627\u0654\u064a \u0645\u0648\u0654\u0634\u0631\u0627\u062a \u0627\u0654\u0648 \u0639\u0644\u0627\u0645\u0627\u062a \u0644\u0644\u0627\u062e\u062a\u0646\u0627\u0642.<div data-oembed-url=\"https://x.com/alyaum/status/2062157732174516614\"><blockquote align=\"center\" class=\"twitter-tweet\" data-dnt=\"true\"><p dir=\"rtl\" lang=\"ar\">\u00ab\u0637\u0628\u064a\u0629 \u0645\u0643\u0629\u00bb \u062a\u0642\u0647\u0631 \u0627\u0644\u062d\u0633\u0627\u0633\u064a\u0629 \u0627\u0644\u062f\u0648\u0627\u064a\u0654\u064a\u0629 \u0648\u062a\u0646\u0642\u0630 \u062d\u0627\u062c\u0629 \u0645\u0627\u0644\u064a\u0632\u064a\u0629 \u0628\u0628\u0631\u0648\u062a\u0648\u0643\u0648\u0644 \u00ab\u0627\u0644\u0627\u0654\u0633\u0628\u0631\u064a\u0646\u00bb \u0627\u0644\u0645\u062a\u0642\u062f\u0645<br />\u200b<a href=\"https://x.com/hashtag/%D8%A7%D9%84%D9%8A%D9%88%D9%85?src=hash&ref_src=twsrc%5Etfw\">#\u0627\u0644\u064a\u0648\u0645</a><a href=\"https://t.co/06H4Lr60Fn\">https://t.co/06H4Lr60Fn</a></p>\u2014 \u0635\u062d\u064a\u0641\u0629 \u0627\u0644\u064a\u0648\u0645 (@alyaum) <a href=\"https://x.com/alyaum/status/2062157732174516614?ref_src=twsrc%5Etfw\">June 3, 2026</a></blockquote> </div><h2>\u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0637\u0628\u064a\u0629</h2>\u0643\u0645\u0627 \u0627\u0633\u062a\u0643\u0645\u0644 \u0627\u0644\u0641\u0631\u064a\u0642 \u0643\u0627\u0641\u0629 \u0627\u0644\u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0629 \u0627\u0644\u0644\u0627\u0632\u0645\u0629 \u0641\u064a \u0645\u062b\u0644 \u0647\u0630\u0647 \u0627\u0644\u062d\u0627\u0644\u0627\u062a\u060c \u0648\u0627\u0644\u062a\u064a \u0634\u0645\u0644\u062a \u0642\u0635 \u0627\u0644\u062d\u0628\u0644 \u0627\u0644\u0633\u0631\u064a\u060c \u0648\u0627\u0644\u0645\u0633\u0627\u0639\u062f\u0629 \u0627\u0644\u062c\u0631\u0627\u062d\u064a\u0629 \u0641\u064a \u0648\u0644\u0627\u062f\u0629 \u0627\u0644\u0645\u0634\u064a\u0645\u0629 \u0648\u0627\u0644\u062a\u0627\u0654\u0643\u062f \u0645\u0646 \u062e\u0631\u0648\u062c\u0647\u0627 \u0628\u0634\u0643\u0644 \u0643\u0627\u0645\u0644 \u0648\u0633\u0644\u064a\u0645\u060c \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u0645\u062d\u0627\u0644\u064a\u0644 \u0627\u0644\u0639\u0644\u0627\u062c\u064a\u0629 \u0648\u0627\u0644\u0627\u0654\u062f\u0648\u064a\u0629 \u0627\u0644\u0644\u0627\u0632\u0645\u0629 \u0644\u0644\u0627\u0654\u0645 \u0648\u0645\u062a\u0627\u0628\u0639\u0629 \u0645\u0648\u0654\u0634\u0631\u0627\u062a\u0647\u0627 \u0627\u0644\u0635\u062d\u064a\u0629 \u0628\u062f\u0642\u0629.<br /><br />\u0648\u0639\u0642\u0628 \u0627\u0644\u0627\u0637\u0645\u064a\u0654\u0646\u0627\u0646 \u0627\u0644\u062a\u0627\u0645 \u0639\u0644\u0649 \u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0627\u0644\u062d\u0627\u0644\u0629 \u0648\u0636\u0645\u0627\u0646 \u0633\u0644\u0627\u0645\u062a\u0647\u0627\u060c \u062c\u0631\u0649 \u0646\u0642\u0644 \u0627\u0644\u0627\u0654\u0645 \u0648\u0637\u0641\u0644\u062a\u0647\u0627 \u0639\u0644\u0649 \u0648\u062c\u0647 \u0627\u0644\u0633\u0631\u0639\u0629 \u0639\u0628\u0631 \u0633\u064a\u0627\u0631\u0629 \u0627\u0644\u0627\u0655\u0633\u0639\u0627\u0641 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u0649 \u0627\u0644\u062a\u062e\u0635\u0635\u064a \u0644\u0627\u0633\u062a\u0643\u0645\u0627\u0644 \u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0637\u0628\u064a\u0629 \u0648\u0627\u0644\u0646\u0641\u0633\u064a\u0629 \u0627\u0644\u0644\u0627\u0632\u0645\u0629\u060c \u0648\u0647\u0645\u0627 \u064a\u062a\u0645\u062a\u0639\u0627\u0646 \u0628\u0635\u062d\u0629 \u062c\u064a\u062f\u0629 \u0648\u062d\u0627\u0644\u0629 \u0645\u0633\u062a\u0642\u0631\u0629 \u062a\u0645\u0627\u0645\u0627\u064b.<h2>\u0641\u0631\u064a\u0642 \u0637\u0628\u064a \u0645\u062a\u0645\u064a\u0632</h2>\u0648\u0642\u062f \u0628\u0627\u0634\u0631 \u0627\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0644\u062d\u0627\u0644\u0629 \u0627\u0644\u062d\u0631\u062c\u0629 \u0641\u0631\u064a\u0642 \u0637\u0628\u064a \u0648\u0635\u062d\u064a \u0645\u062a\u0645\u064a\u0632 \u0636\u0645: \u0627\u0644\u0637\u0628\u064a\u0628\u0629 \u0628\u062b\u064a\u0646\u0629 \u0627\u0644\u063a\u0627\u0645\u062f\u064a\u060c \u0648\u062f. \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0642\u0634\u0642\u0631\u064a\u060c \u0648\u062f. \u0627\u0654\u062d\u0645\u062f \u062c\u0648\u0647\u0631\u062c\u064a\u060c \u0648\u062f. \u0639\u0628\u0627\u0633 \u062d\u0644\u0648\u0627\u0646\u064a\u060c \u0648\u0627\u0644\u0645\u0645\u0631\u0636\u0629 \u0631\u0648\u0632\u060c \u0648\u0630\u0644\u0643 \u062a\u062d\u062a \u0627\u0655\u0634\u0631\u0627\u0641 \u0648\u0645\u062a\u0627\u0628\u0639\u0629 \u0645\u0628\u0627\u0634\u0631\u0629 \u0645\u0646 \u0645\u062f\u064a\u0631 \u0627\u0644\u0645\u0631\u0643\u0632 \u062f. \u0627\u0654\u062d\u0645\u062f \u0627\u0644\u0634\u0631\u064a\u0641.<br /><br />\u0648\u064a\u0627\u0654\u062a\u064a \u0647\u0630\u0627 \u0627\u0644\u062a\u062f\u062e\u0644 \u0627\u0644\u0637\u0628\u064a \u0627\u0644\u0646\u0627\u062c\u062d \u0648\u0627\u0644\u0645\u0648\u0641\u0642 \u0636\u0645\u0646 \u062c\u0647\u0648\u062f \u0645\u0633\u0627\u0631 \u0635\u062d\u0629 \u0627\u0644\u0645\u0631\u0627\u0654\u0629 \u0648\u0627\u0644\u0637\u0641\u0644\u060c \u0627\u0644\u0630\u064a \u064a\u0639\u062f \u0627\u0654\u062d\u062f \u0627\u0644\u0645\u0633\u0627\u0631\u0627\u062a \u0627\u0644\u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 \u0644\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0635\u062d\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\u060c \u0628\u0647\u062f\u0641 \u062a\u0642\u062f\u064a\u0645 <a href=\"https://www.alyaum.com/articles/6665074/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B7%D8%A8%D9%8A%D8%A9-%D9%85%D9%83%D8%A9-%D8%AA%D9%82%D9%87%D8%B1-%D8%A7%D9%84%D8%AD%D8%B3%D8%A7%D8%B3%D9%8A%D8%A9-%D8%A7%D9%84%D8%AF%D9%88%D8%A7%D8%A6%D9%8A%D8%A9-%D9%88%D8%AA%D9%86%D9%82%D8%B0-%D8%AD%D8%A7%D8%AC%D8%A9-%D9%85%D8%A7%D9%84%D9%8A%D8%B2%D9%8A%D8%A9-%D8%A8%D8%A8%D8%B1%D9%88%D8%AA%D9%88%D9%83%D9%88%D9%84-%D8%A7%D9%84%D8%A3%D8%B3%D8%A8%D8%B1%D9%8A%D9%86-%D8%A7%D9%84%D9%85%D8%AA%D9%82%D8%AF%D9%85\">\u0631\u0639\u0627\u064a\u0629 \u0635\u062d\u064a\u0629 </a>\u0645\u062a\u0643\u0627\u0645\u0644\u0629\u060c \u0627\u0653\u0645\u0646\u0629\u060c \u0648\u0645\u0633\u062a\u062f\u0627\u0645\u0629 \u0644\u0644\u0627\u0654\u0645 \u0648\u0627\u0644\u0637\u0641\u0644\u060c \u0648\u0627\u0644\u0627\u0631\u062a\u0642\u0627\u0621 \u0628\u062c\u0648\u062f\u0629 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0629 \u0627\u0644\u0645\u0642\u062f\u0645\u0629 \u0644\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646.<br /><br />\u0643\u0645\u0627 \u064a\u0639\u0643\u0633 \u0647\u0630\u0627 \u0627\u0644\u0646\u062c\u0627\u062d \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a \u0627\u0644\u062c\u0627\u0647\u0632\u0