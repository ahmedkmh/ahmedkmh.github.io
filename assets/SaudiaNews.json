45 \u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0631\u0642\u0627\u0628\u0629 \u0648\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u0641\u0633\u0627\u062f \u0628\u0627\u0654\u0646 \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0628\u0627\u0634\u0631\u062a \u0639\u062f\u062f\u0627\u064b \u0645\u0646 \u0627\u0644\u0642\u0636\u0627\u064a\u0627 \u0627\u0644\u062c\u0646\u0627\u064a\u0654\u064a\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629\u060c \u0648\u062c\u0627\u0631\u064d \u0627\u0633\u062a\u0643\u0645\u0627\u0644 \u0627\u0644\u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0646\u0638\u0627\u0645\u064a\u0629 \u0628\u062d\u0642 \u0645\u0631\u062a\u0643\u0628\u064a\u0647\u0627. \u0648\u0643\u0627\u0646\u062a \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0642\u0636\u0627\u064a\u0627 \u0639\u0644\u0649 \u0627\u0644\u0646\u062d\u0648 \u0627\u0644\u0627\u0653\u062a\u064a\u061b \u0627\u0644\u0642\u0636\u064a\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0627\u0655\u064a\u0642\u0627\u0641 \u0631\u062c\u0644 \u0627\u0654\u0639\u0645\u0627\u0644 \u0644\u0642\u064a\u0627\u0645\u0647 \u0628\u0639\u0631\u0636 \u0645\u0628\u0644\u063a 1600000 \u0631\u064a\u0627\u0644 \u0639\u0644\u0649 \u0627\u0654\u062d\u062f \u0627\u0644\u0645\u062e\u0644\u0651\u0635\u064a\u0646 \u0627\u0644\u062c\u0645\u0631\u0643\u064a\u064a\u0646 \u0644\u062a\u0633\u0647\u064a\u0644 \u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u062f\u062e\u0648\u0644 \u00ab\u062d\u0627\u0648\u064a\u062a\u064a \u0634\u062d\u0646\u00bb \u0639\u0628\u0631 \u0645\u064a\u0646\u0627\u0621 \u062c\u062f\u0629 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a \u062a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u0645\u0627\u062f\u0629 \u0627\u0644\u062a\u0628\u063a \u0627\u0644\u0645\u0642\u064a\u062f \u0627\u0633\u062a\u064a\u0631\u0627\u062f\u0647\u060c \u0645\u0642\u0627\u0628\u0644 \u0639\u062f\u0645 \u062f\u0641\u0639 \u0627\u0644\u0631\u063