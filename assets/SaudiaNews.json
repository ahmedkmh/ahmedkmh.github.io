icate": false}, {"article_id": "c32bf9daab7073efc6ced9b9ad0f9bd0", "link": "https://www.alyaum.com/articles/6662228/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%B1%D9%83%D8%B2-%D8%A7%D9%84%D9%85%D9%84%D9%83-%D8%B3%D9%84%D9%85%D8%A7%D9%86-%D9%84%D9%84%D8%A5%D8%BA%D8%A7%D8%AB%D8%A9-%D9%8A%D8%AF%D8%B4%D9%86-%D9%85%D8%B4%D8%B1%D9%88%D8%B9-%D8%AF%D8%B9%D9%85-%D8%A7%D9%84%D8%AE%D8%AF%D9%85%D8%A7%D8%AA-%D8%A7%D9%84%D8%AA%D8%B9%D9%84%D9%8A%D9%85%D9%8A%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D9%8A%D9%85%D9%86", "title": "\u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629 \u064a\u062f\u0634\u0646 \u0645\u0634\u0631\u0648\u0639 \u062f\u0639\u0645 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u0641\u064a \u0627\u0644\u064a\u0645\u0646", "description": "\u062f\u0634\u0646 <a href=\"https://www.alyaum.com/articles/6662225/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D8%B3%D8%AA%D9%81%D8%A7%D8%AF-%D9%85%D9%86%D9%87%D8%A7-24500-%D9%81%D8%B1%D8%AF-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%AA%D9%88%D8%B2%D8%B9-%D9%88%D8%AC%D8%A8%D8%A7%D8%AA-%D8%BA%D8%B0%D8%A7%D8%A6%D9%8A%D8%A9-%D8%B3%D8%A7%D8%AE%D9%86%D8%A9-%D9%81%D9%8A-%D8%BA%D8%B2%D8%A9\">\u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629</a> \u0648\u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0645\u0634\u0631\u0648\u0639 \"\u062f\u0639\u0645 \u0627\u0633\u062a\u0645\u0631\u0627\u0631\u064a\u0629 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u0648\u062a\u0639\u0627\u0641\u064a \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a \u0645\u0646 \u0627\u0653\u062b\u0627\u0631 \u0627\u0644\u0627\u0654\u0632\u0645\u0629 \u0648\u0627\u0644\u0646\u0632\u0648\u062d \u0641\u064a <a href=\"https://www.alyaum.com/articles/6662081/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B1%D8%A6%D9%8A%D8%B3-%D9%88%D9%81%D8%AF-%D8%A7%D9%84%D8%AD%D9%83%D9%88%D9%85%D8%A9-%D8%A7%D9%84%D9%8A%D9%85%D9%86%D9%8A%D8%A9-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%AA%D8%AF%D8%B9%D9%85-%D8%AC%D9%87%D9%88%D8%AF-%D8%AA%D8%B5%D9%81%D9%8A%D8%B1-%D8%B3%D8%AC%D9%88%D9%86-%D8%A7%D9%84%D9%8A%D9%85%D9%86-%D9%85%D9%86-%D8%A7%D9%84%D8%A3%D8%B3%D8%B1%D9%89\">\u0627\u0644\u064a\u0645\u0646</a>\"\u060c \u0628\u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0645\u0639 \u0627\u0644\u0645\u0646\u0638\u0645\u0629 \u0627\u0644\u062f\u0648\u0644\u064a\u0629 \u0644\u0644\u0647\u062c\u0631\u0629.<br /><br />\u0648\u064a\u062a\u0636\u0645\u0646 \u0627\u0644\u0645\u0634\u0631\u0648\u0639 \u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0627\u0654\u0647\u064a\u0644 \u0648\u062a\u0648\u0633\u0639\u0629 (12) \u0645\u062f\u0631\u0633\u0629 \u0645\u0646\u0647\u0627 (4) \u0645\u062f\u0627\u0631\u0633 \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u0639\u062f\u0646\u060c \u0648(3) \u0645\u062f\u0627\u0631\u0633 \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u0644\u062d\u062c\u060c \u0648(5) \u0645\u062f\u0627\u0631\u0633 \u0645\u062d\u0627\u0641\u0638\u0629 \u0641\u064a \u062a\u0639\u0632\u060c \u0634\u0645\u0644\u062a \u0628\u0646\u0627\u0621 (44) \u0641\u0635\u0644\u064b\u0627 \u062f\u0631\u0627\u0633\u064a\u064b\u0627 \u0648\u0645\u0643\u062a\u0628\u064a\u0646 \u0627\u0655\u062f\u0627\u0631\u064a\u064a\u0646\u060c \u0648\u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0627\u0654\u0647\u064a\u0644 (120) \u0641\u0635\u0644\u0627\u064b \u062f\u0631\u0627\u0633\u064a\u064b\u0627 \u0648(10) \u0645\u062e\u062a\u0628\u0631\u0627\u062a\u060c \u0648(13) \u0645\u0643\u062a\u0628\u064b\u0627 \u0627\u0655\u062f\u0627\u0631\u064a\u064b\u0627\u060c \u0648(5) \u0645\u062e\u0627\u0632\u0646 \u0644\u0644\u0645\u0633\u062a\u0644\u0632\u0645\u0627\u062a \u0627\u0644\u062f\u0631\u0627\u0633\u064a\u0629\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0628\u0646\u0627\u0621 (10) \u062f\u0648\u0631\u0627\u062a \u0645\u064a\u0627\u0647\u060c \u0648\u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0627\u0654\u0647\u064a\u0644 (124) \u0627\u0654\u062e\u0631\u0649.<br /> <h2>\u062f\u0639\u0645 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0645\u0633\u062a\u062f\u0627\u0645\u0629</h2>\u0648\u0641\u064a \u0633\u064a\u0627\u0642 \u062f\u0639\u0645 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0645\u0633\u062a\u062f\u0627\u0645\u0629\u060c \u0633\u064a\u0632\u0648\u0651\u062f \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629 (8) \u0645\u062f\u0627\u0631\u0633 \u0628\u0645\u0646\u0638\u0648\u0645\u0627\u062a \u0637\u0627\u0642\u0629 \u0634\u0645\u0633\u064a\u0629\u060c \u0643\u0645\u0627 \u0633\u064a\u062a\u0645 \u062a\u0627\u0654\u062b\u064a\u062b \u0627\u0644\u0645\u062f\u0627\u0631\u0633 \u0648\u0627\u0644\u0645\u0643\u0627\u062a\u0628 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u064a\u0629 \u0628\u0640(1.030) \u0645\u0642\u0639\u062f\u064b\u0627 \u062f\u0631\u0627\u0633\u064a\u064b\u0627 \u0645\u0632\u062f\u0648\u062c\u064b\u0627\u060c \u0648(98) \u0633\u0628\u0648\u0631\u0629 \u0628\u064a\u0636\u0627\u0621\u060c \u0648\u0645\u0639\u062f\u0627\u062a \u0627\u0655\u062f\u0627\u0631\u064a\u0629 \u0648\u0627\u0654\u062c\u0647\u0632\u0629 \u062a\u0642\u0646\u064a\u0629 \u0634\u0645\u0644\u062a \u0637\u0627\u0628\u0639\u0627\u062a \u0648\u062a\u0648\u0635\u064a\u0644\u0627\u062a \u0643\u0647\u0631\u0628\u0627\u064a\u0654\u064a\u0629\u060c \u064a\u0633\u062a\u0641\u064a\u062f \u0645\u0646 \u0627\u0644\u0645\u0634\u0631\u0648\u0639 (18.000) \u0637\u0627\u0644\u0628 \u0648\u0637\u0627\u0644\u0628\u0629.<br /> <br />\u0648\u0627\u0654\u0634\u0627\u062f \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0645\u0643\u062a\u0628 \u0627\u0644\u0641\u0646\u064a \u0628\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062a\u0631\u0628\u064a\u0629 \u0648\u0627\u0644\u062a\u0639\u0644\u064a\u0645 \u0639\u0645\u0631 \u0628\u0627\u0633\u0644\u064a\u0645 \u0628\u0627\u0644\u0645\u0634\u0631\u0648\u0639 \u0627\u0644\u0645\u0645\u0648\u0644 \u0645\u0646 \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629\u060c \u0645\u0648\u0654\u0643\u062f\u064b\u0627 \u0627\u0654\u0646\u0647 \u064a\u0645\u062b\u0644 \u0627\u0655\u0636\u0627\u0641\u0629 \u0645\u0647\u0645\u0629 \u0641\u064a \u0627\u0644\u062a\u0648\u0633\u0639 \u0628\u0627\u0644\u0645\u062f\u0627\u0631\u0633 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0648\u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0627\u0654\u0647\u064a\u0644\u0647\u0627\u060c \u0645\u062b\u0645\u0646\u064b\u0627 \u0627\u0644\u062f\u0648\u0631 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a \u0648\u0627\u0644\u062a\u0646\u0645\u0648\u064a \u0627\u0644\u0630\u064a \u062a\u0636\u0637\u0644\u0639 \u0628\u0647 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0641\u064a \u062f\u0639\u0645 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0633\u062a\u0642\u0631\u0627\u0631\u0647\u0627.<br /> <br />\u0648\u064a\u0627\u0654\u062a\u064a \u0630\u0644\u0643 \u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u0633\u0644\u0633\u0644\u0629<a href=\"https://www.alyaum.com/articles/6662056/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D9%85%D8%B1%D9%83%D8%B2-%D8%A7%D9%84%D9%85%D9%84%D9%83-%D8%B3%D9%84%D9%85%D8%A7%D9%86-%D9%84%D9%84%D8%A5%D8%BA%D8%A7%D8%AB%D8%A9-%D9%8A%D9%88%D8%B2%D8%B9-25-%D8%A3%D9%84%D9%81-%D9%88%D8%AC%D8%A8%D8%A9-%D8%BA%D8%B0%D8%A7%D8%A6%D9%8A%D8%A9-%D8%B3%D8%A7%D8%AE%D9%86%D8%A9-%D9%81%D9%8A-%D8%BA%D8%B2%D8%A9\"> \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0627\u0655\u063a\u0627\u062b\u064a\u0629 </a>\u0648\u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0646\u0641\u0630\u0647\u0627 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0639\u0628\u0631 \u0630\u0631\u0627\u0639\u0647\u0627 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629\u061b \u0644\u0644\u0627\u0631\u062a\u0642\u0627\u0621 \u0628\u0627\u0644\u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u0648\u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u0628\u0646\u0649 \u0627\u0644\u062a\u062d\u062a\u064a\u0629 \u0644\u0644\u0645\u0648\u0654\u0633\u0633\u0627\u062a \u0627\u0644\u062a\u0631\u0628\u0648\u064a\u0629 \u0641\u064a \u0645\u062e\u062a\u0644\u0641 \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0627\u062a \u0627\u0644\u064a\u0645\u0646\u064a\u0629.<br /><br /><br /><br />", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["education", "top"], "datatype": "news", "pubDate": "2026-05-15 22:30:00", "pubDateTZ": "UTC", "fetched_at": "2026-05-15 22:46:34", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN COR