{"status": "success", "totalResults": 4137, "results": [{"article_id": "8d8ef813e6d214a09b24ce1d6f613eab", "link": "https://www.alyaum.com/articles/6658342/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A3%D9%88%D8%A8%D8%A7%D9%85%D8%A7-%D9%8A%D8%B9%D9%84%D9%82-%D8%B9%D9%84%D9%89-%D8%A5%D8%B7%D9%84%D8%A7%D9%82-%D8%A7%D9%84%D9%86%D8%A7%D8%B1-%D9%81%D9%8A-%D8%B9%D8%B4%D8%A7%D8%A1-%D8%A7%D9%84%D8%B1%D8%A6%D9%8A%D8%B3-%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%85%D8%A7%D8%B0%D8%A7-%D9%82%D8%A7%D9%84", "title": "\u0627\u0654\u0648\u0628\u0627\u0645\u0627 \u064a\u0639\u0644\u0642 \u0639\u0644\u0649 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631 \u0641\u064a \u0639\u0634\u0627\u0621 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u062a\u0631\u0627\u0645\u0628.. \u0645\u0627\u0630\u0627 \u0642\u0627\u0644\u061f", "description": "\u062f\u0639\u0627 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u0627\u0644\u0633\u0627\u0628\u0642 <a href=\"https://www.alyaum.com/articles/6606058/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A8%D8%B3%D8%A8%D8%A8-%D8%A7%D8%AF%D8%B9%D8%A7%D8%A1%D8%A7%D8%AA-%D8%A7%D9%84%D8%AA%D8%AF%D8%AE%D9%84-%D8%A7%D9%84%D8%B1%D9%88%D8%B3%D9%8A-%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%8A%D8%AA%D9%87%D9%85-%D8%A3%D9%88%D8%A8%D8%A7%D9%85%D8%A7-%D8%A8%D8%A7%D9%84%D8%AE%D9%8A%D8%A7%D9%86%D8%A9-%D9%88%D9%8A%D8%AF%D8%B9%D9%88-%D9%84%D9%85%D8%AD%D8%A7%D9%83%D9%85%D8%AA%D9%87\" target=\"_blank\">\u0628\u0627\u0631\u0627\u0643 \u0627\u0654\u0648\u0628\u0627\u0645\u0627</a> \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u064a\u0646 \u0627\u0655\u0644\u0649 \u0646\u0628\u0630 \u0627\u0644\u0639\u0646\u0641 \u0641\u064a \u0627\u0654\u0639\u0642\u0627\u0628 \u0627\u0642\u062a\u062d\u0627\u0645 \u0645\u0647\u0627\u062c\u0645 \u0639\u0634\u0627\u0621 \u0645\u0631\u0627\u0633\u0644\u064a \u0627\u0644\u0628\u064a\u062a \u0627\u0644\u0627\u0654\u0628\u064a\u0636 \u0627\u0644\u0630\u064a \u0643\u0627\u0646 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u062f\u0648\u0646\u0627\u0644\u062f <a href=\"https://www.alyaum.com/articles/6658244/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A7%D9%84%D9%85%D8%A4%D8%AB%D8%B1%D9%88%D9%86-%D9%87%D9%85-%D8%A7%D9%84%D9%85%D8%B3%D8%AA%D9%87%D8%AF%D9%81%D9%88%D9%86-%D8%AA%D8%B9%D9%84%D9%8A%D9%82-%D8%AC%D8%AF%D9%8A%D8%AF-%D9%85%D9%86-%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D8%B9%D9%84%D9%89-%D8%A5%D8%B7%D9%84%D8%A7%D9%82-%D8%A7%D9%84%D9%86%D8%A7%D8%B1-%D8%A8%D9%88%D8%A7%D8%B4%D9%86%D8%B7%D9%86\" target=\"_blank\">\u062a\u0631\u0627\u0645\u0628</a> \u064a\u062d\u0636\u0631\u0647.<br />\u0648\u0643\u062a\u0628 <a href=\"https://www.alyaum.com/articles/6643766/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A7%D9%84%D8%A8%D9%8A%D8%AA-%D8%A7%D9%84%D8%A3%D8%A8%D9%8A%D8%B6-%D9%8A%D8%AD%D8%B0%D9%81-%D9%81%D9%8A%D8%AF%D9%8A%D9%88-%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D8%A7%D9%84%D9%85%D8%B3%D9%8A%D8%A1-%D9%84%D8%A3%D9%88%D8%A8%D8%A7%D9%85%D8%A7-%D9%88%D8%B2%D9%88%D8%AC%D8%AA%D9%87-%D9%88%D9%8A%D9%88%D8%B6%D8%AD-%D8%A7%D9%84%D9%85%D8%B3%D8%A4%D9%88%D9%84\" target=\"_blank\">\u0627\u0654\u0648\u0628\u0627\u0645\u0627</a> \u0641\u064a \u0645\u0646\u0634\u0648\u0631 \u0639\u0644\u0649 \u0645\u0646\u0635\u0629 \u0627\u0655\u0643\u0633: \"\u0639\u0644\u0649 \u0627\u0644\u0631\u063a\u0645 \u0645\u0646 \u0627\u0654\u0646\u0646\u0627 \u0644\u0627 \u0646\u0645\u0644\u0643 \u062d\u062a\u0649 \u0627\u0644\u0627\u0653\u0646 \u062a\u0641\u0627\u0635\u064a\u0644 \u0639\u0646 \u0627\u0644\u062f\u0648\u0627\u0641\u0639 \u0648\u0631\u0627\u0621 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631 \u0627\u0644\u0644\u064a\u0644\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629 \u062e\u0644\u0627\u0644 \u0639\u0634\u0627\u0621 \u0645\u0631\u0627\u0633\u0644\u064a \u0627\u0644\u0628\u064a\u062a \u0627\u0644\u0627\u0654\u0628\u064a\u0636\u060c \u0641\u0627\u0655\u0646\u0647 \u064a\u062a\u0639\u064a\u0646 \u0639\u0644\u064a\u0646\u0627 \u062c\u0645\u064a\u0639\u064b\u0627 \u0646\u0628\u0630 \u0641\u0643\u0631\u0629 \u0627\u0654\u0646 \u064a\u0643\u0648\u0646 \u0644\u0644\u0639\u0646\u0641 \u0627\u0654\u064a \u0645\u0643\u0627\u0646 \u0641\u064a \u062f\u064a\u0645\u0648\u0642\u0631\u0627\u0637\u064a\u062a\u0646\u0627\".<br />\u0648\u0627\u0654\u062b\u0646\u0649 \u0639\u0644\u0649 \u0636\u0628\u0627\u0637 \u0627\u0655\u0646\u0641\u0627\u0630 \u0627\u0644\u0642\u0627\u0646\u0648\u0646 \u0627\u0644\u0630\u064a\u0646 \u0633\u0627\u0631\u0639\u0648\u0627 \u0644\u062d\u0645\u0627\u064a\u0629 \u062a\u0631\u0627\u0645\u0628.<h2>\u0627\u0642\u062a\u062d\u0627\u0645 \u062d\u0641\u0644 \u0627\u0644\u0639\u0634\u0627\u0621</h2><p>\u062a\u0631\u062c\u062d<a href=\"https://www.alyaum.com/articles/6657651/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%88%D9%81%D8%A7%D8%A9-%D8%B4%D8%AE%D8%B5%D9%8A%D9%86-%D9%88%D8%A5%D8%B5%D8%A7%D8%A8%D8%A9-19-%D8%A5%D8%AB%D8%B1-%D8%AA%D8%B3%D8%B1%D8%A8-%D9%83%D9%8A%D9%85%D9%8A%D8%A7%D8%A6%D9%8A-%D9%81%D9%8A-%D9%85%D8%B5%D9%86%D8%B9-%D8%A8%D9%81%D8%B1%D8%AC%D9%8A%D9%86%D9%8A%D8%A7-%D8%A7%D9%84%D8%BA%D8%B1%D8%A8%D9%8A%D8%A9\" target=\"_blank\"> \u0627\u0644\u0633\u0644\u0637\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629</a> \u0627\u0654\u0646 \u0627\u0644\u0645\u0633\u0644\u062d \u0627\u0644\u0630\u064a \u0627\u0654\u0648\u0642\u0641 \u0628\u0639\u062f\u0645\u0627 \u062d\u0627\u0648\u0644 \u0627\u0642\u062a\u062d\u0627\u0645 \u062d\u0641\u0644 \u0639\u0634\u0627\u0621 \u0645\u0631\u0627\u0633\u0644\u064a <a href=\"https://www.alyaum.com/articles/6658206/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D8%B7%D9%88%D8%B1-%D8%A3%D9%84%D8%B9%D8%A7%D8%A8-%D9%88%D9%85%D9%86-%D9%85%D9%86%D8%A7%D8%B5%D8%B1%D9%8A-%D8%AD%D8%B2%D8%A8-%D8%A8%D8%A7%D9%8A%D8%AF%D9%86-%D9%85%D9%86-%D9%87%D9%88-