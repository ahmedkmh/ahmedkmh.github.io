%D8%A7%D9%84%D9%81%D9%86/%D8%AB%D9%82%D8%A7%D9%81%D8%A9/%D8%A7%D9%84%D8%A3%D9%88%D8%B3%D9%83%D8%A7%D8%B1-%D8%AA%D8%AA%D9%88%D8%AC-%D9%88%D8%A7%D9%86-%D8%A8%D8%A7%D8%AA%D9%84-%D8%A3%D9%81%D8%AA%D8%B1-%D8%A3%D9%86%D8%A7%D8%B0%D8%B1-%D8%A3%D9%81%D8%B6%D9%84-%D9%81%D9%8A%D9%84%D9%85-%D9%88%D9%85%D8%A7%D9%8A%D9%83%D9%84-%D8%A8%D9%8A-%D8%AC%D9%88%D8%B1%D8%AF%D8%A7%D9%86-%D8%A3%D9%81%D8%B6%D9%84-%D9%85%D9%85%D8%AB%D9%84", "title": "\u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u062a\u062a\u0648\u062c \u201c\u0648\u0627\u0646 \u0628\u0627\u062a\u0644 \u0627\u0654\u0641\u062a\u0631 \u0627\u0654\u0646\u0627\u0630\u0631\u201d \u0627\u0654\u0641\u0636\u0644 \u0641\u064a\u0644\u0645 \u0648\u0645\u0627\u064a\u0643\u0644 \u0628\u064a \u062c\u0648\u0631\u062f\u0627\u0646 \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644", "description": "\u0641\u0627\u0632 \u0641\u064a\u0644\u0645 \"\u0648\u0627\u0646 \u0628\u0627\u062a\u0644 \u0627\u0654\u0641\u062a\u0631 \u0627\u0654\u0646\u0627\u0630\u0631\" \u0628\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0641\u064a \u0641\u064a\u0654\u0629 \u0627\u0654\u0641\u0636\u0644 \u0641\u064a\u0644\u0645\u060c \u062e\u0644\u0627\u0644 \u062d\u0641\u0644\u0629 \u062a\u0648\u0632\u064a\u0639 \u062c\u0648\u0627\u064a\u0654\u0632 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0627\u0644\u062b\u0627\u0645\u0646\u0629 \u0648\u0627\u0644\u062a\u0633\u0639\u064a\u0646.\u0648\u062a\u0646\u0627\u0641\u0633\u062a \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u062c\u0627\u064a\u0654\u0632\u0629 \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0641\u064a\u0644\u0645 \u0627\u0644\u0641\u0627\u064a\u0654\u0632\u060c \u0627\u0654\u0641\u0644\u0627\u0645 \"\u0628\u0648\u063a\u0648\u0646\u064a\u0627\" \u0648\"\u0627\u0655\u0641 1\" \u0648\"\u0641\u0631\u0627\u0646\u0643\u0646\u0634\u062a\u0627\u064a\u0646\" \u0648\"\u0647\u0627\u0645\u0646\u062a\" \u0648\"\u0645\u0627\u0631\u062a\u064a \u0633\u0648\u0628\u0631\u064a\u0645\" \u0648\"\u0630\u064a \u0633\u064a\u0643\u0631\u062a \u0627\u0655\u064a\u062c\u0646\u062a\" \u0648\"\u0633\u0646\u062a\u064a\u0645\u0646\u062a\u0644 \u0641\u0627\u0644\u064a\u0648\" \u0648\"\u0633\u064a\u0646\u0631\u0632\" \u0648\"\u062a\u0631\u0627\u064a\u0646 \u062f\u0631\u064a\u0645\u0632\".\u0645\u0627\u064a\u0643\u0644 \u0628\u064a. \u062c\u0648\u0631\u062f\u0627\u0646 \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644\u0641\u0627\u0632 \u0645\u0627\u064a\u0643\u0644 \u0628\u064a. \u062c\u0648\u0631\u062f\u0627\u0646 \u0628\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0641\u064a \u0641\u064a\u0654\u0629 \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644 \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0633\u064a\u0646\u0631\u0632\" \u062e\u0644\u0627\u0644 \u062d\u0641\u0644\u0629 \u062a\u0648\u0632\u064a\u0639 \u062c\u0648\u0627\u064a\u0654\u0632 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0627\u0644\u062b\u0627\u0645\u0646\u0629 \u0648\u0627\u0644\u062a\u0633\u0639\u064a\u0646.\u0648\u062a\u0646\u0627\u0641\u0633 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0641\u064a\u0654\u0629 \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0641\u0627\u064a\u0654\u0632\u060c \u062a\u064a\u0645\u0648\u062b\u064a \u0634\u0627\u0644\u0627\u0645\u064a\u0647 \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0645\u0627\u0631\u062a\u064a \u0633\u0648\u0628\u0631\u064a\u0645\" \u0648\u0644\u064a\u0648\u0646\u0627\u0631\u062f\u0648 \u062f\u064a \u0643\u0627\u0628\u0631\u064a\u0648 \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0648\u0627\u0646 \u0628\u0627\u062a\u0644 \u0627\u0654\u0641\u062a\u0631 \u0627\u0654\u0646\u0627\u0630\u0631\" \u0648\u0627\u0655\u064a\u062b\u0627\u0646 \u0647\u0648\u0643 \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0628\u0644\u0648 \u0645\u0648\u0646\" \u0648\u0641\u0627\u063a\u0646\u0631 \u0645\u0648\u0631\u0627 \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0630\u064a \u0633\u064a\u0643\u0631\u062a \u0627\u0655\u064a\u062c\u0646\u062a\".\u062c\u064a\u0633\u064a \u0628\u0627\u0643\u0644\u064a \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644\u0629\u0641\u0627\u0632\u062a \u062c\u064a\u0633\u064a \u0628\u0627\u0643\u0644\u064a \u0628\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0641\u064a \u0641\u064a\u0654\u0629 \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644\u0629 \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \"\u0647\u0627\u0645\u0646\u062a\" \u062e\u0644\u0627\u0644 \u062d\u0641\u0644\u0629 \u062a\u0648\u0632\u064a\u0639 \u062c\u0648\u0627\u064a\u0654\u0632 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0627\u0644\u062b\u0627\u0645\u0646\u0629 \u0648\u0627\u0644\u062a\u0633\u0639\u064a\u0646.\u0648\u062a\u0646\u0627\u0641\u0633\u062a \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0641\u064a\u0654\u0629 \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0641\u0627\u064a\u0654\u0632\u0629\u060c \u0631\u0648\u0632 \u0628\u064a\u0631\u0646 \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \"\u0627\u0655\u064a\u0641 \u0627\u0653\u064a \u0647\u0627\u062f \u0644\u064a\u063a\u0632 \u0627\u0654\u064a\u062f \u0643\u064a\u0643 \u064a\u0648\" \u0648\u0643\u0627\u064a\u062a \u0647\u062f\u0633\u0648\u0646 \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \"\u0633\u0648\u0646\u063a \u0633\u0627\u0646\u063a \u0628\u0644\u0648\" \u0648\u0631\u064a\u0646\u0627\u062a\u064a \u0631\u0627\u064a\u0646\u0633\u0641\u064a \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \"\u0633\u0646\u062a\u064a\u0645\u0646\u062a\u0644 \u0641\u0627\u0644\u064a\u0648\" \u0648\u0627\u0655\u064a\u0645\u0627 \u0633\u062a\u0648\u0646 \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \"\u0628\u0648\u063a\u0648\u0646\u064a\u0627\".\u0628\u0648\u0644 \u062a\u0648\u0645\u0627\u0633 \u0627\u0654\u0646\u062f\u0631\u0633\u0648\u0646 \u0627\u0654\u0641\u0636\u0644 \u0645\u062e\u0631\u062c\u0641\u0627\u0632 \u0628\u0648\u0644 \u062a\u0648\u0645\u0627\u0633 \u0627\u0654\u0646\u062f\u0631\u0633\u0648\u0646 \u0628\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0639\u0646 \u0641\u064a\u0654\u0629 \u0627\u0654\u0641\u0636\u0644 \u0645\u062e\u0631\u062c \u0644\u0641\u064a\u0644\u0645 \"\u0648\u0627\u0646 \u0628\u0627\u062a\u0644 \u0627\u0654\u0641\u062a\u0631 \u0627\u0654\u0646\u0627\u0630\u0631\".\u0648\u062a\u0646\u0627\u0641\u0633 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u062c\u0627\u064a\u0654\u0632\u0629 \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646\u062f\u0631\u0633\u0648\u0646\u060c \u0631\u0627\u064a\u0646 \u0643\u0648\u063a\u0644\u0631 \u0639\u0646 \"\u0633\u064a\u0646\u0631\u0632\"\u060c \u0648\u0643\u0644\u0648\u064a \u062a\u0634\u0627\u0648 \u0639\u0646 \"\u0647\u0627\u0645\u0646\u062a\" \u0648\u062c\u0648\u0634 \u0635\u0641\u062f\u064a \u0639\u0646 \"\u0645\u0627\u0631\u062a\u064a \u0633\u0648\u0628\u0631\u064a\u0645\" \u0648\u064a\u0648\u0627\u0643\u064a\u0645 \u062a\u0631\u0627\u064a\u0631 \u0639\u0646 \"\u0633\u0646\u062a\u064a\u0645\u0646\u062a\u0644 \u0641\u0627\u0644\u064a\u0648\". \"\u0633\u0646\u062a\u064a\u0645\u0646\u062a\u0644 \u0641\u0627\u0644\u064a\u0648\" \u0627\u0654\u0641\u0636\u0644 \u0641\u064a\u0644\u0645 \u062f\u0648\u0644\u064a\u0641\u0627\u0632 \u0641\u064a\u0644\u0645 \"\u0633\u0646\u062a\u064a\u0645\u0646\u062a\u0644 \u0641\u0627\u0644\u064a\u0648\" \u0628\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0627\u0654\u0641\u0636\u0644 \u0641\u064a\u0644\u0645 \u062f\u0648\u0644\u064a.\u0648\u062a\u0646\u0627\u0641\u0633 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0641\u064a\u0654\u0629 \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0641\u064a\u0644\u0645 \u0627\u0644\u0641\u0627\u064a\u0654\u0632\u060c \"\u0630\u064a \u0633\u064a\u0643\u0631\u062a \u0627\u0655\u064a\u062c\u0646\u062a\" (\u0627\u0644\u0628\u0631\u0627\u0632\u064a\u0644) \u0648\"\u0627\u0655\u062a \u0648\u0627\u0632 \u062c\u0633\u062a \u0627\u0654\u0646 \u0627\u0654\u0643\u0633\u064a\u062f\u0646\u062a\" (\u0641\u0631\u0646\u0633\u0627) \u0648\"\u0633\u064a\u0631\u0627\u062a\" (\u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627) \u0648\"\u0635\u0648\u062a \u0647\u0646\u062f \u0631\u062c\u0628\" (\u062a\u0648\u0646\u0633).\u0634\u0648\u0646 \u0628\u0646 \u064a\u0641\u0648\u0632 \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644 \u0641\u064a \u062f\u0648\u0631 \u062b\u0627\u0646\u0648\u064a\u0641\u0627\u0632 \u0634\u0648\u0646 \u0628\u0646 \u0627\u0644\u0627\u0654\u062d\u062f \u0628\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0639\u0646 \u0641\u064a\u0654\u0629 \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644 \u0641\u064a \u062f\u0648\u0631 \u062b\u0627\u0646\u0648\u064a \u0641\u064a \u0641\u064a\u0644\u0645 \"\u0648\u0627\u0646 \u0628\u0627\u062a\u0644 \u0627\u0654\u0641\u062a\u0631 \u0627\u0654\u0646\u0627\u0630\u0631\".\u0648\u062a\u0646\u0627\u0641\u0633 \u0634\u0648\u0646 \u0628\u0646 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u062c\u0627\u064a\u0654\u0632\u0629 \u0645\u0639 \u0628\u064a\u0646\u064a\u0633\u064a\u0648 \u062f\u064a\u0644 \u062a\u0648\u0631\u0648 \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0648\u0627\u0646 \u0628\u0627\u062a\u0644 \u0627\u0654\u0641\u062a\u0631 \u0627\u0654\u0646\u0627\u0630\u0631\" \u0648\u062c\u0627\u064a\u0643\u0648\u0628 \u0627\u0655\u0644\u0648\u0631\u062f\u064a \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0641\u0631\u0627\u0646\u0643\u0646\u0634\u062a\u0627\u064a\u0646\" \u0648\u062f\u064a\u0644\u0631\u0648\u064a \u0644\u064a\u0646\u062f\u0648 \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0633\u064a\u0646\u0631\u0632\" \u0648\u0633\u062a\u064a\u0644\u0627\u0646 \u0633\u0643\u0627\u0631\u0633\u063a\u0627\u0631\u062f \u0639\u0646 \u062f\u0648\u0631\u0647 \u0641\u064a \"\u0633\u0646\u062a\u064a\u0645\u0646\u062a\u0644 \u0641\u0627\u0644\u064a\u0648\".\u0627\u0655\u064a\u0645\u064a \u0645\u0627\u062f\u064a\u063a\u0627\u0646 \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644\u0629 \u0641\u064a \u062f\u0648\u0631 \u062b\u0627\u0646\u0648\u064a\u0641\u0627\u0632\u062a \u0627\u0655\u064a\u0645\u064a \u0645\u0627\u062f\u064a\u063a\u0627\u0646 \u0627\u0644\u0627\u0654\u062d\u062f \u0628\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0627\u0654\u0648\u0633\u0643\u0627\u0631 \u0639\u0646 \u0641\u064a\u0654\u0629 \u0627\u0654\u0641\u0636\u0644 \u0645\u0645\u062b\u0644\u0629 \u0641\u064a \u062f\u0648\u0631 \u062b\u0627\u0646\u0648\u064a \u0641\u064a \u0641\u064a\u0644\u0645 \u0627\u0644\u0631\u0639\u0628 \"\u0648\u064a\u0628\u0646\u0632\".\u0648\u062a\u0646\u0627\u0641\u0633\u062a \u0645\u0627\u062f\u064a\u063a\u0627\u0646 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u062c\u0627\u064a\u0654\u0632\u0629 \u0645\u0639 \u0627\u0644\u0645\u0645\u062b\u0644\u0627\u062a \u0627\u0655\u064a\u0644 \u0641\u0627\u0646\u064a\u0646\u063a \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \"\u0633\u0646\u062a\u064a\u0645\u0646\u062a\u0644 \u0641\u0627\u0644\u064a\u0648\" \u0648\u0627\u0655\u0646\u063a\u0627 \u0627\u0655\u0628\u0633\u062f\u0648\u062a\u0631 \u0644\u064a\u0644\u064a\u0627\u0633 \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \u0627\u0644\u0641\u064a\u0644\u0645 \u0646\u0641\u0633\u0647\u060c \u0648\u0648\u0646\u0645\u064a \u0645\u0648\u0633\u0627\u0643\u0648 \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \"\u0633\u064a\u0646\u0631\u0632\" \u0648\u062a\u064a\u0627\u0646\u0627 \u062a\u0627\u064a\u0644\u0648\u0631 \u0639\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a 