le_id": "bc5014a307da7bdbe08010e249d3dd92", "link": "https://www.alyaum.com/articles/6655502/%D8%A7%D9%84%D9%85%D9%8A%D8%AF%D8%A7%D9%86-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6%D9%8A/%D8%A7%D9%84%D8%AF%D9%88%D8%B1%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A/%D8%A7%D9%84%D8%AE%D9%84%D9%88%D8%AF-%D9%8A%D8%AD%D9%82%D9%82-%D8%A7%D9%86%D8%AA%D8%B5%D8%A7%D8%B1%D8%A7-%D8%AB%D9%85%D9%8A%D9%86%D8%A7-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%AA%D8%B9%D8%A7%D9%88%D9%86-%D9%81%D9%8A-%D8%B1%D9%88%D8%B4%D9%86", "title": "\u0627\u0644\u062e\u0644\u0648\u062f \u064a\u062d\u0642\u0642 \u0627\u0646\u062a\u0635\u0627\u0631\u064b\u0627 \u062b\u0645\u064a\u0646\u064b\u0627 \u0639\u0644\u0649 \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0641\u064a \u0631\u0648\u0634\u0646", "description": "\u0633\u0642\u0637 \u0646\u0627\u062f\u064a \u0627\u0644\u062a\u0639\u0627\u0648\u0646\u060c \u0641\u064a \u0641\u062e \u0627\u0644\u0647\u0632\u064a\u0645\u0629 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u062e\u0644\u0648\u062f\u060c \u0628\u0647\u062f\u0641\u064a\u0646 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641 \u0648\u062d\u064a\u062f\u060c \u0641\u064a \u0627\u0644\u0644\u0642\u0627\u0621 \u0627\u0644\u0630\u064a \u062c\u0645\u0639 \u0627\u0644\u0641\u0631\u064a\u0642\u064a\u0646\u060c \u0636\u0645\u0646 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062a\u0627\u0633\u0639\u0629 \u0648\u0627\u0644\u0639\u0634\u0631\u064a\u0646 \u0645\u0646 \u0645\u0633\u0627\u0628\u0642\u0629 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0644\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646\u060c \u0648\u0627\u0644\u062a\u064a \u0627\u0654\u0642\u064a\u0645\u062a \u0639\u0644\u0649 \u0627\u0654\u0631\u0636\u064a\u0629 \u0645\u0644\u0639\u0628 \u0627\u0644\u0645\u0644\u0643 \u0639\u0628\u062f\u0627\u0644\u0644\u0647 \u0628\u0628\u0631\u064a\u062f\u0629.<br /><br />\u0648\u062c\u0627\u0621\u062a \u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0646\u0627\u062f\u064a \u0627\u0644\u062e\u0644\u0648\u062f \u0639\u0646 \u0637\u0631\u064a\u0642 \u0634\u0627\u0643\u064a\u0644 \u0628\u064a\u0646\u0627\u0633 (4)\u060c \u0648\u0633\u062c\u0644 \u063a\u0648\u063a\u0627 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u062b\u0627\u0646\u064a (23) \u0645\u0646 \u0639\u0645\u0631 \u0627\u0644\u0644\u0642\u0627\u0621\u060c \u0628\u064a\u0646\u0645\u0627 \u062c\u0627\u0621 \u0647\u062f\u0641 \u0646\u0627\u062f\u064a \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0627\u0644\u0648\u062d\u064a\u062f \u0639\u0646 \u0637\u0631\u064a\u0642 \u0644\u0627\u0639\u0628 \u0627\u0644\u0641\u0631\u064a\u0642 \u0645\u062d\u0645\u062f \u0627\u0644\u062f\u0648\u0633\u0631\u064a (8).<br /><br />\u0648\u0627\u0631\u062a\u0641\u0639 \u0631\u0635\u064a\u062f \u0646\u0627\u062f\u064a \u0627\u0644\u062e\u0644\u0648\u062f \u0627\u0655\u0644\u0649 \u0627\u0644\u0646\u0642\u0637\u0629 (29) \u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0644\u062b \u0639\u0634\u0631 \u0628\u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u0645\u0633\u0627\u0628\u0642\u0629 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0644\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646\u060c \u0628\u064a\u0646\u0645\u0627 \u062a\u062c\u0645\u062f \u0631\u0635\u064a\u062f \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0639\u0646\u062f \u0627\u0644\u0646\u0642\u0637\u0629 (46) \u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062e\u0627\u0645\u0633 \u0628\u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u0627\u0644\u062f\u0648\u0631\u064a.<br /><br />\u0627\u0644\u0644\u0642\u0627\u0621 \u0628\u062f\u0627\u0654 \u0628\u0636\u063a\u0637 \u0645\u0628\u0643\u0631 \u0645\u0646 \u062c\u0627\u0646\u0628 \u0646\u0627\u062f\u064a \u0627\u0644\u062a\u0639\u0627\u0648\u0646\u060c \u0648\u0630\u0644\u0643 \u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u0627\u0654\u0648\u0644 \u0641\u064a \u0634\u0628\u0627\u0643 \u0646\u0627\u062f\u064a \u0627\u0644\u062e\u0644\u0648\u062f\u060c \u0648\u062e\u0637\u0641 \u0627\u0644\u0646\u0642\u0627\u0637 \u0627\u0644\u062b\u0644\u0627\u062b \u0645\u0646 \u0627\u0644\u0644\u0642\u0627\u0621\u060c \u0648\u0645\u0648\u0627\u0635\u0644\u0629 \u0627\u0644\u062a\u0642\u062f\u0645 \u0628\u0627\u0644\u062c\u062f\u0648\u0644.<br /><br />\u0648\u0639\u0644\u0649 \u0639\u0643\u0633 \u0633\u064a\u0631 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629\u060c \u062a\u062d\u0635\u0644 \u0646\u0627\u062f\u064a \u0627\u0644\u062e\u0644\u0648\u062f \u0639\u0644\u0649 \u0631\u0643\u0644\u0629 \u062c\u0632\u0627\u0621\u060c \u062a\u0645\u0643\u0646 \u0634\u0627\u0643\u064a\u0644 \u0628\u064a\u0646\u0627\u0633 \u0644\u0627\u0639\u0628 \u0627\u0644\u0641\u0631\u064a\u0642 \u0645\u0646 \u062a\u062d\u0648\u064a\u0644\u0647\u0627 \u062f\u0627\u062e\u0644 \u0627\u0644\u0634\u0628\u0627\u0643 \u0644\u064a\u0633\u062c\u0644 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u0627\u0654\u0648\u0644 \u0641\u064a \u0634\u0628\u0627\u0643 \u0627\u0644\u062a\u0639\u0627\u0648\u0646 (4).<br /><br />\u0648\u0646\u062c\u062d \u0627\u0644\u062a\u0639\u0627\u0648\u0646\u060c \u0641\u064a \u0645\u0639\u0627\u062f\u0644\u0629 \u0627\u0644\u0646\u062a\u064a\u062c\u0629\u060c \u0639\u0646 \u0637\u0631\u064a\u0642 \u0645\u062f\u0627\u0641\u0639\u0647 \u0645\u062d\u0645\u062f \u0627\u0644\u062f\u0648\u0633\u0631\u064a\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0654\u062a\u064a\u062d\u062a \u0644\u0647 \u0643\u0631\u0629\u060c \u0646\u062c\u062d \u0641\u064a \u062a\u062d\u0648\u064a\u0644\u0647\u0627 \u062f\u0627\u062e\u0644 \u0634\u0628\u0627\u0643 \u0643\u0648\u0632\u0646\u064a \u062d\u0627\u0631\u0633 \u0627\u0644\u062e\u0644\u0648\u062f (8).<br /><br />\u0648\u0639\u0627\u062f \u0646\u0627\u062f\u064a \u0627\u0644\u062e\u0644\u0648\u062f \u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u062b\u0627\u0646\u064a\u060c \u0639\u0646 \u0637\u0631\u064a\u0642 \u063a\u0648\u063a\u0627\u060c \u0628\u0639\u062f \u062a\u0645\u0631\u064a\u0631\u0629 \u0645\u0646 \u062c\u0627\u0646\u0628 \u0647\u062a\u0627\u0646 \u0628\u0627\u0647\u0628\u0631\u064a\u060c \u0646\u062c\u062d \u0632\u0645\u064a\u0644\u0647 \u0628\u0627\u0644\u0641\u0631\u064a\u0642 \u0641\u064a \u062a\u062d\u0648\u064a\u0644\u0647\u0627 \u062f\u0627\u062e\u0644 \u0627\u0644\u0634\u0628\u0627\u0643 (23).<br /><br />\u0648\u0644\u0645 \u062a\u0646\u062c\u062d \u0645\u062d\u0627\u0648\u0644\u0627\u062a \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0641\u064a \u0645\u0639\u0627\u062f\u0644\u0629 \u0627\u0644\u0646\u062a\u064a\u062c\u0629\u060c \u0644\u064a\u0646\u062a\u0647\u064a \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u0627\u0654\u0648\u0644\u060c \u0628\u062a\u0642\u062f\u0645 \u0646\u0627\u062f\u064a \u0627\u0644\u062e\u0644\u0648\u062f \u0628\u0647\u062f\u0641\u064a\u0646 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641 \u0648\u062d\u064a\u062f \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0627\u0654\u0635\u062d\u0628\u0627 \u0627\u0644\u0627\u0654\u0631\u0636.<br /><br />\u0648\u0634\u0647\u062f \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u062b\u0627\u0646\u064a \u0645\u062d\u0627\u0648\u0644\u0627\u062a \u0645\u0646 \u062c\u0627\u0646\u0628 \u0646\u0627\u062f\u064a \u0627\u0644\u062a\u0639\u0627\u0648\u0646\u060c \u0648\u0630\u0644\u0643 \u0645\u0646 \u0627\u0654\u062c\u0644 \u062a\u0639\u062f\u064a\u0644 \u0646\u062a\u064a\u062c\u0629 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629\u060c \u0648\u0633\u0637 \u062a\u0645\u0631\u0643\u0632 \u062f\u0641\u0627\u0639\u064a \u062c\u064a\u062f \u0645\u0646 \u062c\u0627\u0646\u0628 \u0627\u0644\u062e\u0644\u0648\u062f \u0641\u064a \u0648\u0633\u0637 \u0627\u0644\u0645\u0644\u0639\u0628\u060c \u0644\u064a\u0646\u062a\u0647\u064a \u0627\u0644\u0644\u0642\u0627\u0621 \u0628\u0627\u0646\u062a\u0635\u0627\u0631 \u0627\u0644\u062e\u0644\u0648\u062f \u0628\u0647\u062f\u0641\u064a\u0646 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641 \u