3\u0627\u062a\u0647\u0645 \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644\u064a\u0629.<br /><br />\u0648\u062c\u0627\u0621 \u0647\u0630\u0627 \u0627\u0644\u062a\u0642\u062f\u0645 \u0628\u0639\u062f \u0627\u0654\u062f\u0627\u0621 \u0645\u062b\u064a\u0631 \u0642\u062f\u0645\u0647 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0645\u0635\u0631\u064a \u0627\u0654\u0645\u0627\u0645 \u0646\u064a\u0648\u0632\u064a\u0644\u0646\u062f\u0627\u060c \u062d\u064a\u062b \u0642\u0644\u0628 \u062a\u0627\u0654\u062e\u0631\u0647 \u0628\u0647\u062f\u0641 \u0641\u064a \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u0627\u0654\u0648\u0644 \u0627\u0655\u0644\u0649 \u0641\u0648\u0632 \u0645\u0633\u062a\u062d\u0642 \u0628\u062b\u0644\u0627\u062b\u0629 \u0627\u0654\u0647\u062f\u0627\u0641 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641\u060c \u0644\u064a\u0643\u062a\u0628 \u0635\u0641\u062d\u0629 \u062c\u062f\u064a\u062f\u0629 \u0641\u064a \u0633\u062c\u0644\u0627\u062a\u0647 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629 \u0648\u064a\u0643\u0633\u0631 \u0639\u0642\u062f\u0629 \u0637\u0648\u064a\u0644\u0629 \u0644\u0627\u0632\u0645\u062a\u0647 \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629.<br /><br />\u0648\u0628\u0647\u0630\u0627 \u0627\u0644\u0641\u0648\u0632\u060c \u0635\u0639\u062f \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u064026 \u0639\u0627\u0644\u0645\u064a\u0627\u064b\u060c \u0644\u064a\u062d\u062a\u0644 \u0627\u0654\u064a\u0636\u0627\u064b \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0631\u0627\u0628\u0639 \u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0642\u0627\u0631\u0629 \u0627\u0644\u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0629\u060c \u0641\u064a \u0627\u0646\u0639\u0643\u0627\u0633 \u0645\u0628\u0627\u0634\u0631 \u0644\u062a\u0637\u0648\u0631 \u0627\u0644\u0627\u0654\u062f\u0627\u0621 \u0648\u0627\u0644\u0646\u062a\u0627\u064a\u0654\u062c \u0