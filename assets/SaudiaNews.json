alyaum.com/articles/6661941/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%BA%D8%B0%D8%A7%D8%A1-%D9%88%D8%A7%D9%84%D8%AF%D9%88%D8%A7%D8%A1-%D9%85%D8%B9%D8%A7%D9%8A%D9%8A%D8%B1-%D8%AC%D8%AF%D9%8A%D8%AF%D8%A9-%D9%84%D8%B6%D8%A8%D8%B7-%D8%AC%D9%88%D8%AF%D8%A9-%D8%A7%D9%84%D8%A3%D8%AF%D9%88%D9%8A%D8%A9-%D8%A7%D9%84%D9%85%D8%B9%D9%82%D8%AF%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9\" target=\"_blank\">\u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u063a\u0630\u0627\u0621 \u0648\u0627\u0644\u062f\u0648\u0627\u0621</a> \u0639\u0646 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0643\u0627\u0645\u064a\u0631\u0627\u062a \u0627\u0644\u062c\u0633\u062f\u064a\u0629 \u0636\u0645\u0646 \u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u062a\u0641\u062a\u064a\u0634 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a \u062e\u0644\u0627\u0644 <a href=\"https://www.alyaum.com/articles/6662025/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A3%D9%85%D9%86-%D8%A7%D9%84%D8%B5%D9%86%D8%A7%D8%B9%D9%8A-%D8%AA%D9%83%D8%AB%D9%81-%D8%A3%D8%B9%D9%85%D8%A7%D9%84-%D8%A7%D9%84%D8%B1%D9%82%D8%A7%D8%A8%D8%A9-%D9%88%D8%A7%D9%84%D9%85%D8%AA%D8%A7%D8%A8%D8%B9%D8%A9-%D8%B9%D9%84%D9%89-%D9%85%D9%86%D8%B4%D8%A2%D8%AA-%D9%85%D9%88%D8%B3%D9%85-%D8%A7%D9%84%D8%AD%D8%AC\" target=\"_blank\">\u0645\u0648\u0633\u0645 \u0627\u0644\u062d\u062c</a>\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u0648\u0641\u0631 \u062e\u0635\u0627\u064a\u0654\u0635 \u0645\u062a\u0642\u062f\u0645\u0629 \u062a\u0634\u0645\u0644 \u0627\u0644\u0628\u062b \u0627\u0644\u0645\u0628\u0627\u0634\u0631 \u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a\u060c \u0648\u0627\u0655\u0645\u0643\u0627\u0646\u064a\u0629 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0627\u0644\u0635\u0648\u062a\u064a \u0627\u0644\u0644\u062d\u0638\u064a \u0645\u0639 \u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u0631\u0642\u0627\u0628\u064a\u0629 \u0641\u064a \u0627\u0654\u062b\u0646\u0627\u0621 \u0627\u0654\u062f\u0627\u0621 \u0627\u0644\u0645\u0647\u0627\u0645\u060c \u0628\u0645\u0627 \u064a\u062a\u064a\u062d \u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0641\u0646\u064a \u0648\u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a \u0627\u0644\u0641\u0648\u0631\u064a.<br />\u0627\u0655\u0636\u0627\u0641\u0629\u064b \u0627\u0655\u0644\u0649 \u062a\u0641\u0639\u064a\u0644 \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0627\u0633\u062a\u063a\u0627\u062b\u0629 \u0648\u0627\u0644\u0637\u0648\u0627\u0631\u064a\u0654\u060c \u0644\u062a\u0639\u0632\u064a\u0632 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u0631\u0642\u0627\u0628\u064a\u0629 \u0648\u0633\u0631\u0639\u0629 \u0627\u0644\u0627\u0633\u062a\u062c\u0627\u0628\u0629 \u0644\u0644\u062d\u0627\u0644\u0627\u062a \u0627\u0644\u0639\u0627\u062c\u0644\u0629.<br />\u064a\u0627\u0654\u062a\u064a \u0630\u0644\u0643 \u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u062a\u0633\u062e\u064a\u0631 \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0645\u0646\u0638\u0648\u0645\u0629 \u0645\u062a\u0642\u062f\u0645\u0629 \u0645\u0646 \u0627\u0644\u062a\u0642\u0646\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u0642\u062f\u0645\u0629 \u0648\u0627\u0644\u0627\u0654\u062f\u0648\u0627\u062a \u0627\u0644\u062d\u062f\u064a\u062b\u0629 \u0644\u062f\u0639\u0645 \u0641\u0631\u0642\u0647\u0627 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629\u060c \u0648\u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u0629 \u0627\u0644\u0627\u0633\u062a\u062c\u0627\u0628\u0629 \u0648\u0627\u0644\u0631\u0642\u0627\u0628\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u062e\u0627\u0636\u0639\u0629 \u0644\u0631\u0642\u0627\u0628\u062a\u0647\u0627\u060c \u0636\u0645\u0646 \u062c\u064