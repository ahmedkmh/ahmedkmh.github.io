45\u062d\u0637\u0627\u062a \u062a\u0648\u0644\u064a\u062f \u0627\u0644\u0637\u0627\u0642\u0629 </a>\u0627\u0644\u062a\u064a \u062a\u0639\u0645\u0644 \u0628\u0627\u0644\u0641\u062d\u0645 \u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0631\u062a\u0641\u0627\u0639 \u062a\u0643\u0627\u0644\u064a\u0641 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621 \u0641\u064a \u0638\u0644 \u062a\u062f\u0627\u0639\u064a\u0627\u062a \u0627\u0644\u062d\u0631\u0628 \u0641\u064a \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0639\u0644\u0649 \u0634\u062d\u0646\u0627\u062a \u0627\u0644\u063a\u0627\u0632.<br /><br />\u0648\u062a\u0639\u062a\u0645\u062f <a href=\"https://www.alyaum.com/articles/6638170/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D8%B9-%D8%A7%D8%B3%D8%AA%D9%85%D8%B1%D8%A7%D8%B1-%D8%AA%D8%AF%D9%81%D9%82-%D8%A7%D9%84%D8%AD%D9%85%D9%85-%D8%A7%D9%84%D8%A8%D8%B1%D9%83%D8%A7%D9%86%D9%8A%D8%A9-%D8%A7%D9%84%D9%81%D9%84%D8%A8%D9%8A%D9%86-%D8%AA%D8%AD%D8%B0%D8%B1-%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B1%D8%A7%D8%A8-%D9%85%D9%86-%D8%A8%D8%B1%D9%83%D8%A7%D9%86-%D9%85%D8%A7%D9%8A%D9%88%D9%86\" target=\"_blank\">\u0627\u0644\u0641\u064a\u0644\u064a\u0628\u064a\u0646 </a>\u0627\u0644\u062a\u064a \u064a\u0628\u0644\u063a \u0639\u062f\u062f \u0633\u0643\u0627\u0646\u0647\u0627 116 \u0645\u0644\u064a\u0648\u0646 \u0646\u0633\u0645\u0629 \u0648\u0627\u0644\u062a\u064a \u0644\u062f\u064a\u0647\u0627 \u0628\u0639\u0636 \u0645\u0646 \u0627\u0654\u0639\u0644\u0649 \u062a\u0643\u0627\u0644\u064a\u0641 \u0627\u0644\u0637\u0627\u0642\u0629 \u0641\u064a \u0627\u0644\u0645\u0646\u0637\u0642\u0629\u060c \u0639\u0644\u0649 \u0627\u0644\u0641\u062d\u0645 \u0644\u062a\u0648\u0644\u064a\u062f \u062d\u0648\u0627\u0644\u0649 60% \u0645\u0646 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621.<br /><br /> <h2>\u0627\u0644\u0639\u0648\u062f\u0629 \u0644\u0644\u0648\u0642\u0648\u062f \u0627\u0644\u0627\u0654\u062d\u0641\u0648\u0631\u064a</h2><br />\u0648\u0642\u0627\u0644\u062a \u0634\u0627\u0631\u0648\u0646 \u063a\u0627\u0631\u064a\u0646 \u0644\u0635\u062d\u0627\u0641\u064a\u064a\u0646 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621\u060c \u0627\u0655\u0646\u0647 \u0645\u0639 \u0627\u0631\u062a\u0641\u0627\u0639 \u0643\u0644\u0641\u0629 \u0627\u0644\u063a\u0627\u0632 \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0627\u0644\u0645\u0633\u0627\u0644\u060c \u0633\u062a\u0636\u0637\u0631 \u0627\u0644\u0628\u0644\u0627\u062f \"\u0645\u0648\u0654\u0642\u062a\u0627\" \u0644\u0644\u0627\u0639\u062a\u0645\u0627\u062f \u0628\u0634\u0643\u0644 \u0627\u0654\u0643\u0628\u0631 \u0639\u0644\u0649 <a href=\"https://www.alyaum.com/articles/6632524/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D9%85%D9%86%D9%88%D8%B9%D8%A7%D8%AA/%D8%AE%D9%84%D8%A7%D9%81-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D9%88%D9%82%D9%88%D8%AF-%D8%A7%D9%84%D8%A3%D8%AD%D9%81%D9%88%D8%B1%D9%8A-%D9%8A%D9%85%D9%86%D8%B9-%D8%B5%D8%AF%D9%88%D8%B1-%D9%85%D9%84%D8%AE%D8%B5-%D8%A7%D9%84%D8%AA%D9%82%D8%B1%D9%8A%D8%B1-%D8%A7%D9%84%D8%A3%D9%85%D9%85%D9%8A-%D8%B9%D9%86-%D8%A7%D9%84%D8%A8%D9%8A%D8%A6%D8%A9\" target=\"_blank\">\u0627\u0644\u0648\u0642\u0648\u062f \u0627\u0644\u0627\u0654\u062d\u0641\u0648\u0631\u064a</a> \u0627\u0644\u0630\u064a \u064a\u0639\u062a\u0628\u0631 \u0645\u0646 \u0627\u0654\u0643\u0628\u0631 \u0627\u0644\u0645\u0644\u0648\u062b\u0627\u062a \u0644\u0644\u0628\u064a\u064a\u0654\u0629.<br /><br />\u0648\u0627\u0654\u0636\u0627\u0641\u062a \"\u062a\u062d\u062f\u062b\u0646\u0627 \u0645\u0639 \u0634\u0631\u0643\u0627\u062a \u0644\u062a\u0648\u0644\u064a\u062f \u0627\u0644\u0637\u0627\u0642\u0629 \u0648\u0645\u062d\u0637\u0627\u062a \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u062a\u064a \u062a\u0639\u0645\u0644 \u0628\u0627\u0644\u0641\u062d\u0645 \u0644\u062a\u0642\u064a\u064a\u0645 \u0645\u062f\u0649 \u0642\u062f\u0631\u062a\u0647\u0627 \u0639\u0644\u0649 \u0632\u064a\u0627\u062f\u0629 \u0627\u0655\u0646\u062a\u0627\u062c\u0647\u0627\"\u060c \u0645\u0634\u064a\u0631\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0627 \u0627\u0644\u0627\u0655\u062c\u0631\u0627\u0621 \"\u0627\u0644\u0645\u0648\u0642\u062a\" \u0642\u062f \u064a\u062f\u062e\u0644 \u062d\u064a\u0632 \u0627\u0644\u062a\u0646\u0641\u064a\u0630 \u0627\u0639\u062a\u0628\u0627\u0631\u0627 \u0645\u0646 1 \u0627\u0654\u0628\u0631\u064a\u0644.<h2>\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621</h2><br />\u062a\u0627\u0628\u0639\u062a \u063a\u0627\u0631\u064a\u0646 \"\u0627\u0655\u0630\u0627 \u062a\u0645\u0643\u0646\u0627 \u0645\u0646 \u062a\u0646\u0641\u064a\u0630 \u0630\u0644\u0643\u060c \u0633\u0646\u0643\u0648\u0646 \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0642\u0644 \u0642\u0627\u062f\u0631\u064a\u0646 \u0639\u0644\u0649 \u0627\u0644\u062d\u062f \u0645\u0646 \u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621 \u0627\u0644\u0645\u0631\u062a\u0628\u0637 \u0628\u0627\u0644\u062d\u0631\u0628 \u0641\u064a \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637\".<br /><br />\u0648\u0627\u0654\u0636\u0627\u0641\u062a \u0627\u0644\u0648\u0632\u064a\u0631\u0629 \u0627\u0654\u0646 \u0627\u0644\u0641\u064a\u0644\u064a\u0628\u064a\u0646\u060c \u0645\u0639 \u0633\u0639\u064a\u0647\u0627 \u0644\u0632\u064a\u0627\u062f\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0641\u062d\u0645 \u0627\u0644\u0645\u062d\u0644\u064a \u0627\u0655\u0644\u0649 \u062f\u0631\u062c\u0627\u062a\u0647 \u0627\u0644\u0642\u0635\u0648\u0649\u060c \u062a\u062d\u062a\u0641\u0638 \u0627\u0654\u064a\u0636\u0627 \u0628\u062d\u0642\u0647\u0627 \u0641\u064a \u0627\u0655\u0645\u0643\u0627\u0646 \u0632\u064a\u0627\u062f\u0629 \u0645\u0634\u062a\u0631\u064a\u0627\u062a\u0647\u0627 \u0645\u0646 \u0627\u0644\u0641\u062d\u0645 \u0645\u0646 \u0627\u0655\u0646\u062f\u0648\u0646\u064a\u0633\u064a\u0627\u060c \u0645\u0648\u0631\u062f\u0647\u06