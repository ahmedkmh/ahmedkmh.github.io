D8%AD%D8%A7%D9%85-%D9%88%D8%AA%D8%B9%D8%B2%D9%8A%D8%B2-%D8%A7%D9%84%D8%A7%D9%86%D8%B6%D8%A8%D8%A7%D8%B7-%D8%A7%D9%84%D9%85%D8%B1%D9%88%D8%B1%D9%8A\" target=\"_blank\">\u062d\u0644\u0648\u0644 \u0645\u0633\u062a\u062f\u0627\u0645\u0629</a> \u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0644\u0645\u064a\u0627\u0647 \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0639\u0627\u0644\u0645\u064a.<br />\u062c\u0627\u0621 \u0630\u0644\u0643 \u062e\u0644\u0627\u0644 \u0627\u062c\u062a\u0645\u0627\u0639 \u0639\u0642\u062f\u062a\u0647 \u0627\u0644\u0645\u0646\u0638\u0645\u0629 \u0644\u0631\u0648\u0654\u0633\u0627\u0621 \u0648\u0641\u0648\u062f \u0627\u0644\u062f\u0648\u0644 \u0627\u0644\u0627\u0654\u0639\u0636\u0627\u0621 \u0627\u0644\u062b\u0645\u0627\u0646\u064a \u0627\u0644\u0645\u0648\u0654\u0633\u0633\u0629 \u0644\u0647\u0627\u060c \u0639\u0644\u0649 \u0647\u0627\u0645\u0634 \u0627\u0654\u0639\u0645\u0627\u0644 \"<a href=\"https://www.alyaum.com/articles/6669795/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A7%D9%87%D8%AA%D9%85%D8%A7%D9%85-%D8%A8%D8%A3%D8%B3%D8%A8%D9%88%D8%B9-%D8%A7%D9%84%D9%85%D9%8A%D8%A7%D9%87-%D9%8A%D8%A4%D9%83%D8%AF-%D9%85%D9%83%D8%A7%D9%86%D8%A9-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D9%85%D9%86%D8%B5%D8%A9-%D8%B9%D8%A7%D9%84%D9%85%D9%8A%D8%A9-%D9%84%D9%85%D8%B9%D8%A7%D9%84%D8%AC%D8%A9-%D9%82%D8%B6%D8%A7%D9%8A%D8%A7-%D8%A7%D9%84%D9%85%D9%8A%D8%A7%D9%87\" target=\"_blank\">\u0627\u0654\u0633\u0628\u0648\u0639 \u0627\u0644\u0645\u064a\u0627\u0647 \u0627\u0644\u0633\u0639\u0648\u062f\u064a</a>\"\u060c \u0627\u0644\u0630\u064a \u064a\u0646\u0639\u0642\u062f \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 \u0645\u0646 28 \u064a\u0648\u0646\u064a\u0648 \u0627\u0655\u0644\u0649 2 \u064a\u0648\u0644\u064a\u0648 \u0627\u0644\u0645\u0642\u0628\u0644 \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u062c\u062f\u0629.<br />\u