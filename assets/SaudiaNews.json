60c \u0648\u064a\u0633\u0647\u0645 \u0641\u064a \u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0645\u0634\u0647\u062f \u0627\u0644\u062d\u0636\u0631\u064a \u0628\u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629.<br /><br />\u0648\u062a\u0647\u062f\u0641 \u0627\u0644\u062e\u0637\u0648\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u062d\u062f \u0645\u0646 <a href=\"https://www.alyaum.com/articles/6657368/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AC%D8%AF%D9%88%D9%84-%D8%AC%D8%B2%D8%A7%D8%A1%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D8%AE%D8%A7%D9%84%D9%81%D8%A7%D8%AA-%D8%A7%D9%84%D8%A8%D9%84%D8%AF%D9%8A%D8%A9-%D9%85%D8%A7-%D8%A2%D9%84%D9%8A%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D9%87%D9%84%D8%A9-%D8%A7%D9%84%D8%AA%D8%B5%D8%AD%D9%8A%D8%AD%D9%8A%D8%A9-%D9%82%D8%A8%D9%84-%D8%A7%D9%84%D8%AA%D8%B7%D8%A8%D9%8A%D9%82\" target=\"_blank\">\u0627\u0644\u0645\u062e\u0627\u0644\u0641\u0627\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629</a> \u0648\u0631\u0641\u0639 \u062c\u0648\u062f\u0629 \u0627\u0644\u062e\u062f\u0645\u0627\u062a.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d \u0627\u0644\u0645\u062a\u062d\u062f\u062b \u0627\u0644\u0631\u0633\u0645\u064a \u0644\u0627\u0654\u0645\u0627\u0646\u0629 \u0627\u0644\u0627\u0654\u062d\u0633\u0627\u0621 \u062e\u0627\u0644\u062f \u0628\u0648\u0648\u0634\u0644\u060c \u0627\u0654\u0646 \u0627\u0644\u0645\u0628\u0627\u062f\u0631\u0629 \u062a\u062f\u0639\u0645 \u062c\u0647\u0648\u062f \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0628\u0644\u062f\u064a\u0627\u062a \u0648\u0627\u0644\u0627\u0655\u0633\u0643\u0627\u0646 \u0644\u0644\u062a\u062d\u0648\u0644 \u0646\u062d\u0648 \u0627\u0644\u0631\u0642\u0627\u0628\u0629 \u0627\u0644\u0645\u0639\u062a\u0645\u062f\u0629 \u0639\u0644\u0649 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u062a\u0642\u0646\u064a\u0629\u060c \u0645\u0628\u064a\u0646\u0627\u064b \u0627\u0654\u0646 \u0647\u0630\u0627 \u0627\u0644\u0645\u0633\u0627\u0