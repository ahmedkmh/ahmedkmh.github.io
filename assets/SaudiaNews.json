1%D9%8A-%D8%A3%D8%B9%D8%AF%D8%A7%D8%AF-%D8%A7%D9%84%D9%88%D8%A7%D9%81%D8%AF%D9%8A%D9%86-%D9%85%D9%86-%D9%84%D8%A8%D9%86%D8%A7%D9%86-%D8%A5%D9%84%D9%89-%D8%B3%D9%88%D8%B1%D9%8A%D8%A7\" target=\"_blank\">\u0644\u0628\u0646\u0627\u0646</a> \u062e\u0631\u0648\u062c \u0645\u062d\u0637\u0629 \u0631\u064a\u0654\u064a\u0633\u064a\u0629 \u0644\u062a\u062d\u0648\u064a\u0644 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621 \u0645\u0646 \u0627\u0644\u062e\u062f\u0645\u0629 \u0641\u064a <a href=\"https://www.alyaum.com/articles/6650764/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D9%82%D9%88%D8%A7%D8%AA-%D9%8A%D9%88%D9%86%D9%8A%D9%81%D9%8A%D9%84-%D9%81%D9%8A-%D8%AC%D9%86%D9%88%D8%A8-%D9%84%D8%A8%D9%86%D8%A7%D9%86-%D8%AA%D8%AA%D8%B9%D8%B1%D8%B6-%D9%84-3-%D8%AD%D9%88%D8%A7%D8%AF%D8%AB-%D8%A5%D8%B7%D9%84%D8%A7%D9%82-%D9%86%D8%A7%D8%B1\" target=\"_blank\">\u062c\u0646\u0648\u0628 \u0627\u0644\u0628\u0644\u0627\u062f</a>\u060c \u062c\u0631\u0627\u0621 \u0642\u0635\u0641 \u0627\u0644\u0627\u062d\u062a\u0644\u0627\u0644 <a href=\"https://www.alyaum.com/articles/6651054/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A8%D9%8A%D9%86%D9%87%D9%85-111-%D8%B7%D9%81%D9%84%D8%A7-912-%D9%82%D8%AA%D9%8A%D9%84%D8%A7-%D8%AD%D8%B5%D9%8A%D9%84%D8%A9-%D8%A7%D9%84%D8%BA%D8%A7%D8%B1%D8%A7%D8%AA-%D8%A7%D9%84%D8%A5%D8%B3%D8%B1%D8%A7%D8%A6%D9%8A%D9%84%D9%8A%D8%A9-%D8%B9%D9%84%D9%89-%D9%84%D8%A8%D9%86%D8%A7%D9%86\" target=\"_blank\">\u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a</a>\u060c \u0641\u064a \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u064a\u0627\u0654\u062a\u064a \u0639\u0642\u0628 \u063a\u0627\u0631\u0627\u062a \u0637\u0627\u0644\u062a \u062c\u0633\u0648\u0631\u064b\u0627 \u0648\u0637\u0631\u0642\u064b\u0627 \u062d\u064a\u0648\u064a\u0629 \u0639\u0644\u0649 \u0648\u0642\u0639 \u0627\u0644\u062d\u0631\u0628 \u0627\u0644\u0645\u0633\u062a\u0645\u0631\u0629 \u0645\u0646\u0630 \u0646\u062d\u0648 3 \u0627\u0654\u06