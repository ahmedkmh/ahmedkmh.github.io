{"status": "success", "totalResults": 5482, "results": [{"article_id": "e379efcb81f844c281eb73d95780e859", "link": "https://www.alyaum.com/articles/6657224/%D8%A7%D9%84%D9%85%D9%8A%D8%AF%D8%A7%D9%86-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6%D9%8A/%D8%A7%D9%84%D8%AF%D9%88%D8%B1%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A/%D8%B9%D8%A7%D8%AC%D9%84-%D9%84%D8%AC%D9%86%D8%A9-%D8%A7%D9%84%D8%A7%D9%86%D8%B6%D8%A8%D8%A7%D8%B7-%D9%88%D8%A7%D9%84%D8%A3%D8%AE%D9%84%D8%A7%D9%82-%D8%AA%D8%B9%D9%84%D9%86-%D8%AA%D9%88%D9%82%D9%8A%D8%B9-%D8%B9%D9%82%D9%88%D8%A8%D8%A9-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D9%84%D8%B5%D8%A7%D9%84%D8%AD-%D8%A7%D9%84%D8%A7%D8%AA%D9%81%D8%A7%D9%82-%D9%86%D9%86%D8%B4%D8%B1-%D8%A7%D9%84%D8%AA%D9%81%D8%A7%D8%B5%D9%8A%D9%84", "title": "\u0639\u0627\u062c\u0644.. \u0644\u062c\u0646\u0629 \u0627\u0644\u0627\u0646\u0636\u0628\u0627\u0637 \u0648\u0627\u0644\u0627\u0654\u062e\u0644\u0627\u0642 \u062a\u0639\u0644\u0646 \u062a\u0648\u0642\u064a\u0639 \u0639\u0642\u0648\u0628\u0629 \u0639\u0644\u0649 \u0627\u0644\u0631\u064a\u0627\u0636 \u0644\u0635\u0627\u0644\u062d \u0627\u0644\u0627\u062a\u0641\u0627\u0642.. \u0646\u0646\u0634\u0631 \u0627\u0644\u062a\u0641\u0627\u0635\u064a\u0644", "description": "\u0627\u0654\u0639\u0644\u0646\u062a \u0644\u062c\u0646\u0629 \u0627\u0644\u0627\u0646\u0636\u0628\u0627\u0637 \u0648\u0627\u0644\u0627\u0654\u062e\u0644\u0627\u0642\u060c \u0639\u0646 \u0639\u0642\u0648\u0628\u0629 \u0636\u062f \u0646\u0627\u062f\u064a \u0627\u0644\u0631\u064a\u0627\u0636 \u0644\u0635\u0627\u0644\u062d \u0646\u0627\u062f\u064a \u0627\u0644\u0627\u062a\u0641\u0627\u0642\u060c \u0648\u0630\u0644\u0643 \u0639\u0642\u0628 \u0627\u0644\u0627\u0654\u0632\u0645\u0629 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u062f\u0639\u0648\u064a \u0627\u0644\u0627\u0654\u062e\u064a\u0631 \u0639\u0646 \u062a\u062f\u0631\u064a\u0628 \u0627\u0644\u0644\u0627\u0639\u0628 \u0631\u064a\u0627\u0646 \u0628\u0646 \u062f\u0631\u0648\u064a\u0634 \u0628\u0646 \u0645\u062d\u0645\u062f \u0627\u0644\u0628\u0644\u0648\u0634\u064a.<br /><br />\u0648\u0646\u0634\u0631\u062a \u0644\u062c\u0646\u0629 \u0627\u0644\u0627\u0646\u0636\u0628\u0627\u0637 \u0648\u0627\u0644\u0627\u0654\u062e\u0644\u0627\u0642 \u0639\u0628\u0631 \u062d\u0633\u0627\u0628\u0647\u0627 \u0627\u0644\u0631\u0633\u0645\u064a: \" \u0646\u0627\u062f\u064a \u0627\u0644\u0631\u064a\u0627\u0636 \u0627\u0655\u0644\u0632\u0627\u0645\u0647 \u0628\u062f\u0641\u0639 \u063a\u0631\u0627\u0645\u0629 \u0645\u0627\u0644\u064a\u0629 (20,000) \u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645. \u0627\u0655\u0644\u0632\u0627\u0645\u0647 \u0628\u062f\u0641\u0639 (995,248,15) \u0631\u064a\u0627\u0644 \u0633\u0639\u0648\u062f\u064a \u0644\u0644\u0645\u062d\u062a\u0643\u0645 (\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u062a\u0641\u0627\u0642) \u062a\u0639\u0648\u064a\u0636\u0627\u064b \u0639\u0646 \u062a\u062f\u0631\u064a\u0628 \u0627\u0644\u0644\u0627\u0639\u0628 \u0631\u064a\u0627\u0646 \u0628\u0646 \u062f\u0631\u0648\u064a\u0634 \u0628\u0646 \u0645\u062d\u0645\u062f \u0627\u0644\u0628\u0644\u0648\u0634\u064a. \u0627\u0655\u0644\u0632\u0627\u0645\u0647 \u0628\u0627\u0654\u0646 \u064a\u062f\u0641\u0639 \u0644\u0644\u0645\u062d\u062a\u0643\u0645 (\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u062a\u0641\u0627\u0642) \u0645\u0628\u0644\u063a \u0648\u0642\u062f\u0631\u0647 (5,000) \u0631\u064a\u0627\u0644 \u0633\u0639\u0648\u062f\u064a \u0631\u0633\u0648\u0645 \u0631\u0641\u0639 \u0627\u0644\u062f\u0639\u0648\u0649.<br /><br />\u0648\u062a\u0627\u0628\u0639\u062a: \"\u0627\u0655\u0644\u0632\u0627\u0645\u0647 \u0628\u0627\u0654\u0646 \u064a\u062f\u0641\u0639 \u0644\u0644\u0645\u062d\u062a\u0643\u0645 (\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u062a\u0641\u0627\u0642) \u0643\u0627\u0641\u0629 \u0627\u0644\u062a\u0643\u0627\u0644\u064a\u0641 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u062a\u0631\u062a\u0628\u0629 \u0639\u0644\u0649 \u062a\u0642\u062f\u064a\u0645 \u0637\u0644\u0628 \u0627\u0644\u062a\u062d\u0643\u064a\u0645 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0645\u0631\u0643\u0632 \u0628\u0645\u0628\u0644\u063a (104,800) \u0631\u064a\u0627\u0644 \u0633\u0639\u0648\u062f\u064a\"<br /><br />\u0648\u064a\u0633\u062a\u0639\u062f \u0646\u0627\u062f\u064a \u0627\u0644\u0627\u062a\u0641\u0627\u0642\u060c \u0644\u0645\u0644\u0627\u0642\u0627\u0629 \u0627\u0644\u0627\u0654\u062e\u062f\u0648\u062f\u060c \u0648\u0630\u0644\u0643 \u0636\u0645\u0646 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u0642\u0627\u062f\u0645\u0629 \u0645\u0646 \u0645\u0633\u0627\u0628\u0642\u0629 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0644\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u0642\u0627\u0645 \u0639\u0644\u0649 \u0645\u0644\u0639\u0628 \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0647\u0630\u0644\u0648\u0644 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-04-20 20:07:00", "pubDateTZ": "UTC", "fetched_at": "2026-04-20 20:45:53", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "