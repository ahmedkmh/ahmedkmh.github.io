\u063a\u0637 \u0639\u0644\u0649 \u0643\u0648\u0628\u0627 \u0645\u0639 \u0641\u0631\u0636 \u062d\u0635\u0627\u0631 \u0646\u0641\u0637\u064a \u0639\u0644\u064a\u0647\u0627 \u0645\u0646\u0630 \u064a\u0646\u0627\u064a\u0631\u060c \u0645\u0627 \u0627\u0654\u062f\u0649 \u0627\u0655\u0644\u0649 \u062e\u0646\u0642 \u0627\u0655\u0645\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0648\u0642\u0648\u062f \u0648\u0627\u0642\u062a\u0635\u0627\u062f\u0647\u0627 \u0627\u0644\u0630\u064a \u0643\u0627\u0646 \u064a\u0639\u0627\u0646\u064a \u0627\u0654\u0635\u0644\u0627 \u0628\u0633\u0628\u0628 \u0633\u0646\u0648\u0627\u062a \u0645\u0646 \u0627\u0644\u062d\u0638\u0631 \u0627\u0644\u062a\u062c\u0627\u0631\u064a \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a.<h2>\u0627\u0654\u0645\u0631\u064a\u0643\u0627 \u0648\u0643\u0648\u0628\u0627</h2>\u0648\u0644\u0645 \u064a\u062d\u062f\u062f \u062a\u0631\u0627\u0645\u0628 \u0645\u0627 \u064a\u0646\u0648\u064a \u0627\u0644\u0642\u064a\u0627\u0645 \u0628\u0647 \u0628\u0634\u0627\u0654\u0646\u0647\u0627\u060c \u0641\u064a\u0645\u0627 \u0642\u0627\u0644 \u0644\u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \"\u062a\u062c\u0627\u0647\u0644\u0648\u0627 \u0647\u0630\u0627 \u0627\u0644\u062a\u0635\u0631\u064a\u062d\"\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0643\u0631\u0651\u0631 \"\u0643\u0648\u0628\u0627 \u0647\u064a \u0627\u0644\u062a\u0627\u0644\u064a\u0629\"\u060c \u0627\u0644\u0627\u0654\u0645\u0631 \u0627\u0644\u0630\u064a \u0627\u0654\u062b\u0627\u0631 \u0636\u062d\u0643 \u0627\u0644\u062d\u0627\u0636\u0631\u064a\u0646.<br /><br />\u0648\u0641\u064a \u0643\u0644\u0645\u0629 \u0627\u0654\u0645\u0627\u0645 \u0645\u0646\u062a\u062f\u0649 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \"\u0627\u0641 \u0627\u064a \u0627\u064a \u0628\u0631\u0627\u064a\u0648\u0631\u064a\u062a\u064a\" (FII Priority) \u0648\u0627\u0644\u0630\u064a \u0639\u064f\u0642\u062f \u0641\u064a \u0645\u064a\u0627\u0645\u