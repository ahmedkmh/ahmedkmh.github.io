9-%D8%A8%D8%B9%D8%B6-%D9%85%D8%AF%D9%86-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9\">\u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0644\u0627\u0654\u0631\u0635\u0627\u062f</a>\u060c \u0639\u0646<a href=\"https://www.alyaum.com/articles/6655273/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%AF%D9%85%D8%A7%D9%85-27-%D9%85%D8%A6%D9%88%D9%8A%D8%A9-%D9%88%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-29-%D8%A8%D9%8A%D8%A7%D9%86-%D8%AF%D8%B1%D8%AC%D8%A7%D8%AA-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9\"> \u0628\u064a\u0627\u0646 \u062f\u0631\u062c\u0627\u062a \u0627\u0644\u062d\u0631\u0627\u0631\u0629</a> \u0627\u0644\u0639\u0638\u0645\u0649 \u0648\u0627\u0644\u0635\u063a\u0631\u0649 \u0628\u0627\u0644\u062f\u0631\u062c\u0629 \u0627\u0644\u0645\u064a\u0654\u0648\u064a\u0629 \u0648\u0627\u0644\u0638\u0648\u0627\u0647\u0631 \u0627\u0644\u062c\u0648\u064a\u0629 \u0627\u0644\u0645\u062a\u0648\u0642\u0639\u0629\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0633\u0628\u062a\u060c \u0641\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629.<br /><br />\u062d\u0633\u0628 \u062a\u0642\u0631\u064a\u0631 <a href=\"https://www.alyaum.com/articles/6655093/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%AF%D9%85%D8%A7%D9%85-29-%D9%85%D8%A6%D9%88%D9%8A%D8%A9-%D8%A8%D9%8A%D8%A7%D9%86-%D8%AF%D8%B1%D8%AC%D8%A7%D8%AA-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D8%A9-%D8%A7%D9%84%D8%B9%D8%B8%D9%85%D9%89-%D8%B9%D9%84%D9%89-%D8%A8%D8%B9%D8%B6-%D9%85%D8%AF%D9%86-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9\">\u0627\u0644\u0627\u0654\u0631\u0635\u0627\u062f</a>\u060c \u062a\u0633\u062c\u0644 \u0627\u0644\u0639\u0638\u0645\u0649 \u0641\u064a \u0627\u0644\u062f\u0645\u0627\u0645 \u0648\u0627\u0644\u0631\u064a\u0627\u0636 29 \u062f\u0631\u062c\u0