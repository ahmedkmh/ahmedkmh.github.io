27\u0632\u0629 \u0627\u0654\u0633\u0644\u062d\u0629 \u0646\u0648\u0648\u064a\u0629\u00bb. \u0644\u064a\u0633\u062a \u062d\u0631\u0628\u0627 \u0628\u0644\u0627 \u0646\u0647\u0627\u064a\u0629\u0648\u0641\u064a \u062a\u0644\u0645\u064a\u062d \u0627\u0655\u0644\u0649 \u0642\u0635\u0631 \u0641\u062a\u0631\u0629 \u0627\u0644\u062d\u0631\u0628\u060c \u0639\u0644\u0642 \u0647\u064a\u063a\u0633\u064a\u062b \u0628\u0627\u0654\u0646 \u00ab\u0647\u0630\u0647 \u0644\u064a\u0633\u062a \u0627\u0644\u0639\u0631\u0627\u0642\u060c \u0648\u0644\u064a\u0633\u062a \u062d\u0631\u0628\u0627\u064b \u0628\u0644\u0627 \u0646\u0647\u0627\u064a\u0629\u00bb.\u0648\u0643\u0634\u0641 \u0648\u0632\u064a\u0631 \u0627\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u0627\u0654\u0646 \u00ab\u0627\u0655\u064a\u0631\u0627\u0646 \u0643\u0627\u0646\u062a \u062a\u0645\u0627\u0637\u0644 \u0627\u0654\u062b\u0646\u0627\u0621 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a\u00bb\u060c \u0645\u0636\u064a\u0641\u0627\u064b \u0627\u0654\u0646 \u00ab\u0639\u0645\u0644\u064a\u0629 \u0627\u0655\u064a\u0631\u0627\u0646 \u0633\u062a\u0646\u0637\u0648\u064a \u0639\u0644\u0649 \u062e\u0633\u0627\u064a\u0654\u0631 \u0628\u0634\u0631\u064a\u0629\u00bb.\u0648\u0646\u0641\u0649 \u0627\u0654\u064a \u0627\u062d\u062a\u0645\u0627\u0644\u0627\u062a \u0644\u062a\u062f\u062e\u0644 \u0628\u0631\u064a \u0627\u0654\u0645\u0631\u064a\u0643\u064a \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646\u060c \u0648\u0648\u0635\u0641 \u0639\u0645\u0644\u064a\u0629 \u00ab\u0627\u0644\u063a\u0636\u0628 \u0627\u0644\u0645\u0644\u062d\u0645\u064a\u00bb \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0636\u062f \u0627\u0655\u064a\u0631\u0627\u0646 \u0628\u0627\u0654\u0646\u0647\u0627 \u00ab\u062c\u0648\u064a\u0629\u00bb.\u0648\u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0648\u0654\u062a\u0645\u0631 \u0627\u0644\u0635\u062d\u0641\u064a\u060c \u0627\u0654\u0641\u0635\u062d \u0631\u064a\u0654\u064a\u0633 \u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0627\u0654\u0631\u0643\u0627\u0646 \u0627\u0644\u0645\u0634\u062a\u0631\u0643\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0627\u0644\u062c\u0646\u0631\u0627\u0644 \u062f\u0627\u0646 \u0643\u064a\u0646 \u0639\u0646 \u0642\u0635\u0641 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 1000 \u0647\u062f\u0641 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646 \u0641\u064a \u0627\u0654\u0648\u0644 24 \u0633\u0627\u0639\u0629 \u0645\u0646 \u0627\u0644\u0647\u062c\u0648\u0645. \u0648\u0643\u0634\u0641 \u062f\u0627\u0646 \u00ab\u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0648\u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0635\u0648\u0627\u0631\u064a\u062e \u0641\u064a \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u0639\u0645\u0644\u064a\u0629\u00bb\u060c \u0645\u0648\u0636\u062d\u0627\u064b \u0627\u0654\u0646 \u00ab\u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0633\u064a\u0628\u0631\u0627\u0646\u064a\u0629 \u0634\u0627\u0631\u0643\u062a \u0628\u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a \u0636\u062f \u0627\u0655\u064a\u0631\u0627\u0646\u00bb.\u0648\u062d\u0648\u0644 \u0627\u0644\u062a\u0635\u062f\u064a \u0644\u0644\u0647\u062c\u0645\u0627\u062a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u0637\u0627\u0644\u062a \u062f\u0648\u0644 \u0627\u0644\u0645\u0646\u0637\u0642\u0629\u060c \u0627\u0654\u0643\u062f \u0648\u0632\u064a\u0631 \u0627\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u00ab\u0646\u0634\u0631 \u0645\u0627 \u064a\u0643\u0641\u064a \u0645\u0646 \u0627\u0644\u0642\u062f\u0631\u0627\u062a \u0627\u0644\u062f\u0641\u0627\u0639\u064a\u0629 \u0644\u0644\u062a\u0635\u062f\u064a \u0644\u0627\u0655\u064a\u0631\u0627\u0646\u00bb\u060c \u0641\u064a\u0645\u0627 \u0627\u0654\u0639\u0644\u0646 \u0631\u064a\u0654\u064a\u0633 \u0627\u