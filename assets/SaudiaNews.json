0/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%B3%D8%B9%D8%B1-%D8%AC%D8%B1%D8%A7%D9%85-%D8%A7%D9%84%D8%B0%D9%87%D8%A8-%D8%B9%D9%8A%D8%A7%D8%B1-21-%D8%A7%D9%84%D9%8A%D9%88%D9%85-%D8%A7%D9%84%D8%AB%D9%84%D8%A7%D8%AB%D8%A7%D8%A1-%D9%81%D9%8A-%D9%85%D8%B5%D8%B1-%D8%A7%D9%86%D8%AE%D9%81%D8%A7%D8%B6-%D8%AC%D8%AF%D9%8A%D8%AF-%D8%A8%D8%A7%D9%84%D8%A3%D8%B3%D9%88%D8%A7%D9%82\" target=\"_blank\">\u0645\u0635\u0631</a>\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621\u060c 6695 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0628\u064a\u0639\u060c \u06486640 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0634\u0631\u0627\u0621.<h2>\u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 18</h2>\u0627\u0631\u062a\u0641\u0639 \u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 18 \u0641\u064a \u0645\u0635\u0631\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 \u0627\u0655\u0644\u0649: 5025 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0628\u064a\u0639\u060c \u06484980 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0634\u0631\u0627\u0621.<h2>\u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 14</h2>\u0633\u062c\u0644 \u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 14 \u0641\u064a \u0645\u0635\u0631\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621\u060c 3905 \u062c\u0646\u064a\u0647\u0627\u062a \u0644\u0644\u0628\u064a\u0639\u060c \u06483875 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0634\u0631\u0627\u0621.<h2>\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0630\u0647\u0628 \u0627\u0644\u064a\u0648\u0645 \u0641\u064a \u0645\u0635\u0631</h2>\u0633\u062c\u0644 \u0633\u0639\u0631 \u0627\u0644\u062c\u0646\u064a\u0647 \u0627\u06