0635\u064a\u0646\u064a\u0629 \u0639\u0628\u0631 \u00ab\u0648\u064a\u0628\u0648\u00bb\u0627\u0644\u0646\u0627\u062f\u064a \u0646\u0634\u0631\u060c \u0628\u0627\u0633\u0645 \u0627\u0644\u0644\u0627\u0639\u0628\u060c \u0631\u0633\u0627\u0644\u0629 \u0627\u0639\u062a\u0630\u0627\u0631 \u0628\u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0635\u064a\u0646\u064a\u0629 \u0639\u0628\u0631 \u0645\u0646\u0635\u0629 Weibo\u060c \u062c\u0627\u0621 \u0641\u064a\u0647\u0627:\u00ab\u0627\u0654\u0639\u062a\u0630\u0631 \u0628\u0635\u062f\u0642 \u0644\u0627\u0654\u0635\u062f\u0642\u0627\u064a\u0654\u064a \u0627\u0644\u0635\u064a\u0646\u064a\u064a\u0646. \u0642\u0645\u062a \u0633\u0627\u0628\u0642\u0627\u064b \u0628\u0627\u0655\u0639\u0627\u062f\u0629 \u0646\u0634\u0631 \u0645\u062d\u062a\u0648\u0649 \u062a\u0636\u0645\u0646 \u0631\u0633\u0627\u064a\u0654\u0644 \u0645\u0633\u064a\u064a\u0654\u0629 \u0645\u0646 \u062f\u0648\u0646 \u0642\u0635\u062f. \u0643\u0627\u0646 \u0630\u0644\u0643 \u063a\u064a\u0631 \u0645\u062a\u0639\u0645\u062f \u062a\u0645\u0627\u0645\u0627\u064b\u060c \u0648\u0627\u0654\u0639\u0631\u0628 \u0639\u0646 \u0627\u0654\u0633\u0641\u064a \u0644\u0644\u0627\u0655\u0632\u0639\u0627\u062c \u0627\u0644\u0630\u064a \u062a\u0633\u0628\u0628\u062a \u0641\u064a\u0647\u00bb.\u0635\u0648\u0631\u0629 \u062a\u0634\u0639\u0644 \u0627\u0644\u063a\u0636\u0628\u0627\u0644\u062c\u062f\u0644 \u0627\u0646\u062f\u0644\u0639 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639\u060c \u062d\u064a\u0646 \u0627\u0654\u0639\u0627\u062f \u0647\u0648\u064a\u0633\u0646 (20 \u0639\u0627\u0645\u0627\u064b) \u0646\u0634\u0631 \u0635\u0648\u0631\u0629 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628\u0647 \u0641\u064a Instagram \u2014 \u062d\u064f\u0630\u0641\u062a \u0644\u0627\u062d\u0642\u0627\u064b \u2014 \u0627\u0639\u062a\u0628\u0631\u0647\u0627 \u0645\u0633\u062a\u062e\u062f\u0645\u0648\u0646 \u0635\u064a\u0646\u064a\u0648\u0646 \u062a\u062d\u0645\u0644 \u0627\u0655\u064a\