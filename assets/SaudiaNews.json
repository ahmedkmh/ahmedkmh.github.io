: "\u0627\u0654\u0639\u0644\u0646\u062a \u0634\u0631\u0643\u0629 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u062a\u0648\u0632\u064a\u0639 \u0627\u0654\u0631\u0628\u0627\u062d \u0646\u0642\u062f\u064a\u0629 \u0639\u0644\u0649 \u0645\u0627\u0644\u0643\u064a \u0648\u062d\u062f\u0627\u062a \u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0631\u064a\u062a (1) \u0639\u0646 \u0627\u0644\u0641\u062a\u0631\u0629 \u0645\u0646 1 \u064a\u0648\u0644\u064a\u0648 2025\u0645 \u0627\u0655\u0644\u0649 31 \u062f\u064a\u0633\u0645\u0628\u0631 2025\u0645.<br /><br />\u0648\u0648\u0641\u0642\u0627 \u0644\u0628\u064a\u0627\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\": \u0633\u062a\u0643\u0648\u0646 \u0627\u0654\u062d\u0642\u064a\u0629 \u0627\u0644\u062a\u0648\u0632\u064a\u0639\u0627\u062a \u0627\u0644\u0646\u0642\u062f\u064a\u0629 \u0644\u0645\u0627\u0644\u0643\u064a \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0648\u0630\u0644\u0643 \u062d\u0633\u0628 \u0633\u062c\u0644 \u0645\u0627\u0644\u0643\u064a \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0628\u0646\u0647\u0627\u064a\u0629 \u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 15 \u0627\u0654\u0628\u0631\u064a\u0644 2026\u0645 (\u0646\u0647\u0627\u064a\u0629 \u064a\u0648\u0645 \u0627\u0644\u062a\u062f\u0627\u0648\u0644\u060c \u064a\u0648\u0645 \u0627\u0644\u0627\u0655\u062b\u0646\u064a\u0646 \u0628\u062a\u0627\u0631\u064a\u062e 13 \u0627\u0654\u0628\u0631\u064a\u0644 2026\u0645).<br /><br />\u0648\u0642\u0627\u0644\u062a: \u0627\u0655\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0627\u0654\u0631\u0628\u0627\u062d \u0627\u0644\u0645\u0648\u0632\u0639\u0629 \u062a\u0642\u062f\u0631 \u0628\u0646\u062d\u0648 30.25 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0641\u064a\u0645\u0627 \u064a\u0628\u0644\u063a \u0639\u062f\u062f \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0627\u0644\u0642\u0627\u064a\u0654\u0645\u0629 \u0627\u0644\u062a\u064a \u0633\u062a\u062a\u0645 \u0627\u0644\u062a\u0648\u0632\u064a\u0639\u0627\u062a \u0627\u0644\u0646\u0642\u062f\u064a\u0629 \u0639\u0644\u0649 \u0627\u0654\u0633\u0627\u0633\u0647\u0627 137.5 \u0645\u0644\u064a\u0648\u0646 \u0648\u062d\u062f\u0629.<br /><br />\u0648\u0627\u0654\u0636\u0627\u0641\u062a \u0627\u0654\u0646 \u0642\u064a\u0645\u0629 \u0627\u0644\u0631\u0628\u062d \u0627\u0644\u0645\u0648\u0632\u0639 \u0644\u0643\u0644 \u0648\u062d\u062f\u0629 0.220 \u0631\u064a\u0627\u0644\u060c \u0641\u064a\u0645\u0627 \u062a\u0628\u0644\u063a \u0646\u0633\u0628\u0629 \u0627\u0644\u062a\u0648\u0632\u064a\u0639 \u0645\u0646 \u0635\u0627\u0641\u064a \u0642\u064a\u0645\u0629 \u0627\u0644\u0627\u0654\u0635\u0648\u0644 2.16%.<br /><br />\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0628\u062f\u0641\u0639 \u0627\u0644\u062a\u0648\u0632\u064a\u0639\u0627\u062a \u062e\u0644\u0627\u0644 30 \u064a\u0648\u0645 \u0639\u0645\u0644 \u0628\u0639\u062f \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0633\u062a\u062d\u0642\u0627\u0642.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["business"], "datatype": "news", "pubDate": "2026-03-31 15:37:00", "pubDateTZ": "UTC", "fetched_at": "2026-03-31 16:18:28", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLAN