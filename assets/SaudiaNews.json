0648\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u062a\u0635\u062d\u0631</a> \u062a\u062d\u0631\u0643\u0627\u064b \u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0627\u064b \u0644\u062a\u0639\u0632\u064a\u0632 \u0627\u0633\u062a\u062f\u0627\u0645\u0629 2,7 \u0645\u0644\u064a\u0648\u0646 \u0647\u0643\u062a\u0627\u0631 \u0645\u0646 \u0627\u0644\u063a\u0627\u0628\u0627\u062a \u0627\u0644\u0648\u0637\u0646\u064a\u0629\u060c \u0639\u0628\u0631 \u062a\u0646\u0638\u064a\u0645 \u0648\u0631\u0634\u0629 \u0639\u0645\u0644 \u0644\u062a\u0645\u0643\u064a\u0646 <a href=\"https://www.alyaum.com/articles/6656339/%D8%A7%D9%84%D8%AB%D9%82%D8%A7%D9%81%D8%A9-%D9%88%D8%A7%D9%84%D9%81%D9%86/%D8%AB%D9%82%D8%A7%D9%81%D8%A9/%D8%A8%D8%AD%D8%B6%D9%88%D8%B1-%D8%B9%D8%A7%D9%84%D9%85%D9%8A-%D9%85%D9%84%D8%AA%D9%82%D9%89-%D8%A7%D9%84%D9%82%D8%B7%D8%A7%D8%B9-%D8%A7%D9%84%D8%AB%D9%82%D8%A7%D9%81%D9%8A-%D8%BA%D9%8A%D8%B1-%D8%A7%D9%84%D8%B1%D8%A8%D8%AD%D9%8A-%D9%8A%D9%86%D8%A7%D9%82%D8%B4-%D8%B5%D9%86%D8%A7%D8%B9%D8%A9-%D9%85%D8%B3%D8%AA%D9%82%D8%A8%D9%84-%D8%A7%D9%84%D8%AB%D9%82%D8%A7%D9%81%D8%A9\" target=\"_blank\">\u0627\u0644\u0642\u0637\u0627\u0639 \u063a\u064a\u0631 \u0627\u0644\u0631\u0628\u062d\u064a</a> \u0648\u062a\u0631\u0633\u064a\u062e \u062a\u0643\u0627\u0645\u0644 \u0627\u0644\u062c\u0647\u0648\u062f \u0627\u0644\u0628\u064a\u064a\u0654\u064a\u0629.<br /><br />\u0648\u0643\u0634\u0641 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u063a\u0637\u0627\u0621 \u0627\u0644\u0646\u0628\u0627\u062a\u064a \u0648\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u062a\u0635\u062d\u0631 \u0639\u0646 \u0645\u062c\u0627\u0644\u0627\u062a \u0634\u0631\u0627\u0643\u0629 \u062d\u064a\u0648\u064a\u0629 \u0645\u0639 \u0627\u0644\u062c\u0645\u0639\u064a\u0627\u062a \u0627\u0644\u0628\u064a\u064a\u0654\u064a\u0629\u060c \u0645\u0648\u0654\u0643\u062f\u0627\u064b \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u0643\u064a\u0627\u0646\u0627\u062a \u062a\u0639\u062f \u0634\u0631\u064a\u0643\u0627\u064b \u0627\u0654\u0633\u0627\u0633\u064a\u0627\u064b \u0641\u064a \u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0637\u0628\u064a\u0639\u064a\u0629 \u0648\u0627\u0655\u062f\u0627\u0631\u062a\u0647\u0627 \u0628\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0629 \u062a\u0627\u0645\u0629.<br /><br /> <h2>\u0627\u0633\u062a\u062f\u0627\u0645\u0629 \u0627\u0644\u063a\u0627\u0628\u0627\u062a</h2><br />\u0627\u0654\u0648\u0636\u062d \u0645\u0633\u0648\u0654\u0648\u0644\u0648 \u0627\u0644\u0645\u0631\u0643\u0632 \u062e\u0644\u0627\u0644 \u0648\u0631\u0634\u0629 \u0639\u0645\u0644 \u062d\u0645\u0644\u062a \u0639\u0646\u0648\u0627\u0646 \u00ab\u062f\u0648\u0631 \u0627\u0644\u062c\u0645\u0639\u064a\u0627\u062a \u0641\u064a \u062a\u0639\u0632\u064a\u0632 \u0627\u0633\u062a\u062f\u0627\u0645\u0629 \u0627\u0644\u063a\u0627\u0628\u0627\u062a\u00bb\u060c \u0627\u0644\u0627\u0653\u062b\u0627\u0631 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629 \u0648\u0627\u0644\u0628\u064a\u064a\u0654\u064a\u0629 \u0627\u0644\u0639\u0645\u064a\u0642\u0629 \u0644\u0644\u0645\u0628\u0627\u062f\u0631\u0627\u062a \u0648\u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0645\u0633\u062a\u062f\u0627\u0645\u0629 \u0627\u0644\u062a\u064a \u062a\u0642\u0648\u062f\u0647\u0627 \u0645\u0648\u0654\u0633\u0633\u0627\u062a \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u062b\u0627\u0644\u062b.<br /><br />\u0648\u0628\u064a\u0651\u0646\u062a \u0627\u0644\u0646\u0642\u0627\u0634\u0627\u062a \u0627\u0654\u0646 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0633\u062a\u062f\u0627\u0645\u0629 \u0644\u0644\u063a\u0627\u0628\u0627\u062a \u062a\u0645\u062b\u0644 \u0646\u0647\u062c\u0627\u064b \u0645\u062a\u0643\u0627\u0645\u0644\u0627\u064b \u064a\u062d\u0627\u0641\u0638 \u0639\u0644\u0649 <a href=\"https://www.alyaum.com/articles/6625205/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B9%D8%A7%D8%AC%D9%84-%D9%86%D8%AA%D8%A7%D8%A6%D8%AC-%D8%AF%D8%B1%D8%A7%D8%B3%D8%A9-%D8%AC%D9%8A%D9%86%D9%8A%D8%A9-%D8%AA%D9%83%D8%B4%D9%81-%D8%B9%D9%86-%D8%AA%D9%86%D9%88%D8%B9-%D8%A3%D8%AD%D9%8A%D8%A7%D8%A6%D9%8A-%D8%BA%D9%8A%D8%B1-%D9%85%D8%B3%D8%A8%D9%88%D9%82-%D9%81%D9%8A-%D8%A7%D9%84%D8%A8%D8%AD%D8%B1-%D8%A7%D9%84%D8%A3%D8%AD%D9%85%D8%B1\" target=\"_blank\">\u0627\u0644\u062a\u0646\u0648\u0639 \u0627\u0644\u0627\u0654\u062d\u064a\u0627\u064a\u0654\u064a</a>\u060c \u0648\u064a\u062d\u0642\u0642 \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0627\u0644\u0642\u0635\u0648\u0649 \u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0627\u064b \u0648\u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0627\u064b \u062f\u0648\u0646 \u0627\u0655\u0644\u062d\u0627\u0642 \u0627\u0654\u064a \u0636\u0631\u0631 \u0628\u0627\u0644\u0627\u0654\u0646\u0638\u0645\u0629 \u0627\u0644\u0628\u064a\u064a\u0654\u064a\u0629.<br /><br /> <h2>\u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0627\u0654\u0647\u064a\u0644 \u0627\u0644\u063a\u0627\u0628\u0627\u062a</h2><br />\u0644\u0641\u062a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u063a\u0637\u0627\u0621 \u0627\u0644\u0646\u0628\u0627\u062a\u064a \u0648\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u062a\u0635\u062d\u0631 \u0627\u0655\u0644\u0649 \u0627\u0644\u062a\u0632\u0627\u0645\u0647 \u0627\u0644\u0643\u0627\u0645\u0644 \u0628\u062a\u0646\u0645\u064a\u0629 \u0648\u062d\u0645\u0627\u064a\u0629 \u0648\u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0627\u0654\u0647\u064a\u0644 \u0627\u0644\u063a\u0627\u0628\u0627\u062a \u0627\u0644\u0645\u062a\u0636\u0631\u0631\u0629\u060c \u0633\u0648\u0627\u0621 \u0627\u0644\u062c\u0628\u0644\u064a\u0629 \u0627\u0654\u0648 \u063a\u0627\u0628\u0627\u062a \u00ab\u0627\u0644\u0645\u0627\u0646\u062c\u0631\u0648\u0641\u00bb \u0627\u0644\u0633\u0627\u062d\u0644\u064a\u0629 \u0627\u0654\u0648 \u0627\u0644\u0645\u0645\u062a\u062f\u0629 \u0641\u064a \u0627\u0644\u0627\u0654\u0648\u062f\u064a\u0629 \u0648\u0627\u0644\u0646\u0637\u0627\u0642\u0627\u062a \u0627\u0644\u062d\u0636\u0631\u064a\u0629.<br /><br />\u0648\u062a\u0627\u0654\u062a\u064a \u0647\u0630\u0647 \u0627\u0644\u062a\u062d\u0631\u0643\u0627\u062a \u0627\u0644\u0645\u0648\u0654\u0633\u0633\u064a\u0629 \u0644\u062a\u0633\u0644\u0637 \u0627\u0644\u0636\u0648\u0621 \u0639\u0644\u0649 \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0627\u0644\u0639\u0627\u0644\u064a\u0629 \u0644\u0644\u062b\u0631\u0648\u0629 \u0627\u0644\u063a\u0627\u0628\u064a\u0629\u060c \u0648\u062a\u062f\u0641\u0639 \u0628\u0627\u062a\u062c\u0627\u0647 \u0631\u0641\u0639 \u0627\u0644\u0648\u0639\u064a \u0627\u0644\u0645\u062c\u062a\u0645\u0639\u064a \u0644\u0636\u0645\u0627\u0646 \u0645\u0633\u062a\u0642\u0628\u0644 \u0628\u064a\u064a\u0654\u064a \u0645\u0633\u062a\u062f\u0627\u0645 \u064a\u062d\u0642\u0642 \u0627\u0644\u0645\u0633\u062a\u0647\u062f\u0641\u0627\u062a \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0627\u0644\u0634\u0627\u0645\u0644\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["top", "environment"], "datatype": "news", "pubDate": "2026-04-28 10:05:00", "pubDateTZ": "UTC", "fetched_at": "2026-04-28 10:14:23", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "