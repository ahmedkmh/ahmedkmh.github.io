\u0644\u0627\u0646\u062a\u0627 \u0627\u0654\u0645\u0627\u0645 \u062c\u062f\u0627\u0631 \u062a\u0627\u0631\u064a\u062e\u064a \u0635\u0644\u0628\u061b \u062d\u064a\u062b \u062e\u0627\u0636\u062a \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u062f\u0648\u0631 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0628\u0646\u0638\u0627\u0645\u0647 \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a 5 \u0645\u0631\u0627\u062a \u0633\u0627\u0628\u0642\u0629 (\u062f\u0648\u0646 \u0627\u062d\u062a\u0633\u0627\u0628 \u0646\u0633\u062e\u0629 1978 \u0627\u0644\u062a\u064a \u062a\u0627\u0654\u0647\u0644\u062a \u0641\u064a\u0647\u0627 \u0644\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0645\u0646 \u062f\u0648\u0631 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0627\u0644\u062b\u0627\u0646\u064a \u0645\u0628\u0627\u0634\u0631\u0629)\u060c \u0648\u062c\u0627\u0621\u062a \u0643\u0627\u0644\u062a\u0627\u0644\u064a:<!--TgQPHd||[]--><ul><li><strong>\u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a 1930:<!--TgQPHd||[]--></strong> \u0627\u0643\u062a\u0633\u062d\u062a \u0627\u0654\u0645\u0631\u064a\u0643\u0627 (6-1).<!--TgQPHd||[]--><!--TgQPHd||[]--></li><li><strong>\u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a 1986:<!--TgQPHd||[]--></strong> \u0647\u0632\u0645\u062a \u0628\u0644\u062c\u064a\u0643\u0627 (2-0).<!--TgQPHd||[]--><!--TgQPHd||[]--></li><li><strong>\u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a 1990:<!--TgQPHd||[]--></strong> \u0627\u0654\u0642\u0635\u062a \u0635\u0627\u062d\u0628\u0629 \u0627\u0644\u0627\u0654\u0631\u0636 \u0627\u0655\u064a\u0637\u0627\u0644\u064a\u0627 \u0628\u0631\u0643\u0644\u0627\u062a \u0627\u0644\u062a\u0631\u062c\u064a\u062d.<!--TgQPHd||[]--><!--TgQPHd||[]--></li><li><strong>\u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a 2014:<!--TgQPHd||[]--></strong> \u0627\u0654\u0637\u0627\u062d\u062a \u0628\u0647\u0648\u0644\u0646\u062f\u0627 \u0628\u0631\u0643\u0644\u0627\u062a \u0627\u0644\u062a\u0631\u062c\u064a\u062d.<!--TgQPHd||[]--><!--TgQPHd||[]--></li><li><strong>\u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a 2022:<!--TgQPHd||[]--></strong> \u0636\u0631\u0628\u062a \u0643\u0631\u0648\u0627\u062a\u064a\u0627 \u0628\u062b\u0644\u0627\u062b\u064a\u0629 \u0646\u0638\u064a\u0641\u0629 (3-0).</li></ul>", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-07-12 04:08:00", "pubDateTZ": "UTC", "fetched_at": "2026-07-12 04:19:13", "image_url": "https://www.alyaum.com/uploads/images/2026/07/12/3043665.jpg", "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}], "nextPage": "1783829280479526848"}