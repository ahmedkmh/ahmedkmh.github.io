\u0627\u0644\u0645\u062d\u0633\u0646 \u0627\u0644\u0639\u0645\u0631\u060c \u062e\u0631\u064a\u062c \u0627\u0644\u0632\u0645\u0627\u0644\u0629 \u0627\u0644\u0637\u0628\u064a\u0629 \u0641\u064a \u062a\u062e\u0635\u0635 \u0627\u0636\u0637\u0631\u0627\u0628 \u0627\u0644\u0635\u0631\u0639 \u0648\u0641\u0633\u064a\u0648\u0644\u0648\u062c\u064a\u0627 \u0627\u0644\u0627\u0654\u0639\u0635\u0627\u0628 \u0627\u0644\u0627\u0655\u0643\u0644\u064a\u0646\u064a\u0643\u064a\u0629 \u0628\u062c\u0627\u0645\u0639\u0629 \u0647\u0627\u0631\u0641\u0627\u0631\u062f\u060c \u0628\u062d\u0635\u0648\u0644\u0647 \u0639\u0644\u0649 \u062c\u0627\u064a\u0654\u0632\u0629 Robert B. Daroff Award \u062a\u0642\u062f\u064a\u0631\u064b\u0627 \u0644\u062a\u0645\u064a\u0632\u0647 \u0641\u064a \u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0637\u0628\u064a\u0629.<h2>\u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u0635\u062d\u064a \u0648\u0627\u0644\u0628\u062d\u062b\u064a</h2>\u0648\u0641\u064a \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u0635\u062d\u064a \u0648\u0627\u0644\u0628\u062d\u062b\u064a\u060c \u062d\u0642\u0642 \u062f. \u0639\u0628\u062f\u0627\u0644\u0631\u062d\u0645\u0646 \u0628\u0646 \u0632\u064a\u0627\u062f \u0646\u0642\u0634\u0628\u0646\u062f\u064a\u060c \u062e\u0631\u064a\u062c \u0627\u0644\u062f\u0643\u062a\u0648\u0631\u0627\u0629 \u0645\u0646 \u062c\u0627\u0645\u0639\u0629 \u0647\u0627\u0631\u0641\u0627\u0631\u062f \u0648\u0627\u0644\u0645\u062a\u062f\u0631\u0628 \u0633\u0631\u064a\u0631\u064a\u064b\u0627 \u0641\u064a \u062a\u062e\u0635\u0635 \u0637\u0628 \u0627\u0644\u0641\u0645 \u0628\u0645\u0633\u062a\u0634\u0641\u0649 \u0628\u0631\u064a\u062c\u0647\u0627\u0645 \u0627\u0653\u0646\u062f \u0648\u064a\u0645\u0646\u0632\u060c 5 \u062c\u0648\u0627\u064a\u0654\u0632 \u0639\u0644\u0645\u064a\u0629 \u0648\u0628\u062d\u062b\u064a\u0629 \u0645\u062a\u062e\u0635\u0635\u0629\u060c \u0634\u0645\u0644\u062a \u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0654\u0641\u0636\u0644 \u062d\u0627\u0644\u0629 \u0633\u0631\u064a\u0631\u064a\u0629 \u0644\u0637\u0628\u064a\u0628 \u0645\u062a\u062f\u0631\u0628\u060c \u0648\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u0628\u0627\u062d\u062b \u0627\u0644\u0635\u0627\u0639\u062f\u060c \u0648\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0654\u0641\u0636\u0644 \u0645\u0644\u0635\u0642 \u0639\u0644\u0645\u064a \u0644\u0644\u0627\u0654\u0628\u062d\u0627\u062b \u0627\u0644\u0637\u0628\u064a\u0629\u060c \u0648\u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0654\u0641\u0636\u0644 \u0627\u0644\u0627\u0654\u0628\u062d\u0627\u062b \u0627\u0644\u0645\u0642\u062f\u0645\u0629 \u0645\u0646 \u0637\u0644\u0627\u0628 \u0627\u0644\u062f\u0631\u0627\u0633\u0627\u062a \u0627\u0644\u0639\u0644\u064a\u0627.<br />\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u062d\u0635\u0648\u0644\u0647 \u0639\u0644\u0649 \u0645\u0631\u062a\u0628\u0629 \u0627\u0644\u0634\u0631\u0641 \u0641\u064a \u0628\u062d\u062b \u0627\u0644\u062f\u0643\u062a\u0648\u0631\u0627\u0629 \u0628\u0643\u0644\u064a\u0629 \u0647\u0627\u0631\u0641\u0627\u0631\u062f \u0644\u0637\u0628 \u0627\u0644\u0627\u0654\u0633\u0646\u0627\u0646.<br />\u0643\u0645\u0627 \u062d\u0635\u0644\u062a \u062f. \u0645\u0646\u062f\u0644\u064a\u0646 \u0628\u0646\u062a \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0644\u0645\u0648\u0633\u0649\u060c \u062e\u0631\u064a\u062c\u0629 \u0627\u0644\u062f\u0643\u062a\u0648\u0631\u0627\u0629 \u0645\u0646 \u062c\u0627\u0645\u0639\u0629 \u0647\u0627\u0631\u0641\u0627\u0631\u062f \u0648\u0627\u0644\u0645\u062a\u062f\u0631\u0628\u0629 \u0641\u064a \u062a\u062e\u0635\u0635 \u0637\u0628 \u0627\u0644\u0641\u0645 \u0628\u0645\u0633\u062a\u0634\u0641\u0649 \u0628\u0631\u064a\u062c\u0647\u0627\u0645 \u0627\u0653\u0646\u062f \u0648\u064a\u0645\u0646\u0632\u060c \u0639\u0644\u0649 \u062c\u0627\u064a\u0654\u0632\u0629 Lester Burket \u0627\u0644\u0645\u0631\u0645\u0648\u0642\u0629 \u0644\u0627\u0654\u0641\u0636\u0644 \u0628\u062d\u062b 