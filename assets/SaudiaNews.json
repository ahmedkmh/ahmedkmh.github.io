{"status": "success", "totalResults": 5456, "results": [{"article_id": "7895e9d4cf20b6753b1f288ca3cca0e8", "link": "https://www.alyaum.com/articles/6660080/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AA%D8%B3%D8%AA%D9%87%D8%AF%D9%81-%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-200-%D8%A3%D9%84%D9%81-%D8%AD%D8%A7%D8%AC-%D8%A8%D8%AF%D8%A1-%D8%AF%D9%88%D8%B1%D8%A9-%D8%B2%D8%A7%D8%AF-%D8%A7%D9%84%D8%AD%D8%AC-%D9%81%D9%8A-%D9%85%D8%B3%D8%AC%D8%AF-%D9%82%D8%A8%D8%A7%D8%A1-%D8%BA%D8%AF%D8%A7", "title": "\u062a\u0633\u062a\u0647\u062f\u0641 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 200 \u0627\u0654\u0644\u0641 \u062d\u0627\u062c.. \u0628\u062f\u0621 \u062f\u0648\u0631\u0629 \"\u0632\u0627\u062f \u0627\u0644\u062d\u062c\" \u0641\u064a \u0645\u0633\u062c\u062f \u0642\u0628\u0627\u0621 \u063a\u062f\u0627", "description": "\u0628\u0631\u0639\u0627\u064a\u0629 \u0648\u0632\u064a\u0631<a href=\"https://www.alyaum.com/articles/6660005/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A8%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-113-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D8%B1%D9%8A%D8%A7%D9%84%D8%AA%D8%B1%D8%B3%D9%8A%D8%A9-%D8%B9%D9%82%D9%88%D8%AF-%D8%B5%D9%8A%D8%A7%D9%86%D8%A9-%D9%88%D8%AA%D8%B4%D8%BA%D9%8A%D9%84-1837-%D9%85%D8%B3%D8%AC%D8%AF%D8%A7-%D9%88%D8%AC%D8%A7%D9%85%D8%B9%D8%A7-%D9%81%D9%8A-%D9%85%D9%86%D8%A7%D8%B7%D9%82-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9\"> \u0627\u0644\u0634\u0648\u0654\u0648\u0646 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629 </a>\u0648\u0627\u0644\u062f\u0639\u0648\u0629 \u0648\u0627\u0644\u0627\u0655\u0631\u0634\u0627\u062f\u060c \u0627\u0644\u0645\u0634\u0631\u0641 \u0627\u0644\u0639\u0627\u0645 \u0639\u0644\u0649 \u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u062d\u062c \u0648\u0627\u0644\u0639\u0645\u0631\u0629 \u0648\u0627\u0644\u0632\u064a\u0627\u0631\u0629\u060c \u0627\u0644\u0634\u064a\u062e \u0639\u0628\u062f\u0627\u0644\u0644\u0637\u064a\u0641 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0653\u0644 \u0627\u0644\u0634\u064a\u062e\u060c \u062a\u0646\u0641\u0651\u0630 <a href=\"https://www.alyaum.com/articles/6659985/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AE%D8%B7%D8%A8%D8%A9-%D8%A7%D9%84%D8%AC%D9%85%D8%B9%D8%A9-%D8%AA%D9%86%D8%A7%D9%82%D8%B4-%D8%A7%D9%84%D8%B6%D9%88%D8%A7%D8%A8%D8%B7-%D8%A7%D9%84%D8%B4%D8%B1%D8%B9%D9%8A%D8%A9-%D9%84%D8%A7%D8%B3%D8%AA%D8%AE%D8%AF%D8%A7%D9%85-%D9%88%D8%B3%D8%A7%D8%A6%D9%84-%D8%A7%D9%84%D8%AA%D9%88%D8%A7%D8%B5%D9%84-%D9%88%D8%A7%D9%84%D8%B0%D9%83%D8%A7%D8%A1-%D8%A7%D9%84%D8%A7%D8%B5%D8%B7%D9%86%D8%A7%D8%B9%D9%8A\">\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0634\u0648\u0654\u0648\u0646 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629</a> \u0648\u0627\u0644\u062f\u0639\u0648\u0629 \u0648\u0627\u0644\u0627\u0655\u0631\u0634\u0627\u062f\u060c \u0645\u0645\u062b\u0644\u0629\u064b \u0628\u0641\u0631\u0639\u0647\u0627 \u0628\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629\u060c \u062f\u0648\u0631\u0629 \"\u0632\u0627\u062f <a href=\"https://www.alyaum.com/articles/6660069/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B7%D8%B1%D9%8A%D9%82-%D9%85%D9%83%D8%A9-%D8%B3%D8%AF%D8%A7%D9%8A%D8%A7-%D8%AA%D9%88%D8%B8%D9%81-%D8%A7%D9%84%D8%AA%D9%82%D9%86%D9%8A%D8%A7%D8%AA-%D9%84%D8%AA%D8%B3%D9%87%D9%8A%D9%84-%D9%85%D8%BA%D8%A7%D8%AF%D8%B1%D8%A9-%D8%A7%D9%84%D8%AD%D8%AC%D8%A7%D8%AC-%D9%81%D9%8A-%D8%A7%D9%84%D9%85%D8%BA%D8%B1%D8%A8\">\u0627\u0644\u062d\u062c</a>\u201d \u0641\u064a \u0645\u0633\u062c\u062f \u0642\u0628\u0627\u0621 \u0627\u0639\u062a\u0628\u0627\u0631\u064b\u0627 \u0645\u0646 \u064a\u0648\u0645 \u063a\u062f \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 19 \u0630\u064a \u0627\u0644\u0642\u0639\u062f\u0629 \u0648\u062d\u062a\u0649 \u0627\u0644\u062a\u0627\u0633\u0639 \u0645\u0646 \u0634\u0647\u0631 \u0630\u064a \u0627\u0644\u062d\u062c\u0629 1447\u0647\u0640\u060c \u0636\u0645\u0646 \u062e\u0637\u062a\u0647\u0627 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0644\u0645\u0648\u0633\u0645 \u062d\u062c 1447\u0647\u0640\u060c \u0648\u0630\u0644\u0643 \u0628\u0647\u062f\u0641 \u062a\u0648\u0639\u064a\u0629 \u0636\u064a\u0648\u0641 \u0627\u0644\u0631\u062d\u0645\u0646 \u0648\u0627\u0655\u0631\u0634\u0627\u062f\u0647\u0645 \u0648\u0641\u0642 \u0627\u0644\u0645\u0646\u0647\u062c \u0627\u0644\u0648\u0633\u0637\u064a \u0627\u0644\u0645\u0639\u062a\u062f\u0644.<br /><br /><br /><br />\u0648\u062a\u062a\u0636\u0645\u0646 \u0627\u0644\u062f\u0648\u0631\u0629 \u062a\u0646\u0641\u064a\u0630 (36) \u062f\u0631\u0633\u064b\u0627 \u0639\u0644\u0645\u064a\u064b\u0627 \u064a\u0642\u062f\u0651\u0645\u0647\u0627 \u0646\u062e\u0628\u0629 \u0645\u0646 \u0627\u0644\u0645\u0634\u0627\u064a\u062e \u0648\u0627\u0644\u062f\u0639\u0627\u0629\u060c \u062d\u064a\u062b \u062a\u062a\u0646\u0627\u0648\u0644 \u0645\u0648\u0636\u0648\u0639\u0627\u062a\u064d \u0645\u062a\u0646\u0648\u0639\u0629 \u062a\u0634\u0645\u0644: \u0627\u0654\u062d\u0643\u0627\u0645 \u0627\u0644\u0645\u0646\u0627\u0633\u0643\u060c \u0648\u062a\u0641\u0633\u064a\u0631 \u0627\u0653\u064a\u0627\u062a \u0627\u0644\u062d\u062c\u060c \u0648\u0645\u0639\u0627\u0644\u0645 \u0627\u0644\u062a\u0648\u062d\u064a\u062f\u060c \u0648\u062a\u0639\u0638\u064a\u0645 \u0634\u0639\u0627\u064a\u0654\u0631 \u0627\u0644\u0644\u0647\u060c \u0648\u0641\u0636\u0627\u064a\u0654\u0644 \u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0634\u0631\u062d \u0639\u062f\u062f\u064d \u0645\u0646 \u0627\u0644\u0645\u062a\u0648\u0646 \u0627\u0644\u0639\u0644\u0645\u064a\u0629\u060c \u0628\u0645\u0627 \u064a\u0633\u0647\u0645 \u0641\u064a \u062a\u0631\u0633\u064a\u062e \u0627\u0644\u0645\u0641\u0627\u0647\u064a\u0645 \u0627\u0644\u0634\u0631\u0639\u064a\u0629 \u0627\u0644\u0635\u062d\u064a\u062d\u0629 \u0644\u062f\u0649 \u0627\u0644\u062d\u062c\u0627\u062c.<br /><br /> <h2>\u0645\u062d\u062a\u0648\u0649 \u0639\u0644\u0645\u064a \u0645\u064a\u0633\u0651\u0631</h2><br />\u0648\u062a\u0633\u062a\u0647\u062f\u0641 \u0627\u0644\u062f\u0648\u0631\u0629 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 (200,000) \u062d\u0627\u062c \u0645\u0646 \u0632\u0648\u0627\u0631 \u0645\u0633\u062c\u062f \u0642\u0628\u0627\u0621\u060c \u0645\u0646 \u062e\u0644\u0627\u0644 \u062a\u0642\u062f\u064a\u0645 \u0645\u062d\u062a\u0648\u0649 \u0639\u0644\u0645\u064a \u0645\u064a\u0633\u0651\u0631 \u064a\u0631\u0627\u0639\u064a \u062a\u0646\u0648\u0651\u0639 \u0627\u0644\u0644\u063a\u0627\u062a \u0648\u0627\u0644\u062b\u0642\u0627\u0641\u0627\u062a\u060c \u0648\u062a\u0646\u0638\u064a\u0645 \u0627\u0654\u0648\u0642\u0627\u062a \u0627\u0644\u062f\u0631\u0648\u0633 \u0628\u0645\u0627 \u064a\u062a\u0646\u0627\u0633\u0628 \u0645\u0639 \u062c\u062f\u0627\u0648\u0644 \u0627\u0644\u062d\u062c\u0627\u062c\u060c \u0628\u0645\u0627 \u064a\u0639\u0632\u0651\u0632 \u0645\u0646 \u0627\u0654\u062b\u0631 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0627\u0644\u062f\u0639\u0648\u064a\u0629 \u0648\u064a\u0633\u0647\u0645 \u0641\u064a \u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0648\u0639\u064a \u0627\u0644\u0634\u0631\u0639\u064a \u0644\u062f\u064a\u0647\u0645.<br /><br /> <br /><br />\u0648\u062a\u0627\u0654\u062a\u064a \u0627\u0644\u062f\u0648\u0631\u0629 \u0627\u0645\u062a\u062f\u0627\u062f\u064b\u0627 \u0644\u062c\u0647\u0648\u062f \u0627\u0644\u0648\u0632\u0627\u0631\u0629 \u0641\u064a \u062a\u0633\u062e\u064a\u0631 \u0627\u0655\u0645\u0643\u0627\u0646\u0627\u062a\u0647\u0627 \u0643\u0627\u0641\u0629 \u0644\u062e\u062f\u0645\u0629 \u0627\u0644\u062d\u062c\u0627\u062c \u0648\u0627\u0644\u0632\u0648\u0627\u0631\u060c \u0639\u0628\u0631 \u064