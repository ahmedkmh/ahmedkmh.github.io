46 \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062b\u0627\u0644\u062b\u0629 \u0645\u0646 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0641\u064a \u0643\u0627\u0654\u0633 \u0627\u0653\u0633\u064a\u0627\u060c \u0639\u0644\u0649 \u0645\u0644\u0639\u0628 \u0642\u0627\u0639\u0629 \u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0644\u0643 \u0639\u0628\u062f \u0627\u0644\u0644\u0647 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629. \u0648\u0633\u062c\u0644 \u0644\u0644\u0627\u0654\u062e\u0636\u0631 \u064a\u062d\u064a\u0649 \u0633\u0639\u064a\u062f \u0639\u0646\u062f \u0627\u0644\u062f\u0642\u064a\u0642\u0629 13\u060c \u0648\u0639\u0644\u064a \u0627\u0644\u0634\u0647\u0631\u0627\u0646\u064a \u00ab\u0647\u062f\u0641\u064a\u0646\u00bb \u0639\u0646\u062f \u0627\u0644\u062f\u0642\u064a\u0642\u062a\u064a\u0646 18 \u064833 \u0645\u0646 \u0631\u0643\u0644\u0629 \u062c\u0632\u0627\u0621\u060c \u0648\u0632\u064a\u062f \u0627\u0644\u062f\u0648\u0631\u064a \u0639\u0646\u062f \u0627\u0644\u062f\u0642\u064a\u0642\u0629 39\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0636\u064a\u0641 \u0641\u064a\u0635\u0644 \u0628\u064a\u0648\u064a \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u062e\u0627\u0645\u0633 \u0639\u0646\u062f \u0627\u0644\u062f\u0642\u064a\u0642\u0629 54. \u0641\u064a \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u060c \u062a\u0646\u0627\u0648\u0628 \u0639\u0644\u0649 \u062a\u0633\u062c\u064a\u0644 \u0627\u0654\u0647\u062f\u0627\u0641 \u0645\u0646\u062a\u062e\u0628 \u0637\u0627\u062c\u064a\u0643\u0633\u062a\u0627\u0646 \u0645\u0646\u0627\u0641\u0627\u0631 \u0627\u0654\u0641\u0627\u0631\u0632\u0648\u062f \u00ab\u0647\u062f\u0641\u064a\u0646\u00bb \u0639\u0646\u062f \u0627\u0644\u062f\u0642\u064a\u0642\u062a\u064a\u0646 27 \u064849\u060c \u0648\u0627\u0654\u0633\u062f\u064a\u0628\u0643 \u0645\u062e\u062a\u0648\u0645\u0648\u0641 \u0639\u0646\u062f \u0627\u0644\u062f\u0642\u064a