AA%D8%B5%D8%A7%D8%AF/%D8%A3%D8%B3%D9%88%D8%A7%D9%82-%D8%A7%D9%84%D8%A3%D8%B3%D9%87%D9%85/%D8%A7%D9%84%D8%AF%D8%B1%D8%B9-%D8%A7%D9%84%D8%B9%D8%B1%D8%A8%D9%8A-%D8%AA%D8%AA%D8%AD%D9%88%D9%84-%D9%84%D9%84%D8%AE%D8%B3%D8%A7%D8%B1%D8%A9-%D8%A8437-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D8%B1%D9%8A%D8%A7%D9%84-%D9%81%D9%8A-2025", "title": "\u00ab\u0627\u0644\u062f\u0631\u0639 \u0627\u0644\u0639\u0631\u0628\u064a\u00bb \u062a\u062a\u062d\u0648\u0644 \u0644\u0644\u062e\u0633\u0627\u0631\u0629 \u0628\u064043.7 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0641\u064a 2025", "description": "\u062a\u062d\u0648\u0644\u062a \u0634\u0631\u0643\u0629 \u0627\u0644\u062f\u0631\u0639 \u0627\u0644\u0639\u0631\u0628\u064a \u0644\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u062a\u0639\u0627\u0648\u0646\u064a \u0644\u0644\u062e\u0633\u0627\u0631\u0629 \u0641\u064a 2025 \u0628\u064043.7 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0645\u0642\u0627\u0628\u0644 \u0627\u0654\u0631\u0628\u0627\u062d \u0628\u064090.9 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0641\u064a 2024.\u0648\u0648\u0641\u0642\u0627 \u0644\u0628\u064a\u0627\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\"\u060c \u0627\u0646\u062e\u0641\u0636 \u0635\u0627\u0641\u064a \u0627\u0644\u062f\u062e\u0644 \u0642\u0628\u0644 \u0627\u0644\u0632\u0643\u0627\u0629 \u0648\u0636\u0631\u064a\u0628\u0629 \u0627\u0644\u062f\u062e\u0644 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0628\u0645\u0642\u062f\u0627\u0631 (124,995) \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0628\u062a\u0631\u0627\u062c\u0639 \u0642\u062f\u0631\u0647 133% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0648\u0630\u0644\u0643 \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0654\u0633\u0628\u0627\u0628 \u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629:- \u0627\u0644\u0627\u0631\u062a\u0641\u0627\u0639 \u0641\u064a \u0645\u0635\u0627\u0631\u064a\u0641 \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0645\u0628\u0644\u063a 490,871 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0627\u0631\u062a\u0641\u0627\u0639 \u0628\u0646\u0633\u0628\u0629 34%.- \u0627\u0644\u0627\u0646\u062e\u0641\u0627\u0636 \u0641\u064a \u0635\u0627\u0641\u064a \u062f\u062e\u0644 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0645\u0628\u0644\u063a 22,662 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642 \u0627\u0646\u062e\u0641\u0627\u0636 \u0628\u0646\u0633\u0628\u0629 25%.- \u0627\u0644\u0627\u0631\u062a\u0641\u0627\u0639 \u0641\u064a \u0635\u0627\u0641\u064a \u0645\u0635\u0627\u0631\u064a\u0641 \u062a\u0645\u0648\u064a\u0644 \u0627\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0645\u0628\u0644\u063a 1,920 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642 \u0627\u0631\u062a\u0641\u0627\u0639 \u0628\u0646\u0633\u0628\u0629 43%.- \u0627\u0644\u0627\u0631\u062a\u0641\u0627\u0639 \u0641\u064a \u0627\u0644\u0645\u0635\u0627\u0631\u064a\u0641 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0627\u0644\u0627\u0654\u062e\u0631\u0649 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0645\u0628\u0644\u063a 3,378 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642 \u0627\u0631\u062a\u0641\u0627\u0639 \u0628\u0646\u0633\u0628\u0629 15%. \u0642\u0627\u0628\u0644\u0647\u0627.- \u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0655\u064a\u0631\u0627\u062f\u0627\u062a \u0627\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0645\u0628\u0644\u063a 315,088 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0646\u0641\u0633 \u0627\u0644\u0641\u062a\u0631\u0629 \u0645\u0646 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642 \u0627\u0631\u062a\u0641\u0627\u0639 \u0628\u0646\u0633\u0628\u0629 20%.- \u0627\u0644\u0627\u0646\u062e\u0641\u0627\u0636 \u0641\u064a \u0635\u0627\u0641\u064a \u0645\u0635\u0627\u0631\u064a\u0641 \u0639\u0642\u0648\u062f \u0627\u0655\u0639\u0627\u062f\u0629 \u0627\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0645\u0628\u0644\u063a 82,676 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0627\u0646\u062e\u0641\u0627\u0636 \u0628\u0646\u0633\u0628\u0629 68%.\u0627\u0644\u0627\u0631\u062a\u0641\u0627\u0639 \u0641\u064a \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0654\u0642\u0633\u0627\u0637 \u0627\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u0645\u0643\u062a\u062a\u0628\u0629 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0645\u0628\u0644\u063a 1,083,765 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0627\u0631\u062a\u0641\u0627\u0639 \u0628\u0646\u0633\u0628\u0629 59%.", "content": "ON