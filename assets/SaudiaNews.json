%84%D9%87%D8%AC%D9%88%D9%85-%D8%B9%D9%84%D9%89-%D9%85%D8%B5%D9%81%D8%A7%D8%A9-%D8%A7%D9%84%D9%86%D9%81%D8%B7\">\u0643\u064a\u064a\u0641</a>\u060c \u0628\u062d\u0633\u0628 \u0645\u0627 \u0627\u0654\u0641\u0627\u062f \u0639\u062f\u062f \u0645\u0646 \u0635\u062d\u0627\u0641\u064a\u064a \u0648\u0643\u0627\u0644\u0629 \u0641\u0631\u0627\u0646\u0633 \u0628\u0631\u0633\u060c \u0628\u0639\u062f \u062f\u0642\u0627\u064a\u0654\u0642 \u0645\u0646 \u062a\u062d\u0630\u064a\u0631 \u0633\u0644\u0627\u062d \u0627\u0644\u062c\u0648 \u0648\u0627\u0644\u0633\u0644\u0637\u0627\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629 \u0645\u0646 \u0631\u0635\u062f<a href=\"https://www.alyaum.com/articles/6668986/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A3%D9%88%D9%83%D8%B1%D8%A7%D9%86%D9%8A%D8%A7-%D8%B6%D8%B1%D8%A8%D8%A9-%D8%B1%D9%88%D8%B3%D9%8A%D8%A9-%D8%A8%D8%AE%D9%8A%D8%B1%D8%B3%D9%88%D9%86-%D8%AA%D8%B3%D8%A8%D8%A8-%D9%85%D9%82%D8%AA%D9%84-%D8%AE%D8%A8%D9%8A%D8%B1-%D9%81%D9%8A-%D8%A5%D8%B2%D8%A7%D9%84%D8%A9-%D8%A7%D9%84%D8%A3%D9%84%D8%BA%D8%A7%D9%85\"> \u0635\u0648\u0627\u0631\u064a\u062e \u0631\u0648\u0633\u064a\u0629</a> \u062a\u062a\u062c\u0647 \u0646\u062d\u0648 \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0627\u0644\u0627\u0654\u0648\u0643\u0631\u0627\u0646\u064a\u0629.<br /><br />\u0648\u0627\u0654\u0634\u0627\u0631 \u0631\u064a\u0654\u064a\u0633 \u0628\u0644\u062f\u064a\u0629 \u0643\u064a\u064a\u0641 \u0641\u064a\u062a\u0627\u0644\u064a \u0643\u0644\u064a\u062a\u0634\u0643\u0648 \u0639\u0628\u0631 \u0645\u0646\u0635\u0629 \u062a\u0644\u063a\u0631\u0627\u0645 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u062f\u0641\u0627\u0639\u0627\u062a \u0627\u0644\u062c\u0648\u064a\u0629 \u0627\u0644\u0627\u0654\u0648\u0643\u0631\u0627\u0646\u064a\u0629 \u062a\u0639\u0645\u0644 \u0639\u0644\u0649 \u0627\u0644\u062a\u0635\u062f\u064a \u0644\u0644\u0635\u0648\u0627\u0631\u064a\u062e \u0627\u0644\u0631\u0648\u0633\u064a\u0629\u060c \u062f\u0627\u0639\u064a\u0627 \u0627\u0644\u0633\u0643\u0627\u0646 \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u062d\u062a\u0645\u0627\u0621 \u0641\u064a \u0627\u0644\u0645\u0644\u0627\u062c\u064a\u0654.<h2>\u062d\u0637\u0627\u0645 \u0635\u0648\u0627\u0631\u064a\u062e</h2>\u0648\u0641\u064a \u0645\u0646\u0634\u0648\u0631 \u0645\u0646\u0641\u0635\u0644\u060c \u0627\u0654\u0639\u0644\u0646 \u0627\u0654\u0646 \"\u062d\u0637\u0627\u0645 \u0635\u0648\u0627\u0631\u064a\u062e\" \u0631\u0648\u0633\u064a\u0629 \u0633\u0642\u0637 \u0641\u064a \u062d\u064a \u062f\u0627\u0631\u0646\u064a\u062a\u0633\u0627 \u0641\u064a \u062c\u0646\u0648\u0628 \u0634\u0631\u0642 \u0643\u064a\u064a\u0641\u060c \u0648\u0627\u0654\u0646 \u0641\u0631\u0642 \u0627\u0644\u0627\u0655\u0646\u0642\u0627\u0630 \u0647\u0631\u0639\u062a \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0646\u0637\u0642\u0629.<br /> <br />\u0648\u0643\u0627\u0646 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u0644\u0644\u0639\u0627\u0635\u0645\u0629 \u062a\u064a\u0645\u0648\u0631 \u062a\u0643\u0627\u062a\u0634\u064a\u0646\u0643\u0648 \u0627\u0654\u0641\u0627\u062f \u0641\u064a \u0648\u0642\u062a \u0633\u0627\u0628\u0642 \u0628\u0627\u0654\u0646 \u0631\u0648\u0633\u064a\u0627 \u0627\u0654\u0637\u0644\u0642\u062a \"\u0635\u0648\u0627\u0631\u064a\u062e \u0628\u0627\u0644\u0633\u062a\u064a\u0629\" \u0628\u0627\u062a\u062c\u0627\u0647 \u0643\u064a\u064a\u0641.<h2>\u0627\u0644\u062f\u0641\u0627\u0639\u0627\u062a \u0627\u0644\u062c\u0648\u064a\u0629</h2>\u0648\u0631\u0635\u062f \u0635\u062d\u0627\u0641\u064a\u0648\u0646 \u0645\u0646 \u0648\u0643\u0627\u0644\u0629 \u0641\u0631\u0627\u0646\u0633 \u0628\u0631\u0633 \u0633\u062d\u0628\u0627 \u0627\u0654\u062d\u062f\u062b\u0647\u0627 \u0641\u064a \u0633\u0645\u0627\u0621 \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0627\u0655\u0637\u0644\u0627\u0642 \u0635\u0648\u0627\u0631\u064a\u062e \u0627\u0644\u062f\u0641\u0627\u0639