u0627. \u0633\u0646\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0644\u0627\u0654\u0645\u0631 \u0627\u0655\u0630\u0627 \u0644\u0632\u0645 \u0627\u0644\u0627\u0654\u0645\u0631\".\u0648\u0627\u0654\u0636\u0627\u0641: \"\u0646\u062d\u0646 \u0646\u0631\u0627\u0642\u0628 \u0643\u0644 \u0634\u064a\u0621\" \u0645\u0646 \u062f\u0648\u0646 \u0627\u0654\u0646 \u064a\u0648\u0654\u0643\u062f \u0647\u0630\u0647 \u0627\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a. \u0645\u0648\u0627\u0642\u0639 \u0639\u0633\u0643\u0631\u064a\u0629 \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0635\u062d\u064a\u0641\u0629 \"\u0648\u0627\u0634\u0646\u0637\u0646 \u0628\u0648\u0633\u062a\" \u0646\u0642\u0644\u0627 \u0639\u0646 \u0645\u0635\u0627\u062f\u0631 \u0645\u0637\u0644\u0639\u0629 \u0639\u0644\u0649 \u0627\u0644\u0634\u0648\u0654\u0648\u0646 \u0627\u0644\u0627\u0633\u062a\u062e\u0628\u0627\u0631\u0627\u062a\u064a\u0629 \u0628\u0627\u0654\u0646 \u0631\u0648\u0633\u064a\u0627 \u0632\u0648\u0651\u062f\u062a \u0627\u0655\u064a\u0631\u0627\u0646 \u0645\u0648\u0627\u0642\u0639 \u062a\u062c\u0647\u064a\u0632\u0627\u062a \u0639\u0633\u0643\u0631\u064a\u0629 \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629\u060c \u0628\u0645\u0627 \u0641\u064a\u0647\u0627 \u0633\u0641\u0646 \u0648\u0637\u0627\u064a\u0654\u0631\u0627\u062a.\u0648\u0641\u064a \u0648\u0642\u062a \u0633\u0627\u0628\u0642 \u0627\u0644\u062c\u0645\u0639\u0629\u060c \u0642\u0644\u0644 \u0627\u0644\u0628\u064a\u062a \u0627\u0644\u0627\u0654\u0628\u064a\u0636 \u0627\u0654\u064a\u0636\u0627 \u0645\u0646 \u0627\u0654\u0647\u0645\u064a\u0629 \u0647\u0630\u0647 \u0627\u0644\u062a\u0642\u0627\u0631\u064a\u0631.\u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629\u0648\u0642\u0627\u0644\u062a \u0627\u0644\u0646\u0627\u0637\u0642\u0629 \u0628\u0627\u0633\u0645 \u0627\u0644\u0628\u064a\u062a \u0627\u0644\u0627\u0654\u0628\u064a\u0636 \u0643\u0627\u0631\