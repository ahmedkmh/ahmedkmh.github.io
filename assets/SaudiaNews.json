A%D8%B1%D9%81-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D9%8A%D8%B7%D9%84%D9%82-%D8%A7%D8%B3%D8%AA%D8%B1%D8%A7%D8%AA%D9%8A%D8%AC%D9%8A%D8%A9-2030-%D9%84%D8%AF%D8%B9%D9%85-%D8%A7%D9%84%D9%82%D8%B7%D8%A7%D8%B9-%D8%A7%D9%84%D8%AE%D8%A7%D8%B5", "title": "\u0639\u0628\u0631 22 \u0645\u0628\u0627\u062f\u0631\u0629.. \u0627\u062a\u062d\u0627\u062f \u0627\u0644\u063a\u0631\u0641 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u064a\u0637\u0644\u0642 \u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 2030 \u0644\u062f\u0639\u0645 \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u062e\u0627\u0635", "description": "\u0627\u0654\u0637\u0644\u0642 \u0627\u062a\u062d\u0627\u062f \u0627\u0644\u063a\u0631\u0641 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0655\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u062a\u0647 \u0644\u0644\u0641\u062a\u0631\u0629 (2026\u20132030)\u060c \u0641\u064a \u062e\u0637\u0648\u0629 \u0646\u0648\u0639\u064a\u0629 \u062a\u0647\u062f\u0641 \u0627\u0655\u0644\u0649 \u062a\u0639\u0632\u064a\u0632 \u062a\u0646\u0627\u0641\u0633\u064a\u0629 <a href=\"https://www.alyaum.com/articles/6658819/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A8%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-2-%D9%85%D9%84%D9%8A%D8%A7%D8%B1-%D8%B1%D9%8A%D8%A7%D9%84-%D8%A3%D9%85%D9%8A%D8%B1-%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D9%8A%D8%AF%D8%B4%D9%86-%D9%85%D8%B4%D8%A7%D8%B1%D9%8A%D8%B9-%D8%A8%D9%84%D8%AF%D9%8A%D8%A9-%D9%88%D8%A5%D8%B3%D9%83%D8%A7%D9%86%D9%8A%D8%A9-%D9%88%D8%A7%D8%B3%D8%AA%D8%AB%D9%85%D8%A7%D8%B1%D9%8A%D8%A9\" target=\"_blank\">\u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u062e\u0627\u0635</a>\u060c \u0648\u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u0629 \u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644\u060c \u0648\u062a\u0631\u0633\u064a\u062e \u062f\u0648\u0631 \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u062e\u0627\u0635 \u0634\u0631\u064a\u0643\u064b\u0627 \u0631\u064a\u0654\u064a\u0633\u064a\u064b\u0627 \u0641\u064a \u062a\u062d\u0642\u064a\u0642 \u0645\u0633\u062a\u0647\u062f\u0641\u0627\u062a \u0631\u0648\u0654\u064a\u0629 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 2030.<br /><br />\u0648\u062d\u062f\u0651\u062f\u062a \u0627\u0644\u0627\u0655\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 3 \u0631\u0643\u0627\u064a\u0654\u0632 \u0631\u064a\u0654\u064a\u0633\u064a\u0629 \u062a\u062a\u0645\u062b\u0644 \u0641\u064a: \u062a\u0639\u0632\u064a\u0632 \u062a\u0645\u062b\u064a\u0644 \u0627\u0644\u0645\u0635\u0627\u0644\u062d \u0627\u0644\u0645\u0634\u062a\u0631\u0643\u0629 \u0644\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u062e\u0627\u0635\u060c \u0648\u062a\u0645\u0643\u064a\u0646 \u0627\u0644\u063a\u0631\u0641 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0648\u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u062a\u0647\u0627\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u062a\u0631\u0633\u064a\u062e \u0627\u0644\u062d\u0648\u0643\u0645\u0629 \u0648\u0627\u0644\u062a\u0645\u064a\u0632 \u0627\u0644\u0645\u0648\u0654\u0633\u0633\u064a \u0648\u0627\u0644\u0627\u0633\u062a\u062f\u0627\u0645\u0629\u060c \u0628\u0645\u0627 \u064a\u062f\u0639\u0645 \u0627\u0644\u062f\u0648\u0631 \u0627\u0644\u0642\u064a\u0627\u062f\u064a \u0644\u0644\u0627\u062a\u062d\u0627\u062f \u0641\u064a \u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644.<br /><br />\u0648\u062a\u062a\u0641\u0631\u0639 \u0639\u0646 \u0647\u0630\u0647 \u0627\u0644\u0631\u0643\u0627\u064a\u0654\u0632 10 \u0627\u0654\u0647\u062f\u0627\u0641 \u0627\u0655\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 \u0645\u062f\u0639\u0648\u0645\u0629 \u0628\u0640 22 \u0645\u0628\u0627\u062f\u0631\u0629 \u062a\u0646\u0641\u064a\u0630\u064a\u0629\u060c \u062a\u0633\u062a\u0647\u062f\u0641 \u0631\u0641\u0639 \u0627\u0644\u0643\u0641\u0627\u0621\u0629 \u0627\u0644\u0645\u0648\u0654\u0633\u0633\u064a\u0629 \u0648\u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629\u060c \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u062a\u0643\u0627\u0645\u0644 \u0628\u064a\u0646 <a href=\"https://www.alyaum.com/articles/6651835/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AE%D8%B7%D8%B7-%D8%A7%D8%B3%D8%AA%D8%A8%D8%A7%D9%82%D9%8A%D8%A9-%D9%88%D8%B4%D8%A7%D8%AD%D9%86%D8%A7%D8%AA-%D8%A5%D8%B6%D8%A7%D9%81%D9%8A%D8%A9-%D9%84%D8%B6%D9%85%D8%A7%D9%86-%D8%A7%D9%86%D8%B3%D9%8A%D8%A7%D8%A8%D9%8A%D8%A9-%D8%AD%D8%B1%D9%83%D8%A9-%D8%A7%D9%84%D8%AA%D8%AC%D8%A7%D8%B1%D8%A9-%D8%B9%D8%A8%D8%B1-%D8%A7%D9%84%D8%AD%D8%AF%D9%88%D8%AF\" target=\"_blank\">\u0627\u0644\u063a\u0631\u0641 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629</a>\u060c \u0648\u062a\u0648\u0633\u064a\u0639 \u0627\u0644\u0634\u0631\u0627\u0643\u0627\u062a \u0627\u0644\u0627\u0655\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 \u0645\u062d\u0644\u064a\u064b\u0627 \u0648\u062f\u0648\u0644\u064a\u064b\u0627\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u062f\u0639\u0645 \u0646\u0645\u0648 \u0627\u0644\u0635\u0627\u062f\u0631\u0627\u062a\u060c \u0648\u062c\u0630\u0628 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a\u060c \u0648\u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u062a\u0628\u0627\u062f\u0644 \u0627\u0644\u062a\u062c\u0627\u0631\u064a.<br /><br />\u0648\u062a\u0627\u0654\u062a\u064a \u0627\u0644\u0627\u0655\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0644\u062a\u0645\u062b\u0644 \u0627\u0655\u0637\u0627\u0631\u064b\u0627 \u0645\u062a\u0643\u0627\u0645\u0644\u064b\u0627 \u0644\u062a\u0637\u0648\u064a\u0631 \u062f\u0648\u0631 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u062c\u0647\u0629 \u0648\u0637\u0646\u064a\u0629 \u0645\u0645\u0643\u0646\u0629 \u0644\u0644\u0642\u0637\u0627\u0639 \u