D8%B3%D8%B9%D9%88%D8%AF%D9%8A/%D8%AD%D8%B3%D9%85-%D9%85%D9%88%D9%82%D9%81-%D8%B3%D8%A7%D8%AF%D9%8A%D9%88-%D9%85%D8%A7%D9%86%D9%8A-%D9%85%D9%86-%D9%85%D8%A8%D8%A7%D8%B1%D8%A7%D8%A9-%D8%A7%D9%84%D9%86%D8%B5%D8%B1-%D8%A3%D9%85%D8%A7%D9%85-%D8%A7%D9%84%D8%B4%D8%A8%D8%A7%D8%A8", "title": "\u062d\u0633\u0645 \u0645\u0648\u0642\u0641 \u0633\u0627\u062f\u064a\u0648 \u0645\u0627\u0646\u064a \u0645\u0646 \u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0646\u0635\u0631 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0634\u0628\u0627\u0628", "description": "\u062d\u0633\u0645 \u0645\u0633\u064a\u0654\u0648\u0644\u0648 \u0646\u0627\u062f\u064a \u0627\u0644\u0646\u0635\u0631\u060c \u0645\u0648\u0642\u0641 \u0633\u0627\u062f\u064a\u0648 \u0645\u0627\u0646\u064a\u060c \u0645\u0646 \u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0634\u0628\u0627\u0628\u060c \u0641\u064a \u0627\u0644\u0644\u0642\u0627\u0621 \u0627\u0644\u0630\u064a \u064a\u062c\u0645\u0639 \u0627\u0644\u0641\u0631\u064a\u0642\u064a\u0646\u060c \u0636\u0645\u0646 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062d\u0627\u062f\u064a\u0629 \u0648\u0627\u0644\u062b\u0644\u0627\u062b\u064a\u0646 \u0645\u0646 \u0645\u0633\u0627\u0628\u0642\u0629 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0644\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u0642\u0627\u0645 \u0639\u0644\u0649 \u0627\u0654\u0631\u0636\u064a\u0629 \u0645\u0644\u0639\u0628 \u0627\u0644\u0627\u0654\u0648\u0644 \u0628\u0627\u0631\u0643.<br /><br />\u0648\u0634\u0627\u0631\u0643 \u0633\u0627\u062f\u064a\u0648 \u0645\u0627\u0646\u064a\u060c \u0641\u064a \u0627\u0644\u062a\u062f\u0631\u064a\u0628\u0627\u062a \u0627\u0644\u062c\u0645\u0627\u0639\u064a\u0629 \u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0646\u0635\u0631\u060c \u0648\u0630\u0644\u0643 \u0628\u0639\u062f \u062a\u0639\u0627\u0641\u064a\u0647 \u0645\u0646 \u0627\u0644\u0627\u0655\u0635\u0627\u0628\u0629 \u0627\u0644\u062a\u064a \u0644\u062d\u0642\u062a \u0628\u0647 \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629\u060c \u0648\u0627\u0644\u062a\u064a \u0627\u0654\u0628\u0639\u062f\u062a\u0647 \u0639\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0629 \u0645\u0639 \u0627\u0644\u0641\u0631\u064a\u0642.<br /><br />\u0648\u064a\u0639\u062f \u0633\u0627\u062f\u064a\u0648 \u0645\u0627\u0646\u064a\u060c \u0627\u0654\u062d\u062f \u0627\u0644\u0631\u0643\u0627\u064a\u0654\u0632 \u0627\u0644\u0627\u0654\u0633\u0627\u0633\u064a\u0629 \u0641\u064a \u0627\u0644\u062a\u0634\u0643\u064a\u0644 \u0627\u0644\u0631\u0633\u0645\u064a \u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0646\u0635\u0631\u060c \u0641\u064a \u0644\u0642\u0627\u0621 \u0627\u0644\u0634\u0628\u0627\u0628\u060c \u0648\u0630\u0644\u0643 \u0645\u0646 \u0627\u0654\u062c\u0644 \u0627\u0644\u0641\u0648\u0632 \u0628\u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629\u060c \u0648\u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0646\u0642\u0627\u0637 \u0627\u0644\u062b\u0644\u0627\u062b \u0628\u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629.<br /><br />\u0648\u062e\u0633\u0631 \u0627\u0644\u0646\u0635\u0631\u060c \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0627\u0654\u0645\u0627\u0645 \u0646\u0627\u062f\u064a \u0627\u0644\u0642\u0627\u062f\u0633\u064a\u0629\u060c \u0628\u0646\u062a\u064a\u062c\u0629 \u062b\u0644\u0627\u062b\u0629 \u0627\u0654\u0647\u062f\u0627\u0641 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641 \u0648\u062d\u064a\u062f\u060c \u0641\u064a \u0627\u0644\u0644\u0642\u0627\u0621 \u0627\u0644\u0630\u064a \u062c\u0645\u0639 \u0627\u0644\u0641\u0631\u064a\u0642\u064a\u0646\u060c \u0636\u0645\u0646 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629 \u0645\u0646 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0644\u0644\u0645\u062d\