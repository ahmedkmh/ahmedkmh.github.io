0629\u060c \u0648\u062a\u0648\u0627\u0643\u0628 \u0627\u0644\u0627\u0655\u0642\u0628\u0627\u0644 \u0627\u0644\u0645\u062a\u0632\u0627\u064a\u062f \u0645\u0646 \u0627\u0644\u0627\u0654\u0647\u0627\u0644\u064a \u0648\u0627\u0644\u0632\u0648\u0627\u0631 \u062e\u0644\u0627\u0644 \u0627\u0654\u064a\u0627\u0645 <a href=\"https://www.alyaum.com/articles/6651328/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B5%D9%88%D8%B1-%D8%AA%D9%87%D9%8A%D8%A6%D8%A9-%D8%A7%D9%84%D9%85%D8%B1%D8%A7%D9%81%D9%82-%D9%88%D8%AA%D9%83%D8%AB%D9%8A%D9%81-%D8%A7%D9%84%D8%B1%D9%82%D8%A7%D8%A8%D8%A9-%D8%AE%D8%B7%D8%A9-%D8%AA%D8%B4%D8%BA%D9%8A%D9%84%D9%8A%D8%A9-%D9%85%D8%AA%D9%83%D8%A7%D9%85%D9%84%D8%A9-%D8%AA%D8%B3%D8%A8%D9%82-%D8%A7%D9%84%D8%B9%D9%8A%D8%AF-%D8%A8%D8%A7%D9%84%D9%84%D9%87%D8%A7%D8%A8%D8%A9\">\u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631 \u0627\u0644\u0645\u0628\u0627\u0631\u0643</a>.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d \u0645\u062f\u064a\u0631 \u0639\u0627\u0645 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \u0648\u0627\u0644\u0645\u062a\u062d\u062f\u062b \u0627\u0644\u0631\u0633\u0645\u064a \u0644\u0627\u0654\u0645\u0627\u0646\u0629 <a href=\"https://www.alyaum.com/articles/6651322/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%B5%D8%AD%D8%A9-%D9%88%D8%AA%D8%BA%D8%B0%D9%8A%D8%A9/%D9%86%D8%B5%D8%A7%D8%A6%D8%AD-%D9%85%D9%86-%D8%A7%D9%84%D8%B5%D8%AD%D8%A9-%D8%A8%D8%AE%D8%B5%D9%88%D8%B5-%D8%A7%D9%84%D8%A3%D9%84%D8%B9%D8%A7%D8%A8-%D8%A7%D9%84%D9%86%D8%A7%D8%B1%D9%8A%D8%A9-%D8%AE%D9%84%D8%A7%D9%84-%D8%A7%D9%84%D8%B9%D9%8A%D8%AF-%D8%A7%D8%AD%D8%B0%D8%B1-%D8%A7%D9%84%D8%A5%D8%B9%D8%A7%D9%82%D8%A9-%D8%A7%D9%84%D8%AF%D8%A7%D8%A6%D9%85%D8%A9\">\u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629</a>\u060c \u0641\u064a\u0635\u0644 \u0627\u0644\u0632\u0647\u0631\u0627\u0646\u064a\u060c \u0627\u0654\u0646 \u0627\u0644\u0627\u0633\u062a\u0639\u062f\u0627\u062f\u0627\u062a \u0634\u0645\u0644\u062a \u062a\u062c\u0647\u064a\u0632 18 \u0645\u0646\u062a\u0632\u0647\u064b\u0627 \u0639\u0627\u0645\u064b\u0627 \u0641\u064a \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0645\u062f\u0646\u060c \u0645\u0646 \u062e\u0644\u0627\u0644 \u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u0629 \u0627\u0644\u0645\u0631\u0627\u0641\u0642 \u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0648\u0627\u0644\u062e\u062f\u0645\u064a\u0629\u060c \u0648\u0635\u064a\u0627\u0646\u0629 \u0627\u0644\u0627\u0654\u0644\u0639\u0627\u0628 \u0648\u0627\u0644\u0645\u0633\u0637\u062d\u0627\u062a \u0627\u0644\u062e\u0636\u0631\u0627\u0621\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u062a\u0643\u062b\u064a\u0641 \u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0646\u0638\u0627\u0641\u0629\u060c \u0628\u0645\u0627 \u064a\u0636\u0645\u0646 \u062a\u0648\u0641\u064a\u0631 \u0628\u064a\u064a\u0654\u0629 \u0627\u0653\u0645\u0646\u0629 \u0648\u0645\u0631\u064a\u062d\u0629 \u0644\u0644\u0639\u0627\u064a\u0654\u0644\u0627\u062a.<h2>\u062a\u0647\u064a\u064a\u0654\u0629 14 \u0643\u0648\u0631\u0646\u064a\u0634\u064b\u0627 \u0648\u0648\u0627\u062c\u0647\u0629 \u0628\u062d\u0631\u064a\u0629</h2>\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0645\u0627\u0646\u0629 \u0639\u0645\u0644\u062a \u0639\u0644\u0649 \u062a\u0647\u064a\u064a\u0654\u0629 14 \u0643\u0648\u0631\u0646\u064a\u0634\u064b\u0627 \u0648\u0648\u0627\u062c\u0647\u0629 \u0628\u062d\u0631\u064a\u0629\u060c \u0639\u0628\u0631 \u062a\u0646\u0641\u064a\u0630 \u0627\u0654\u0639\u0645\u0627\u0644 \u0646\u0638\u0627\u0641\u0629 \u0634\u0627\u0645\u0644\u0629\u060c \u0648\u0635\u064a\u0627\u0646\u0629 \u0627\u0644\u0627\u0655\u0646\u0627\u0631\u0629\u060c \u0648\u062a\u0639\u0632\u064a\u0632 \u0639\u0646\u0627\u0635\u0631 \u0627\u0644\u0633\u0644\u0627\u0645\u0629\u060c \u0648\u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0645\u0634\u0647\u062f \u0627\u0644\u0628\u0635\u0631\u064a\u060c \u0644\u062a\u0643\u0648\u0646 \u0648\u062c\u0647\u0627\u062a \u062c\u0627\u0630\u0628\u0629 \u0644\u0644\u0645\u062a\u0646\u0632\u0647\u064a\u0646 \u062e\u0644\u0627\u0644 \u0627\u0655\u062c\u0627\u0632\u0629 \u0627\u0644\u0639\u064a\u062f.<br /><br />\u0643\u0645\u0627 \u0634\u0645\u0644\u062a \u0627\u0644\u062c\u0647\u0648\u062f \u062a\u062c\u0647\u064a\u0632 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 979 \u062d\u062f\u064a\u0642\u0629 \u0648\u0633\u0627\u062d\u0629 \u0628\u0644\u062f\u064a\u0629\u060c \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0639\u0646\u0627\u064a\u0629 \u0628\u0627\u0644\u0645\u0633\u0637\u062d\u0627\u062a \u0627\u0644\u062e\u0636\u0631\u0627\u0621 \u0648\u0632\u0631\u0627\u0639\u0629 \u0627\u0644\u0632\u0647\u0648\u0631 \u0627\u0644\u0645\u0648\u0633\u0645\u064a\u0629 \u0648\u0635\u064a\u0627\u0646\u0629 \u0627\u0644\u0645\u0631\u0627\u0641\u0642\u060c \u0628\u0645\u0627 \u064a\u0648\u0641\u0631 \u0645\u0633\u0627\u062d\u0627\u062a \u0645\u0641\u062a\u0648\u062d\u0629 \u0645\u0646\u0627\u0633\u0628\u0629 \u0644\u0644\u062a\u0646\u0632\u0647 \u0648\u0627\u0644\u062a\u062c\u0645\u0639\u0627\u062a \u0627\u0644\u0639\u0627\u064a\u0654\u0644\u064a\u0629\u060c \u0648\u064a\u0639\u0632\u0632 \u0645\u0646 \u062c\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u062f\u0646.<br /><br />\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0644\u0632\u0647\u0631\u0627\u0646\u064a \u0627\u0655\u0644\u0649 \u062a\u062c\u0647\u064a\u0632 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 213 \u0645\u0636\u0645\u0627\u0631\u064b\u0627 \u0644\u0644\u0645\u0634\u064a\u060c \u0639\u0628\u0631 \u0635\u064a\u0627\u0646\u0629 \u0627\u0644\u0645\u0633\u0627\u0631\u0627\u062a \u0648\u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0627\u0655\u0646\u0627\u0631\u0629 \u0648\u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0646\u0638\u0627\u0641\u0629\u060c \u0628\u0645\u0627 \u064a\u062f\u0639\u0645 \u0645\u0645\u0627\u0631\u0633\u0629 \u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629 \u0648\u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629.<br /><br /> <h2>\u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631 \u0641\u064a \u0627\u0644\u0634\u0631\u0642\u064a\u0629</h2>\u0648\u062a\u0639\u0643\u0633 \u0647\u0630\u0647 \u0627\u0644\u062c\u0647\u0648\u062f \u062d\u0631\u0635 \u0627\u0644\u0627\u0654\u0645\u0627\u0646\u0629 \u0639\u0644\u0649 \u062a\u0647\u064a\u064a\u0654\u0629 \u0645\u0631\u0627\u0641\u0642 \u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u062a\u0639\u0632\u0632 \u062c\u0648\u062f\u0629 \u0627\u0644\u062d\u064a\u0627\u0629\u060c \u0648\u062a\u0648\u0641\u0631 \u062a\u062c\u0631\u0628\u0629 \u0645\u062a\u0645\u064a\u0632\u0629 \u0644\u0633\u0643\u0627\u0646 \u0648\u0632\u0648\u0627\u0631 \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u062e\u0644\u0627\u0644 \u0645\u0648\u0633\u0645 \u0627\u0644\u0639\u064a\u062f.<br /><br />\u0648\u0627\u0654\u0643\u062f \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0645\u0627\u0646\u0629 \u0643\u062b\u0651\u0641\u062a \u0645\u0646 \u0627\u0644\u062c\u0648\u0644\u0627\u062a \u0627\u0644\u0631\u0642\u0627\u0628\u064a\u0629 \u0648\u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u062e\u0644\u0627\u0644 \u0641\u062a\u0631\u0629 \u0627\u0644\u0639\u064a\u062f\u060c \u0644\u0636\u0645\u0627\u0646 \u0627\u0633\u062a\u0645\u0631\u0627\u0631\u064a\u0629 \u0627\u0644\u062e\u062f\u0645\u0627\u062a\u060c \u0648\u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u0645\u0644\u0627\u062d\u0638\u0627\u062a \u0628\u0634\u0643\u0644 \u0641\u0648\u0631\u064a\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u062a\u0639\u0632\u064a\u0632 \u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0646\u0638\u0627\u0641\u0629 \u0648\u0627\u0644\u0635\u064a\u0627\u0646\u0629 \u0639\u0644\u0649 \u0645\u062f\u0627\u0631 \u0627\u0644\u0633\u0627\u0639