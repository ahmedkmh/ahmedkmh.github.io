1 \u0628\u0646 \u0647\u0644\u0627\u0644 \u0627\u0644\u0645\u0634\u064a\u0637\u064a \u0627\u0646\u0637\u0644\u0627\u0642 \u0627\u0654\u0639\u0645\u0627\u0644 <a href=\"http://www.alyaum.com/articles/6654045/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B5%D9%84%D8%A9-%D8%A7%D9%84%D8%B9%D8%B7%D8%A7%D8%A1-%D8%AA%D8%B7%D9%84%D9%82-%D9%85%D8%A8%D8%A7%D8%AF%D8%B1%D8%A9-%D8%AA%D9%88%D8%B9%D9%88%D9%8A%D8%A9-%D9%84%D8%AD%D9%81%D8%B8-%D8%A7%D9%84%D9%86%D8%B9%D9%85%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D9%82%D8%B7%D9%8A%D9%81\">\u0627\u0644\u0645\u0644\u062a\u0642\u0649 \u0627\u0644\u062b\u0627\u0646\u064a \u0644\u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629</a>\u060c \u0627\u0644\u0630\u064a \u0627\u0654\u0642\u064a\u0645 \u0641\u064a \u0645\u062f\u064a\u0646\u0629 <a href=\"https://www.alyaum.com/articles/6649458/%D8%A7%D9%84%D8%B1%D8%A3%D9%8A/%D9%83%D9%84%D9%85%D8%A9-%D9%88%D9%85%D9%82%D8%A7%D9%84/%D8%AC%D9%85%D8%B9%D9%8A%D8%A7%D8%AA-%D8%AD%D9%81%D8%B8-%D8%A7%D9%84%D9%86%D8%B9%D9%85%D8%A9-%D8%A3%D9%8A%D9%82%D9%88%D9%86%D8%A9-%D8%A7%D9%84%D8%A3%D9%85%D9%86-%D8%A7%D9%84%D8%BA%D8%B0%D8%A7%D8%A6%D9%8A\">\u0627\u0644\u0631\u064a\u0627\u0636</a> \u0628\u0645\u0634\u0627\u0631\u0643\u0629 \u0648\u0627\u0633\u0639\u0629 \u0645\u0646 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0648<a href=\"https://www.alyaum.com/articles/6646874/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AC%D9%85%D8%B9%D9%8A%D8%A9-%D8%AD%D9%81%D8%B8-%D8%A7%D9%84%D9%86%D8%B9%D9%85%D8%A9-%D8%AA%D9%88%D9%81%D8%B1-%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-22-%D8%A3%D9%84%D9%81-%D9%88%D8%AC%D8%A8%D8%A9-%D8%A5%D9%81%D8%B7%D8%A7%D8%B1-%D8%A8%D8%A7%D9%84%D9%85%D8%B3%D8%AC%D8%AF-%D8%A7%D9%84%D9%86%D8%A8%D9%88%D9%8A\">\u0627\u0644\u0645\u0646\u0638\u0645\u0627\u062a \u063a\u064a\u0631 \u0627\u0644\u0631\u0628\u062d\u064a\u0629</a> \u0648\u0627\u0644\u0645\u0647\u062a\u0645\u064a\u0646 \u0628\u0645\u062c\u0627\u0644 <a href=\"https://www.alyaum.com/articles/6610155/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%81%D9%8A-%D8%B9%D8%B4%D8%B1-%D8%B3%D9%86%D9%88%D8%A7%D8%AA-%D8%A5%D9%83%D8%B1%D8%A7%D9%85-%D9%85%D9%83%D8%A9-%D8%AA%D9%82%D8%AF%D9%85-%D8%AE%D8%AF%D9%85%D8%A7%D8%AA%D9%87%D8%A7-%D9%84%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-100-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D9%85%D8%B3%D8%AA%D9%81%D9%8A%D8%AF\">\u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629 \u0648\u0627\u0644\u0627\u0633\u062a\u062f\u0627\u0645\u0629</a>.<br /><br />\u0648\u064a\u0627\u0654\u062a\u064a \u062a\u0646\u0638\u064a\u0645 \u0627\u0644\u0645\u0644\u062a\u0642\u0649 \u0636\u0645\u0646 \u062c\u0647\u0648\u062f \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0628\u064a\u064a\u0654\u0629 \u0648\u0627\u0644\u0645\u064a\u0627\u0647 \u0648\u0627\u0644\u0632\u0631\u0627\u0639\u0629 \u0627\u0644\u0631\u0627\u0645\u064a\u0629 \u0627\u0655\u0644\u0649 \u062a\u0639\u0632\u064a\u0632 \u0643\u0641\u0627\u0621\u0629 \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u0645\u0648\u0627\u0631\u062f\u060c \u0648\u0627\u0644\u062d\u062f \u0645\u0646 \u0627\u0644\u0641\u0642\u062f \u0648\u0627\u0644\u0647\u062f\u0631 \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a\u060c \u0648\u062a\u0645\u0643\u064a\u0646 \u0645\u0646\u0638\u0645\u0627\u062a \u0627\u0644\u0642\u0637\u0627\u0639 \u063a\u064a\u0631 \u0627\u0644\u0631\u0628\u062d\u064a \u0627\u0644\u0639\u0627\u0645\u0644\u0629 \u0641\u064a \u0645\u062c\u0627\u0644 \u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629 \u0645\u0646 \u0627\u0654\u062f\u0627\u0621 \u062f\u0648\u0631\u0647\u0627 \u0627\u0644\u062a\u0646\u0645\u0648\u064a\u060c \u0628\u0645\u0627 \u064a\u0633\u0647\u0645 \u0641\u064a \u062a\u0639\u0638\u064a\u0645 \u0627\u0654\u062b\u0631\u0647\u0627 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a \u0648\u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a \u0648\u0627\u0644\u0628\u064a\u064a\u0654\u064a\u060c \u0648\u062a\u062d\u0642\u064a\u0642 \u0645\u0633\u062a\u0647\u062f\u0641\u0627\u062a \u0631\u0648\u0654\u064a\u0629 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 2030 \u0641\u064a \u0645\u062c\u0627\u0644\u0627\u062a \u0627\u0644\u0627\u0633\u062a\u062f\u0627\u0645\u0629 \u0648\u0627\u0644\u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u0645\u062c\u062a\u0645\u0639\u064a\u0629.<h2>\u0645\u0644\u062a\u0642\u0649 \u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629 \u0644\u0644\u062d\u062f \u0645\u0646 \u0627\u0644\u0647\u062f\u0631 \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a</h2>\u0648\u0627\u0654\u0643\u062f\u062a \u0627\u0644\u0648\u0632\u0627\u0631\u0629 \u062d\u0631\u0635\u0647\u0627 \u0639\u0644\u0649 \u062f\u0639\u0645 \u0627\u0644\u0645\u0628\u0627\u062f\u0631\u0627\u062a \u0627\u0644\u0646\u0648\u0639\u064a\u0629 \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u062a\u0643\u0627\u0645\u0644 \u0628\u064a\u0646 \u0627\u0644\u062c\u0647\u0627\u062a \u0630\u0627\u062a \u0627\u0644\u0639\u0644\u0627\u0642\u0629\u060c \u0628\u0645\u0627 \u064a\u0633\u0647\u0645 \u0641\u064a \u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u0629 \u0645\u0646\u0638\u0648\u0645\u0629 \u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629 \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0633\u062a\u062f\u0627\u0645\u062a\u0647\u0627\u060c \u0627\u0646\u0637\u0644\u0627\u0642\u064b\u0627 \u0645\u0646 \u062f\u0648\u0631\u0647\u0627 \u0641\u064a \u062a\u0645\u0643\u064a\u0646 \u0627\u0644\u0642\u0637\u0627\u0639 \u063a\u064a\u0631 \u0627\u0644\u0631\u0628\u062d\u064a \u0648\u062a\u0648\u0633\u064a\u0639 \u0646\u0637\u0627\u0642 \u0627\u0655\u0633\u0647\u0627\u0645\u0647 \u0641\u064a \u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0644\u062a\u0646\u0645\u0648\u064a\u0629 \u0648\u062a\u062d\u0648\u064a\u0644\u0647\u0627 \u0627\u0655\u0644\u0649 \u0641\u0631\u0635 \u0630\u0627\u062a \u0627\u0654\u062b\u0631 \u0645\u0633\u062a\u062f\u0627\u0645.<br /><br />\u0648\u0634\u0647\u062f \u0627\u0644\u0645\u0644\u062a\u0642\u0649 \u062c\u0644\u0633\u0629 \u062d\u0648\u0627\u0631\u064a\u0629 \u0645\u062a\u062e\u0635\u0635\u0629 \u0628\u0639\u0646\u0648\u0627\u0646 \u00ab\u062a\u0643\u0627\u0645\u0644 \u0627\u0644\u062c\u0647\u0648\u062f \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0644\u062a\u0639\u0638\u064a\u0645 \u0627\u0644\u0627\u0654\u062b\u0631 \u0648\u062a\u0642\u0644\u064a\u0644 \u0627\u0644\u0647\u062f\u0631\u00bb\u060c \u0646\u0627\u0642\u0634\u062a \u0633\u0628\u0644 \u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0628\u064a\u0646 \u0627\u0644\u0642\u0637\u0627\u0639\u0627\u062a \u0627\u0644\u0645\u062e\u062a\u0644\u0641\u0629\u060c \u0648\u0627\u0633\u062a\u0639\u0631\u0636\u062a \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0645\u0645\u0627\u0631\u0633\u0627\u062a \u0648\u0627\u0644\u062a\u062c\u0627\u0631\u0628 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0641\u064a \u0645\u062c\u0627\u0644 \u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629.<br /><br />\u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0648\u0631\u0634\u0629 \u0639\u0645\u0644 \u062a\u0646\u0627\u0648\u0644\u062a \u062a\u0639\u0632\u064a\u0632 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u063a\u0630\u0627\u0621 \u0641\u064a \u0628\u0631\u0627\u0645\u062c \u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629\u060c \u0648\u0627\u0654\u0647\u0645\u064a\u0629 \u062a\u0637\u0628\u064a\u0642 \u0627\u0644\u0645\u0639\u0627\u064a\u064a\u0631 \u0648\u0627\u0644\u0645\u0645\u0627\u0631\u0633\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0633\u0647\u0645 \u0641\u064a \u0631\u0641\u0639 \u062c\u0648\u062f\u0629 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u0642\u062f\u0645\u0629 \u0644\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646.<br /><br /> <h2>\u062a\u0639\u0638\u064a\u0645 \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u0645\u0648\u0627\u0631\u062f</h2>\u0648\u0627\u0654\u0643\u062f \u0645\u062f\u064a\u0631 \u0639\u0627\u0645 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0645\u0646\u0638\u0645\u0627\u062a \u0627\u0644\u0642\u0637\u0627\u0639 \u063a\u064a\u0631 \u0627\u0644\u0631\u0628\u062d\u064a \u0627\u0644\u062f\u0643\u062a\u0648\u0631 \u0627\u0644\u0631\u0645\u0636\u064a \u0628\u0646 \u0642\u0627\u0639\u062f \u0627\u0644\u0635\u0642\u0631\u064a \u0627\u0654\u0646 \u0627\u0644\u0645\u0644\u062a\u0642\u0649 \u064a\u062c\u0633\u062f \u0627\u0644\u0627\u0647\u062a\u0645\u0627\u0645 \u0627\u0644\u0630\u064a \u062a\u0648\u0644\u064a\u0647 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0644\u0642\u0636\u0627\u064a\u0627 \u0627\u0644\u0627\u0633\u062a\u062f\u0627\u0645\u0629 \u0648\u062a\u0639\u0638\u064a\u0645 \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u0645\u0648\u0627\u0631\u062f\u060c \u0648\u064a\u0639\u0643\u0633 \u0627\u0654\u0647\u0645\u064a\u0629 \u062a\u0643\u0627\u0645\u0644 \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0628\u064a\u0646 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0648\u0627\u0644\u0642\u0637\u0627\u0639 \u063a\u064a\u0631 \u0627\u0644\u0631\u0628\u062d\u064a \u0648\u0627\u0644\u062c\u0647\u0627\u062a \u0630\u0627\u062a \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0644\u0641\u0642\u062f \u0648\u0627\u0644\u0647\u062f\u0631 \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a.<br /><br />\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0642\u0637\u0627\u0639 \u063a\u064a\u0631 \u0627\u0644\u0631\u0628\u062d\u064a \u064a\u0639\u062f \u0634\u0631\u064a\u0643\u064b\u0627 \u062a\u0646\u0645\u0648\u064a\u064b\u0627 \u0641\u0627\u0639\u0644\u064b\u0627 \u0641\u064a \u0645\u0646\u0638\u0648\u0645\u0629 \u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0628\u0627\u062f\u0631\u0627\u062a \u0627\u0644\u0646\u0648\u0639\u064a\u0629 \u0648\u0627\u0644\u0634\u0631\u0627\u0643\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0633\u0647\u0645 \u0641\u064a \u062a\u0639\u0638\u064a\u0645 \u0627\u0644\u0627\u0654\u062b\u0631\u060c \u0645\u0639\u0631\u0628\u064b\u0627 \u0639\u0646 \u062a\u0637\u0644\u0639\u0647 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u064a\u0633\u0647\u0645 \u0627\u0644\u0645\u0644\u062a\u0642\u0649 \u0641\u064a \u062a\u0628\u0627\u062f\u0644 \u0627\u0644\u062e\u0628\u0631\u0627\u062a \u0648\u0627\u0633\u062a\u0639\u0631\u0627\u0636 \u0627\u0644\u062a\u062c\u0627\u0631\u0628 \u0627\u0644\u0646\u0627\u062c\u062d\u0629 \u0648\u0627\u0644\u062e\u0631\u0648\u062c \u0628\u062a\u0648\u0635\u064a\u0627\u062a \u062a\u062f\u0639\u0645 \u062a\u0637\u0648\u064a\u0631 \u0645\u0646\u0638\u0648\u0645\u0629 \u062d\u0641\u0638 \u0627\u0644\u0646\u0639\u0645\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0648\u0637\u0646\u064a.<br /><br />\u0648\u0631\u0641\u0639 \u0627\u0644\u062f\u0643\u062a\u0648\u0631 \u0627\u0644\u0635\u0642\u0631\u064a \u0634\u0643\u0631\u0647 \u0644\u0645\u0639\u0627\u0644\u064a \u0648\u0632\u064a\u0631 \u0627\u0644\u0628\u064a\u064a\u0654\u0629 \u0648\u0627\u0644\u0645\u064a\u0627\u0647 \u0648\u0627\u0644\u0632\u0631\u0627\u0639\u0629 \u0627\u0644\u0645\u0647\u0646\u062f\u0633 \u0639\u0628\u062f\u0627\u0644\u0631\u062d\u0645\u0646 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0645\u062d\u0633\u0646 \u0627\u0644\u0641\u0636\u0644\u064a\u060c \u0648\u0644\u0645\u0639\u0627\u0644\u064a \u0646\u0627\u064a\u0654\u0628 \u0627\u0644\u0648\u0632\u064a\u0631 \u0627\u0644\u0645\u0647\u0646\u062f\u0633 \u0645\u0646\u0635\u0648\u0631 \u0627\u0644\u0645\u0634\u064a\u063