D9%88%D9%85/%D9%86%D9%82%D9%84-800-%D8%A3%D9%84%D9%81-%D8%B1%D8%A7%D9%83%D8%A8-%D8%B9%D8%A8%D8%B1-%D9%82%D8%B7%D8%A7%D8%B1-%D8%A7%D9%84%D8%AD%D8%B1%D9%85%D9%8A%D9%86-%D9%85%D9%86%D8%B0-%D8%A7%D9%86%D8%B7%D9%84%D8%A7%D9%82-%D8%AE%D8%B7%D8%A9-%D8%A7%D9%84%D8%AD%D8%AC\" target=\"_blank\"> \u0627\u0644\u062f\u0648\u0631 \u0627\u0644\u0645\u062d\u0648\u0631\u064a \u0644\u0644\u0642\u0637\u0627\u0631</a> \u0641\u064a \u062a\u0639\u0632\u064a\u0632 \u0627\u0646\u0633\u064a\u0627\u0628\u064a\u0629 \u0627\u0644\u062d\u0631\u0643\u0629 \u0628\u0627\u0644\u062a\u0646\u0633\u064a\u0642 \u0627\u0644\u0645\u0628\u0627\u0634\u0631 \u0645\u0639 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0648\u0627\u0644\u062e\u062f\u0645\u064a\u0629\u060c \u0645\u0633\u0627\u0647\u0645\u064b\u0627 \u0641\u064a \u0627\u0644\u0627\u0633\u062a\u063a\u0646\u0627\u0621 \u0639\u0646 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 50 \u0627\u0654\u0644\u0641 \u0631\u062d\u0644\u0629 \u062d\u0627\u0641\u0644\u0629 \u0644\u0631\u0641\u0639 \u0643\u0641\u0627\u0621\u0629 \u0627\u0644\u062a\u0646\u0642\u0644.<br /><br />\u0648\u0643\u0627\u0646\u062a \u0627\u0644\u062e\u0637\u0648\u0637 \u0627\u0644\u062d\u062f\u064a\u062f\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u00ab<a href=\"https://www.alyaum.com/articles/6657741/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%B3%D8%A7%D8%B1-%D8%AA%D9%85%D8%AF%D9%8A%D8%AF-%D8%A7%D9%84%D8%AA%D8%AE%D8%B2%D9%8A%D9%86-%D8%A7%D9%84%D9%85%D8%AC%D8%A7%D9%86%D9%8A-%D9%81%D9%8A-%D8%A7%D9%84%D9%85%D9%8A%D9%86%D8%A7%D8%A1-%D8%A7%D9%84%D8%AC%D8%A7%D9%81-%D8%A8%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D8%A5%D9%84%D9%89-30-%D9%8A%D9%88%D9%85%D8%A7\" target=\"_blank\">\u0633\u0627\u0631</a>\u00bb \u0642\u062f \u0627\u0654\u0643\u062f\u062a \u062c\u0627\u0647\u0632\u064a\u0629 \u0627\u0644\u0627\u0654\u0633\u0637\u0648\u0644 \u0627\u0644\u0645\u0643\u0648\u0646 \u0645\u0