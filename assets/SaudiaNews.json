2\u0627\u0621 \u064a\u062d\u0645\u0644 \u0627\u0644\u0643\u062b\u064a\u0631 \u0645\u0646 \u0627\u0644\u0627\u0654\u0631\u0642\u0627\u0645 \u0648\u0627\u0644\u0627\u0655\u062d\u0635\u0627\u064a\u0654\u064a\u0627\u062a \u0627\u0644\u0645\u062b\u064a\u0631\u0629 \u0627\u0644\u062a\u064a \u062a\u0639\u0643\u0633 \u062d\u062c\u0645 \u0627\u0644\u062a\u0646\u0627\u0641\u0633 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a \u0628\u064a\u0646 \u0627\u0644\u0641\u0631\u064a\u0642\u064a\u0646.<br /><br /><strong>\u062a\u0641\u0648\u0642 \u0646\u0633\u0628\u064a \u0644\u0644\u0628\u0644\u0648\u0632 \u0639\u0644\u0649 \u0645\u0644\u0639\u0628\u0647\u0645</strong><br /><br />\u064a\u062f\u062e\u0644 \u062a\u0634\u064a\u0644\u0633\u064a \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0628\u062b\u0642\u0629 \u0646\u0633\u0628\u064a\u0629 \u0639\u0644\u0649 \u0627\u0654\u0631\u0636\u0647\u060c \u062d\u064a\u062b \u0644\u0645 \u064a\u062a\u0639\u0631\u0636 \u0633\u0648\u0649 \u0644\u0647\u0632\u064a\u0645\u0629 \u0648\u0627\u062d\u062f\u0629 \u0641\u0642\u0637 \u0641\u064a \u0627\u0653\u062e\u0631 12 \u0645\u0628\u0627\u0631\u0627\u0629 \u0639\u0644\u0649 \u0645\u0644\u0639\u0628\u0647 \u0627\u0654\u0645\u0627\u0645 \u0645\u0627\u0646\u0634\u0633\u062a\u0631 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a (6 \u0627\u0646\u062a\u0635\u0627\u0631\u0627\u062a \u06485 \u062a\u0639\u0627\u062f\u0644\u0627\u062a). \u0643\u0645\u0627 \u064a\u0633\u0639\u0649 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0644\u0646\u062f\u0646\u064a \u0644\u062a\u062d\u0642\u064a\u0642 \u0641\u0648\u0632\u0647 \u0627\u0644\u062b\u0627\u0644\u062b \u062a\u0648\u0627\u0644\u064a\u064b\u0627 \u0639\u0644\u0649 \u063a\u0631\u064a\u0645\u0647 \u0641\u064a \u0633\u062a\u0627\u0645\u0641\u0648\u0631\u062f \u0628\u0631\u064a\u062f\u062c\u060c \u0648\u0647\u0648 \u0627\u0655\u0646\u062c\u0627\u0632 \u0644\u0645 \u064a\u062a\u062d\u0642\u0642 \u0645\u0646\u0630 \u0627\u0654\u0628\u0631\u064a\u0644 2006.<br /><br /><strong>\u0637\u0645\u0648\u062d \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0644\u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u062b\u0646\u0627\u064a\u0654\u064a\u0629</strong><br /><br />\u0641\u064a \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u060c \u064a\u0637\u0645\u062d \u0645\u0627\u0646\u0634\u0633\u062a\u0631 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0644\u062a\u0643\u0631\u0627\u0631 \u0627\u0646\u062a\u0635\u0627\u0631\u0647 \u0628\u0639\u062f \u0641\u0648\u0632\u0647 \u0630\u0647\u0627\u0628\u064b\u0627 \u0628\u0646\u062a\u064a\u062c\u0629 2-1 \u0641\u064a \u0633\u0628\u062a\u0645\u0628\u0631 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0645\u0646 \u0627\u0654\u062c\u0644 \u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0639\u0644\u0649 \u062a\u0634\u064a\u0644\u0633\u064a \u0641\u064a \u0645\u0648\u0633\u0645 \u0648\u0627\u062d\u062f\u060c \u0648\u0647\u0648 \u0627\u0655\u0646\u062c\u0627\u0632 \u0644\u0645 \u064a\u062d\u0642\u0642\u0647 \u0633\u0648\u0649 \u0645\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0641\u0642\u0637 \u0645\u0646 \u0642\u0628\u0644\u060c \u062e\u0644\u0627\u0644 \u0645\u0648\u0633\u0645 2019-2020.<br /><br /><strong>\u0627\u0644\u062a\u0639\u0627\u062f\u0644 \u0633\u064a\u062f \u0627\u0644\u0645\u0648\u0642\u0641 \u062a\u0627\u0631\u064a\u062e\u064a\u064b\u0627</strong><br /><br />\u062a\u064f\u0639\u062f \u0645\u0648\u0627\u062c\u0647\u0629 \u062a\u0634\u064a\u0644\u0633\u064a \u0648\u0645\u0627\u0646\u0634\u0633\u062a\u0631 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u0627\u0646\u062a\u0647\u0627\u0621\u064b \u0628\u0627\u0644\u062a\u0639\u0627\u062f\u0644 \u0641\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a \u0627\u0644\u0645\u0645\u062a\u0627\u0632\u060c \u062d\u064a\u062b \u062d\u064f\u0633\u0645\u062a 27 \u0645\u0628\u0627\u0631\u0627\u0629 \u0628\u064a\u0646\u0647\u0645\u0627 \u0628\u0647\u0630\u0647 \u0627\u0644\u0646\u062a\u064a\u062c\u0629\u060c \u0645\u0646 \u0628\u064a\u0646\u0647\u0627 20 \u062a\u0639\u0627\u062f\u0644\u064b\u0627 \u0634\u0647\u062f \u062a\u0633\u062c\u064a\u0644 \u0627\u0654\u0647\u062f\u0627\u0641\u060c \u0648\u0647\u0648 \u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0627\u0654\u0639\u0644\u0649 \u0641\u064a \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629.<br /><br /><strong>\u062a\u0631\u0627\u062c\u0639 \u062d\u0627\u062f \u0641\u064a \u0646\u062a\u0627\u064a\u0654\u062c \u062a\u0634\u064a\u0644\u0633\u064a</strong><br /><br />\u0639\u0644\u0649 \u0627\u0644\u0631\u063a\u0645 \u0645\u0646 \u062a\u0641\u0648\u0642\u0647 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u060c \u064a\u0639\u0627\u0646\u064a \u062a\u0634\u064a\u0644\u0633\u064a \u0645\u0646 \u062a\u0631\u0627\u062c\u0639 \u0648\u0627\u0636\u062d \u0641\u064a \u0627\u0644\u0646\u062a\u0627\u064a\u0654\u062c \u0645\u0648\u0654\u062e\u0631\u064b\u0627\u060c \u0627\u0655\u0630 \u064a\u064f\u0639\u062f \u0627\u0654\u0643\u062b\u0631 \u0627\u0644\u0641\u0631\u0642 \u062a\u0639\u0631\u0636\u064b\u0627 \u0644\u0644\u0647\u0632\u0627\u064a\u0654\u0645 \u0628\u064a\u0646 \u0627\u0654\u0646\u062f\u064a\u0629 \u0627\u0644\u062f\u0648\u0631\u064a\u0627\u062a \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a\u0629 \u0627\u0644\u062e\u0645\u0633 \u0627\u0644\u0643\u0628\u0631\u0649 \u0645\u0646\u0630 \u0628\u062f\u0627\u064a\u0629 \u0645\u0627\u0631\u0633\u060c \u0628\u062e\u0633\u0627\u0631\u062a\u0647 6 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0645\u0646 \u0627\u0654\u0635\u0644 9. \u0648\u064a\u0627\u0654\u062a\u064a \u0630\u0644\u0643 \u0628\u0639\u062f \u0641\u062a\u0631\u0629 \u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0646\u0633\u0628\u064a \u0634\u0647\u062f\u062a 6 \u0647\u0632\u0627\u064a\u0654\u0645 \u0641\u0642\u0637 \u062e\u0644\u0627\u0644 29 \u0645\u0628\u0627\u0631\u0627\u0629 \u0633\u0627\u0628\u0642\u0629.<br /><br />\u0643\u0645\u0627 \u062e\u0633\u0631 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0653\u062e\u0631 \u062b\u0644\u0627\u062b \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0644\u0647 \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a\u060c \u0648\u0644\u0645 \u064a\u062a\u0639\u0631\u0636 \u0644\u0627\u0654\u0631\u0628\u0639 \u0647\u0632\u0627\u064a\u0654\u0645 \u0645\u062a\u062a\u0627\u0644\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629 \u062e\u0644\u0627\u0644 \u0647\u0630\u0627 \u0627\u0644\u0642\u0631\u0646 \u0633\u0648\u0649 \u0645\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0641\u0642\u0637\u060c \u0643\u0627\u0646\u062a \u0641\u064a 2023 \u062a\u062d\u062a \u0642\u064a\u0627\u062f\u0629 \u0641\u0631\u0627\u0646\u0643 \u0644\u0627\u0645\u0628\u0627\u0631\u062f.<br /><br /><strong>\u062a\u0630\u0628\u0630\u0628 \u0641\u064a \u0645\u0633\u062a\u0648\u0649 \u0645\u0627\u0646\u0634\u0633\u062a\u0631 \u064a\u0648\u0646\u0627\u064a\u062a\u062f</strong><br /><br />\u0639\u0644\u0649 \u0627\u0644\u062c\u0627\u0646\u0628 \u0627\u0644\u0627\u0653\u062e\u0631\u060c \u0644\u0645 \u064a\u0643\u0646 \u0645\u0627\u0646\u0634\u0633\u062a\u0631 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0641\u064a \u0627\u0654\u0641\u0636\u0644 \u062d\u0627\u0644\u0627\u062a\u0647\u060c \u062d\u064a\u062b \u062e\u0633\u0631 \u0645\u0628\u0627\u0631\u0627\u062a\u064a\u0646 \u0645\u0646 \u0627\u0653\u062e\u0631 \u0627\u0654\u0631\u0628\u0639 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a\u060c \u0628\u0639\u062f \u0627\u0654\u0646 \u0643\u0627\u0646 \u0642\u062f \u062a\u0639\u0631\u0636 \u0644\u0647\u0632\u064a\u0645\u062a\u064a\u0646 \u0641\u0642\u0637 \u0641\u064a 22 \u0645\u0628\u0627\u0631\u0627\u0629 \u0633\u0627\u0628\u0642\u0629. \u0648\u064a\u0648\u0627\u062c\u0647 \u0627\u0644\u0641\u0631\u064a\u0642 \u062e\u0637\u0631 \u0627\u0644\u062a\u0639\u0631\u0636 \u0644\u062e\u0633\u0627\u0631\u062a\u064a\u0646 \u0645\u062a\u062a\u0627\u0644\u064a\u062a\u064a\u0646 \u0644\u0627\u0654\u0648\u0644 \u0645\u0631\u0629 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0633\u0645.<br /><br /><strong>\u0627\u0654\u0632\u0645\u0629 \u062f\u0641\u0627\u0639\u064a\u0629 \u062e\u0627\u0631\u062c \u0627\u0644\u0627\u0654\u0631\u0636</strong><br /><br />\u064a\u0639\u0627\u0646\u064a \u0645\u0627\u0646\u0634\u0633\u062a\u0631 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u062f\u0641\u0627\u0639\u064a\u064b\u0627 \u062e\u0627\u0631\u062c \u0645\u0644\u0639\u0628\u0647\u060c \u0627\u0655\u0630 \u062d\u0627\u0641\u0638 \u0639\u0644\u0649 \u0646\u0638\u0627\u0641\u0629 \u0634\u0628\u0627\u0643\u0647 \u0645\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0641\u0642\u0637 \u0641\u064a \u0627\u0653\u062e\u0631 21 \u0645\u0628\u0627\u0631\u0627\u0629 \u062e\u0627\u0631\u062c \u0627\u0654\u0631\u0636\u0647 \u0628\u0627\u0644\u062f\u0648\u0631\u064a. \u0648\u0627\u0644\u0645\u0641\u0627\u0631\u0642\u0629 \u0627\u0654\u0646 \u0627\u0653\u062e\u0631 \u0645\u0628\u0627\u0631\u0627\u062a\u064a\u0646 \u0628\u0634\u0628\u0627\u0643 \u0646\u0638\u064a\u0641\u0629 \u062e\u0627\u0631\u062c \u0645\u0644\u0639\u0628\u0647 \u0643\u0627\u0646\u062a\u0627 \u0627\u0654\u0645\u0627\u0645 \u0641\u0631\u0642 \u064a\u0642\u0648\u062f\u0647\u0627 \u0645\u062f\u0631\u0628\u0648\u0646 \u0633\u0628\u0642 \u0644\u0647\u0645 \u062a\u062f\u0631\u064a\u0628 \u064a\u0648\u0646\u0627\u064a\u062a\u062f.<br /><br /><strong>\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a\u0629 \u0628\u0646\u0643\u0647\u0629 \u062e\u0627\u0635\u0629</strong><br /><br />\u062a\u062d\u0645\u0644 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0637\u0627\u0628\u0639\u064b\u0627 \u062e\u0627\u0635\u064b\u0627\u060c \u0627\u0655\u0630 \u062a\u064f\u0639\u062f \u0633\u0627\u062f\u0633 \u0645\u0648\u0627\u062c\u0647\u0629 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0633\u0645 \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0628\u064a\u0646 \u0645\u062f\u0631\u0628\u064a\u0646 \u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a\u064a\u0646\u060c \u0643\u0645\u0627 \u0627\u0654\u0646\u0647\u0627 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0645\u0646\u0630 \u0627\u0654\u0628\u0631\u064a\u0644 1999 \u0627\u0644\u062a\u064a \u062a\u062c\u0645\u0639 \u0628\u064a\u0646 \u0645\u062f\u0631\u0628\u064a\u0646 \u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a\u064a\u0646 \u064a\u0642\u0648\u062f\u0627\u0646 \u0641\u0631\u064a\u0642\u064a\u0646 \u0636\u0645\u0646 \u0627\u0644\u0633\u062a\u0629 \u0627\u0644\u0627\u0654\u0648\u0627\u064a\u0654\u0644 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u062a\u0648\u0642\u064a\u062a \u0645\u0646 \u0627\u0644\u0645\u0648\u0633\u0645.<br /><br /><strong>\u0639\u0648\u062f\u0629 \u0645\u0631\u062a\u0642\u0628\u0629 \u0648\u062a\u0627\u0654\u0644\u0642 \u0641\u0631\u062f\u064a</strong><br /><br />\u0642\u062f \u064a\u0634\u0647\u062f \u0627\u0644\u0644\u0642\u0627\u0621 \u0639\u0648\u062f\u0629 \u0627\u0644\u0646\u062c\u0645 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0627\u0655\u0646\u0632\u0648 \u0641\u064a\u0631\u0646\u0627\u0646\u062f\u064a\u0632 \u0627\u0655\u0644\u0649 \u0635\u0641\u0648\u0641 \u062a\u0634\u064a\u0644\u0633\u064a\u060c \u062d\u064a\u062b \u064a\u064f\u0639\u062f \u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0639\u0646\u0627\u0635\u0631 \u0627\u0644\u0641\u0631\u064a\u0642 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0633\u0645\u060c \u0628\u062a\u0635\u062f\u0631\u0647 \u0642\u0627\u064a\u0654\u0645\u0629 \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u0635\u0646\u0627\u0639\u0629 \u0644\u0644\u0641\u0631\u0635 (51)\u060c \u0648\u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u062a\u0645\u0631\u064a\u0631\u064b\u0627 \u0641\u064a \u0627\u0644\u062b\u0644\u062b \u0627\u0644\u0627\u0654\u062e\u064a\u0631 (459)\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628