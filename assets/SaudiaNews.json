\u0645\u0629 \u062d\u062a\u0649 \u062f\u0627\u062e\u0644 \u0639\u0627\u0644\u0645 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0646\u0627\u0634\u064a\u0654\u0629.\u0641\u064a \u063a\u0636\u0648\u0646 \u0646\u062d\u0648 3 \u0627\u0654\u0634\u0647\u0631 \u0641\u0642\u0637 \u0645\u0646 \u0627\u0644\u0627\u0655\u0637\u0644\u0627\u0642 \u0641\u064a 2026\u060c \u062d\u0642\u0642\u062a \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0655\u064a\u0631\u0627\u062f\u0627\u062a \u0633\u0646\u0648\u064a\u0629 \u0645\u062a\u0643\u0631\u0631\u0629 \u0648\u0635\u0644\u062a \u0627\u0655\u0644\u0649 300 \u0627\u0654\u0644\u0641 \u062f\u0648\u0644\u0627\u0631\u060c \u0645\u0639 \u0647\u0648\u0627\u0645\u0634 \u0631\u0628\u062d \u062a\u062a\u062c\u0627\u0648\u0632 90%\u060c \u0648\u062a\u0643\u0627\u0644\u064a\u0641 \u062a\u0634\u063a\u064a\u0644 \u0645\u0646\u062e\u0641\u0636\u0629 \u0628\u0634\u0643\u0644 \u063a\u064a\u0631 \u0645\u0633\u0628\u0648\u0642\u060c \u0641\u064a \u0646\u0645\u0648\u0630\u062c \u064a\u0643\u0627\u062f \u064a\u0642\u0644\u0628 \u0645\u0641\u0627\u0647\u064a\u0645 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a.\u0648\u0627\u0644\u0627\u0654\u063a\u0631\u0628 \u0627\u0654\u0646 \u0643\u0644 \u0630\u0644\u0643 \u0628\u062f\u0627\u0654 \u0628\u0631\u0627\u0654\u0633 \u0645\u0627\u0644 \u0644\u0627 \u064a\u062a\u062c\u0627\u0648\u0632 300 \u062f\u0648\u0644\u0627\u0631\u060c \u062f\u0648\u0646 \u0627\u0644\u0627\u0639\u062a\u0645\u0627\u062f \u0639\u0644\u0649 \u062c\u0648\u0644\u0627\u062a \u062a\u0645\u0648\u064a\u0644 \u0636\u062e\u0645\u0629 \u0627\u0654\u0648 \u0641\u0631\u0642 \u0639\u0645\u0644 \u0645\u0648\u0633\u0639\u0629. \u0648\u0645\u0639 \u0648\u0635\u0648\u0644 \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0655\u0644\u0649 \u0645\u0631\u062d\u0644\u0629 \u0645\u062a\u0642\u062f\u0645\u0629 \u0645\u0646 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a \u0645\u0639 \u0645\u0633\u062a\u062b\u0645\u0631\u064a\u0646 \u0643\u0628\u0627\u0631\u060c \u0627\u062a\u062e\u0630 \u0627\u0644\u0645\u0648\u0654\u0633\u0633\u0648\u0646 \u0642\u0631\u0627\u0631\u0627\u064b \u063a\u064a\u0631 \u0645\u062a\u0648\u0642\u0639 \u064a\u062a\u0645\u062b\u0644 \u0641\u064a: \u0631\u0641\u0636 \u0627\u0644\u062a\u0645\u0648\u064a\u0644 \u0628\u0627\u0644\u0643\u0627\u0645\u0644.\u0648\u064a\u0634\u0631\u062d \u0633\u0627\u0645 \u0628\u0631\u0627\u0648\u0646 \u0627\u0644\u0641\u0643\u0631\u0629 \u0628\u0628\u0633\u0627\u0637\u0629 \u063a\u064a\u0631 \u0645\u0639\u062a\u0627\u062f\u0629: \u00ab\u0644\u0645 \u0646\u0639\u062f \u0628\u062d\u0627\u062c\u0629 \u0644\u062a\u0648\u0633\u064a\u0639 \u0627\u0644\u0641\u0631\u0642\u060c \u0628\u0644 \u0644\u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0639\u0631\u064a\u0641 \u0645\u0639\u0646\u0649 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0654\u0635\u0644\u0627\u064b. \u0641\u0628\u062f\u0644\u0627\u064b \u0645\u0646 \u062a\u0648\u0638\u064a\u0641 \u0639\u0634\u0631\u0627\u062a \u0627\u0644\u0627\u0654\u0634\u062e\u0627\u0635\u060c \u064a\u062a\u0645 \u0628\u0646\u0627\u0621 \u0645\u0646\u0638\u0648\u0645\u0629 \u062a\u0639\u062a\u0645\u062f \u0639\u0644\u0649 \u0648\u0643\u0644\u0627\u0621 \u0630\u0643\u0627\u0621 \u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0642\u0627\u062f\u0631\u064a\u0646 \u0639\u0644\u0649 \u0627\u0654\u062f\u0627\u0621 \u0627\u0644\u0645\u0647\u0645\u0627\u062a \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0628\u062f\u0642\u0629 \u0648\u0633\u0631\u0639\u0629\u00bb.\u0648\u0644\u0627 \u064a\u0642\u062a\u0635\u0631 \u0627\u0644\u0646\u0638\u0627\u0645 \u062f\u0627\u062e\u0644 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0644\u0649 \u0627\u0644\u0628\u064a\u0639 \u0641\u0642\u0637\u060c \u0628\u0644 \u064a\u0645\u062a\u062f \u0627\u0655\u0644\u0649 \u062a\u062d\u0644\u064a\u0644 \u0633\u0644\u0648\u0643 \u0627\u0644\u0639\u0645\u0644\u0627\u0621\u060c \u0648\u062a\u0648\u0644\u064a\u062f \u0627\u0