0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629\u060c \u0641\u064a\u0645\u0627 \u064a\u064f\u0633\u0645\u062d \u0644\u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \u0628\u062d\u0636\u0648\u0631 \u062c\u0627\u0646\u0628\u064d \u0645\u0646 \u062a\u062f\u0631\u064a\u0628\u0627\u062a\u0647 \u0639\u0644\u0649 \u0631\u062f\u064a\u0641 \u0645\u0644\u0639\u0628 \u00ab\u0627\u0644\u0627\u0655\u0646\u0645\u0627\u0621\u00bb \u0641\u064a \u062c\u062f\u0629 \u0627\u0654\u064a\u0627\u0645 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 \u0648\u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 \u0648\u0627\u0644\u062e\u0645\u064a\u0633. \u0648\u0633\u064a\u062a\u062d\u062f\u064e\u0651\u062b \u0631\u064a\u0646\u0627\u0631\u062f \u0644\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \u062e\u0644\u0627\u0644 \u0645\u0648\u0654\u062a\u0645\u0631\u064d \u0635\u062d\u0627\u0641\u064a\u060c \u0627\u0644\u062e\u0645\u064a\u0633. \u0648\u064a\u0633\u062a\u0636\u064a\u0641 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0646\u0638\u064a\u0631\u0647 \u0627\u0644\u0645\u0635\u0631\u064a \u0639\u0644\u0649 \u0645\u0644\u0639\u0628 \u00ab\u0627\u0644\u0627\u0655\u0646\u0645\u0627\u0621\u00bb\u060c \u0648\u064a\u0646\u0632\u0644 \u0636\u064a\u0641\u064b\u0627 \u0639\u0644\u0649 \u0635\u0631\u0628\u064a\u0627 \u0641\u064a \u0645\u0644\u0639\u0628 \u00ab\u062a\u064a \u0627\u0655\u0633 \u0633\u064a - \u0628\u0627\u0643\u0627 \u062a\u0648\u0628\u0648\u0644\u0627\u00bb. \u0648\u0633\u064a\u062a\u0627\u0628\u0639 \u0645\u0645\u062b\u0644\u0648 \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \u062c\u0627\u0646\u0628\u064b\u0627 \u0645\u0646 \u0627\u0653\u062e\u0631 \u062a\u062f\u0631\u064a\u0628\u064d \u0644\u0643\u062a\u064a\u0628\u0629 \u0631\u064a\u0646\u0627\u0631\u062f \u0642\u0628\u0644 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062b\u0627\