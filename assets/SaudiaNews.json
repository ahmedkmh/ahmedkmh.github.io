\u0647 \u0627\u0644\u062d\u0631\u0627\u0645 \u0644\u0627\u0654\u062f\u0627\u0621 \u0635\u0644\u0627\u0629 \u0627\u0644\u062a\u0647\u062c\u062f\u060c \u0641\u064a \u0627\u0654\u062c\u0648\u0627\u0621 \u0631\u0648\u062d\u0627\u0646\u064a\u0629 \u0645\u0641\u0639\u0645\u0629 \u0628\u0627\u0644\u0627\u0655\u064a\u0645\u0627\u0646 \u0648\u0627\u0644\u062e\u0634\u0648\u0639\u060c \u0627\u0655\u0630 \u0627\u0645\u062a\u0644\u0627\u0654\u062a \u0627\u0654\u0631\u0648\u0642\u062a\u0647 \u0648\u0633\u0627\u062d\u0627\u062a\u0647 \u0628\u0627\u0644\u0645\u0635\u0644\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u062a\u0648\u0627\u0641\u062f\u0648\u0627 \u0645\u0646\u0630 \u0633\u0627\u0639\u0627\u062a \u0645\u0628\u0643\u0631\u0629\u060c \u0627\u063a\u062a\u0646\u0627\u0645\u064b\u0627 \u0644\u0641\u0636\u0644 \u0647\u0630\u0647 \u0627\u0644\u0644\u064a\u0644\u0629 \u0627\u0644\u0645\u0628\u0627\u0631\u0643\u0629.<br /><br />\u0648\u062a\u0639\u0627\u0644\u062a \u0641\u064a \u0627\u0654\u0631\u062c\u0627\u0621 \u0627\u0644\u0645\u0633\u062c\u062f \u0627\u0644\u062d\u0631\u0627\u0645 \u0627\u0654\u0635\u0648\u0627\u062a \u0627\u0644\u062a\u0644\u0627\u0648\u0627\u062a \u0627\u0644\u0639\u0637\u0631\u0629\u060c \u0641\u064a\u0645\u0627 \u0627\u0635\u0637\u0641 <a href=\"https://www.alyaum.com/articles/6651271/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D9%85%D9%86%D9%88%D8%B9%D8%A7%D8%AA/%D8%AA%D8%AF%D8%B4%D9%8A%D9%86-%D8%A7%D9%84%D9%85%D8%B5%D8%AD%D9%81-%D8%A7%D9%84%D8%B5%D9%88%D8%AA%D9%8A-%D9%88%D8%A7%D9%84%D9%85%D8%B1%D8%A6%D9%8A-%D8%A8%D9%84%D8%A7%D8%BA-%D9%85%D9%86-%D8%A7%D9%84%D8%AA%D8%B1%D8%A7%D9%88%D9%8A%D8%AD-%D9%88%D8%A7%D9%84%D8%AA%D9%87%D8%AC%D8%AF-%D8%A8%D8%A7%D9%84%D9%85%D8%B3%D8%AC%D8%AF-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D9%85\">\u0627\u0644\u0645\u0635\u0644\u0648\u0646 </a>\u0641\u064a \u0645\u0634\u0647\u062f \u0645\u0647\u064a\u0628 \u064a\u062c\u0633\u062f \u0648\u062d\u062f\u0629 \u0627\u0644\u0645\u0633\u0644\u0645\u064a\u0646\u060c \u0648\u062a\u062c\u0644\u065