635\u064a\u0641\u0647\u060c \u0641\u064a \u0627\u0644\u062f\u0648\u0631 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0644\u0628\u0637\u0648\u0644\u0629 \u0648\u0627\u062d\u062f\u0629\u061b \u0628\u0639\u062f\u0645\u0627 \u062a\u0648\u062c\u062a \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0628\u0644\u0642\u0628 \u0645\u0648\u0646\u062f\u064a\u0627\u0644 \u0642\u0637\u0631 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0641\u0631\u0646\u0633\u0627\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u062a\u062d\u0635\u062f \u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627 \u0644\u0642\u0628 \u0628\u0637\u0648\u0644\u0629 \u0627\u0654\u0648\u0631\u0648\u0628\u0627 \u0639\u0627\u0645 2024 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627.\u0643\u0645\u0627 \u0642\u062f \u062a\u0634\u0647\u062f \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0627\u0654\u0648\u0644 \u0646\u0647\u0627\u064a\u0654\u064a \u0645\u0643\u0631\u0631 \u0628\u064a\u0646 \u0645\u0646\u062a\u062e\u0628\u064a\u0646 \u0645\u0646\u0630 \u0645\u0648\u0627\u062c\u0647\u062a\u064a \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0648\u0627\u0654\u0644\u0645\u0627\u0646\u064a\u0627 \u0641\u064a \u0646\u0647\u0627\u064a\u0654\u064a\u064a \u0639\u0627\u0645\u064a 1986 \u06481990\u060c \u0639\u0646\u062f\u0645\u0627 \u062a\u0642\u0627\u0633\u0645 \u0627\u0644\u0645\u0646\u062a\u062e\u0628\u0627\u0646 \u0627\u0644\u0644\u0642\u0628 \u062e\u0644\u0627\u0644 \u062a\u0644\u0643 \u0627\u0644\u0641\u062a\u0631\u0629.\u0648\u062a\u0639\u062f \u0647\u0630\u0647 \u0627\u0644\u0645\u0631\u0629 \u0627\u0644\u062d\u0627\u062f\u064a\u0629 \u0639\u0634\u0631\u0629 \u0627\u0644\u062a\u064a \u064a\u0636\u0645 \u0641\u064a\u0647\u0627 \u0627\u0644\u062f\u0648\u0631 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u062b\u0644\u0627\u062b\u0629 \u0645\u0646\u062a\u062e\u0628\u0627\u062a \u0627\u0654\u0648\u0631\u0648\u062