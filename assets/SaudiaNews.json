064a\u0633\u0648\u0631\u0629 \u0645\u064a\u0634\u064a\u0644 \u0633\u0628\u064a\u0631\u060c \u0627\u0654\u0633\u062a\u0627\u0630\u0629 \u0627\u0644\u062a\u0634\u0631\u064a\u062d \u0641\u064a \u062c\u0627\u0645\u0639\u0629 \u0628\u0631\u064a\u0633\u062a\u0648\u0644\u060c \u0627\u0654\u0646 \u0627\u0644\u062f\u0645\u0627\u063a \u0627\u0644\u0628\u0634\u0631\u064a \u062a\u0637\u0648\u0631 \u0639\u0628\u0631 \u0627\u0653\u0644\u0627\u0641 \u0627\u0644\u0633\u0646\u064a\u0646 \u0644\u064a\u0628\u0642\u0649 \u0641\u064a \u062d\u0627\u0644\u0629 \u0627\u0633\u062a\u0639\u062f\u0627\u062f \u062f\u0627\u064a\u0654\u0645 \u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0627\u0654\u062e\u0637\u0627\u0631\u060c \u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u0627\u0653\u0644\u064a\u0629 \u0646\u0641\u0633\u0647\u0627 \u0642\u062f \u062a\u062a\u0641\u0627\u0639\u0644 \u0627\u0644\u064a\u0648\u0645 \u0645\u0639 \u0636\u063a\u0648\u0637 \u0645\u062e\u062a\u0644\u0641\u0629 \u062a\u0645\u0627\u0645\u064b\u0627\u060c \u0645\u062b\u0644 \u0636\u063a\u0648\u0637 \u0627\u0644\u0639\u0645\u0644 \u0627\u0654\u0648 \u0627\u0644\u0631\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u0639\u0627\u062c\u0644\u0629 \u0627\u0654\u0648 \u0627\u0644\u062a\u0641\u0643\u064a\u0631 \u0641\u064a \u0627\u0644\u0645\u0633\u062a\u0642\u0628\u0644\u060c \u0648\u0643\u0627\u0654\u0646\u0647\u0627 \u062a\u0647\u062f\u064a\u062f\u0627\u062a \u062a\u062a\u0637\u0644\u0628 \u0627\u0644\u0627\u0633\u062a\u0646\u0641\u0627\u0631.\u0648\u062a\u0634\u064a\u0631 \u0633\u0628\u064a\u0631 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u062d\u0627\u062c\u0629 \u0627\u0644\u062c\u0633\u0645 \u0627\u0655\u0644\u0649 \u0627\u0644\u0646\u0648\u0645 \u0644\u0627 \u062a\u0639\u0646\u064a \u0628\u0627\u0644\u0636\u0631\u0648\u0631\u0629 \u0627\u0654\u0646 \u0627\u0644\u0639\u0642\u0644 \u062f\u062e\u0644 \u062d\u0627\u0644\u0629 \u0627\u0644\u0631\u0627\u062d\u0629\u061b \u0641\u0627\u0644\u0627\u0655\u0631\u0647\u0627\u0642 \u0627\u0644\u062c\u0633\u062f\u064a \u0642\u062f \u064a\u0643\u0648\u0646 \u062d\u0627\u0636\u0631\u064b\u0627 \u0628\u0642\u0648\u0629\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0628\u0642\u0649 \u0627\u0644\u062f\u0645\u0627\u063a \u0646\u0634\u0637\u064b\u0627 \u0641\u064a \u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0645\u0639\u0627\u0644\u062c\u0629 \u0627\u0644\u0645\u0634\u0643\u0644\u0627\u062a \u0627\u0654\u0648 \u062a\u0648\u0642\u0639 \u0627\u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0644\u0642\u0627\u062f\u0645\u0629.\u0648\u064a\u0631\u062a\u0628\u0637 \u0647\u0630\u0627 \u0627\u0644\u0627\u0654\u0645\u0631 \u0628\u0645\u0627 \u064a\u0639\u0631\u0641 \u0628\u0640\u00ab\u0627\u0633\u062a\u062c\u0627\u0628\u0629 \u0627\u0644\u0642\u062a\u0627\u0644 \u0627\u0654\u0648 \u0627\u0644\u0647\u0631\u0648\u0628\u00bb\u060c \u0648\u0647\u064a \u0627\u0653\u0644\u064a\u0629 \u0641\u0637\u0631\u064a\u0629 \u062a\u0633\u0627\u0639\u062f \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646 \u0639\u0644\u0649 \u0627\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0644\u0645\u062e\u0627\u0637\u0631. \u063a\u064a\u0631 \u0627\u0654\u0646 \u0627\u0644\u062f\u0645\u0627\u063a \u0644\u0627 \u064a\u0645\u064a\u0632 \u062f\u0627\u064a\u0654\u0645\u064b\u0627 \u0628\u064a\u0646 \u0627\u0644\u062e\u0637\u0631 \u0627\u0644\u062d\u0642\u064a\u0642\u064a \u0648\u0627\u0644\u0636\u063a\u0648\u0637 \u0627\u0644\u064a\u0648\u0645\u064a\u0629\u060c \u0641\u0639\u0646\u062f\u0645\u0627 \u062a\u0646\u0634\u0637 \u0627\u0644\u0644\u0648\u0632\u0629 \u0627\u0644\u062f\u0645\u0627\u063a\u064a\u0629\u060c \u064a\u0628\u062f\u0627\u0654 \u0627\u0644\u062c\u0633\u0645 \u0628\u0627\u0655\u0641\u0631\u0627\u0632 \u0647\u0631\u0645\u0648\u0646\u0627\u062a \u0645\u062b\u0644 \u0627\u0644\u0627\u0654\u062f\u0631\u064a\u0646\u0627\u0644\u064a\u0646 \u0648\u0627\u0644\u0643\u0648\u0631\u062a\u064a\u0632\u0648\u0644\u060c \u0645\u0627 \u064a\u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u064a\u0642\u0638\u0629 \u0648\u064a\u062c\u0639\u0644 \u0627\u0644\u0639\u0648\u062f\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0646\u0648\u0645 \u0627\u0654\u0643\u062b\u0631 \u0635\u0639\u0648\u0628\u0629.\u0648\u062a\u0644\u0641\u062a \u0627\u0644\u0628\u0631\u0648\u0641\u064a\u0633\u0648\u0631\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0636\u0637\u0631\u0627\u0628 \u0646\u0645\u0637 \u0627\u0644\u0646\u0648\u0645 \u0642\u062f \u064a\u0631\u062a\u0628\u0637 \u0627\u0654\u064a\u0636\u064b\u0627 \u0628\u062e\u0644\u0644 \u0641\u064a \u0627\u0644\u0627\u0655\u064a\u0642\u0627\u0639 \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0644\u0647\u0631\u0645\u0648\u0646 \u0627\u0644\u0643\u0648\u0631\u062a\u064a\u0632\u0648\u0644\u061b \u0627\u0655\u0630 \u064a\u0646\u062e\u0641\u0636 \u0645\u0633\u062a\u0648\u0627\u0647 \u0639\u0627\u062f\u0629 \u062e\u0644\u0627\u0644 \u0633\u0627\u0639\u0627\u062a \u0627\u0644\u0645\u0633\u0627\u0621 \u0644\u062a\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u062c\u0633\u0645 \u0644\u0627\u0655\u0646\u062a\u0627\u062c \u0627\u0644\u0645\u064a\u0644\u0627\u062a\u0648\u0646\u064a\u0646 \u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644 \u0639\u0646 \u0627\u0644\u0646\u0639\u0627\u0633 \u0648\u0627\u0644\u0627\u0633\u062a\u0639\u062f\u0627\u062f \u0644\u0644\u0646\u0648\u0645. \u0644\u0643\u0646 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062a\u0648\u062a\u0631 \u0642\u062f \u064a\u0628\u0642\u064a \u0627\u0644\u062c\u0633\u0645 \u0641\u064a \u062d\u0627\u0644\u0629 \u062a\u0627\u0654\u0647\u0628 \u062d\u062a\u0649 \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0630\u064a \u064a\u0641\u062a\u0631\u0636 \u0627\u0654\u0646 \u064a\u0647\u062f\u0627\u0654 \u0641\u064a\u0647.\u0648\u0644\u0627 \u062a\u0642\u062a\u0635\u0631 \u0627\u0654\u0633\u0628\u0627\u0628 \u0647\u0630\u0647 \u0627\u0644\u062d\u0627\u0644\u0629 \u0639\u0644\u0649 \u0627\u0644\u0639\u0648\u0627\u0645\u0644 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629\u060c \u0627\u0655\u0630 \u062a\u0644\u0639\u0628 \u0627\u0644\u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u0627 \u0627\u0644\u062d\u062f\u064a\u062b\u0629 \u062f\u0648\u0631\u064b\u0627 \u0645\u0648\u0654\u062b\u0631\u064b\u0627 \u0641\u064a \u0627\u0655\u0628\u0642\u0627\u0621 \u0627\u0644\u062f\u0645\u0627\u063a \u0646\u0634\u0637\u064b\u0627 \u062e\u0644\u0627\u0644 \u0627\u0644\u0644\u064a\u0644. \u0641\u0627\u0644\u0634\u0627\u0634\u0627\u062a \u0644\u0627 \u062a\u0648\u0654\u062b\u0631 \u0641\u0642\u0637 \u0628\u0633\u0628\u0628 \u0627\u0644\u0636\u0648\u0621 \u0627\u0644\u0630\u064a \u0642\u062f \u064a\u0639\u064a\u0642 \u0627\u0655\u0641\u0631\u0627\u0632 \u0627\u0644\u0645\u064a\u0644\u0627\u062a\u0648\u0646\u064a\u0646\u060c \u0628\u0644 \u0627\u0654\u064a\u0636\u064b\u0627 \u0628\u0633\u0628\u0628 \u0627\u0644\u0645\u062d\u062a\u0648\u0649 \u0627\u0644\u0645\u062d\u0641\u0632 \u0627\u0644\u0630\u064a \u064a\u0648\u0627\u0635\u0644 \u062a\u0646\u0634\u064a\u0637 \u0627\u0644\u0639\u0642\u0644\u060c \u0645\u062b\u0644 \u0645\u062a\u0627\u0628\u0639\u0629 \u0627\u0644\u0627\u0654\u062e\u0628\u0627\u0631 \u0627\u0654\u0648 \u0627\u0644\u062a\u0635\u0641\u062d \u0627\u0644\u0645\u0633\u062a\u0645\u0631 \u0627\u0654\u0648 \u0627\u0644\u0628\u062d\u062b \u0639\u0646 \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u062c\u062f\u064a\u062f\u0629.\u0648\u062a\u0631\u0649 \u0633\u0628\u064a\u0631 \u0627\u0654\u0646 \u0627\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0636\u0637\u0631\u0627\u0628\u0627\u062a \u0627\u0644\u0627\u0633\u062a\u064a\u0642\u0627\u0638 \u0627\u0644\u0644\u064a\u0644\u064a \u0644\u0627 \u064a\u0639\u062a\u0645\u062f \u0641\u0642\u0637 \u0639\u0644\u0649 \u0627\u0644\u062d\u0644\u0648\u0644 \u0627\u0644\u062f\u0648\u0627\u064a\u0654\u064a\u0629\u060c \u0628\u0644 \u064a\u062d\u062a\u0627\u062c \u0627\u0655\u0644\u0649 \u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0646\u0