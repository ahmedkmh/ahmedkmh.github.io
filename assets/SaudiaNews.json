646\u0633\u0627\u0646\u064a\u0629 (<a href=\"https://www.alyaum.com/articles/6657239/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%B3%D8%A7%D9%85-%D9%8A%D9%88%D8%A7%D8%B5%D9%84-%D8%AA%D8%B7%D9%87%D9%8A%D8%B1-%D8%A7%D9%84%D9%8A%D9%85%D9%86-%D8%A2%D9%84%D8%A7%D9%81-%D8%A7%D9%84%D8%A3%D9%84%D8%BA%D8%A7%D9%85-%D8%A7%D9%84%D9%85%D9%86%D8%B2%D9%88%D8%B9%D8%A9-%D8%AE%D9%84%D8%A7%D9%84-%D8%A3%D8%A8%D8%B1%D9%8A%D9%84\">\u0645\u0633\u0627\u0645</a>) \u0641\u064a \u062c\u0647\u0648\u062f <a href=\"https://www.alyaum.com/articles/6654604/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%B3%D8%A7%D9%85-%D9%8A%D9%86%D8%B2%D8%B9-1231-%D9%84%D8%BA%D9%85%D8%A7-%D9%85%D9%86-%D8%A7%D9%84%D8%A3%D8%B1%D8%A7%D8%B6%D9%8A-%D8%A7%D9%84%D9%8A%D9%85%D9%86%D9%8A%D8%A9-%D8%AE%D9%84%D8%A7%D9%84-%D8%A3%D8%B3%D8%A8%D9%88%D8%B9\">\u062a\u0637\u0647\u064a\u0631 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0644\u064a\u0645\u0646\u064a\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0644\u063a\u0627\u0645</a>.<br /><br />\u0648\u062a\u0645\u0643\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0627\u0644\u0631\u0627\u0628\u0639 \u0645\u0646 \u0634\u0647\u0631 \u0627\u0654\u0628\u0631\u064a\u0644\u060c \u0645\u0646 \u0627\u0646\u062a\u0632\u0627\u0639 (1.273) \u0644\u063a\u0645\u064b\u0627 \u0641\u064a \u0645\u062e\u062a\u0644\u0641 \u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u064a\u0645\u0646\u060c \u0645\u0646\u0647\u0627 (105) \u0627\u0654\u0644\u063a\u0627\u0645 \u0645\u0636\u0627\u062f\u0629 \u0644\u0644\u062f\u0628\u0627\u0628\u0627\u062a\u060c \u0648(3) \u0627\u0654\u0644\u063a\u0627\u0645 \u0645\u0636\u0627\u062f\u0629 \u0644\u0644\u0627\u0654\u0641\u0631\u0627\u062f\u060c \u0648(1.157) \u0630\u062e\u064a\u0631\u0629 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629\u060c \u0648(8) \u0639\u0628\u0648\u0627\u062a \u0646\u0627\u0633\u0641\u0629.<h2>\u062a\u0637\u0647\u064a\u0631 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0644\u064a\u0645\u0646\u064a\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0644\u063a\u0627\u0645</h2>\u0648\u0646\u0632\u0639 \u0641\u0631\u064a\u0642 \"\u0645\u0633\u0627\u0645\" \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u0639\u062f\u0646 \u0630\u062e\u064a\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629 \u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u062e\u0648\u0631 \u0645\u0643\u0633\u0631\u060c \u0648(247) \u0630\u062e\u064a\u0631\u0629 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629 \u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u0639\u062f\u0646\u060c \u0648\u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u0642\u0639\u0637\u0628\u0629 \u0628\u0645\u062d\u0627\u0641\u0638\u0629 \u0627\u0644\u0636\u0627\u0644\u0639 \u062a\u0645 \u0646\u0632\u0639 \u0644\u063a\u0645\u064a\u0646 \u0645\u0636\u0627\u062f\u064a\u0646 \u0644\u0644\u0627\u0654\u0641\u0631\u0627\u062f\u060c \u0648\u0646\u0632\u0639 \u0627\u0644\u0641\u0631\u064a\u0642 \u0641\u064a \u0645\u062f\u064a\u0631\u064a\u0629 \u062d\u064a\u0633 \u0628\u0645\u062d\u0627\u0641\u0638\u0629 \u0627\u0644\u062d\u062f\u064a\u062f\u0629 \u0630\u062e\u064a\u0631\u062a\u064a\u0646 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629.<br /><br />\u0648\u0641\u064a \u0645\u062f\u064a\u0631\u064a\u0629 \u0627\u0644\u0645\u0643\u0644\u0627 \u0628\u0645\u062d\u0627\u0641\u0638\u0629 \u062d\u0636\u0631\u0645\u0648\u062a \u0646\u064f\u0632\u0639 \u0644\u063a\u0645\u064a\u0646 \u0645\u0636\u0627\u062f\u064a\u0646 \u0644\u0644\u062f\u0628\u0627\u0628\u0627\u062a \u0648(162) \u0630\u062e\u064a\u0631\u0629 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629 \u0648\u0627\u0654\u0631\u0628\u0639 \u0639\u0628\u0648\u0627\u062a \u0646\u0627\u0633\u0641\u0629\u060c \u0648\u0641\u064a \u0645\u062f\u064a\u0631\u064a\u0629 \u0645\u064a\u062f\u064a \u0628\u0645\u062d\u0627\u0641\u0638\u0629 \u062d\u062c\u0629 \u0646\u064f\u0632\u0639 \u0644\u063a\u0645 \u0648\u0627\u062d\u062f \u0645\u0636\u0627\u062f \u0644\u0644\u0627\u0654\u0641\u0631\u0627\u062f \u0648(93) \u0644\u063a\u0645\u064b\u0627 \u0645\u0636\u0627\u062f\u064b\u0627 \u0644\u0644\u062f\u0628\u0627\u0628\u0627\u062a \u0648(353) \u0630\u062e\u064a\u0631\u0629 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629 \u0648\u062b\u0644\u0627\u062b \u0639\u0628\u0648\u0627\u062a \u0646\u0627\u0633\u0641\u0629\u060c \u0648\u0641\u064a \u0645\u062f\u064a\u0631\u064a\u0629 \u0627\u0644\u0645\u0636\u0627\u0631\u0628\u0629 \u0628\u0645\u062d\u0627\u0641\u0638\u0629 \u0644\u062d\u062c \u062a\u0645 \u0646\u0632\u0639 (6) \u0627\u0654\u0644\u063a\u0627\u0645 \u0645\u0636\u0627\u062f\u0629 \u0644\u0644\u062f\u0628\u0627\u0628\u0627\u062a \u0648\u0630\u062e\u064a\u0631\u062a\u064a\u0646 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629.<br /><br />\u0648\u0641\u064a \u0645\u062f\u064a\u0631\u064a\u0629 \u0645\u0627\u0654\u0631\u0628 \u0628\u0645\u062d\u0627\u0641\u0638\u0629 \u0645\u0627\u0654\u0631\u0628 \u0646\u0632\u0639 \u0627\u0644\u0641\u0631\u064a\u0642 (350) \u0630\u062e\u064a\u0631\u0629 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629\u060c \u0648\u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u0639\u064a\u0646 \u0628\u0645\u062d\u0627\u0641\u0638\u0629 \u0634\u0628\u0648\u0629 \u062a\u0645 \u0646\u0632\u0639 \u0627\u0654\u0631\u0628\u0639 \u0630\u062e\u0627\u064a\u0654\u0631 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629.<br /><br /> <h2>\u062c\u0647\u0648\u062f \u0628\u0631\u0646\u0627\u0645\u062c \u0645\u0633\u0627\u0645 \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0641\u064a \u0627\u0644\u064a\u0645\u0646</h2>\u0648\u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u062a\u0639\u0632 \u0646\u064f\u0632\u0639 \u0644\u063a\u0645\u064a\u0646 \u0645\u0636\u0627\u062f\u064a\u0646 \u0644\u0644\u062f\u0628\u0627\u0628\u0627\u062a \u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u0627\u0644\u0645\u062e\u0627\u0621\u060c \u0648\u0644\u063a\u0645\u064a\u0646 \u0645\u0636\u0627\u062f\u064a\u0646 \u0644\u0644\u062f\u0628\u0627\u0628\u0627\u062a \u0648 (23) \u0630\u062e\u064a\u0631\u0629 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629 \u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u0630\u0628\u0627\u0628\u060c \u0648(13) \u0630\u062e\u064a\u0631\u0629 \u063a\u064a\u0631 \u0645\u0646\u0641\u062c\u0631\u0629 \u0648\u0639\u0628\u0648\u0629 \u0646\u0627\u0633\u0641\u0629 \u0648\u0627\u062d\u062f\u0629 \u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u0635\u0644\u0648\u062d.<br /><br />\u0648\u0628\u0630\u0644\u0643 \u0627\u0631\u062a\u0641\u0639 \u0639\u062f\u062f \u0627\u0644\u0627\u0654\u0644\u063a\u0627\u0645 \u0627\u0644\u0645\u0646\u0632\u0648\u0639\u0629 \u062e\u0644\u0627\u0644 \u0634\u0647\u0631 \u0627\u0654\u0628\u0631\u064a\u0644 \u062d\u062a\u0649 \u0627\u0644\u0627\u0653\u0646 \u0627\u0655\u0644\u0649 (5.818) \u0644\u063a\u0645\u064b\u0627\u060c \u0648\u0645\u0646\u0630 \u0628\u062f\u0627\u064a\u0629 \u0645\u0634\u0631\u0648\u0639 \"\u0645\u0633\u0627\u0645\" \u062d\u062a\u0649 \u0627\u0644\u0627\u0653\u0646 \u0627\u0655\u0644\u0649 (557.007) \u0627\u0654\u0644\u063a\u0627\u0645\u060c \u0628\u0639\u062f \u0627\u0654\u0646 \u0632\u064f\u0631\u0639\u062a \u0639\u0634\u0648\u0627\u064a\u0654\u064a\u064b\u0651\u0627 \u0641\u064a \u0645\u062e\u062a\u0644\u0641 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0644\u064a\u0645\u0646\u064a\u0629 \u0644\u062d\u0635\u062f \u0627\u0644\u0627\u0654\u0631\u0648\u0627\u062d \u0627\u0644\u0628\u0631\u064a\u064a\u0654\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0637\u0641\u0627\u0644 \u0648\u0627\u0644\u0646\u0633\u0627\u0621 \u0648\u0643\u0628\u0627\u0631 \u0627\u0644\u0633\u0646\u060c \u0648\u0632\u0631\u0639 \u0627\u0644\u062e\u0648\u0641 \u0641\u064a \u0642\u0644\u0648\u0628 \u0627\u0644\u0627\u0653\u0645\u0646\u064a\u0646.<br /><br />\u0648\u062a\u0648\u0627\u0635\u0644 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0639\u0628\u0631 \u0630\u0631\u0627\u0639\u0647\u0627 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629 \u062c\u0647\u0648\u062f\u0647\u0627 \u0641\u064a \u062a\u0637\u0647\u064a\u0631 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0644\u064a\u0645\u0646\u064a\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0644\u063a\u0627\u0645\u060c \u0636\u0645\u0646 \u0645\u0634\u0631\u0648\u0639 \u064a\u064f\u0639\u0632\u0632 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u062f\u0646\u064a\u064a\u0646\u060c \u0648\u064a\u0633\u0647\u0645 \u0641\u064a \u062a\u0645\u0643\u064a\u0646 \u0627\u0644\u0627\u0654\u0634\u0642\u0627\u0621 \u0627\u0644\u064a\u0645\u0646\u064a\u064a\u0646 \u0645\u0646 \u0639\u064a\u0634 \u062d\u064a\u0627\u0629 \u0643\u0631\u064a\u0645\u0629 \u0648\u0627\u0653\u0645\u0646\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["lifestyle", "top"], "datatype": "news", "pubDate": "2026-04-27 18:40:00", "pubDateTZ": "UTC", "fetched_at": "2026-04-27 18:44:13", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "2175e446a57125af762f01d514f09f4d", "link": "https://arriyadiyah.com/889979", "title": "\u00ab\u0627\u0644\u0631\u064a\u0627\u0636\u0629 \u0644\u0644\u062c\u0645\u064a\u0639\u00bb \u064a\u0639\u064a\u062f \u062a\u0634\u0643\u064a\u0644 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629", "description": "\u0627\u0654\u0639\u0644\u0646 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0644\u0644\u0631\u064a\u0627\u0636\u0629 \u0644\u0644\u062c\u0645\u064a\u0639 \u0639\u0646 \u062a\u0634\u0643\u064a\u0644 \u0645\u062c\u0644\u0633 \u0627\u0655\u062f\u0627\u0631\u062a\u0647 \u0627\u0644\u062c\u062f\u064a\u062f \u0628\u0631\u064a\u0654\u0627\u0633\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u062e\u0627\u0644\u062f \u0628\u0646 \u0627\u0644\u0648\u0644\u064a\u062f \u0628\u0646 \u0637\u0644\u0627\u0644\u060c \u0633\u0639\u064a\u064b\u0627 \u0644\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u062c\u0647\u0648\u062f \u0627\u0644\u062a\u064a \u062a\u0647\u062f\u0641 \u0627\u0655\u0644\u0649 \u0631\u0641\u0639 \u0645\u0639\u062f\u0651\u0644\u0627\u062a \u0645\u0645\u0627\u0631\u0633\u0629 \u0627\u0644\u0646\u0634\u0627\u0637 \u0627\u0644\u0628\u062f\u0646\u064a\u060c \u0648\u062a\u0627\u0654\u0643\u064a\u062f \u0645\u0643\u0627\u0646\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0643\u0645\u0631\u062c\u0639\u064a\u0629 \u0639\u0627\u0644\u0645\u064a\u0629 \u0641\u064a \u0627\u0644\u0631\u064a\u0627\u0636\u0629 \u0627\u0644\u0645\u062c\u062a\u0645\u0639\u064a\u0629\u060c \u0628\u0645\u0627 \u064a\u062a\u0645\u0627\u0634\u0649 \u0645\u0639 \u0631\u0648\u0654\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 2030 \u0648\u0628\u0631\u0646\u0627\u0645\u062c \u062c\u0648\u062f\u0629 \u0627\u0644\u062d\u064a\u0627\u0629. \u0648\u064a\u0636\u0645 \u0627\u0644\u062a\u0634\u0643\u064a\u0644 \u0627\u0644\u062c\u062f\u064a\u062f \u0644\u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0646\u062e\u0628\u