8A-%D8%A7%D9%84%D8%AA%D8%A7%D9%8A%D9%85%D8%B2-%D9%84%D9%84%D8%AA%D8%A3%D8%AB%D9%8A%D8%B1\" target=\"_blank\">\u062a\u0635\u0646\u064a\u0641 \u0627\u0644\u062a\u0627\u064a\u0645\u0632 \u0644\u0644\u062a\u0627\u0654\u062b\u064a\u0631</a> 2026 \u0627\u0644\u0635\u0627\u062f\u0631 \u0639\u0646 \u0645\u0648\u0654\u0633\u0633\u0629 <a href=\"https://www.alyaum.com/articles/6590788/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AC%D8%A7%D9%85%D8%B9%D8%A9-%D8%A3%D9%85-%D8%A7%D9%84%D9%82%D8%B1%D9%89-%D8%AA%D8%AA%D9%82%D8%AF%D9%85-43-%D9%85%D8%B1%D9%83%D8%B2%D8%A7-%D9%81%D9%8A-%D8%AA%D8%B5%D9%86%D9%8A%D9%81-%D8%A7%D9%84%D8%AA%D8%A7%D9%8A%D9%85%D8%B2-%D9%84%D9%84%D8%AC%D8%A7%D9%85%D8%B9%D8%A7%D8%AA-%D8%A7%D9%84%D8%A2%D8%B3%D9%8A%D9%88%D9%8A%D8%A9\" target=\"_blank\">\u0627\u0644\u062a\u0627\u064a\u0645\u0632</a> \u0644\u0644\u062a\u0639\u0644\u064a\u0645 \u0627\u0644\u0639\u0627\u0644\u064a\u060c \u0628\u062d\u0635\u0648\u0644\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0641\u064a\u0654\u0629 (401-600) \u0639\u0627\u0644\u0645\u064a\u064b\u0627 \u0641\u064a \u0627\u0644\u062a\u0635\u0646\u064a\u0641 \u0627\u0644\u0639\u0627\u0645\u060c \u0645\u0646 \u0628\u064a\u0646 1,646 \u062c\u0627\u0645\u0639\u0629 \u0634\u0645\u0644\u0647\u0627 \u0627\u0644\u062a\u0635\u0646\u064a\u0641 \u0645\u0646 116 \u062f\u0648\u0644\u0629 \u0648\u0627\u0655\u0642\u0644\u064a\u0645\u064b\u0627 \u0641\u064a \u0627\u0644\u0639\u0627\u0644\u0645.<br />\u0643\u0645\u0627 \u0633\u062c\u0644\u062a \u0627\u0644\u062c\u0627\u0645\u0639\u0629 \u0646\u062a\u0627\u064a\u0654\u062c \u0645\u062a\u0645\u064a\u0632\u0629 \u0641\u064a \u0639\u062f\u062f \u0645\u0646 \u0627\u0654\u0647\u062f\u0627\u0641 \u0627\u0644\u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u062f\u0627\u0645\u0629\u060c \u0627\u0655\u0630 \u062d\u0642\u0642\u062a \u0627\u0644\u0645\u0631\u0643\u0632 18 \u0639\u0627\u0644\u0645\u064a\u064b\u0627 \u0641\u064a \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u0633\u0627\u062f\u0633 \"\u0627\u0644\u0645\u064a\u0627\u0647 \u0627\u0644\u0646\u0638\u064a\u0641\u0629 \u0648\u0627\u0644\u0635\u0631\u0641 \u0627\u0644\u0635\u062d\u064a\"\u060c \u0648\u0627\u0644\u0645\u0631\u0643\u0632 49 \u0639\u0627\u0644\u0645\u064a\u064b\u0627 \u0641\u064a \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u0631\u0627\u0628\u0639 \"\u0627\u0644\u062a\u0639\u0644\u064a\u0645 \u0627\u0644\u062c\u064a\u062f\"\u060c \u0648\u062c\u0627\u0621\u062a \u0636\u0645\u0646 \u0627\u0644\u0641\u064a\u0654\u0629 (101-200) \u0639\u0627\u0644\u0645\u064a\u064b\u0627 \u0641\u064a \u0643\u0644 \u0645\u0646 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u062a\u0627\u0633\u0639 \"\u0627\u0644\u0627\u0628\u062a\u0643\u0627\u0631 \u0627\u0644\u0635\u0646\u0627\u0639\u064a \u0648\u0627\u0644\u0628\u0646\u064a\u0629 \u0627\u0644\u062a\u062d\u062a\u064a\u0629\"\u060c \u0648\u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u062b\u0627\u0645\u0646 \"\u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0644\u0627\u064a\u0654\u0642 \u0648\u0646\u0645\u0648 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\".<br />\u0643\u0645\u0627 \u062d\u0644\u062a \u0636\u0645\u0646 \u0627\u0644\u0641\u064a\u0654\u0629 (201-300) \u0639\u0627\u0644\u0645\u064a\u064b\u0627 \u0641\u064a \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u0633\u0627\u0628\u0639 \u0639\u0634\u0631 \"\u0639\u0642\u062f \u0627\u0644\u0634\u0631\u0627\u0643\u0627\u062a \u0644\u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0627\u0654\u0647\u062f\u0627\u0641\"\u060c \u0648\u0636\u0645\u0646 \u0627\u0644\u0641\u064a\u0654\u0629 (301-400) \u0639\u0627\u0644\u0645\u064a\u064b\u0627 \u0641\u064a \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u0633\u0627\u0628\u0639 \"\u0637\u0627\u0642\u0629 \u0646\u0638\u064a\u0641\u0629 \u0648\u0628\u0627\u0654\u0633\u0639\u0627\u0631 \u0645\u0639\u0642\u0648\u0644\u0629\".<h2>4 \u0645\u0639\u0627\u064a\u064a\u0631 \u0631\u064a\u0654\u064a\u0633\u0629</h2>\u0648\u064a\u0