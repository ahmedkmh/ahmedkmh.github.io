8%B0-%D8%A7%D9%84%D8%A3%D9%88%D9%84-%D9%85%D9%86-%D8%B0%D9%8A-%D8%A7%D9%84%D9%82%D8%B9%D8%AF%D8%A9\" target=\"_blank\">\u0646\u0633\u0643</a>\u00bb \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 12 \u0645\u0644\u064a\u0648\u0646 \u062a\u0641\u0627\u0639\u0644\u060c \u0641\u064a \u0645\u0648\u0654\u0634\u0631 \u064a\u0639\u0643\u0633 \u0627\u0644\u0627\u0639\u062a\u0645\u0627\u062f \u0627\u0644\u0645\u062a\u0632\u0627\u064a\u062f \u0639\u0644\u0649 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0631\u0642\u0645\u064a\u0629 \u0641\u064a \u0627\u0655\u062b\u0631\u0627\u0621 \u062a\u062c\u0631\u0628\u0629 <a href=\"https://www.alyaum.com/articles/6664314/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%88%D9%84%D9%8A-%D8%A7%D9%84%D8%B9%D9%87%D8%AF-%D9%8A%D9%82%D9%8A%D9%85-%D8%AD%D9%81%D9%84-%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D9%82%D8%A8%D8%A7%D9%84-%D8%A7%D9%84%D8%B3%D9%86%D9%88%D9%8A-%D9%84%D9%83%D8%A8%D8%A7%D8%B1-%D8%B6%D9%8A%D9%88%D9%81-%D8%AE%D8%A7%D8%AF%D9%85-%D8%A7%D9%84%D8%AD%D8%B1%D9%85%D9%8A%D9%86-%D9%85%D9%86-%D8%A7%D9%84%D8%AD%D8%AC%D8%A7%D8%AC\" target=\"_blank\">\u0627\u0644\u062d\u062c\u0627\u062c</a> \u0648\u062a\u0633\u0647\u064a\u0644 \u0631\u062d\u0644\u062a\u0647\u0645.<br />\u0643\u0634\u0641\u062a \u0630\u0644\u0643 \u0627\u0654\u0631\u0642\u0627\u0645 \u062e\u062f\u0645\u064a\u0629 \u0648\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0635\u0627\u062f\u0631\u0629 \u0639\u0646 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062d\u062c \u0648\u0627\u0644\u0639\u0645\u0631\u0629\u060c \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 \u0645\u0646 1 \u0630\u0648 \u0627\u0644\u0642\u0639\u062f\u0629 \u062d\u062a\u0649 11 \u0630\u0648 \u0627\u0644\u062d\u062c\u0629 \u0627\u0644\u062d\u0627\u0644\u064a\u060c \u0639\u0627\u0643\u0633\u0629\u064b \u062d\u062c\u0645 \u0627\u0644\u062a\u0643\u0627\u0645\u0644 \u0627\u0644\u062a\u0642\u0646\u064a \u0648\u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a \u0641\u064a \u062e\u062f\u0645\u0629 \u0636\u064a\u0648\u0641 \u0627\u0644\u0631\u062d\u0645\u0646.<br />\u0648\u0627\u0654\u0638\u0647\u0631\u062a \u0627\u0644\u0627\u0655\u062d\u0635\u0627\u064a\u0654\u064a\u0627\u062a \u0627\u0644\u0645\u0646\u0634\u0648\u0631\u0629 \u0627\u0654\u0646 \u0628\u0637\u0627\u0642\u0627\u062a \u00ab<a href=\"https://www.alyaum.com/articles/6663622/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B9%D8%A7%D8%AC%D9%84-%D8%A7%D9%84%D8%AD%D8%AC-%D9%88%D8%A7%D9%84%D8%B9%D9%85%D8%B1%D8%A9-%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-34-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D9%82%D8%B1%D8%A7%D8%A1%D8%A9-%D9%84%D8%A8%D8%B7%D8%A7%D9%82%D8%A9-%D9%86%D8%B3%D9%83-%D9%8880-%D8%A3%D9%84%D9%81-%D8%AC%D9%88%D9%84%D8%A9-%D8%B1%D9%82%D8%A7%D8%A8%D9%8A%D8%A9\" target=\"_blank\">\u0646\u0633\u0643</a>\u00bb \u0642\u064f\u0631\u064a\u0654\u062a \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 6 \u0645\u0644\u0627\u064a\u064a\u0646 \u0645\u0631\u0629 \u0644\u0628\u0637\u0627\u0642\u0627\u062a \u0627\u0644\u062d\u062c\u0627\u062c\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 573 \u0627\u0654\u0644\u0641 \u062d\u0627\u062c \u0645\u0646 \u062f\u0644\u064a\u0644 \u0627\u0644\u062d\u062c \u0627\u0644\u062a\u0648\u0639\u0648\u064a \u062f\u0627\u062e\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u060c \u0645\u0627 \u064a\u0639\u0632\u0632 \u0645\u0646 \u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0648\u0639\u064a \u0648\u0627\u0644\u0627\u0655\u0631\u0634\u0627\u062f \u0644\u0644\u062d\u062c\u0627\u062c \u0628\u0639\u062f\u0629 \u0644\u063a\u0627\u062a \u0648\u062e\u062f\u0645\u0627\u062a \u0631\u0642\u0645\u064a\u0629 \u0645\u062a\u0643\u0627\u0645\u0644\u0629.<h2>260 \u0627\u0654\u0644\u0641 \u062e\u062f\u0645\u0629</h2>\u0643\u0645\u0627 \u0642\u062f\u0645\u062a \u00ab\