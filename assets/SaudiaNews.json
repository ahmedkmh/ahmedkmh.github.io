4dfb2c91dc65c0f36e46fd4b15462e", "link": "https://www.alyaum.com/articles/6649174/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%AA%D9%83%D9%86%D9%88%D9%84%D9%88%D8%AC%D9%8A%D8%A7/%D8%B9%D8%A8%D8%B1-6-%D9%85%D8%AC%D8%A7%D9%84%D8%A7%D8%AA-%D8%A3%D8%A8%D8%B1%D8%B2-%D8%AC%D9%87%D9%88%D8%AF-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D9%84%D8%AA%D8%AD%D9%82%D9%8A%D9%82-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%AF%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%A8%D9%8A%D8%A7%D9%86%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D9%81%D8%AA%D9%88%D8%AD%D8%A9", "title": "\u0639\u0628\u0631 6 \u0645\u062c\u0627\u0644\u0627\u062a.. \u0627\u0654\u0628\u0631\u0632 \u062c\u0647\u0648\u062f \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0644\u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0631\u064a\u0627\u062f\u0629 \u0641\u064a \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629", "description": "\u062a\u0648\u0627\u0635\u0644 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u062a\u0639\u0632\u064a\u0632 \u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629 \u0644\u062f\u0639\u0645 \u0627\u0644\u0634\u0641\u0627\u0641\u064a\u0629 \u0648\u062a\u062d\u0641\u064a\u0632 \u0627\u0644\u0627\u0628\u062a\u0643\u0627\u0631 \u0648\u062a\u0639\u0638\u064a\u0645 \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a.\u0648\u064a\u062a\u0645 \u0630\u0644\u0643 \u0639\u0628\u0631 \u0639\u062f\u0629 \u0645\u062c\u0627\u0644\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0646\u062d\u0648 \u0627\u0644\u062a\u0627\u0644\u064a:-\u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629.\u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u0633\u064a\u0627\u0633\u0627\u062a \u0648\u0627\u0644\u0636\u0648\u0627\u0628\u0637.\u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0645\u0646\u0635\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0644\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629.\u062a\u0645\u0643\u064a\u0646 \u0645\u0634\u0627\u0631\u0643\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629.\u0627\u0655\u062a\u0627\u062d\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0644\u0644\u0627\u0654\u0641\u0631\u0627\u062f \u0648\u0627\u0644\u0628\u0627\u062d\u062b\u064a\u0646 \u0648\u0627\u0644\u0645\u0637\u0648\u0631\u064a\u0646.\u062f\u0639\u0645 \u0627\u0644\u0627\u0628\u062a\u0643\u0627\u0631 \u0627\u0644\u0642\u0627\u064a\u0654\u0645 \u0639\u0644\u0649 \u062f\u0639\u0645 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a. \u0647\u0630\u0627 \u0648\u062a\u0633\u0647\u0645 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629 \u0641\u064a \u062f\u0639\u0645 \u0627\u0644\u0627\u0628\u062a\u0643\u0627\u0631 \u0648\u062a\u0645\u0643\u064a\u0646 \u0627\u0644\u0627\u0654\u0628\u062d\u0627\u062b \u0648\u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f \u0627\u0644\u0642\u0627\u064a\u0654\u0645 \u0639\u0644\u0649 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0628\u0627\u0644\u0645\u0645\u0644\u0643\u0629.\u0643\u0645\u0627 \u062a\u062a\u064a\u062d \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629 \u0645\u062c\u0627\u0644\u0627\u062a \u0648\u0627\u0633\u0639\u0629 \u0644\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646\u0647\u0627\u060c \u0645\u0646 \u0627\u0654\u0628\u0631\u0632\u0647\u0627 \u0645\u0627 \u064a\u0644\u064a:-\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0644\u0627\u062a\u062e\u0627\u0630 \u0642\u0631\u0627\u0631\u0627\u062a \u0627\u0654\u0641\u0636\u0644.\u0648\u062f\u0639\u0645 \u0627\u0644\u062f\u0631\u0627\u0633\