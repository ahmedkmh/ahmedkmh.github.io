-%D8%A3%D9%85%D8%A7%D9%86%D8%A9-%D8%AC%D8%AF%D8%A9-%D8%AA%D8%A8%D8%AF%D8%A3-%D8%A7%D8%B3%D8%AA%D9%82%D8%A8%D8%A7%D9%84-%D8%B7%D9%84%D8%A8%D8%A7%D8%AA-%D8%AA%D8%B5%D8%A7%D8%B1%D9%8A%D8%AD-%D8%B0%D8%A8%D8%AD-%D8%A7%D9%84%D8%A3%D8%B6%D8%A7%D8%AD%D9%8A-%D8%B1%D9%82%D9%85%D9%8A%D8%A7\" target=\"_blank\">\u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u0635\u062d\u064a\u0629</a> \u0641\u064a \u0646\u0637\u0627\u0642 11 \u0628\u0644\u062f\u064a\u0629 \u0641\u0631\u0639\u064a\u0629\u060c \u0648\u062a\u0647\u062f\u0641 \u0627\u0655\u0644\u0649 \u0631\u0641\u0639 \u0646\u0633\u0628\u0629 \u0627\u0645\u062a\u062b\u0627\u0644 \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0648\u0627\u0644\u0635\u062d\u064a\u0629 \u0648\u0627\u0644\u062a\u064a \u0633\u062a\u0646\u0639\u0643\u0633 \u0639\u0644\u0649 \u062c\u0648\u062f\u0629 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u0642\u062f\u0645\u0629\u060c \u0648\u062a\u0633\u0627\u0647\u0645 \u0641\u064a \u0627\u0654\u0645\u0646 \u0648\u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u063a\u0630\u0627\u0621 \u0627\u0644\u0645\u0642\u062f\u0645 \u0644\u0644\u0633\u0643\u0627\u0646 \u0648\u0627\u0644\u0632\u0627\u064a\u0654\u0631\u064a\u0646.</p><h2>\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062c\u0647\u0648\u062f \u0627\u0644\u0631\u0642\u0627\u0628\u064a\u0629</h2><p>\u0648\u0627\u0654\u0643\u062f\u062a \u0627\u0654\u0645\u0627\u0646\u0629 \u062c\u062f\u0629 \u0645\u0648\u0627\u0635\u0644\u0629 \u062c\u0647\u0648\u062f\u0647\u0627 \u0627\u0644\u0631\u0642\u0627\u0628\u064a\u0629 \u0639\u0628\u0631 <a href=\"https://www.alyaum.com/articles/6665006/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D8%B3%D8%AA%D9%87%D8%AF%D8%A7%D9%81-%D9%85%D8%B7%D8%A7%D8%B1-%D8%A7%D9%84%D9%83%D9%88%D9%8A%D8%AA-%D8%A7%D9%84%D8%AF%D9%88%D9%84%D9%8A-%D8%A8%D9%85%D8%B3%D9%8A%D8%B1%D8%A7%D8%AA-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9-%D9%88%D8%AA%D9%81%D8%B9%D9%8A%D9%84-%D8%AE%D8%B7%D8%A9-%D8%A7%D9%84%D8%B7%D9%88%D8%A7%D8%B1%D8%A6\" target=\"_blank\">\u062c\u0648\u0644\u0627\u062a\u0647\u0627 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629</a> \u0644\u0645\u062a\u0627\u0628\u0639\u0629 \u062a\u0637\u0628\u064a\u0642 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0637\u0627\u062a \u0627\u0644\u0635\u062d\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a\u0629 \u0648\u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0627\u0645\u062a\u062b\u0627\u0644\u060c \u0645\u0634\u064a\u0631\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u064a\u0645\u0643\u0646\u0647\u0627 \u0627\u0644\u0648\u0635\u0648\u0644 \u0644\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629 \u0628\u0643\u0644 \u064a\u0633\u0631 \u0648\u0633\u0647\u0648\u0644\u0629 \u0639\u0628\u0631 \u0645\u0646\u0635\u0629 \u0628\u0644\u062f\u064a \u0648\u0627\u0644\u062a\u064a \u062a\u062a\u064a\u062d \u0627\u0655\u0645\u0643\u0627\u0646\u064a\u0629 \u0627\u0655\u0635\u062f\u0627\u0631 \u0627\u0644\u0634\u0647\u0627\u062f\u0629 \u0627\u0644\u0635\u062d\u064a\u0629 \u0648\u0637\u0628\u0627\u0639\u062a\u0647\u0627 \u062f\u0648\u0646 \u0627\u0644\u062d\u0627\u062c\u0629 \u0644\u0645\u0631\u0627\u062c\u0639\u0629 \u0627\u0644\u0627\u0654\u0645\u0627\u0646\u0629\u060c \u0648\u0630\u0644\u0643 \u0639\u0628\u0631 \u0631\u0628\u0637 \u0646\u062a\u0627\u064a\u0654\u062c \u0627\u0644\u0641\u062d\u0635 \u0627\u0644\u0637\u0628\u064a \u0645\u0639 \u0645\u0646\u0635\u0629 \u0627\u0644\u0635\u062d\u0629 \u0627\u0655\u0644\u0643\u062a\u0631\u0648\u0646\u064a\u0627\u064b.</p><p> </p>", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["health", "top"], "datatype": "news", "pubDate": "2026-06-03 11:09:00", "pu