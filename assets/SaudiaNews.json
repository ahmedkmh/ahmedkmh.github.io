A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%81%D9%8A-%D8%AC%D9%88%D8%A8%D8%A7-%D8%A7%D9%84%D8%AE%D8%B1%D9%8A%D8%AC%D9%8A-%D9%8A%D8%B3%D8%AA%D8%B9%D8%B1%D8%B6-%D8%A7%D9%84%D8%B9%D9%84%D8%A7%D9%82%D8%A7%D8%AA-%D8%A7%D9%84%D8%AB%D9%86%D8%A7%D8%A6%D9%8A%D8%A9-%D9%85%D8%B9-%D8%B1%D8%A6%D9%8A%D8%B3-%D8%AC%D9%86%D9%88%D8%A8-%D8%A7%D9%84%D8%B3%D9%88%D8%AF%D8%A7%D9%86\" target=\"_blank\">\u062c\u0648\u0628\u0627</a> \u0639\u0627\u0635\u0645\u0629 <a href=\"https://www.alyaum.com/articles/6653268/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/73-%D9%82%D8%AA%D9%8A%D9%84%D8%A7-%D9%81%D9%8A-%D9%87%D8%AC%D9%88%D9%85-%D9%85%D8%B3%D9%84%D8%AD%D9%8A%D9%86-%D9%85%D8%AC%D9%87%D9%88%D9%84%D9%8A%D9%86-%D8%B9%D9%84%D9%89-%D9%85%D9%86%D8%AC%D9%85-%D9%84%D9%84%D8%B0%D9%87%D8%A8-%D9%81%D9%8A-%D8%AC%D9%86%D9%88%D8%A8-%D8%A7%D9%84%D8%B3%D9%88%D8%AF%D8%A7%D9%86\" target=\"_blank\">\u062c\u0646\u0648\u0628 \u0627\u0644\u0633\u0648\u062f\u0627\u0646</a>\u060c \u0628\u062d\u0633\u0628 \u0645\u0627 \u0627\u0654\u0641\u0627\u062f\u062a \u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0637\u064a\u0631\u0627\u0646 \u0627\u0644\u0645\u062f\u0646\u064a \u0627\u0644\u0645\u062d\u0644\u064a\u0629 \u0627\u0644\u0627\u062b\u0646\u064a\u0646.<br />\u0648\u0642\u0627\u0644\u062a \u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0637\u064a\u0631\u0627\u0646 \u0627\u0644\u0645\u062f\u0646\u064a \u0641\u064a \u062c\u0646\u0648\u0628 \u0627\u0644\u0633\u0648\u062f\u0627\u0646 \u0641\u064a \u0628\u064a\u0627\u0646\u060c \u0627\u0655\u0646\u0651 \u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0629 \u0645\u0646 \u0637\u0631\u0627\u0632 \u0633\u064a\u0633\u0646\u0627 \u0627\u0654\u0642\u0644\u0639\u062a \u0645\u0646 \u0645\u0637\u0627\u0631 \u062c\u0648\u0628\u0627 \u0627\u0644\u062f\u0648\u0644\u064a \u0641\u064a \u0627\u0644\u0633\u0627\u0639\u0629 7,15 \u0628\u062a\u0648\u0642\u064a\u062a \u062c\u0631\u064a\u0646\u062a\u0634\u060c \u0648\u062a\u062d\u0637\u0645\u062a \u0639\u0644\u0649 \u0628\u0639\u062f \u0646\u062d\u0648 20 \u0643\u064a\u0644\u0648\u0645\u062a\u0631\u064b\u0627 \u0645\u0646 \u0627\u0644\u0639\u0627\u0635\u0645\u0629\u060c \u0648\u0644\u0645 \u064a\u0646\u062c \u0627\u0654\u064a \u0645\u0646 \u0631\u0643\u0627\u0628\u0647\u0627.<br />\u0648\u0643\u0627\u0646 \u0639\u0644\u0649 \u0645\u062a\u0646 \u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0629 12 \u0634\u062e\u0635\u064b\u0627 \u0645\u0646 \u062c\u0646\u0648\u0628 \u0627\u0644\u0633\u0648\u062f\u0627\u0646 \u0648\u0634\u062e\u0635\u0627\u0646 \u0645\u0646 \u0643\u064a\u0646\u064a\u0627.<h2>\u062c\u0645\u064a\u0639 \u0627\u0644\u062c\u062b\u062b \u0645\u062a\u0641\u062d\u0651\u0645\u0629</h2>\u0648\u0642\u0627\u0644 \u0627\u0654\u062d\u062f \u0627\u0654\u0639\u0636\u0627\u0621 \u0641\u0631\u064a\u0642 \u0627\u0644\u0627\u0655\u0646\u0642\u0627\u0630 \u0627\u0644\u062a\u0627\u0628\u0639 \u0644\u0644\u0627\u0654\u0645\u0645 \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0627\u0644\u0630\u064a \u0627\u064f\u0654\u0631\u0633\u0644 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0643\u0627\u0646: \"\u0643\u0627\u0646\u062a \u062c\u0645\u064a\u0639 \u0627\u0644\u062c\u062b\u062b \u0645\u062a\u0641\u062d\u0651\u0645\u0629 \u0644\u062f\u0631\u062c\u0629 \u064a\u0635\u0639\u0628 \u0645\u0639\u0647\u0627 \u0627\u0644\u062a\u0639\u0631\u0651\u0641 \u0639\u0644\u064a\u0647\u0627\".<br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0637\u064a\u0631\u0627\u0646 \u0627\u0644\u0645\u062f\u0646\u064a \u0627\u0654\u0646\u0651 \u0627\u0644\u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0644\u0627\u0654\u0648\u0644\u064a\u0629 \u062a\u0641\u064a\u062f \u0628\u0627\u0654\u0646\u0651 \u0633\u0628\u0628 \u0627\u0644\u062d\u0627\u062f\u062b \u0647\u0648 \u0627\u0644\u0638\u0631\u0648\u0641 \u0627\u0644\u062c\u0648\u064a\u0629 \u0627\u0644\u0633\u064a\u064a\u0654\u0629\u060c \u062e\u0635\u0648\u0635\u064b\u0627 \u0627\u0646\u062e\u0641\u0627\u0636 \u0645\u0633\u062a\u0648\u0649 \u06