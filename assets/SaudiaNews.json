064a \u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0627\u0654\u0647\u062f\u0627\u0641 \u0627\u0644\u0627\u0654\u0648\u0644\u064a\u0629 \u0627\u0644\u062a\u064a \u0648\u0636\u0639\u062a\u0647\u0627 \u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0646\u062a\u062e\u0628\u060c \u0648\u0627\u0654\u0628\u0631\u0632\u0647\u0627 \u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0645\u0643\u0627\u0646\u0629 \u0627\u0644\u0641\u0631\u064a\u0642 \u0641\u064a \u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0654\u0645\u0645 \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a\u0629 \u0648\u0628\u0644\u0648\u063a \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0627\u0644\u0645\u062a\u0642\u062f\u0645\u0629 \u0641\u064a \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644.<br /><br />\u0648\u0642\u062f\u0645 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0628\u0644\u062c\u064a\u0643\u064a \u0627\u0654\u062f\u0627\u0621\u064b \u0645\u0642\u0646\u0639\u064b\u0627 \u062e\u0644\u0627\u0644 \u0645\u0634\u0648\u0627\u0631\u0647 \u0641\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u063a\u0627\u062f\u0631 \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0645\u0646 \u0631\u0628\u0639 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0628\u0639\u062f \u062e\u0633\u0627\u0631\u062a\u0647 \u0627\u0654\u0645\u0627\u0645 \u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627 \u0628\u0647\u062f\u0641 \u062f\u0648\u0646 \u0631\u062f\u060c \u0641\u064a \u0645\u0648\u0627\u062c\u0647\u0629 \u062d\u064f\u0633\u0645\u062a \u0628\u062a\u0641\u0627\u0635\u064a\u0644 \u0635\u063a\u064a\u0631\u0629\u060c \u0628\u0639\u062f\u0645\u0627 \u062e\u0631\u062c \"\u0627\u0644\u0634\u064a\u0627\u0637\u064a\u0646 \u0627\u0644\u062d\u0645\u0631\" \u0645\u0646 \u0627\u0644\u0645\u0646\u0627\u0641\u0633\u0629 \u0628\u0633\u0628\u0628 \u0644\u0645\u0633\u0629 \u064a\u062f \u0641\u064a \u0627\u0644\u062f\u0642\u0627\u064a\u065