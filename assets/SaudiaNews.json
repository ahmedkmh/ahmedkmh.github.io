062d\u0627\u062f \u0627\u0644\u0646\u064a\u0628\u0627\u0644\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645\u060c \u0633\u0648\u0631\u064a\u0634 \u0634\u0627\u0647\u060c \u0644\u0648\u0643\u0627\u0644\u0629 \u0641\u0631\u0627\u0646\u0633 \u0628\u0631\u0633: \"\u064a\u0645\u062b\u0644 \u0647\u0630\u0627 \u0627\u0644\u062a\u0639\u0644\u064a\u0642 \u0645\u0635\u062f\u0631 \u0642\u0644\u0642 \u0628\u0627\u0644\u063a\u060c \u0648\u0646\u062d\u0646 \u0646\u062c\u0631\u064a \u0645\u0634\u0627\u0648\u0631\u0627\u062a \u0645\u0639 \u062c\u0645\u064a\u0639 \u0627\u0644\u0627\u0654\u0637\u0631\u0627\u0641 \u0627\u0644\u0645\u0639\u0646\u064a\u0629 \u0645\u0646 \u0627\u0654\u062c\u0644 \u0631\u0641\u0639\u0647\u060c \u0645\u0639 \u0627\u0655\u0639\u0637\u0627\u0621 \u0627\u0644\u0627\u0654\u0648\u0644\u0648\u064a\u0629 \u0644\u0645\u0635\u0644\u062d\u0629 \u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u0627\u0644\u0646\u064a\u0628\u0627\u0644\u064a\u0629\".<br /><br />\u0648\u064a\u0639\u0646\u064a \u0627\u0644\u0642\u0631\u0627\u0631 \u062d\u0631\u0645\u0627\u0646 \u0646\u064a\u0628\u0627\u0644 \u0645\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0629 \u0641\u064a \u0627\u0644\u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062f\u0648\u0644\u064a\u0629\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0641\u0642\u062f\u0627\u0646 \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0628\u0631\u0627\u0645\u062c \u0627\u0644\u062a\u0637\u0648\u064a\u0631 \u0648\u0627\u0644\u062f\u0648\u0631\u0627\u062a \u0627\u0644\u062a\u062f\u0631\u064a\u0628\u064a\u0629 \u0648\u0627\u0644\u062a\u0627\u0654\u0647\u064a\u0644\u064a\u0629 \u0627\u0644\u062a\u064a \u064a\u0646\u0638\u0645\u0647\u0627 \u0641\u064a\u0641\u0627.<br /><br />\u0648\u0627\u0654\u0636\u0627\u0641 \u0634\u0627\u0647 \"\u0627\u0644\u0642\u0631\u0627\u0631 \u064a\u0648\u0654\u062b\u0631 \u0639\u0644\u0649 \u0644\u0627\u0639\u0628\u064a\u0646\u0627\u060c \u0