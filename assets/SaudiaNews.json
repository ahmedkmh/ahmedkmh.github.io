646 \u0627\u0654\u062d\u0642\u064a\u0629 \u0627\u0644\u0627\u0654\u0631\u0628\u0627\u062d \u0644\u0645\u0633\u0627\u0647\u0645\u064a \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0627\u0644\u0643\u064a\u0646 \u0644\u0644\u0627\u0654\u0633\u0647\u0645 \u064a\u0648\u0645 \u0627\u0646\u0639\u0642\u0627\u062f \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0648\u0627\u0644\u0645\u0642\u064a\u062f\u064a\u0646 \u0641\u064a \u0633\u062c\u0644 \u0645\u0633\u0627\u0647\u0645\u064a \u0627\u0644\u0634\u0631\u0643\u0629 \u0644\u062f\u0649 \u0645\u0631\u0643\u0632 \u0627\u0655\u064a\u062f\u0627\u0639 \u0627\u0644\u0627\u0654\u0648\u0631\u0627\u0642 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 (\u0627\u0655\u064a\u062f\u0627\u0639) \u0641\u064a \u0646\u0647\u0627\u064a\u0629 \u062b\u0627\u0646\u064a \u064a\u0648\u0645 \u062a\u062f\u0627\u0648\u0644 \u064a\u0644\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0646\u0639\u0642\u0627\u062f \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629\u060c \u0648\u0627\u0644\u0630\u064a \u0633\u064a\u062a\u0645 \u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0646 \u0639\u0646\u0647 \u0644\u0627\u062d\u0642\u0627\u064b \u0628\u0639\u062f \u0627\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0627\u0641\u0642\u0627\u062a \u0627\u0644\u0644\u0627\u0632\u0645\u0629 \u0645\u0646 \u0627\u0644\u062c\u0647\u0627\u062a \u0630\u0627\u062a \u0627\u0644\u0639\u0644\u0627\u0642\u0629.\u0648\u0646\u0648\u0647\u062a \u0628\u062a\u062d\u062f\u064a\u062f \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062a\u0648\u0632\u064a\u0639 \u0644\u0627\u062d\u0642\u0627\u064b \u0628\u0639\u062f \u0645\u0648\u0627\u0641\u0642\u0629 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0639\u0644\u0649 \u062a\u0648\u0635\u064a\u0629 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0628\u062a\u0648\u0632\u064a\u0639 \u0627\u0644\u0