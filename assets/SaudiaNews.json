8%A3%D9%84%D9%81-%D9%85%D8%AA%D8%B1\"> \u0628\u0631\u0643\u0627\u0646 \u062c\u0628\u0644 \u0633\u064a\u0645\u064a\u0631\u0648</a> \u0641\u064a \u0627\u0655\u0642\u0644\u064a\u0645 <a href=\"https://www.alyaum.com/articles/6628736/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A5%D8%AC%D9%84%D8%A7%D8%A1-%D8%A7%D9%84%D9%85%D8%A6%D8%A7%D8%AA-%D9%81%D9%8A-%D8%A5%D9%86%D8%AF%D9%88%D9%86%D9%8A%D8%B3%D9%8A%D8%A7-%D8%AC%D8%B1%D8%A7%D8%A1-%D8%AB%D9%88%D8%B1%D8%A7%D9%86-%D8%A8%D8%B1%D9%83%D8%A7%D9%86-%D8%B3%D9%8A%D9%85%D9%8A%D8%B1%D9%88-%D8%A8%D8%AC%D8%B2%D9%8A%D8%B1%D8%A9-%D8%AC%D8%A7%D9%88%D8%A9\">\u062c\u0627\u0648\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629</a> \u062a\u0633\u0639 \u0645\u0631\u0627\u062a \u0627\u0654\u0645\u0633 \u0627\u0644\u0633\u0628\u062a\u060c \u0648\u0646\u0641\u062b \u0627\u0654\u0639\u0645\u062f\u0629 \u0627\u0644\u0631\u0645\u0627\u062f \u0644\u0645\u0627 \u064a\u0635\u0644 \u0627\u0655\u0644\u0649 \u0627\u0654\u0644\u0641 \u0645\u062a\u0631 \u0641\u0648\u0642 \u0642\u0645\u062a\u0647.<br /><br />\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0648\u0643\u0627\u0644\u0629 \u0627\u0644\u0627\u0654\u0646\u0628\u0627\u0621 \u0627\u0644\u0627\u0655\u0646\u062f\u0648\u0646\u064a\u0633\u064a\u0629 (\u0627\u0654\u0646\u062a\u0627\u0631\u0627) \u0627\u0654\u0646 \u0627\u0644\u0633\u0644\u0637\u0627\u062a \u0627\u0654\u0628\u0642\u062a \u0639\u0644\u0649 \u0648\u0636\u0639 \u0627\u0644\u062a\u062d\u0630\u064a\u0631 \u0648\u062d\u062b\u062a \u0627\u0644\u0633\u0643\u0627\u0646 \u0639\u0644\u0649 \u062a\u062c\u0646\u0628 \u0627\u0644\u0645\u0646\u0627\u0637\u0642 \u0634\u062f\u064a\u062f\u0629 \u0627\u0644\u062e\u0637\u0648\u0631\u0629.<br /> <h2>\u0628\u0631\u0643\u0627\u0646 \u062c\u0628\u0644 \u0633\u064a\u0645\u064a\u0631\u0648</h2>\u0648\u0633\u064f\u062c\u0644 \u0627\u0654\u0648\u0644 \u062b\u0648\u0631\u0627\u0646 \u0644\u0644\u0628\u0631\u0643\u0627\u0646 \u0627\u0644\u0628\u0627\u0644\u063a \u0627\u0631\u062a\