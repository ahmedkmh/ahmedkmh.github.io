\u064f\u0654\u062c\u0631\u064a \u0644\u0644\u0627\u0639\u0628 \u0641\u064a \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u0649 \u0628\u0639\u062f \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0654\u0646\u0647 \u064a\u064f\u0639\u0627\u0646\u064a \u0645\u0646 \u0643\u0633\u0631 \u0641\u064a \u0627\u0644\u0633\u0627\u0639\u062f \u0627\u0644\u0627\u0654\u064a\u0645\u0646. \u0648\u0642\u062f \u062a\u0645 \u0648\u0636\u0639 \u062c\u0628\u064a\u0631\u0629 \u0644\u0647\".<br /><br />\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0644\u0646\u0627\u062f\u064a \u0627\u0644\u062a\u0631\u0643\u064a \u0627\u0654\u0646\u0647 \"\u0633\u064a\u064f\u062a\u062e\u0630 \u0642\u0631\u0627\u0631 \u0627\u0655\u062e\u0636\u0627\u0639\u0647 \u0644\u0639\u0645\u0644\u064a\u0629 \u062c\u0631\u0627\u062d\u064a\u0629 \u0641\u064a \u0627\u0644\u0627\u0654\u064a\u0627\u0645 \u0627\u0644\u0645\u0642\u0628\u0644\u0629 \u0628\u0639\u062f \u0627\u0655\u062c\u0631\u0627\u064a\u0654\u0647 \u0627\u0644\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0641\u062d\u0648\u0635\u0627\u062a\"\u060c \u0645\u0646 \u062f\u0648\u0646 \u0627\u0654\u0646 \u064a\u064f\u062d\u062f\u0651\u062f \u0645\u062f\u0629 \u063a\u064a\u0627\u0628 \u0646\u062c\u0645\u0647 \u0627\u0644\u0630\u064a \u0633\u062c\u0644 \u0633\u0628\u0639\u0629 \u0627\u0654\u0647\u062f\u0627\u0641 \u0641\u064a \u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0654\u0628\u0637\u0627\u0644 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0633\u0645.<br /><br />\u0648\u062f\u062e\u0644 \u0627\u0644\u062c\u0646\u0627\u062d \u0627\u0644\u062f\u0648\u0644\u064a \u0627\u0644\u0647\u0648\u0644\u0646\u062f\u064a \u0646\u0648\u0627 \u0644\u0627\u0646\u063a \u0628\u062f\u0644\u0627 \u0645\u0646 \u0627\u0654\u0648\u0633\u064a\u0645\u0646 (27 \u0639\u0627\u0645\u0627) \u0645\u0639 \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u062b\u0627\u0646\u064a\u060c \u0644\u0643\u0646\u0647 \u0627\u0636\u0637\u0631 \u0628\u062f\u0648\u0631\u0647 