7\u0631\u0648\u062d\u0629 \u0644\u0644\u0645\u0636\u064a \u0642\u062f\u0645\u0627\u064b.\u0648\u0639\u0642\u0628 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u060c \u0642\u0627\u0644 \u0645\u0633\u0648\u0654\u0648\u0644 \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u060c \u0627\u0655\u0646 \u0627\u0655\u062f\u0627\u0631\u0629 \u062a\u0631\u0645\u0628 \u0644\u0627 \u062a\u0632\u0627\u0644 \u0645\u0644\u062a\u0632\u0645\u0629 \u0628\u0627\u0655\u064a\u062c\u0627\u062f \u062d\u0644\u060c \u0648\u0627\u0655\u0646 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0641\u0646\u064a \u0645\u0633\u062a\u0645\u0631\u0629 \u0628\u0647\u062f\u0641 \u0627\u0644\u062a\u0648\u0635\u0644 \u0627\u0655\u0644\u0649 \u0627\u062a\u0641\u0627\u0642 \u0646\u0648\u0648\u064a.\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u062a\u0631\u0645\u0628 \u0627\u0654\u0648\u0636\u062d \u0645\u0648\u0642\u0641\u0647 \u0628\u0634\u0643\u0644 \u0644\u0627 \u0644\u0628\u0633 \u0641\u064a\u0647. \u0627\u0654\u0646 \u0627\u0644\u0647\u062c\u0645\u0627\u062a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0633\u0641\u0646 \u0627\u0644\u0645\u062f\u0646\u064a\u0629 \u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0655\u0631\u0647\u0627\u0628\u064a\u0629. \u0648\u0645\u0630\u0643\u0631\u0629 \u0627\u0644\u062a\u0641\u0627\u0647\u0645 \u062a\u0633\u062a\u0646\u062f \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0654\u062f\u0627\u0621\u060c \u0648\u0645\u0627 \u0642\u0627\u0645\u062a \u0628\u0647 \u0627\u0655\u064a\u0631\u0627\u0646 \u064a\u0645\u062b\u0644 \u0627\u0655\u062e\u0641\u0627\u0642\u0627\u064b \u0641\u064a \u062a\u0646\u0641\u064a\u0630 \u0627\u0644\u062a\u0632\u0627\u0645\u0627\u062a\u0647\u0627 \u0627\u0655\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u063a\u064a\u0631 \u0645\u0642\u0628\u0648\u0644.\u0648\