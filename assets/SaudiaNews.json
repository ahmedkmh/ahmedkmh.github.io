2\u0631\u0627\u0631\u0627\u062a \u062a\u062e\u0641\u064a\u0636 \u0627\u0644\u063a\u0631\u0627\u0645\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0641\u0631\u0648\u0636\u0629 \u0639\u0644\u0649 \u0627\u0644\u062c\u0627\u0645\u0639\u0629 \u0627\u0644\u0645\u0644\u0643\u064a\u0629 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629 \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645\u060c \u0648\u0627\u0644\u0645\u062a\u0639\u0644\u0642\u0629 \u0628\u062d\u0627\u062f\u062b\u0629 \u062c\u0627\u0645\u0639\u064a \u0627\u0644\u0643\u0631\u0627\u062a \u0644\u062a\u0635\u0628\u062d 50 \u0627\u0654\u0644\u0641 \u062f\u0648\u0644\u0627\u0631\u064d\u060c \u0648\u062a\u0642\u0644\u064a\u0644 \u063a\u0631\u0627\u0645\u0629 \u062d\u0627\u062f\u062b\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u0634\u062c\u0639\u064a\u0646 \u0644\u0627\u0654\u0642\u0644\u0627\u0645 \u0627\u0644\u0644\u064a\u0632\u0631 \u0627\u0655\u0644\u0649 \u0639\u0634\u0631\u0629 \u0627\u0653\u0644\u0627\u0641 \u062f\u0648\u0644\u0627\u0631.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0646\u063a\u0627\u0644", "\u0627\u0644\u0645\u063a\u0631\u0628", "\u0643\u0623\u0633 \u0627\u0644\u0623\u0645\u0645 \u0627\u0644\u0625\u0641\u0631\u064a\u0642\u064a\u0629"], "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-03-17 22:03:47", "pubDateTZ": "UTC", "fetched_at": "2026-03-17 22:42:04", "image_url": "https://arriyadiyah.com/media/thumb/5b/d3/800_d840ece504.png", "video_url": null, "source_id": "arriyadiyah", "source_name": "\u0627\u0644\u0631\u064a\u0627\u062f\u064a\u0629", "source_priority": 1120412, "source_url": "https://arriyadiyah.com", "source_icon": "https://n.bytvi.com/arriyadiyah.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "4bdffc7733395b1868eaead5cb180ea0", "link": "https://www.okaz.com.sa/sport/na/2240556", "title": "\u0634\u0645\u0633 \u0627\u0654\u0641\u0631\u064a\u0642\u064a\u0627 \u062a\u0634\u0631\u0642 \u0645\u0646 \u0627\u0644\u0645\u063a\u0631\u0628", "description": "\u0641\u0627\u062c\u0627\u0654 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0627\u0655\u0641\u0631\u064a\u0642\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u0627\u0644\u0639\u0627\u0644\u0645 \u0628\u0642\u0631\u0627\u0631 \u062a\u0627\u0631\u064a\u062e\u064a\u060c \u062a\u0645\u062b\u0644 \u0641\u064a \u0633\u062d\u0628 \u0644\u0642\u0628 \u0628\u0637\u0648\u0644\u0629 \u0643\u0627\u0654\u0633 \u0627\u0654\u0645\u0645 \u0627\u0654\u0641\u0631\u064a\u0642\u064a\u0627 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0645\u0646 \u0627\u0644\u0628\u0637\u0644 \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0646\u063a\u0627\u0644 \u0648\u0627\u0639\u062a\u0628\u0627\u0631\u0647 \u062e\u0627\u0633\u0631\u0627 \u0641\u064a \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0627\u0654\u0645\u0627\u0645 \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0645\u063a\u0631\u0628 \u0628\u0646\u062a\u064a\u062c\u0629 (3-0).\u200f\u0648\u0627\u0639\u062a\u0645\u062f\u062a \u0644\u062c\u0646\u0629 \u0627\u0644\u0627\u0633\u062a\u064a\u0654\u0646\u0627\u0641 \u0641\u064a \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0627\u0655\u0641\u0631\u064a\u0642\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u062e\u0633\u0627\u0631\u0629 \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0646\u063a\u0627\u0644 \u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0643\u0627\u0654\u0633 \u0627\u0654\u0645\u0645 \u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0627 2025 \u0641\u064a \u0627\u0644\u0645\u063a\u0631\u0628\u060c \u0648\u062c\u0627\u0621 \u0627\u0644\u0642\u0631\u0627\u0631 \u0628\u0639\u062f \u0642\u0628\u0648\u0644 \u0627\u0633\u062a\u064a\u0654\u0646\u0627\u0641 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u060c \u0648\u0627\u0655\u0644\u063a\u0627\u0621 \u0642\u0631\u0627\u0631 \u0627\u0644\u0644\u062c\u0646\u0629 \u0627\u0644\u062a\u0627\u0654\u062f\u064a\u0628\u064a\u0629\u060c \u0645\u0639 \u062a\u0627\u0654\u0643\u064a\u062f \u0627\u0654\u0646 \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0646\u063a\u0627\u0644 \u062e\u0627\u0644\u0641 \u0644\u0648\u0627\u064a\u0654\u062d \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0648\u0641\u0642 \u0627\u0644\u0645\u0627\u062f\u062a\u064a\u0646 82 \u064884. \u200f \u0627\u0644\u0642\u0631\u0627\u0631\u0627\u062a:\u2022 \u0627\u0655\u064a\u0642\u0627\u0641 \u0644\u0627\u0639\u0628 \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0655\u0633\u0645\u0627\u0639\u064a\u0644 \u0635\u064a\u0628\u0627\u0631\u064a \u0645\u0628\u0627\u0631\u0627\u062a\u064a\u0646 (\u0648\u0627\u062d\u062f\u0629 \u0645\u0646\u0647\u0627 \u0645\u0639 \u0627\u0655\u064a\u0642\u0627\u0641 \u0627\u0644\u062a\u0646\u0641\u064a\u0630). \u200f\u2022 \u0627\u0655\u0644\u063a\u0627\u0621 \u0627\u0644\u063a\u0631\u0627\u0645\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0639\u0644\u064a\u0647 (100 \u0627\u0654\u0644\u0641 \u062f\u0648\u0644\u0627\u0631). \u200f\u2022 \u062a\u062e\u0641\u064a\u0636 \u063a\u0631\u0627\u0645\u0629 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u0641\u064a \u0642\u0636\u064a\u0629 \u00ab\u062c\u0627\u0645\u0639\u064a \u0627\u0644\u0643\u0631\u0627\u062a\u00bb \u0627\u0655\u0644\u0649 50 \u0627\u0654\u0644\u0641 \u062f\u0648\u0644\u0627\u0631. \u200f\u2022 \u062a\u062b\u0628\u064a\u062a \u063a\u0631\u0627\u0645\u0629 100 \u0627\u0654\u0644\u0641 \u062f\u0648\u0644\u0627\u0631 \u0628\u0633\u0628\u0628 \u0627\u0644\u062a\u062f\u062e\u0644 \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u062a\u0642\u0646\u064a\u0629 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 (VAR). \u200f\u2022 \u062a\u062e\u0641\u064a\u0636 \u063a\u0631\u0627\u0645\u0629 \u00ab\u062d\u0627\u062f\u062b\u0629 \u0627\u0644\u0644\u064a\u0632\u0631\u00bb \u0627\u0655\u0644\u0649 10 \u0627\u0653\u0644\u0627\u0641 \u062f\u0648\u0644\u0627\u0631.\u0648\u064a\u0639\u062a\u0628\u0631 \u0647\u0630\u0627 \u0627\u0644\u0642\u0631\u0627\u0631 \u0647\u0648 \u0627\u0644\u0627\u0654\u0648\u0644 \u062a\u0627\u0631\u064a\u062e\u064a\u0627\u064b \u0641\u064a \u0633\u062d\u0628 \u0628\u0637\u0648\u0644\u0629 \u0642\u0627\u0631\u064a\u0629 \u0645\u0646 \u0645\u0646\u062a\u062e\u0628 \u0628\u0639\u062f \u062a\u062d\u0642\u064a\u0642\u0647\u0627\u060c \u0641\u064a \u062d\u0627\u062f\u062b\u0629 \u0641\u0631\u064a\u062f\u0629 \u0644\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0627\u0654\u0641\u0631\u064a\u0642\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0627\u0644\u0645\u063a\u0631\u0628", "\u0645\u0646", "\u0634\u0645\u0633", "\u062a\u0634\u0631\u0642", "\u0623\u0641\u0631\u064a\u0642\u064a\u0627"], "creator": ["\u0639\u0645\u0631 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 (\u062c\u062f\u0629)"], "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-03-17 22:03:25", "pubDateTZ": "UTC", "fetched_at": "2026-03-17 22:37:17", "image_url": "https://www.okaz.com.sa/okaz/uploads/images/2026/03/18/2678889.webp", "video_url": null, "source_id": "okaz", "source_name": "\u0635\u062d\u064a\u0641\u0629 \u0639\u0643\u0627\u0638", "source_priority": 124260, "source_url": "https://www.okaz.com.sa", "source_icon": "https://n.bytvi.com/okaz.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE 