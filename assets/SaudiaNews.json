u0627\u0644\u0631\u062d\u0645\u0646 \u0627\u0654\u0628\u0648 \u0631\u0634\u064a\u062f \u0648\u0641\u0631\u064a\u062f \u0627\u0644\u0645\u0639\u064a\u062f\u064a \u0648 \u0627\u0644\u0633\u0628\u064a\u0639\u064a \u0648\u0627\u0644\u0628\u064a\u0634\u064a \u0648\u0627\u0644\u0641\u0631\u062d\u0627\u0646 \u0648\u0627\u0644\u0642\u0627\u064a\u0654\u0645\u0629 \u062a\u0637\u0648\u0644 .@ \u0648\u0641\u064a \u0627\u0644\u0639\u0647\u062f \u0627\u0644\u062c\u062f\u064a\u062f \u0644\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0627\u0644\u0630\u064a \u0627\u0654\u0635\u0628\u062d \u0639\u0627\u0644\u0645\u064a\u0627 \u062a\u0637\u0644 \u0645\u0646 \u062c\u062f\u064a\u062f \u0642\u0627\u062f\u0633\u064a\u0629 \u0627\u0654\u0631\u0627\u0645\u0643\u0648 \u0641\u064a \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0644\u062a\u0643\u0648\u0646 \u0627\u0654\u062d\u062f \u0627\u0654\u0636\u0644\u0627\u0639 \u0633\u0628\u0627\u0642 \u0627\u0644\u0645\u0642\u062f\u0645\u0629 \u0641\u064a \u0627\u0644\u0641\u0648\u0632 \u0628\u0644\u0642\u0628 \u0631\u0648\u0634\u0646 .@ ( \u0627\u0653\u0647 ) .. \u062c\u0645\u0644\u0629 \u064a\u0643\u0631\u0631\u0647\u0627 \u0643\u0644 \u0642\u062f\u0633\u0627\u0648\u064a \u0644\u0648 \u0643\u0627\u0646 \u0645\u0639\u0646\u0627 ( \u0631\u0648\u062f \u0631\u0648\u062c\u0631\u0632 ) \u0645\u0646\u0630 \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u0645\u0648\u0633\u0645 \u0644\u0645\u0627 \u062e\u0631\u062c\u0646\u0627 \u0645\u0646 \u0627\u0644\u0643\u0627\u0654\u0633 \u0648\u0644\u0643\u0627\u0646 \u0648\u0636\u0639\u0646\u0627 \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0654\u0641\u0636\u0644 \u0648\u0627\u0654\u062d\u0633\u0646 \u060c \u0648\u0645\u0639 \u0647\u0630\u0627 \u0644\u0645 \u064a\u0631\u0641\u0639\u0648\u0627 \u0627\u0644\u0645\u0646\u062f\u064a\u0644 \u0627\u0644\u0627\u0654\u0628\u064a\u0636 \u060c \u0648\u064a\u0635\u0631\u0648\u0646 \u0627\u0654\u0646 \u062a\u0643\u0648\u0646 \u0643\u0644\u0645\u062a\u0647\u0645 \u0645\u0633\u0645\u0648\u0639\u0629 \u062d\u062a\u0649 \u0627\u0644\u0631\u0645\u0642 \u0627\u0644\u0627\u0654\u062e\u064a\u0631 \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a .@ \u0642\u0627\u062f\u0633\u064a\u0629 \u0627\u0654\u0631\u0627\u0645\u0643\u0648 \u0645\u0639 \u0627\u0644\u0643\u0628\u0627\u0631 \u0644\u0627 \u064a\u062e\u0633\u0631\u0648\u0646 \u0641\u0627\u0632\u0648\u0627 \u0639\u0644\u0649 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0648\u0627\u0644\u0646\u0635\u0631 \u0648 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0648\u062a\u0639\u0627\u062f\u0644\u0648\u0627 \u0645\u0639 \u0627\u0644\u0647\u0644\u0627\u0644 \u060c \u0648\u0627\u0644\u0642\u0627\u062f\u0645 \u0641\u064a \u0627\u0654\u062c\u0646\u062f\u062a\u0647\u0645 \u0627\u0654\u062c\u0645\u0644 .@ \u0641\u064a \u0633\u0628\u0627\u0642 \u0627\u0644\u062f\u0648\u0631\u064a \u063a\u064a\u0631\u0648\u0627 \u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u0645\u0642\u062f\u0645\u0629 \u060c \u0648\u062c\u0639\u0644\u0648\u0627 \u0627\u0644\u0645\u0646\u0627\u0641\u0633\u0629 \u0627\u0654\u0643\u062b\u0631 \u0634\u0631\u0627\u0633\u0629 \u060c \u0648\u0639\u0627\u0647\u062f\u0648\u0627 \u062c\u0645\u0627\u0647\u064a\u0631\u0647\u0645 \u0628\u0627\u0654\u0646 \u0627\u0644\u062e\u0633\u0627\u0631\u0629 \u0645\u0639 \u0631\u0648\u062c\u0631\u0632 \u0644\u0646 \u062a\u062d\u062f\u062b .. \u0647\u0643\u0630\u0627 \u0642\u0627\u0644\u0648\u0627 \u0648\u062a\u0631\u062c\u0645\u0648\u0627 \u0645\u0642\u0648\u0644\u062a\u0647\u0645 \u0644\u0641\u0639\u0644 .@ \u0628\u0639\u062f \u0627\u0654\u0646 \u062a\u062e\u0644\u0641\u0648\u0627 \u0628\u0647\u062f\u0641\u064a\u0646 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0641\u064a \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u0627\u0654\u0648\u0644 \u060c \u0642\u0644\u0628\u0648\u0627 \u0627\u0644\u0637\u0627\u0648\u0644\u0629 \u0641\u064a \u0627\u0644\u0634\u0648\u0637 \u0627\u0644\u062b\u0627\u0646\u064a \