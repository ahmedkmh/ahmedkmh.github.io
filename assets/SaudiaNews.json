7%D9%84%D9%81%D8%B7%D8%B1-%D9%81%D9%8A-%D8%AD%D9%81%D8%B1-%D8%A7%D9%84%D8%A8%D8%A7%D8%B7%D9%86\" target=\"_blank\">\u0635\u0644\u0627\u0629 \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631</a> \u0627\u0644\u0645\u0628\u0627\u0631\u0643 \u0644\u0639\u0627\u0645 1447\u0647\u0640\u060c \u0641\u064a \u0645\u0634\u0647\u062f \u0639\u0645\u0651\u0647 \u0627\u0644\u0641\u0631\u062d \u0648\u0627\u0644\u0633\u0631\u0648\u0631 \u0628\u062d\u0644\u0648\u0644 \u0627\u0644\u0639\u064a\u062f\u060c \u0648\u062a\u0631\u062f\u062f\u062a \u062e\u0644\u0627\u0644\u0647 \u062a\u0643\u0628\u064a\u0631\u0627\u062a \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631.<br /><br />\u0648\u0627\u0645\u062a\u0644\u0627\u0654\u062a \u0627\u0644\u062c\u0648\u0627\u0645\u0639 \u0648\u0627\u0644\u0633\u0627\u062d\u0627\u062a \u0627\u0644\u062a\u0627\u0628\u0639\u0629 \u0644\u0647\u0627 \u0628\u0627\u0644\u0645\u0635\u0644\u064a\u0646 \u0645\u0646 \u0645\u062e\u062a\u0644\u0641 \u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0631\u060c \u0627\u0644\u0630\u064a\u0646 \u062a\u0648\u0627\u0641\u062f\u0648\u0627 \u0645\u0646\u0630 \u0648\u0642\u062a \u0645\u0628\u0643\u0631 \u0627\u0628\u062a\u0647\u0627\u062c\u064b\u0627 \u0628\u062d\u0644\u0648\u0644 \u0627\u0644\u0639\u064a\u062f\u060c \u0648\u062d\u0631\u0635\u064b\u0627 \u0639\u0644\u0649 \u0627\u0654\u062f\u0627\u0621 \u0627\u0644\u0635\u0644\u0627\u0629 \u062c\u0645\u0627\u0639\u0629 \u0627\u0642\u062a\u062f\u0627\u0621\u064b \u0628\u0633\u0646\u0629 \u0627\u0644\u0646\u0628\u064a \u0635\u0644\u0649 \u0627\u0644\u0644\u0647 \u0639\u0644\u064a\u0647 \u0648\u0633\u0644\u0645.<br /> <h2>\u062a\u0646\u0638\u064a\u0645 \u0645\u062a\u0643\u0627\u0645\u0644</h2>\u0648\u0627\u064f\u0654\u0642\u064a\u0645\u062a \u0627\u0644\u0635\u0644\u0627\u0629 \u0628\u0639\u062f \u0634\u0631\u0648\u0642 \u0627\u0644\u0634\u0645\u0633 \u0628\u0646\u062d\u0648 15 \u062f\u0642\u064a\u0642\u0629\u060c \u0648\u0633\u0637 \u062a\u0646\u0638\u064a\u0645 \u0645\u062a\u0643\u0627\