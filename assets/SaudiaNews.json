D8%A9-93-%D8%A5%D9%84%D9%89-3648-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D8%B1%D9%8A%D8%A7%D9%84-%D9%81%D9%8A-2025", "title": "\u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0654\u0631\u0628\u0627\u062d \u00ab\u0637\u064a\u0628\u0629\u00bb 9.3% \u0627\u0655\u0644\u0649 364.8 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0641\u064a 2025", "description": "\u0627\u0631\u062a\u0641\u0639\u062a \u0627\u0654\u0631\u0628\u0627\u062d \u0634\u0631\u0643\u0629 \u0637\u064a\u0628\u0629 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0641\u064a \u0639\u0627\u0645 2025 \u0628\u0646\u0633\u0628\u0629 9.3% \u0627\u0655\u0644\u0649 364.8 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0645\u0642\u0627\u0628\u0644 333.7 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0641\u064a 2024.\u0648\u0628\u062d\u0633\u0628 \u0628\u064a\u0627\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\"\u060c \u064a\u0639\u0632\u0649 \u0647\u0630\u0627 \u0627\u0644\u0627\u0631\u062a\u0641\u0627\u0639 \u0628\u0634\u0643\u0644 \u0631\u064a\u0654\u064a\u0633\u064a \u0627\u0655\u0644\u0649 \u062a\u062d\u0633\u0646 \u0627\u0644\u0627\u0654\u062f\u0627\u0621 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u060c \u0648\u0631\u062f\u0651 \u0645\u062e\u0635\u0635 \u0627\u0644\u0642\u0636\u0627\u064a\u0627 \u0627\u0644\u0630\u064a \u062a\u0645 \u062a\u0643\u0648\u064a\u0646\u0647 \u0641\u064a \u0639\u0627\u0645 2023\u0645 \u0627\u0644\u062e\u0627\u0635 \u0628\u0627\u0655\u0646\u0647\u0627\u0621 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0627\u0644\u062a\u0639\u0627\u0642\u062f\u064a\u0629 \u0645\u0639 \u0627\u0654\u062d\u062f \u0627\u0644\u0645\u0634\u063a\u0644\u064a\u0646 \u0646\u0638\u0631\u0627\u064b \u0644\u0644\u0648\u0635\u0648\u0644 \u0627\u0655\u0644\u0649 \u062a\u0633\u0648\u064a\u0629 \u0628\u064a\u0646 \u0627\u0644\u0637\u0631\u0641\u064a\u0646 \u0648\u0627\u0646\u062a\u0641\u0627\u0621 \u0627\u0644\u063a\u0631\u0636 \u0645\u0646\u0647\u060c \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0654\u0631\u0628\u0627\u062d \u0627\u0644\u0631\u0627\u0654\u0633\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u062d\u0642\u0642\u0629 \u0645\u0646 \u0646\u0632\u0639 \u0645\u0644\u0643\u064a\u0629 \u0627\u0654\u062d\u062f \u0639\u0642\u0627\u0631\u0627\u062a \u0627\u0644\u0634\u0631\u0643\u0629 \u0628\u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629.\u0632\u064a\u0627\u062f\u0629 \u0631\u0627\u0654\u0633 \u0627\u0644\u0645\u0627\u0644\u0627\u0654\u0648\u0635\u0649 \u0645\u062c\u0644\u0633 \u0627\u0655\u062f\u0627\u0631\u0629 \u0634\u0631\u0643\u0629 \u0637\u064a\u0628\u0629 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u060c \u0627\u0654\u0645\u0633\u060c \u0644\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u063a\u064a\u0631 \u0627\u0644\u0639\u0627\u062f\u064a\u0629 \u0644\u0644\u0634\u0631\u0643\u0629 \u0628\u0632\u064a\u0627\u062f\u0629 \u0631\u0627\u0654\u0633 \u0627\u0644\u0645\u0627\u0644 \u0639\u0646 \u0637\u0631\u064a\u0642 \u0645\u0646\u062d \u0627\u0654\u0633\u0647\u0645 \u0645\u062c\u0627\u0646\u064a\u0629 \u0644\u0645\u0633\u0627\u0647\u0645\u064a \u0627\u0644\u0634\u0631\u0643\u0629 \u0648\u0630\u0644\u0643 \u0628\u0645\u0646\u062d 0.9197 \u0633\u0647\u0645 \u0644\u0643\u0644 ( 1 ) \u0633\u0647\u0645.\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0654\u0646 \u0631\u0627\u0654\u0633 \u0627\u0644\u0645\u0627\u0644 \u0642\u0628\u0644 \u0627\u0644\u0632\u064a\u0627\u062f\u0629 2,604,574,830\u060c \u0641\u064a\u0645\u0627 \u0633\u064a\u0643\u0648\u0646 \u0628\u0639\u062f \u0627\u0644\u0632\u064a\u0627\u062f\u0629 5 \u0645\u0644\u064a\u0627\u0631\u0627\u062a \u0631\u064a\u0627\u0644 \u0628\u0632\u064a\u0627\u062f\u0629 \u0646\u0633\u0628\u062a\u0647\u0627 91.97%.\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0628\u0627\u0654\u0646 \u0639\u062f\u062f \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0642\u0628\u0644 \u0627\u0644\u0632\u064a\u0627\u062f\u0629 260457483\u060c \u0641\u064a\u0645\u0627 \u064a\u0635\u0628\u062d \u0628\u0639\u062f \u0627\u0644\u0632\u064a\u0627\u062f\u0629 500 \u0645\u0644\u064a\u0648\u0646 \u0633\u0647\u0645.\u0648\u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0632\u064a\u0627\u062f\u0629 \u0631\u0627\u0654\u0633 \u0627\u0644\u0645\u0627\u0644: \u0644\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0647\u064a\u0643\u0644 \u0627\u0644\u0631\u0627\u0654\u0633\u0645\u0627\u0644\u064a \u0644\u0644\u0634\u0631\u0643\u0629 \u0648\u0644\u062f\u0639\u0645 \u0645\u062a\u0637\u0644\u0628\u0627\u062a \u0627\u0644\u0646\u0645\u0648 \u0648\u0627\u0644\u062a\u0648\u0633\u0639 \u0644\u0644\u062a\u0648\u062c\u0647 \u0627\u0644\u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a \u0644\u0644\u0634\u0631\u0643\u0629 \u0648\u0644\u062a\u0627\u0654\u0643\u064a\u062f \u0642\u0648\u0629 \u0648\u0645\u062a\u0627\u0646\u0629 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0627\u0644\u064a \u0644\u0644\u0634\u0631\u0643\u0629.\u0648\u0646\u0648\u0647\u062a \u0628\u0627\u0644\u0632\u064a\u0627\u062f\u0629 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0631\u0633\u0645\u0644\u0629 \u0645\u0628\u0644\u063a \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644 \u0645\u0646 \u0631\u0635\u064a\u062f \u0627\u0644\u0627\u0655\u062d\u062a\u064a\u0627\u0637\u064a \u0627\u0644\u0646\u0638\u0627\u0645\u064a \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0644\u0631\u0633\u0645\u0644\u0629 \u0645\u0628\u0644\u063a 1,395,425,170 \u0631\u064a\u0627\u0644 \u0645\u0646 \u0631\u0635\u064a\u062f \u0639\u0644\u0627\u0648\u0629 \u0627\u0644\u0627\u0655\u0635\u062f\u0627\u0631 \u060c \u0644\u064a\u0643\u0648\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0645\u0628\u0627\u0644\u063a \u0627\u0644\u062a\u064a \u0633\u064a\u062a\u0645 \u0631\u0633\u0645\u0644\u062a\u0647\u0627 2,395,425,170 \u0631\u064a\u0627\u0644.\u0648\u0633\u062a\u0643\u0648\u0646 \u0627\u0644\u0627\u0654\u062d\u0642\u064a\u0629 \u0644\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646 \u0627\u0644\u0645\u0627\u0644\u0643\u064a\u0646 \u0644\u0644\u0627\u0654\u0633\u0647\u0645 \u064a\u0648\u0645 \u0627\u0644\u0627\u0633\u062a\u062d\u0642\u0627\u0642 \u0627\u0644\u0645\u0642\u064a\u062f\u064a\u0646 \u0641\u064a \u0633\u062c\u0644 \u0645\u0633\u0627\u0647\u0645\u064a \u0627\u0644\u0645\u0635\u062f\u0631 \u0644\u062f\u0649 \u0645\u0631\u0643\u0632 \u0627\u0644\u0627\u0655\u064a\u062f\u0627\u0639 \u0641\u064a \u0646\u0647\u0627\u064a\u0629 \u062b\u0627\u0646\u064a \u064a\u0648\u0645 \u062a\u062f\u0627\u0648\u0644 \u064a\u0644\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0633\u062a\u062d\u0642\u0627\u0642.\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0628\u062a\u062c\u0645\u064a\u0639 \u0627\u0644\u0643\u0633\u0648\u0631 (\u0627\u0655\u0646 \u0648\u062c\u062f\u062a) \u0641\u064a \u0645\u062d\u0641\u0638\u0629 \u0648\u0627\u062d\u062f\u0629 \u0644\u062c\u0645\u064a\u0639 \u062d\u0645\u0644\u0629 \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0648\u062a\u0628\u0627\u0639 \u0628\u0633\u0639\u0631 \u0627\u0644\u0633\u0648\u0642 \u062b\u0645 \u062a\u0648\u0632\u0639 \u0642\u064a\u0645\u062a\u0647\u0627 \u0639\u0644\u0649 \u062d\u0645\u0644\u0629 \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0627\u0644\u0645\u0633\u062a\u062d\u0642\u064a\u0646 \u0644\u0644\u0645\u0646\u062d\u0629 \u0643\u0644 \u0628\u062d\u0633\u0628 \u062d\u0635\u062a\u0647 \u062e\u0644\u0627\u0644 \u0645\u062f\u0629 \u0644\u0627 \u062a\u062a\u062c\u0627\u0648\u0632 30 \u064a\u0648\u0645\u0627\u064b \u0645\u0646 \u062a\u0627\u0631\u064a\u062e \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0627\u0644\u0645\u0633\u062a\u062d\u0642\u0629 \u0644\u0643\u0644 \u0645\u0633\u0627\u0647\u0645.\u062a\u0648\u0632\u064a\u0639 \u0627\u0654\u0631\u0628\u0627\u062d\u0627\u0654\u0648\u0635\u0649 \u0645\u062c\u0644\u0633 \u0627\u0655\u062f\u0627\u0631\u0629 \u0634\u0631\u0643\u0629 \u0637\u064a\u0628\u0629 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0641\u064a \u0627\u062c\u062a\u0645\u0627\u0639\u0647 \u0627\u0644\u0645\u0646\u0639\u0642\u062f\u060c \u0627\u0654\u0645\u0633\u060c \u0644\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0628\u062a\u0648\u0632\u064a\u0639 \u0627\u0654\u0631\u0628\u0627\u062d \u0646\u0642\u062f\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646 \u0639\u0646 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0645\u0627\u0644\u064a 2025.\u0648\u0642\u0627\u0644\u062a \u0627\u0644\u0634\u0631\u0643\u0629: \u0627\u0655\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0645\u0628\u0644\u063a \u0627\u0644\u0645\u0648\u0632\u0639 \u064a\u0642\u062f\u0631 \u0628\u0640169.3 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0641\u064a\u0645\u0627 \u064a\u0628\u0644\u063a \u0639\u062f\u062f \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0627\u0644\u0645\u0633\u062a\u062d\u0642\u0629 \u0644\u0644\u0627\u0654\u0631\u0628\u0627\u062d 260,457,483 \u0633\u0647\u0645\u0627.\u0648\u0627\u0654\u0636\u0627\u0641\u062a \u0627\u0654\u0646 \u062d\u0635\u0629 \u0627\u0644\u0633\u0647\u0645 \u0645\u0646 \u0627\u0644\u062a\u0648\u0632\u064a\u0639 0.65 \u0631\u064a\u0627\u0644 \u0644\u0644\u0633\u0647\u0645 \u0627\u0644\u0648\u0627\u062d\u062f\u060c \u0641\u064a\u0645\u0627 \u062a\u0628\u0644\u063a \u0646\u0633\u0628\u0629 \u0627\u0644\u062a\u0648\u0632\u064a\u0639 \u0627\u0655\u0644\u0649 \u0642\u064a\u0645\u0629 \u0627\u0644\u0633\u0647\u0645 \u0627\u0644\u0627\u0633\u0645\u064a\u0629 6.5%.\u0648\u0633\u064a\u0643\u0648\u0646 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0627\u0654\u062d\u0642\u064a\u0629 \u0633\u062a\u0643\u0648\u0646 \u0644\u0644\u0645\u0633\u0627\u0647\u0645\u064a\u0646 \u0627\u0644\u0645\u0627\u0644\u0643\u064a\u0646 \u0644\u0644\u0627\u0654\u0633\u0647\u0645 \u064a\u0648\u0645 \u0627\u0646\u0639\u0642\u0627\u062f \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0648\u0627\u0644\u0645\u0642\u064a\u062f\u064a\u0646 \u0641\u064a \u0633\u062c\u0644 \u0645\u0633\u0627\u0647\u0645\u064a \u0627\u0644\u0634\u0631\u0643\u0629 \u0644\u062f\u0649 \u0645\u0631\u0643\u0632 \u0627\u0655\u064a\u062f\u0627\u0639 \u0627\u0644\u0627\u0654\u0648\u0631\u0627\u0642 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0628\u0646\u0647\u0627\u064a\u0629 \u062b\u0627\u0646\u064a \u064a\u0648\u0645 \u062a\u062f\u0627\u0648\u0644 \u064a\u0644\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0646\u0639\u0642\u0627\u062f \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0648\u0627\u0644\u0630\u064a \u0633\u064a\u0639\u0644\u0646 \u0639\u0646 \u0645\u0648\u0639\u062f\u0647\u0627 \u0644\u0627\u062d\u0642\u0627\u064b.\u0648\u0646\u0648\u0647\u062a \u0628\u0627\u0655\u0639\u0644\u0627\u0646 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u062a\u0648\u0632\u064a\u0639 \u0644\u0627\u062d\u0642\u0627\u060c \u0648\u0630\u0644\u0643 \u0628\u0639\u062f \u0645\u0648\u0627\u0641\u0642\u0629 \u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0639\u0644\u0649 \u062a\u0648\u0635\u064a\u0629 \u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": ["\u0627\u0644\u064a\u0648\u0645 - \u0627\u0644\u062f\u0645\u0627\u0645"], "language": "arabic", "country": ["saudi arabia"], "category": ["business"], "datatype": "news", "pubDate": "2026-03-02 09:40:00", "pubDateTZ": "UTC", "fetched_at": "2026-03-02 10:18:17", "image_url": "https://www.alyaum.com/uploads/images/2026/03/02/2866049.jpg", "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.a