4\u062e\u0645\u064a\u0633\u060c \u0636\u0645\u0646 \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u0640 26 \u0645\u0646 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u00ab\u062c\u0648\u0644\u0629 \u064a\u0648\u0645 \u0627\u0644\u0639\u0644\u0645\u00bb. \u0648\u0631\u062c\u0651\u062d\u062a \u0645\u0635\u0627\u062f\u0631 \u062e\u0627\u0635\u0629 \u0628\u0640 \u00ab\u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629\u00bb \u0628\u062f\u0621 \u0643\u0627\u064a\u0643\u064a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0639\u0644\u0649 \u0645\u0642\u0627\u0639\u062f \u0627\u0644\u0627\u062d\u062a\u064a\u0627\u0637\u060c \u0648\u0630\u0643\u0631\u062a \u0627\u0654\u0646 \u0627\u0644\u0645\u062f\u0631\u0628 \u0627\u0644\u0628\u0631\u0627\u0632\u064a\u0644\u064a \u0641\u0627\u0628\u064a\u0648 \u0643\u0627\u0631\u064a\u0644\u064a \u0633\u064a\u0643\u0634\u0641 \u0639\u0646 \u062a\u0634\u0643\u064a\u0644\u0647 \u0627\u0644\u0627\u0654\u0633\u0627\u0633\u064a \u0648\u0627\u0654\u0633\u0645\u0627\u0621 \u0627\u0644\u062a\u0633\u0639\u0629 \u0627\u0644\u0627\u062d\u062a\u064a\u0627\u0637\u064a\u064a\u0646 \u062e\u0644\u0627\u0644 \u0627\u062c\u062a\u0645\u0627\u0639\u064d \u0641\u0646\u064a \u0645\u0639 \u0627\u0644\u0644\u0627\u0639\u0628\u064a\u0646 \u0642\u0628\u0644 \u0635\u0627\u0641\u0631\u0629 \u0627\u0644\u0628\u062f\u0627\u064a\u0629 \u0628\u0639\u062f\u0651\u0629 \u0633\u0627\u0639\u0627\u062a. \u0648\u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0653\u0648\u0646\u0629 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629\u060c \u0627\u0642\u062a\u0635\u0631\u062a \u0645\u0634\u0627\u0631\u0643\u0629 \u0627\u0644\u0644\u0627\u0639\u0628\u060c \u0627\u0644\u0628\u0627\u0644\u063a \u0645\u0646 \u0627\u0644\u0639\u0645\u0631 21 \u0639\u0627\u0645\u064b\u0627\u060c \u0639\u0644\u0649 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0641\u0631\u064a\u0642 \u062a\u062d\u062a 21 \u0639\u0627\u0645\u064b\u0627 \u0636\u0645\u0646 \u062f\