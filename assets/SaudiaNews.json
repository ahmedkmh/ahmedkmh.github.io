%AD%D8%B3%D8%A7%D8%A1-%D9%88%D8%A7%D9%84%D8%B5%D9%85%D8%A7%D9%86-%D8%A7%D9%84%D8%A3%D8%B9%D9%84%D9%89-%D8%A8%D9%8A%D8%A7%D9%86-%D8%AF%D8%B1%D8%AC%D8%A7%D8%AA-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D8%A9-%D8%A7%D9%84%D8%B9%D8%B8%D9%85%D9%89-%D8%B9%D9%84%D9%89-%D8%A8%D8%B9%D8%B6-%D9%85%D8%AF%D9%86-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9\" target=\"_blank\">\u062f\u0631\u062c\u0627\u062a \u0627\u0644\u062d\u0631\u0627\u0631\u0629 \u0627\u0644\u0639\u0638\u0645\u0649</a> \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u062e\u0645\u064a\u0633\u060c \u0628\u064a\u0646\u0645\u0627 \u0633\u062c\u0644\u062a \u0627\u0644\u0627\u0654\u062d\u0633\u0627\u0621 \u0648\u062d\u0641\u0631 \u0627\u0644\u0628\u0627\u0637\u0646 \u0648\u0627\u0644\u0635\u0645\u0627\u0646 \u0627\u0654\u0639\u0644\u0649 \u062f\u0631\u062c\u0629 \u062d\u0631\u0627\u0631\u0629 \u0628\u0640 49 \u0645\u064a\u0654\u0648\u064a\u0629.<br />\u0648\u062c\u0627\u0621\u062a <a href=\"https://www.alyaum.com/articles/6672831/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B7%D9%82%D8%B3-%D8%A7%D9%84%D8%AB%D9%84%D8%A7%D8%AB%D8%A7%D8%A1-%D8%A7%D8%B3%D8%AA%D9%85%D8%B1%D8%A7%D8%B1-%D8%A7%D8%B1%D8%AA%D9%81%D8%A7%D8%B9-%D8%AF%D8%B1%D8%AC%D8%A7%D8%AA-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D8%A9-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D9%88%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6\" target=\"_blank\">\u062f\u0631\u062c\u0627\u062a \u0627\u0644\u062d\u0631\u0627\u0631\u0629</a> \u0627\u0644\u0639\u0638\u0645\u0649 \u0643\u0627\u0644\u062a\u0627\u0644\u064a:<br />- \u0627\u0644\u062f\u0645\u0627\u0645 46 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629 42 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0646\u0648\u0631\u0629 46 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0644\u0631\u064a\u0627\u0636 46 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u062c\u062f\u0629 37 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0654\u0628\u0647\u0627 30 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u062d\u0627\u064a\u0654\u0644 42 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0628\u0631\u064a\u062f\u0629 46 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u062a\u0628\u0648\u0643 40 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0644\u0628\u0627\u062d\u0629 30 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0639\u0631\u0639\u0631 44 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0633\u0643\u0627\u0643\u0627 43 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u062c\u0627\u0632\u0627\u0646 38 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0646\u062c\u0631\u0627\u0646 40 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0644\u0637\u0627\u064a\u0654\u0641 36 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0644\u0639\u0644\u0627 44 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u064a\u0646\u0628\u0639 40 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0644\u062f\u0648\u0627\u062f\u0645\u064a 43 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0644\u062e\u0631\u062c 32 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0648\u0627\u062f\u064a \u0627\u0644\u062f\u0648\u0627\u0633\u0631 45 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0634\u0631\u0648\u0631\u0629 45 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629.<br />- \u0627\u0644\u0645\u062c\u0645\u0639\u0629 45 \u062f\u0631\u0