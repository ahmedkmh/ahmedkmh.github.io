{"status": "success", "totalResults": 3868, "results": [{"article_id": "8fb789647c726e6c5ca40c1ad8886a59", "link": "https://www.alyaum.com/articles/6671316/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D9%86%D8%AA%D9%87%D8%B2%D8%AA-%D8%AD%D8%B1%D8%A8-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%84%D8%AA%D8%B1%D8%A8%D8%AD-%D8%A7%D9%84%D9%85%D9%84%D9%8A%D8%A7%D8%B1%D8%A7%D8%AA-%D9%83%D9%88%D8%B1%D9%8A%D8%A7-%D8%AA%D9%84%D8%A7%D8%AD%D9%82-4-%D8%B4%D8%B1%D9%83%D8%A7%D8%AA-%D9%86%D9%81%D8%B7%D9%8A%D8%A9-%D9%83%D8%A8%D8%B1%D9%89", "title": "\u0627\u0646\u062a\u0647\u0632\u062a \u062d\u0631\u0628 \u0627\u0655\u064a\u0631\u0627\u0646 \u0644\u062a\u0631\u0628\u062d \u0627\u0644\u0645\u0644\u064a\u0627\u0631\u0627\u062a.. \u0643\u0648\u0631\u064a\u0627 \u062a\u0644\u0627\u062d\u0642 4 \u0634\u0631\u0643\u0627\u062a \u0646\u0641\u0637\u064a\u0629 \u0643\u0628\u0631\u0649", "description": "\u0648\u062c\u0647\u062a \u0627\u0644\u0646\u064a\u0627\u0628\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0641\u064a<a href=\"https://www.alyaum.com/articles/6669846/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D9%83%D9%88%D8%B1%D9%8A%D8%A7-%D8%AA%D8%B9%D9%84%D9%86-%D8%A7%D8%B3%D8%AA%D8%B1%D8%A7%D8%AA%D9%8A%D8%AC%D9%8A%D8%A9-%D8%A8-576-%D9%85%D9%84%D9%8A%D8%A7%D8%B1-%D8%AF%D9%88%D9%84%D8%A7%D8%B1-%D9%84%D9%84%D8%AA%D9%88%D8%B3%D8%B9-%D9%81%D9%8A-%D8%A7%D9%84%D8%B0%D9%83%D8%A7%D8%A1-%D8%A7%D9%84%D8%A7%D8%B5%D8%B7%D9%86%D8%A7%D8%B9%D9%8A\" target=\"_blank\"> \u0643\u0648\u0631\u064a\u0627 \u0627\u0644\u062c\u0646\u0648\u0628\u064a\u0629</a>\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0655\u062b\u0646\u064a\u0646\u060c \u0627\u062a\u0647\u0627\u0645\u0627\u062a \u0644\u0627\u0654\u0631\u0628\u0639 \u0634\u0631\u0643\u0627\u062a \u0646\u0641\u0637\u064a\u0629 \u0645\u062d\u0644\u064a\u0629 \u0643\u0628\u0631\u0649 \u0628\u0627\u0646\u062a\u0647\u0627\u0643 \u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u062a\u062c\u0627\u0631\u0629 \u0627\u0644\u0639\u0627\u062f\u0644\u0629\u060c \u0645\u0634\u064a\u0631\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u062a\u0644\u0643 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u062a\u0648\u0627\u0637\u0627\u0654\u062a \u0644\u0631\u0641\u0639 <a href=\"https://www.alyaum.com/articles/6670454/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A7%D9%84%D8%AA%D8%B6%D8%AE%D9%85-%D9%81%D9%8A-%D9%83%D9%88%D8%B1%D9%8A%D8%A7-%D9%8A%D8%B3%D8%AC%D9%84-%D8%A3%D8%B9%D9%84%D9%89-%D9%85%D8%B3%D8%AA%D9%88%D9%89-%D9%81%D9%8A-6-%D8%A3%D8%B4%D9%87%D8%B1-%D9%85%D8%AF%D9%81%D9%88%D8%B9%D8%A7-%D8%A8%D8%A3%D8%B3%D8%B9%D8%A7%D8%B1-%D8%A7%D9%84%D9%88%D9%82%D9%88%D8%AF\" target=\"_blank\">\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0648\u0642\u0648\u062f</a> \u0641\u064a \u0627\u0644\u0628\u0644\u0627\u062f \u0639\u0642\u0628 \u0627\u0646\u062f\u0644\u0627\u0639 \u0627\u0644\u062d\u0631\u0628 \u0628\u064a\u0646 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0648\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0648\u0627\u0655\u064a\u0631\u0627\u0646.<br /><br />\u0648\u0648\u0641\u0642\u064b\u0627 \u0644\u0648\u0643\u0627\u0644\u0629 \"\u064a\u0648\u0646\u0647\u0627\u0628\" \u0627\u0644\u0643\u0648\u0631\u064a\u0629 \u0627\u0644\u0631\u0633\u0645\u064a\u0629\u060c \u0627\u0646\u062a\u0647\u0643\u062a \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0627\u0654\u0631\u0628\u0639 \u0642\u0627\u0646\u0648\u0646 \u0627\u0644\u062a\u062c\u0627\u0631\u0629 \u0627\u0644\u0639\u0627\u062f\u0644\u0629 \u0641\u064a \u0627\u0644\u0628\u0644\u0627\u062f \u0647\u064a: \"\u0627\u0655\u062a\u0634 \u062f\u064a \u0647\u064a\u0648\u0646\u062f\u0627\u064a \u0627\u0654\u0648\u064a\u0644\u0628\u0627\u0646\u0643\"\u060c \u0648\"\u0627\u0655\u0633 \u0643\u064a\u0647 \u0627\u0655\u0646\u0631\u062c\u064a\"\u060c \u0648\"\u062c\u064a \u0627\u0655\u0633 \u0643\u0627\u0644\u062a\u0643\u0633\"\u060c \u0648\"\u0627\u0655\u0633-\u0627\u0654\u0648\u064a\u0644\".<br /><br />\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u064a\u0648\u0646\u0647\u0627\u0628\u060c \u0646\u0642\u0644\u0627\u064b \u0639\u0646 \u0627\u0644\u0627\u062f\u0639\u0627\u0621 \u0627\u0644\u0639\u0627\u0645\u060c \u0627\u0654\u0646 \u0634\u0631\u0643\u062a\u064a \"\u0627\u0655\u062a\u0634 \u062f\u064a \u0647\u064a\u0648\u0646\u062f\u0627\u064a \u0627\u0654\u0648\u064a\u0644\u0628\u0627\u0646\u0643\" \u0648\"\u0627\u0655\u0633 \u0643\u064a\u0647 \u0627\u0655\u0646\u0631\u062c\u064a\" \u062a\u0648\u0627\u0637\u0627\u0654\u062a\u0627 \u0641\u064a \u0645\u0628\u064a\u0639\u0627\u062a \u0646\u0641\u0637\u064a\u0629 \u0628\u0642\u064a\u0645\u0629 14.2 \u062a\u0631\u064a\u0644\u064a\u0648\u0646 \u0648\u0648\u0646 (9.2 \u0645\u0644\u064a\u0627\u0631 \u062f\u0648\u0644\u0627\u0631). \u0648\u0628\u0627\u0655\u0636\u0627\u0641\u0629 \u0634\u0631\u0643\u062a\u064a \"\u062c\u064a \u0627\u0655\u0633 \u0643\u0627\u0644\u062a\u0643\u0633\" \u0648\"\u0627\u0655\u0633-\u0627\u0654\u0648\u064a\u0644\"\u060c \u0627\u0644\u0644\u062a\u064a\u0646 \u064a\u064f\u0632\u0639\u0645 \u0627\u0654\u0646\u0647\u0645\u0627 \u0642\u0644\u062f\u062a\u0627 \u062a\u0644\u0643 \u0627\u0644\u0627\u0654\u0633\u0639\u0627\u0631\u060c \u064a\u0635\u0644 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0627\u0654\u062b\u0631 \u0627\u0644\u0627\u062d\u062a\u0643\u0627\u0631\u064a \u0627\u0655\u0644\u0649 \u0646\u062d\u0648 26 \u062a\u0631\u064a\u0644\u064a\u0648\u0646 \u0648\u0648\u0646\u060c \u0628\u062d\u0633\u0628 \u0627\u0644\u062a\u0642\u0631\u064a\u0631.<br /><br />\u0648\u0642\u0627\u0644\u062a \u0627\u0644\u0646\u064a\u0627\u0628\u0629 \u0627\u0655\u0646 \u0627\u0644\u062a\u062d\u0642\u064a\u0642 \u0628\u062f\u0627\u0654 \u0628\u0639\u062f \u0627\u0631\u062a\u0641\u0627\u0639 <a href=\"https://www.alyaum.com/articles/6671270/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D8%A7%D9%84%D8%B7%D8%A7%D9%82%D8%A9/%D8%AA%D8%A8%D8%A7%D9%8A%D9%86-%D8%A3%D8%B3%D8%B9%D8%A7%D8%B1-%D8%A7%D9%84%D9%86%D9%81%D8%B7-%D9%85%D8%B9-%D8%A7%D9%86%D8%AA%D8%B9%D8%A7%D8%B4-%D8%A7%D9%84%D8%B4%D8%AD%D9%86%D8%A7%D8%AA-%D8%B9%D8%A8%D8%B1-%D9%85%D8%B6%D9%8A%D9%82-%D9%87%D8%B1%D9%85%D8%B2-%D9%88%D8%B1%D9%81%D8%B9-%D8%A5%D9%86%D8%AA%D8%A7%D8%AC-%D8%A3%D9%88%D8%A8%D9%83+\" target=\"_blank\">\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0646\u0641\u0637 </a>\u0627\u0644\u0645\u062d\u0644\u064a\u0629 \u0628\u0634\u0643\u0644 \u062d\u0627\u062f \u0639\u0642\u0628 \u0627\u0644\u0635\u0631\u0627\u0639 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u060c \u0648\u062e\u0644\u0635\u0648\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u062a\u0648\u0627\u0637\u0648\u0654 \u0645\u0633\u0648\u0654\u0648\u0644\u064a \u0627\u0644\u062a\u0633\u0639\u064a\u0631 \u0641\u064a \u0634\u0631\u0643\u062a\u064a\u0646 \u0645\u0646 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0644\u062b\u0644\u0627\u062b \u0628\u0634\u0627\u0654\u0646 \u062a\u0648\u0642\u064a\u062a \u0648\u062d\u062c\u0645 \u0627\u0644\u0632\u064a\u0627\u062f\u0627\u062a \u0643\u0627\u0646 \u0627\u0644\u062f\u0627\u0641\u0639 \u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a \u0648\u0631\u0627\u0621 \u0630\u0644\u0643.<br />\u0627\u0654\u0641\u0627\u062f\u062a \u0627\u0644\u0646\u064a\u0627\u0628\u0629 \u0628\u0627\u0654\u0646 \u0627\u0644\u062a\u0648\u0627\u0637\u0648\u0654 \u0644\u0645 \u064a\u0643\u0646 \u062d\u0627\u062f\u062b\u0629 \u0641\u0631\u062f\u064a\u0629\u060c \u0628\u0644 \u0645\u0645\u0627\u0631\u0633\u0629 \u0645\u0646\u0647\u062c\u064a\u0629 \u0637\u0648\u064a\u0644\u0629 \u0627\u0644\u0627\u0654\u0645\u062f \u0638\u0647\u0631\u062a \u062e\u0644\u0627\u0644 \u0627\u0654\u0632\u0645\u0629 \u0639\u0627\u0644\u0645\u064a\u0629.<br /><br />\u0648\u0643\u0627\u0646 \u0627\u0644\u0631\u064a\u0654\u064a\u0