\u0630\u062c \u0627\u0644\u062c\u062f\u064a\u062f \u0645\u062c\u0631\u062f \u062a\u0648\u0644\u064a\u062f \u0627\u0644\u0646\u0635\u0648\u0635 \u0644\u064a\u0642\u062f\u0645 \u0645\u064a\u0632\u0629 \u00ab\u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0645\u0633\u062a\u0642\u0644\u00bb (Autonomous Workflow). \u062a\u062e\u064a\u0644 \u0630\u0643\u0627\u0621\u064b \u0627\u0635\u0637\u0646\u0627\u0639\u064a\u0627\u064b \u0642\u0627\u062f\u0631\u0627\u064b \u0639\u0644\u0649 \u0643\u062a\u0627\u0628\u0629 \u0627\u0644\u0627\u0654\u0643\u0648\u0627\u062f \u0627\u0644\u0628\u0631\u0645\u062c\u064a\u0629\u060c \u0648\u0627\u062e\u062a\u0628\u0627\u0631\u0647\u0627\u060c \u0648\u062a\u0635\u062d\u064a\u062d \u0627\u0654\u062e\u0637\u0627\u064a\u0654\u0647\u0627\u060c \u0648\u0627\u0644\u062a\u0646\u0642\u0644 \u0628\u064a\u0646 \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u062a \u0627\u0644\u0631\u0642\u0645\u064a\u0629 \u062d\u062a\u0649 \u0627\u0655\u0643\u0645\u0627\u0644 \u0627\u0644\u0645\u0634\u0631\u0648\u0639 \u0628\u0627\u0644\u0643\u0627\u0645\u0644\u060c \u0643\u0644 \u0630\u0644\u0643 \u062f\u0648\u0646 \u062a\u062f\u062e\u0644 \u0628\u0634\u0631\u064a \u0645\u0643\u062b\u0641. \u0648\u062a\u0634\u064a\u0631 \u0627\u0644\u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0644\u062a\u0642\u0646\u064a\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0646\u0638\u0627\u0645 \u062d\u0642\u0642 \u062f\u0642\u0629 \u0645\u0630\u0647\u0644\u0629 \u0628\u0644\u063a\u062a 82.7% \u0641\u064a \u0633\u064a\u0631 \u0627\u0644\u0639\u0645\u0644 \u0627\u0644\u0628\u0631\u0645\u062c\u064a\u060c \u0645\u062a\u0641\u0648\u0642\u0627\u064b \u0628\u0630\u0644\u0643 \u0639\u0644\u0649 \u0643\u0627\u0641\u0629 \u0627\u0644\u0646\u0645\u0627\u0630\u062c \u0627\u0644\u0633\u0627\u0628\u0642\u0629.\u0627\u0644\u062a\u062d\u062f\u064a \u0627\u0644\u062a\u0642\u0646\u064a \u0627\u0644\u0630\u064a \u0646\u062c\u062d\u062a OpenAI \u0641\u064a \u062a\u062c\u0627\u0648\u0632\u0647 \u0647\