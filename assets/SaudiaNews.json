4\u062e\u0633\u0627\u064a\u0654\u0631 1 0<br />\u0627\u0644\u0627\u0654\u0647\u062f\u0627\u0641 \u0627\u0644\u0645\u0633\u062c\u0644\u0629 12 16<br />\u0627\u0644\u0627\u0654\u0647\u062f\u0627\u0641 \u0627\u0644\u0645\u0633\u062a\u0642\u0628\u0644\u0629 5 8<br />\u0627\u0644\u0634\u0628\u0627\u0643 \u0627\u0644\u0646\u0638\u064a\u0641\u0629 2 2<br /><br />\u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0645\u0641\u0627\u0631\u0642\u0627\u062a<br /><br />* \u0628\u062f\u0627\u0654\u062a \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0645\u0634\u0648\u0627\u0631\u0647\u0627 \u0641\u064a \u0645\u0648\u0646\u062f\u064a\u0627\u0644 2022 \u0628\u062e\u0633\u0627\u0631\u0629 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u060c \u0644\u0643\u0646\u0647\u0627 \u0646\u062c\u062d\u062a \u0641\u064a \u0642\u0644\u0628 \u0627\u0644\u0645\u0639\u0637\u064a\u0627\u062a \u0648\u062a\u0648\u062c\u062a \u0628\u0637\u0644\u0629 \u0644\u0644\u0639\u0627\u0644\u0645.<br />* \u0641\u064a \u0645\u0648\u0646\u062f\u064a\u0627\u0644 2026\u060c \u0644\u0645 \u062a\u062a\u0639\u0631\u0636 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0644\u0627\u0654\u064a \u062e\u0633\u0627\u0631\u0629 \u062d\u062a\u0649 \u0628\u0644\u0648\u063a \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u0645\u0648\u0654\u0643\u062f\u0629 \u0627\u0633\u062a\u0642\u0631\u0627\u0631\u0647\u0627 \u0627\u0644\u0641\u0646\u064a \u0648\u062b\u0628\u0627\u062a \u0645\u0633\u062a\u0648\u0627\u0647\u0627 \u0637\u0648\u0627\u0644 \u0627\u0644\u0628\u0637\u0648\u0644\u0629.<br />* \u062e\u0627\u0636\u062a \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0641\u064a \u0646\u0633\u062e\u0629 2026 7 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0642\u0628\u0644 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u0645\u0642\u0627\u0628\u0644 6 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0641\u064a \u0646\u0633\u062e\u0629 2022\u060c \u0628\u0633\u0628\u0628 \u0627\u0655\u0636\u0627\u0641\u0629 \u062f\u0648\u0631 \u0627\u0644\u064032.<br />* \u0647\u062c\u0648\u0645\u064a\u064b\u0627\u060c \u0642\u062f\u0645\u062a \u0646\u0633\u062e\u0629 2026 \u0627\u0654\u0631\u0642\u0627\u0645\u064b\u0627 \u0627\u0654\u0641\u0636\u0644\u060c \u0628\u0639\u062f\u0645\u0627 \u0633\u062c\u0644\u062a 16 \u0647\u062f\u0641\u064b\u0627 \u0642\u0628\u0644 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u0645\u0642\u0627\u0628\u0644 12 \u0647\u062f\u0641\u064b\u0627 \u0641\u064a \u0646\u0633\u062e\u0629 2022.<br />* \u062f\u0641\u0627\u0639\u064a\u064b\u0627\u060c \u062a\u0641\u0648\u0642\u062a \u0646\u0633\u062e\u0629 2022\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0633\u062a\u0642\u0628\u0644\u062a 5 \u0627\u0654\u0647\u062f\u0627\u0641 \u0641\u0642\u0637\u060c \u0645\u0642\u0627\u0628\u0644 8 \u0627\u0654\u0647\u062f\u0627\u0641 \u0641\u064a \u0646\u0633\u062e\u0629 2026.<br />* \u062d\u0627\u0641\u0638 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0639\u0644\u0649 \u0646\u0638\u0627\u0641\u0629 \u0634\u0628\u0627\u0643\u0647 \u0641\u064a \u0645\u0628\u0627\u0631\u0627\u062a\u064a\u0646 \u0641\u064a \u0627\u0644\u0646\u0633\u062e\u062a\u064a\u0646.<br />* \u0646\u062c\u062d\u062a \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0641\u064a \u0628\u0644\u0648\u063a \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u062a\u0648\u0627\u0644\u064a\u060c \u0644\u062a\u0648\u0654\u0643\u062f \u0627\u0633\u062a\u0645\u0631\u0627\u0631\u064a\u0629 \u0627\u0644\u0645\u0634\u0631\u0648\u0639 \u0627\u0644\u0641\u0646\u064a \u0628\u0642\u064a\u0627\u062f\u0629 \u0644\u064a\u0648\u0646\u064a\u0644 \u0633\u0643\u0627\u0644\u0648\u0646\u064a\u060c \u0648\u0647\u0648 \u0627\u0655\u0646\u062c\u0627\u0632 \u0644\u0645 