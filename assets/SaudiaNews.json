4\u0627\u0655\u0635\u0627\u0628\u0629 \u0628\u0634\u062f \u0641\u064a \u0627\u0644\u0639\u0636\u0644\u0629 \u0627\u0644\u0636\u0627\u0645\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u062f\u064a\u0631\u0628\u064a \u0644\u064a\u062a\u0645 \u0627\u0633\u062a\u0628\u062f\u0627\u0644\u0647 \u0628\u0632\u0645\u064a\u0644\u0647 \u0641\u0631\u0627\u0633 \u0627\u0644\u0628\u0631\u064a\u0643\u0627\u0646.\u0648\u0633\u064a\u062e\u0636\u0639 \u0627\u0644\u0644\u0627\u0639\u0628 \u0644\u0641\u062d\u0648\u0635\u0627\u062a \u0637\u0628\u064a\u0629 \u062c\u062f\u064a\u062f\u0629 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0633\u0628\u062a \u0644\u062a\u062d\u062f\u064a\u062f \u0645\u062f\u0629 \u063a\u064a\u0627\u0628\u0647.\u0648\u0634\u0627\u0631\u0643 \u0627\u0644\u0644\u0627\u0639\u0628 \u0628\u0642\u0645\u064a\u0635 \u0627\u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062c\u0627\u0631\u064a \u0628\u0640 (27) \u0645\u0628\u0627\u0631\u0627\u0629 \u0641\u064a \u0645\u062e\u062a\u0644\u0641 \u0627\u0644\u0628\u0637\u0648\u0644\u0627\u062a \u0633\u062c\u0644 \u062e\u0644\u0627\u0644\u0647\u0627 \u0647\u062f\u0641\u064b\u0627 \u0648\u0635\u0646\u0639 \u0627\u0653\u062e\u0631 \u0628\u0648\u0627\u0642\u0639 (1572) \u062f\u0642\u064a\u0642\u0629 \u0644\u0639\u0628.\u0648\u062d\u0633\u0645 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0627\u0644\u062f\u064a\u0631\u0628\u064a \u0627\u0654\u0645\u0633 \u0628\u0627\u0644\u0641\u0648\u0632 \u0628\u0644\u0627\u062b\u064a\u0629 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641 \u0639\u0644\u0649 \u0636\u064a\u0641\u0647 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0636\u0645\u0646 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 (25) \u0645\u0646 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646.\u0648\u0645\u0646 \u0627\u0644\u0645\u0642\u0631\u0631 \u0627\u0654\u0646 \u064a\u062d\u0644 \u0641\u0631\u064a\u06