/6647557/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A8%D8%B9%D8%AF-%D8%BA%D9%8A%D8%A7%D8%A8-3-%D8%B3%D9%86%D9%88%D8%A7%D8%AA-%D9%88%D8%B5%D9%88%D9%84-%D8%A3%D9%88%D9%84-%D8%B1%D8%AD%D9%84%D8%A9-%D8%A3%D9%85%D9%85%D9%8A%D8%A9-%D8%A5%D9%84%D9%89-%D8%A7%D9%84%D8%AE%D8%B1%D8%B7%D9%88%D9%85-%D9%85%D9%86%D8%B0-%D8%A7%D9%86%D8%AF%D9%84%D8%A7%D8%B9-%D8%A7%D9%84%D8%AD%D8%B1%D8%A8\" target=\"_blank\">\u0645\u0637\u0627\u0631 \u0627\u0644\u062e\u0631\u0637\u0648\u0645</a> \u0627\u0644\u0627\u062b\u0646\u064a\u0646 \u0648\u0627\u0633\u062a\u062f\u0639\u0649 \u0633\u0641\u064a\u0631\u0647 \u0639\u0644\u0649 \u0627\u0655\u062b\u0631\u0647 \u0644\u0644\u062a\u0634\u0627\u0648\u0631\u060c \u0641\u064a\u0645\u0627 \u0646\u0641\u062a<a href=\"https://www.alyaum.com/articles/6653199/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D9%84%D8%B3%D9%88%D8%AF%D8%A7%D9%86-%D8%AA%D8%AD%D8%B1%D9%83-%D8%AF%D9%88%D9%84%D9%8A-%D9%84%D8%AF%D8%B9%D9%85-%D8%A7%D9%84%D8%AD%D9%84-%D8%A7%D9%84%D8%B3%D9%8A%D8%A7%D8%B3%D9%8A-%D9%88%D8%A7%D8%AA%D9%81%D8%A7%D9%82-%D8%B9%D9%84%D9%89-%D8%B6%D8%B1%D9%88%D8%B1%D8%A9-%D9%88%D9%82%D9%81-%D8%A5%D8%B7%D9%84%D8%A7%D9%82-%D8%A7%D9%84%D9%86%D8%A7%D8%B1\" target=\"_blank\"> \u0627\u0654\u062f\u064a\u0633 \u0627\u0654\u0628\u0627\u0628\u0627</a> \u0627\u0644\u0627\u062a\u0647\u0627\u0645.<br /><br />\u0648\u0648\u062c\u0647\u062a \u0627\u0655\u062b\u064a\u0648\u0628\u064a\u0627 \u0627\u062a\u0647\u0627\u0645\u0627 \u0645\u0636\u0627\u062f\u0627 \u0644\u0644\u062c\u064a\u0634 \u0627\u0644\u0633\u0648\u062f\u0627\u0646\u064a \u0628\u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u062a\u0633\u0644\u064a\u062d \u0648\u0627\u0644\u062a\u0645\u0648\u064a\u0644 \u0644\u0645\u0633\u0644\u0651\u062d\u064a \u0627\u0655\u0642\u0644\u064a\u0645 \u062a\u064a\u063a\u0631\u0627\u064a \u0641\u064a \u0634\u0645\u0627\u0644 \u0627\u0644\u0628\u0644\u0627\u062f\u060c \u0627\u0644\u0630\u064a\u0646 \u062e\u0627\u0636\u0648\u0627 \u062d\u0631\u0628\u0627 \u0637\u0627\u062d\u0646\u0629 \u0645\u0639 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0641\u062f\u0631\u0627\u0644\u064a \u0628\u064a\u0646 2020 \u06482022.<br /><br />\u0648\u062c\u0627\u0621\u062a \u0627\u0644\u0627\u062a\u0647\u0627\u0645\u0627\u062a \u0627\u0644\u0633\u0648\u062f\u0627\u0646\u064a\u0629 \u0644\u0627\u0655\u062b\u064a\u0648\u0628\u064a\u0627 \u063a\u062f\u0627\u0629 \u062a\u0639\u0631\u0636 \u0645\u0637\u0627\u0631 \u0627\u0644\u062e\u0631\u0637\u0648\u0645 \u0648\u0642\u0627\u0639\u062f\u0629 \u0648\u0627\u062f\u064a \u0633\u064a\u062f\u0646\u0627 \u0641\u064a \u0627\u0654\u0645 \u062f\u0631\u0645\u0627\u0646 \u0627\u0644\u0627\u062b\u0646\u064a\u0646 \u0644\u0647\u062c\u0645\u0627\u062a \u0628\u0637\u0627\u064a\u0654\u0631\u0627\u062a \u0645\u0633\u064a\u0631\u0629\u060c \u0628\u062d\u0633\u0628 \u0645\u0627 \u0627\u0654\u0641\u0627\u062f \u0645\u0635\u062f\u0631 \u0639\u0633\u0643\u0631\u064a \u0633\u0648\u062f\u0627\u0646\u064a \u0648\u0643\u0627\u0644\u0629 \u0641\u0631\u0627\u0646\u0633 \u0628\u0631\u0633\u060c \u0643\u0645\u0627 \u0633\u0642\u0637\u062a \u0627\u0655\u062d\u062f\u0649 \u0627\u0644\u0642\u0630\u0627\u064a\u0654\u0641 \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u0633\u0643\u0646\u064a\u0629 \u0645\u062c\u0627\u0648\u0631\u0629 \u0644\u0644\u0645\u0637\u0627\u0631.<br /> <h2>\u0645\u0637\u0627\u0631 \u0628\u062d\u0631 \u062f\u0627\u0631 \u0641\u064a \u0627\u0655\u062b\u064a\u0648\u0628\u064a\u0627</h2>\u0648\u0635\u0628\u0627\u062d \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621\u060c \u0634\u062f\u062f \u0627\u0644\u0645\u062a\u062d\u062f\u062b \u0628\u0627\u0633\u0645 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0633\u0648\u062f\u0627\u0646\u064a \u0639\u0627\u0635\u0645 \u0639\u0648\u0636 \u0639\u0628\u062f \u0627\u0644\u0648\u0647\u0627\u0628 \u0639\u0644\u0649 \u0648\u062c\u0648\u062f \"\u0627\u0654\u062f\u0644\u0629 \u062f\u0627\u0645\u063a\u0629\" \u0639\u0644\u0649 \u0627\u0646\u0637\u0644\u0627\u0642 \u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0627\u062a \u0645\u0646 \u0645\u0637\u0627\u0631 \u0628\u062d\u0631 \u062f\u0627\u0631 \u0641\u064a \u0627\u0655\u062b\u064a\u0648\u0628\u064a\u0627\u060c \u0648\u0630\u0644\u0643 \u0628\u0639\u062f \u0647\u062c\u0645\u0627\u062a \u0645\u0634\u0627\u0628\u0647\u0629 \u0641\u064a \u0645\u0627\u0631\u0633 \u0627\u0633\u062a\u0647\u062f\u0641\u062a \u0648\u0644\u0627\u064a\u0627\u062a \u0634\u0645\u0627\u0644 \u0648\u062c\u0646\u0648\u0628 \u0643\u0631\u062f\u0641\u0627\u0646 \u0648\u0627\u0644\u0646\u064a\u0644 \u0627\u0644\u0627\u0654\u0632\u0631\u0642.<br /><br />\u0648\u0642\u0627\u0644 \u0639\u0628\u062f \u0627\u0644\u0648\u0647\u0627\u0628 \"\u062a\u0645 \u062a\u062d\u0644\u064a\u0644 \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0629 \u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0629\" \u0627\u0644\u062a\u064a \u0633\u0642\u0637\u062a \u0641\u064a \u0647\u062c\u0648\u0645 \u0645\u0627\u0631\u0633\u060c \"\u0648\u0627\u0633\u062a\u0641\u0633\u0631\u0646\u0627 \u0627\u0644\u062c\u0647\u0629 \u0627\u0644\u0645\u064f\u0635\u0646\u0639\u0629 \u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0628\u0627\u0654\u0646.. \u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0629 \u0628\u0627\u0644\u0631\u0642\u0645 +\u0627\u0655\u0633 88+ \u0645\u0645\u0644\u0648\u0643\u0629 \u0644\u062f\u0648\u0644\u0629 \u0627\u0644\u0627\u0655\u0645\u0627\u0631\u0627\u062a \u0648\u0627\u0633\u062a\u064f\u062e\u062f\u0645\u062a \u0645\u0646 \u062f\u0627\u062e\u0644 \u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0655\u062b\u064a\u0648\u0628\u064a\u0627\u061b \u0645\u0637\u0627\u0631 \u0628\u062d\u0631 \u062f\u0627\u0631\".<h2>\u062a\u0633\u0644\u064a\u062d \u062c\u0628\u0647\u0629 \u062a\u064a\u063a\u0631\u0627\u064a</h2>\u0648\u0627\u0654\u0639\u0644\u0646 \u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0644\u0633\u0648\u062f\u0627\u0646\u064a \u0645\u062d\u064a \u0627\u0644\u062f\u064a\u0646 \u0633\u0627\u0644\u0645 \u0641\u064a \u0627\u0644\u0645\u0648\u0654\u062a\u0645\u0631 \u0627\u0644\u0635\u062d\u0627\u0641\u064a \u0627\u0633\u062a\u062f\u0639\u0627\u0621 \u0633\u0641\u064a\u0631 \u0627\u0644\u0633\u0648\u062f\u0627\u0646 \u0644\u062f\u0649 \u0627\u0655\u062b\u064a\u0648\u0628\u064a\u0627 \u0644\u0644\u062a\u0634\u0627\u0648\u0631\u060c \u0642\u0627\u064a\u0654\u0644\u0627 \"\u0644\u062f\u064a\u0646\u0627 \u0643\u0644 \u0627\u0644\u062d\u0642 \u0641\u064a \u0627\u0654\u0646 \u0646\u0631\u062f \u0643\u062d\u0643\u0648\u0645\u0629 \u0639\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0639\u062f\u0648\u0627\u0646 \u0628\u0627\u0644\u0643\u064a\u0641\u064a\u0629 \u0648\u0627\u0644\u0637\u0631\u064a\u0642\u0629 \u0627\u0644\u062a\u064a \u0646\u062d\u062f\u062f\u0647\u0627\".<br /><br />\u0641\u064a \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u060c \u0627\u0639\u062a\u0628\u0631\u062a \u0627\u0655\u062b\u064a\u0648\u0628\u064a\u0627 \u0627\u0654\u0646 \u0627\u062a\u0647\u0627\u0645\u0627\u062a \u0627\u0644\u062e\u0631\u0637\u0648\u0645 \"\u0644\u0627 \u0627\u0654\u0633\u0627\u0633 \u0644\u0647\u0627\" \u0648\u0627\u062a\u0647\u0645\u062a \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0633\u0648\u062f\u0627\u0646\u064a \u0628\u062a\u0633\u0644\u064a\u062d \u062c\u0628\u0647\u0629 \u062a\u062d\u0631\u064a\u0631 \u0634\u0639\u0628 \u062a\u064a\u063a\u0631\u0627\u064a \u0648\u062a\u0645\u0648\u064a\u0644\u0647\u0627.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["top", "crime", "politics"], "datatype": "news", "pubDate": "2026-05-05 16:00:00", "pubDateTZ": "UTC", "fetched_at": "2026-05-05 16:16:54", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPOR