s/6653244/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%B1%D8%B3%D8%A7%D8%A6%D9%84-%D8%AC%D8%AF%D9%8A%D8%AF%D8%A9-%D8%B1%D9%88%D8%A8%D9%8A%D9%88-%D9%8A%D9%83%D8%B4%D9%81-%D8%B9%D9%86-%D8%AA%D9%88%D8%A7%D8%B5%D9%84-%D8%BA%D9%8A%D8%B1-%D8%B1%D8%B3%D9%85%D9%8A-%D9%85%D8%B9-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86\" target=\"_blank\">\u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a</a> <a href=\"https://www.alyaum.com/articles/6653547/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%B1%D9%88%D8%A8%D9%8A%D9%88-%D8%A7%D9%84%D9%88%D9%84%D8%A7%D9%8A%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D8%AA%D8%AD%D8%AF%D8%A9-%D8%B3%D8%AA%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D9%86%D8%B8%D8%B1-%D9%81%D9%8A-%D8%B9%D9%84%D8%A7%D9%82%D8%AA%D9%87%D8%A7-%D9%85%D8%B9-%D8%A7%D9%84%D9%86%D8%A7%D8%AA%D9%88-%D8%A8%D8%B9%D8%AF-%D8%AD%D8%B1%D8%A8-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86\" target=\"_blank\">\u0645\u0627\u0631\u0643\u0648 \u0631\u0648\u0628\u064a\u0648</a> <a href=\"https://www.alyaum.com/articles/6658523/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%81%D8%B1%D9%86%D8%B3%D8%A7-%D8%B9%D9%84%D9%89-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D8%B1%D8%B3%D9%85-%D9%85%D8%B3%D8%A7%D8%B1-%D9%84%D9%84%D8%AA%D8%B9%D8%A7%D9%8A%D8%B4-%D8%A7%D9%84%D8%B3%D9%84%D9%85%D9%8A-%D9%81%D9%8A-%D8%A7%D9%84%D8%B4%D8%B1%D9%82-%D8%A7%D9%84%D8%A3%D9%88%D8%B3%D8%B7\" target=\"_blank\">\u0627\u0655\u064a\u0631\u0627\u0646</a> \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 <a href=\"https://www.alyaum.com/articles/6658501/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D8%AC%D9%84%D8%B3-%D8%A7%D9%84%D8%A3%D9%85%D9%86-%D8%AA%D8%B5%D8%B1%D9%81%D8%A7%D8%AA-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%81%D9%8A-%D9%85%D8%B6%D9%8A%D9%82-%D9%87%D8%B1%D9%85%D8%B2-%D8%AA%D8%B9%D8%B1%D8%B6-%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF-%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85%D9%8A-%D9%84%D9%84%D8%AE%D8%B7%D8%B1\" target=\"_blank\">\u0645\u0636\u064a\u0642 \u0647\u0631\u0645\u0632</a> \u0633\u0644\u0627\u062d\u064b\u0627 \u0646\u0648\u0648\u064a\u064b\u0627 \u0627\u0642\u062a\u0635\u0627\u062f\u064a\u064b\u0627 \u0636\u062f \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0648\u0646\u0642\u0644\u062a \u0642\u0646\u0627\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0639\u0628\u0631 \u062d\u0633\u0627\u0628\u0647\u0627 \u0639\u0644\u0649 \u062a\u0637\u0628\u064a\u0642 \u0627\u0655\u0643\u0633 \u0639\u0646 \u0631\u0648\u0628\u064a\u0648 \u0642\u0648\u0644\u0647\u060c \u0627\u0655\u0646 \u0627\u0655\u064a\u0631\u0627\u0646 \u062a\u062a\u0628\u0627\u0647\u0649 \u0628\u0627\u062d\u062a\u062c\u0627\u0632 \u0627\u0655\u0645\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0637\u0627\u0642\u0629 \u0631\u0647\u064a\u0646\u0629.<br />\u0648\u0627\u0654\u0636\u0627\u0641: \u0627\u0644\u0645\u0641\u0627\u0648\u0636 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u064a\u0636\u0637\u0631 \u0644\u062f\u062e\u0648\u0644 \u0645\u0628\u0627\u062d\u062b\u0627\u062a \u0628\u0627\u0644\u062f\u0627\u062e\u0644 \u0644\u0645\u0639\u0631\u0641\u0629 \u0645\u0627 \u064a\u0645\u0643\u0646 \u062a\u0642\u062f\u064a\u0645\u0647\u060c \u0648\u0639\u062f\u0645 \u0645\u0646\u062d \u0648\u0641\u062f \u0627\u0644\u062a\u0641\u0627\u0648\u0636 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0627\u0644\u0635\u0644\u0627\u062d\u064a\u0627\u062a \u0627\u0644\u0644\u0627\u0632\u0645\u0629 \u0639\u0642\u0628\u0629 \u0631\u064a\u0654\u064a\u0633\u064a\u0629.<br />\u0648\u062a\u0627\u0628\u0639: \u0644\u062f\u064a\u0646\u0627 \u062a\u0633\u0627\u0648\u0654\u0644\u0627\u062a \u0639\u0645\u0627 \u0627\u0655\u0630\u0627 \u0643\u0627\u0646 \u0645\u0642\u062f\u0645\u0648 \u0627\u0644\u0639\u0631\u0636 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0627\u0644\u0627\u0654\u062e\u064a\u0631 \u0644\u062f\u064a\u0647\u0645 \u0633\u0644\u0637\u0629 \u062a\u0646\u0641\u064a\u0630\u0647.<br />\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0645\u0646\u0639 \u0627\u0655\u064a\u0631\u0627\u0646 \u0645\u0646 \u0627\u0645\u062a\u0644\u0627\u0643 \u0633\u0644\u0627\u062d \u0646\u0648\u0648\u064a \u0644\u0627 \u064a\u0632\u0627\u0644 \u0627\u0644\u0642\u0636\u064a\u0629 \u0627\u0644\u0627\u0654\u0633\u0627\u0633\u064a\u0629.<h2>\u062a\u0631\u0627\u0645\u0628 \u0645\u062d\u0628\u0637</h2><p>\u0642\u0627\u0644 <a href=\"https://www.alyaum.com/articles/6656364/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D8%B3%D8%A4%D9%88%D9%84-%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D9%8A-%D8%A7%D9%84%D8%AA%D9%88%D8%A7%D8%B5%D9%84-%D9%85%D8%B9-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%85%D8%B3%D8%AA%D9%85%D8%B1-%D9%85%D9%86%D8%B0-%D8%A7%D9%86%D8%AA%D9%87%D8%A7%D8%A1-%D8%A7%D9%84%D9%85%D8%AD%D8%A7%D8%AF%D8%AB%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D8%A7%D8%B6%D9%8A%D8%A9\" target=\"_blank\">\u0645\u0633\u0648\u0654\u0648\u0644 \u0627\u0654\u0645\u0631\u064a\u0643\u064a</a> \u0627\u0655\u0646 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a <a href=\"https://www.alyaum.com/articles/6658350/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D8%A7%D8%AA%D9%87%D8%A7%D9%85%D8%A7%D8%AA-%D9%85%D9%86%D9%81%D8%B0-%D9%87%D8%AC%D9%88%D9%85-%D8%AD%D9%81%D9%84-%D8%A7%D9%84%D8%B9%D8%B4%D8%A7%D8%A1-%D9%83%D8%A7%D8%B0%D8%A8%D8%A9-%D9%88%D8%AA%D8%A4%D9%83%D8%AF-%D8%A3%D9%86%D9%87-%D9%85%D8%B6%D8%B7%D8%B1%D8%A8\" target=\"_blank\">\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u0628</a> \u0645\u062d\u0628\u0637 \u0628\u0633\u0628\u0628 \u0639\u062f\u0645 \u062a\u062e\u0648\u064a\u0644 \u0648\u0641\u062f <a href=\"https://www.alyaum.com/articles/6658501/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D8%AC%D9%84%D8%B3-%D8%A7%D9%84%D8%A3%D9%85%D9%86-%D8%AA%D8%B5%D8%B1%D9%81%D8%A7%D8%AA-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%81%D9%8A-%D9%85%D8%B6%D9%8A%D9%82-%D9%87%D8%B1%D9%85%D8%B2-%D8%AA%D8%B9%D8%B1%D8%B6-%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF-%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85%D9%8A-%D9%84%D9%84%D8%AE%D8%B7%D8%B1\" target=\"_blank\">\u0627\u0655\u064a\u0631\u0627\u0646</a> \u0628\u062a\u0642\u062f\u064a\u0645 \u062a\u0646\u0627\u0632\u0644\u0627\u062a \u0646\u0648\u0648\u064a\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0627\u062a.<br />\u0648\u062d\u0633\u0628 \u0642\u0646\u0627\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629\u060c \u0641\u0642\u062f \u0642\u0627\u0644 \u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u0644\u0635\u062d\u064a\u0641\u0629 \u0646\u064a\u0648\u064a\u0648\u0631\u0643 \u062a\u0627\u064a\u0645\u0632 \u0627\u0655\u0646 <a href=\"https://www.alyaum.com/articles/6658520/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%8A%D8%B3%D8%AA%D9%82%D8%A8%D9%84%D9%87-%D8%A7%D9%84%D9%85%D9%84%D9%83-%D8%AA%D8%B4%D8%A7%D8%B1%D9%84%D8%B2-%D9%8A%D8%A8%D8%AF%D8%A3-%D8%B2%D9%8A%D8%A7%D8%B1%D8%A9-%D8%AF%D9%88%D9%84%D8%A9-%D8%A5%D9%84%D9%89-%D8%A7%D9%84%D9%88%D9%84%D8%A7%D9%8A%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D8%AA%D8%AD%D8%AF%D8%A9\" target=\"_blank\">\u062a\u0631\u0627\u0645\u0628</a> \u0645\u0635\u0645\u0645 \u0639\u0644\u0649 \u0627\u0644\u0645\u0637\u0627\u0644\u0628 \u0627\u0644\u0646\u0648\u0648\u064a\u0629 \u0644\u0627\u0655\u0646\u0647\u0627\u0621 \u0627\u0644\u062d\u0631\u0628 \u0645\u0639 \u0627\u0655\u064a\u0631\u0627\u0646.<br />\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646 \u062a\u0631\u0627\u0645\u0628 \u063a\u064a\u0631 \u0631\u0627\u0636\u064d \u0639\u0646 \u0645\u0642\u062a\u0631\u062d \u0627\u0655\u064a\u0631\u0627\u0646\u060c \u0648\u0627\u0654\u0646\u0647 \u0627\u0654\u0628\u0644\u063a \u0645\u0633\u062a\u0634\u0627\u0631\u064a\u0647 \u0628\u0627\u0654\u0646 \u0627\u0644\u0639\u0631\u0636 \u064a\u0646\u0643\u0631.<br />\u0648\u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0644\u0635\u062d\u064a\u0641\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0628\u0639\u0636 \u0645\u0633\u062a\u0634\u0627\u0631\u064a \u062a\u0631\u0627\u0645\u0628 \u0627\u0642\u062a\u0631\u062d\u0648\u0627 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062d\u0635\u0627\u0631 \u0639\u0644\u0649 \u0645\u0648\u0627\u0646\u064a \u0627\u0655\u064a\u0631\u0627\u0646 \u0645\u062f\u0629 \u0634\u0647\u0631\u064a\u0646.<br /> </p><div data-oembed-url=\"https://x.com/AlArabiya_Brk/status/2048940437998567562\"><blockquote align=\"center\" class=\"twitter-tweet\" data-dnt=\"true\"><p dir=\"rtl\" lang=\"ar\">\u0631\u0648\u0628\u064a\u0648: \u0627\u0655\u064a\u0631\u0627\u0646 \u062a\u0633\u062a\u062e\u062f\u0645 \u0645\u0636\u064a\u0642 \u0647\u0631\u0645\u0632 \u0643\u0640\"\u0633\u0644\u0627\u062d \u0646\u0648\u0648\u064a \u0627\u0642\u062a\u0635\u0627\u062f\u064a\" \u0636\u062f \u0627\u0644\u0639\u0627\u0644\u0645 <a href=\"https://twitter.com/hashtag/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8%D9%8A%D8%A9_%D8%B9%D8%A7%D8%AC%D9%84?src=hash&ref_src=twsrc%5Etfw\">#\u0627\u0644\u0639\u0631\u0628\u064a\u0629_\u0639\u0627\u062c\u0644</a></p>\u2014 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0639\u0627\u062c\u0644 (@AlArabiya_Brk) <a href=\"https://twitter.com/AlArabiya_Brk/status/2048940437998567562?ref_src=twsrc%5Etfw\">April 28, 2026</a></blockquote> </div><h2>\u0627\u0655\u064a\u0631\u0627\u0646 \u062a\u062a\u0647\u0631\u0628 \u0645\u0646 \u0627\u0655\u0646\u0647\u0627\u0621 \u0627\u0644\u062a\u062e\u0635\u064a\u0628</h2><p>\u0648\u0642\u0627\u0644 \u0645\u0633\u0648\u0654\u0648\u0644\u0648\u0646 \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0648\u0646 \u0644\u0635\u062d\u064a\u0641\u0629 \u0648\u0648\u0644 \u0633\u062a\u0631\u064a\u062a \u062c\u0648\u0631\u0646\u0627\u0644 \u0627\u0655\u0646 \u062a\u0631\u0627\u0