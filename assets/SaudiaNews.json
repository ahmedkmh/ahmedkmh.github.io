A9-%D8%A7%D9%84%D9%84%D9%88%D8%AC%D8%B3%D8%AA%D9%8A%D8%A9-%D8%A8%D9%8A%D9%86-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D9%88%D8%AF%D9%88%D9%84-%D9%85%D8%AC%D9%84%D8%B3-%D8%A7%D9%84%D8%AA%D8%B9%D8%A7%D9%88%D9%86\">\u0627\u0644\u0628\u062f\u064a\u0648\u064a</a>\u060c \u0645\u0639 \u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0644\u0644\u064a\u062a\u0648\u0627\u0646\u064a \u0643\u064a\u0633\u062a\u0648\u062a\u064a\u0633 \u0628\u0648\u062f\u0631\u064a\u0633\u060c \u0627\u0644\u0627\u0654\u0648\u0636\u0627\u0639 \u0641\u064a \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0648\u0633\u0628\u0644 \u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0627\u0644\u0645\u0634\u062a\u0631\u0643\u060c \u0648\u0630\u0644\u0643 \u0639\u0644\u0649 \u0647\u0627\u0645\u0634 <a href=\"https://www.alyaum.com/articles/6654396/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AE%D9%84%D8%A7%D9%84-%D8%A7%D8%AC%D8%AA%D9%85%D8%A7%D8%B9-%D8%A5%D9%8A%D9%83%D8%A7%D9%88-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%AA%D8%AF%D9%8A%D9%86-%D8%A7%D9%84%D9%87%D8%AC%D9%85%D8%A7%D8%AA-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%A8%D9%86%D9%89-%D8%A7%D9%84%D8%AA%D8%AD%D8%AA%D9%8A%D8%A9-%D9%84%D9%84%D8%B7%D9%8A%D8%B1%D8%A7%D9%86-%D8%A7%D9%84%D9%85%D8%AF%D9%86%D9%8A\">\u0645\u0646\u062a\u062f\u0649 \u0627\u0654\u0646\u0637\u0627\u0644\u064a\u0627 \u0627\u0644\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a</a>.<br /><br />\u0648\u062c\u0631\u0649 \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639 \u0628\u062d\u062b \u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u062e\u0644\u064a\u062c\u064a\u0629 \u2013 \u0627\u0644\u0644\u064a\u062a\u0648\u0627\u0646\u064a\u0629\u060c \u0648\u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u062e\u0644\u064a\u062c\u064a\u0629 \u2013 \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a\u0629\u060c \u0648\u0645\u062c\u0627\u0644\u0627\u062a \u0627\u0644\u0634\u0631\u0627\u0643\u0629 \u0627\u0644\u0645\u0634\u062a\u0631\u0643\u0629 \u0627\u0644\u062a\u064a \u062a\u062e\u062f\u0645 \u0627\u0644\u0645\u0635\u0627\u0644\u062d \u0627\u0644\u0645\u0634\u062a\u0631\u0643\u0629 \u0644\u0644\u062c\u0627\u0646\u0628\u064a\u0646.<br /><br /> <h2>\u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u062e\u0644\u064a\u062c\u064a\u0629 \u2013 \u0627\u0644\u0644\u064a\u062a\u0648\u0627\u0646\u064a\u0629</h2>\u0648\u062a\u0628\u0627\u062f\u0644 \u0627\u0644\u062c\u0627\u0646\u0628\u0627\u0646 \u0648\u062c\u0647\u0627\u062a \u0627\u0644\u0646\u0638\u0631 \u062d\u0648\u0644 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0642\u0636\u0627\u064a\u0627 \u0627\u0644\u0627\u0655\u0642\u0644\u064a\u0645\u064a\u0629 \u0648\u0627\u0644\u062f\u0648\u0644\u064a\u0629 \u0627\u0644\u0631\u0627\u0647\u0646\u0629\u060c \u062d\u064a\u062b \u062c\u062f\u062f \u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0644\u0644\u064a\u062a\u0648\u0627\u0646\u064a \u0627\u0655\u062f\u0627\u0646\u0629 \u0628\u0644\u0627\u062f\u0647 \u0644\u0644\u0627\u0639\u062a\u062f\u0627\u0621\u0627\u062a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0639\u0644\u0649 \u062f\u0648\u0644 \u0645\u062c\u0644\u0633 \u0627\u0644\u062a\u0639\u0627\u0648\u0646\u060c \u0648\u0627\u0633\u062a\u0639\u062f\u0627\u062f\u0647\u0627 \u0644\u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u062f\u0639\u0645 \u0644\u062f\u0648\u0644 \u0627\u0644\u0645\u062c\u0644\u0633\u060c \u0645\u0642\u062f\u0645\u064b\u0627 \u0627\u0644\u0634\u0643\u0631 \u0644\u062c\u0647\u0648\u062f \u062f\u0648\u0644 \u0627\u0644\u0645\u062c\u0644\u0633 \u0641\u064a \u0627\u0655\u062c\u0644\u0627\u0621 \u0631\u0639\u0627\u064a\u0627 \u0628\u0644\u0627\u062f\u0647 \u0645\u0646 \u0627\u0644\u0645\u0646\u0637\u0642\u0629\u060c \u0641\u064a\u0645\u0627 \u062b\u0645\u0651\u0646 \u0645\u0639\u0627\u0644\u064a\u0647 \u0