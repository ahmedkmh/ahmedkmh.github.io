0627\u062f\u0629 \u0645\u062f\u0631\u0628\u0647\u0645 \u0627\u0644\u062d\u0627\u0644\u064a\u060c \u062e\u0633\u0650\u0631\u0648\u0627 \u0645\u0646\u0647\u0627 8\u060c \u0645\u0642\u0627\u0628\u0644 16 \u0641\u0648\u0632\u064b\u0627 \u06486 \u062a\u0639\u0627\u062f\u0644\u0627\u062a.\u0648\u0647\u064f\u0632\u0650\u0645 \u0627\u0644\u0627\u062a\u062d\u0627\u062f 1- 3 \u0645\u0646 \u0627\u0644\u0631\u064a\u0627\u0636 \u0645\u0633\u0627\u0621 \u0627\u0644\u062c\u0645\u0639\u0629 \u0636\u0645\u0646 \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u0640 26 \u0645\u0646 \u0645\u0648\u0633\u0645 \u0627\u0644\u062f\u0648\u0631\u064a \u00ab\u062c\u0648\u0644\u0629 \u064a\u0648\u0645 \u0627\u0644\u0639\u0644\u0645\u00bb\u060c \u0628\u0639\u062f \u0627\u0644\u062e\u0633\u0627\u0631\u0629 \u0628\u0627\u0644\u0646\u062a\u064a\u062c\u0629 \u0630\u0627\u062a\u0647\u0627 \u0645\u0646 \u0627\u0644\u0627\u0654\u0647\u0644\u064a\u060c \u0641\u064a \u062f\u064a\u0631\u0628\u064a \u062c\u062f\u0629\u060c \u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u0640 25.\u0648\u0642\u0627\u062f \u0628\u0644\u0627\u0646 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0641\u064a 46 \u0645\u0628\u0627\u0631\u0627\u0629\u060c \u062e\u0633\u0631 \u0627\u062b\u0646\u062a\u0627\u0646 \u0641\u0642\u0637 \u0641\u064a \u0627\u0644\u0640 30 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0648\u062a\u0639\u0631\u0651\u0636 \u0627\u0655\u0644\u0649 \u0627\u0644\u0647\u0632\u064a\u0645\u0629 \u0627\u0644\u062b\u0627\u0644\u062b\u0629 \u0641\u064a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0640 32.\u0648\u0641\u064a \u0645\u0628\u0627\u0631\u064a\u0627\u062a\u0647 \u0627\u0644\u0633\u0628\u0639 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0645\u0639 \u0627\u0644\u0641\u0631\u064a\u0642\u060c \u062a\u0639\u0631\u0651\u0636 \u0627\u0655\u0644\u0649 \u062b\u0644\u0627\u062b \u0647\u0632\u0627\u064a\u0654\u0645\u060c \u0643\u0644\u0651\u0641\u062a\u0647 \u0645\u0646\u0635\u0628\u0647.\u0648\u062d\u0627\u0644\u064a\u064b\u0627\u060c \u064a\u062d\u062a\u0644 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0633\u0627\u062f\u0633 \u0641\u064a \u062c\u062f\u0648\u0644 \u00ab\u0631\u0648\u0634\u0646\u00bb\u060c \u0628\u0631\u0635\u064a\u062f 42 \u0646\u0642\u0637\u0629\u060c \u0645\u0646 12 \u0641\u0648\u0632\u064b\u0627 \u06486 \u062a\u0639\u0627\u062f\u0644\u0627\u062a \u0645\u0642\u0627\u0628\u0644 8 \u0647\u0632\u0627\u064a\u0654\u0645\u060c \u0633\u0628\u0639\u064c \u0645\u0646\u0647\u0627 \u0645\u0639 \u0627\u0644\u0645\u062f\u0631\u0628 \u0627\u0644\u062d\u0627\u0644\u064a.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0622\u062e\u0631 \u0627\u0644\u0623\u062e\u0628\u0627\u0631"], "creator": ["\u0635\u062d\u064a\u0641\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629"], "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-03-13 23:09:18", "pubDateTZ": "UTC", "fetched_at": "2026-03-14 00:18:06", "image_url": "https://arriyadiyah.com//media/thumb/ec/b7/1024_2953c53b06.jpg", "video_url": null, "source_id": "arriyadiyah", "source_name": "\u0627\u0644\u0631\u064a\u0627\u062f\u064a\u0629", "source_priority": 1120412, "source_url": "https://arriyadiyah.com", "source_icon": "https://n.bytvi.com/arriyadiyah.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "6677406344e6063e2f7c6e89c8128213", "link": "https://albiladdaily.com/2026/03/14/690262/", "title": "\u0627\u0654\u0644\u0628\u0627\u0646\u064a\u0627.. \u0627\u0654\u0648\u0644 \u062f\u0648\u0644\u0629 \u062a\u0646\u0636\u0645 \u0