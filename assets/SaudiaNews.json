9%85%D8%B3%D9%88%D8%AF%D8%A9-%D8%A7%D9%84%D8%AA%D9%81%D8%A7%D9%87%D9%85-%D8%A7%D9%84%D9%86%D9%87%D8%A7%D8%A6%D9%8A%D8%A9-%D8%A8%D9%8A%D9%86-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86-%D9%88%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D8%A7\" target=\"_blank\">\u0628\u0627\u0643\u0633\u062a\u0627\u0646</a> \u0627\u0644\u062a\u0648\u0635\u0644 \u0627\u0655\u0644\u0649 \u0627\u062a\u0641\u0627\u0642 \u0628\u064a\u0646 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0648<a href=\"https://www.alyaum.com/articles/6666958/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D8%B3%D8%A4%D9%88%D9%84-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A-%D8%B7%D9%87%D8%B1%D8%A7%D9%86-%D9%88%D8%A7%D9%81%D9%82%D8%AA-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%AA%D8%AE%D9%84%D9%8A-%D8%B9%D9%86-%D8%A7%D9%84%D9%86%D9%88%D9%88%D9%8A\" target=\"_blank\">\u0627\u0655\u064a\u0631\u0627\u0646</a>\u060c \u0648\u062d\u0633\u0628 \u0642\u0646\u0627\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629\u060c \u0641\u0642\u062f \u0627\u0654\u0643\u062f\u062a \u0628\u0627\u0643\u0633\u062a\u0627\u0646 \u0627\u0654\u0646 \u0645\u0631\u0627\u0633\u0645 \u0627\u0644\u062a\u0648\u0642\u064a\u0639 \u0639\u0644\u0649 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0633\u062a\u062c\u0631\u064a \u0641\u064a \u0633\u0648\u064a\u0633\u0631\u0627 \u064a\u0648\u0645 19 \u064a\u0648\u0646\u064a\u0648 \u0627\u0644\u062d\u0627\u0644\u064a.<br />\u0648\u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0637\u0631\u0641\u064a\u0646 \u0627\u062a\u0641\u0642\u0627 \u0639\u0644\u0649 \u0648\u0642\u0641 \u0643\u0644 \u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u0641\u0648\u0631\u064b\u0627 \u0648\u0628\u0634\u0643\u0644 \u062f\u0627\u064a\u0654\u0645 \u0639\u0644\u0649 \u062c\u0645\u064a\u0639 \u0627\u0644\u062c\u0628\u0647\u0627\u062a \