64a\u062c\u0627\u0628\u064a\u0629 \u062e\u0644\u0627\u0644 \u0644\u0642\u0627\u064a\u0654\u0647 \u0645\u0639 \u0646\u0638\u064a\u0631\u0647 \u0627\u0644\u0633\u0648\u064a\u062f\u064a \u0641\u064a \u0645\u0633\u062a\u0647\u0644 \u0645\u0628\u0627\u0631\u064a\u0627\u062a\u0647\u0645\u0627 \u0641\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 2026 \u0627\u0644\u0630\u064a \u064a\u0644\u0639\u0628 \u0628\u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0648\u0627\u0644\u0645\u0643\u0633\u064a\u0643 \u0648\u0643\u0646\u062f\u0627. \u0648\u064a\u0644\u062a\u0642\u064a \u0645\u0646\u062a\u062e\u0628 \u062a\u0648\u0646\u0633 \u0645\u0639 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0648\u064a\u062f\u064a\u060c \u0635\u0628\u0627\u062d \u0627\u0644\u0627\u0655\u062b\u0646\u064a\u0646 \u0641\u064a \u0645\u062f\u064a\u0646\u0629 \u0645\u0648\u0646\u062a\u064a\u0631\u064a \u0627\u0644\u0645\u0643\u0633\u064a\u0643\u064a\u0629\u060c \u0641\u064a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0644\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u0633\u0627\u062f\u0633\u0629 \u0645\u0646 \u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0644\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644\u060c \u0627\u0644\u062a\u064a \u062a\u0636\u0645 \u0627\u0654\u064a\u0636\u064b\u0627 \u0645\u0646\u062a\u062e\u0628\u064a \u0647\u0648\u0644\u0646\u062f\u0627 \u0648\u0627\u0644\u064a\u0627\u0628\u0627\u0646. \u0648\u064a\u0641\u0635\u0644 \u0628\u064a\u0646 \u0627\u0644\u0633\u0648\u064a\u062f \u0648\u062a\u0648\u0646\u0633 \u0633\u0628\u0639\u0629 \u0645\u0631\u0627\u0643\u0632 \u0641\u064a \u0627\u0644\u062a\u0635\u0646\u064a\u0641 \u0627\u0644\u0639\u0627\u0644\u0645\u064a \u0627\u0644\u0627\u0654\u062e\u064a\u0631 \u0644\u0644\u0645\u0646\u062a\u062e\u0628\u0627\u062a\u060c \u0627\u0644\u0635\u0627\u062f\u0631 \u0639\u0646 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u062f\u0648\u0644\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u00ab\u0641\u064a\u0641\u0627\u00bb\u060c \u062d\u064a\u062b \u064a\u062a\u0648\u0627\u062c\u062f \u0645\u0646\u062a\u062e\u0628 \u00ab\u0627\u0644\u0641\u0627\u064a\u0643\u0646\u062c\u00bb \u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u064038 \u0639\u0627\u0644\u0645\u064a\u064b\u0627\u060c \u0641\u064a\u0645\u0627 \u064a\u062d\u062a\u0644 \u0645\u0646\u062a\u062e\u0628 \u00ab\u0646\u0633\u0648\u0631 \u0642\u0631\u0637\u0627\u062c\u00bb \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u064045. \u0648\u064a\u0634\u0627\u0631\u0643 \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0633\u0648\u064a\u062f \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u064013 \u0641\u064a \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0637\u0645\u062d \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u062a\u0648\u0646\u0633\u064a \u0644\u0628\u0644\u0648\u063a \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0627\u0644\u0627\u0655\u0642\u0635\u0627\u064a\u0654\u064a\u0629 \u0628\u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0641\u064a \u0645\u062d\u0627\u0648\u0644\u062a\u0647 \u0627\u0644\u0633\u0627\u0628\u0639\u0629 \u0641\u064a \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629. \u0648\u0627\u0654\u062b\u0627\u0631\u062a \u0628\u0637\u0648\u0644\u0629 \u062f\u0648\u0631\u064a \u0627\u0654\u0645\u0645 \u0627\u0654\u0648\u0631\u0648\u0628\u0627 \u062c\u062f\u0644\u064b\u0627 \u0648\u0627\u0633\u0639\u064b\u0627 \u0645\u0646\u0630 \u0627\u0646\u0637\u0644\u0627\u0642\u0647\u0627\u060c \u0648\u0644\u0643\u0646 \u0628\u0627\u0644\u0646\u0633\u0628\u0629 \u0644\u0644\u062c\u0645\u0627\u0647\u064a\u0631 \u0627\u0644\u0633\u0648\u064a\u062f\u064a\u0