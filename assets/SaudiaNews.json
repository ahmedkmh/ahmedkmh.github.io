627\u0646\u064a\u0629 \u0627\u0644\u0645\u0635\u0627\u062d\u0628\u0629 \u0644\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u0646\u0648\u0639\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0644\u062a\u0633\u0648\u0642 \u0648\u062a\u062d\u0636\u064a\u0631 \u0645\u0633\u062a\u0644\u0632\u0645\u0627\u062a \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631 \u0627\u0644\u0645\u0628\u0627\u0631\u0643\u060c \u0641\u064a \u0628\u064a\u064a\u0654\u0629 \u062a\u0633\u0648\u062f\u0647\u0627 \u0631\u0648\u062d \u0627\u0644\u0627\u0654\u0644\u0641\u0629 \u0648\u0627\u0644\u0628\u0647\u062c\u0629\u060c \u0648\u062a\u062a\u064a\u062d \u0641\u0631\u0635\u064b\u0627 \u0644\u0644\u0627\u0655\u0628\u062f\u0627\u0639 \u0648\u062a\u0645\u0643\u064a\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0635\u063a\u064a\u0631\u0629.\u0648\u064a\u0633\u062a\u0645\u062a\u0639 \u0632\u0648\u0627\u0631 \u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0629 \u0627\u0654\u064a\u0636\u064b\u0627 \u0628\u0645\u0646\u0638\u0631 \u063a\u0631\u0648\u0628 \u0627\u0644\u0634\u0645\u0633 \u0627\u0644\u0633\u0627\u062d\u0631 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0648\u062c\u0647\u0629 \u0627\u0644\u0634\u0627\u0637\u064a\u0654\u064a\u0629 \u0627\u0644\u0631\u0627\u064a\u0654\u0639\u0629\u060c \u0627\u0644\u062a\u064a \u062a\u0636\u0645 \u0645\u0645\u0631\u064b\u0627 \u0628\u062d\u0631\u064a\u064b\u0627 \u0628\u0637\u0648\u0644 (370) \u0645\u062a\u0631\u064b\u0627\u060c \u0648\u0645\u0645\u0634\u0649 \u0631\u064a\u0627\u0636\u064a\u064b\u0627 \u064a\u0645\u062a\u062f \u0644\u0645\u0633\u0627\u0641\u0629 (8) \u0643\u064a\u0644\u0648\u0645\u062a\u0631\u0627\u062a\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0645\u0633\u0627\u0631 \u0644\u0644\u062f\u0631\u0627\u062c\u0627\u062a \u0628\u0637\u0648\u0644 (2) \u0643\u064a\u0644\u0648\u0645\u062a\u0631\u060c \u0645\u0639 \u062a\u0648\u0641\u0631 \u0646\u062d\u0648 (1,200) \u0645\u0648\u0642\u0641 \u0644\u0644\u0633\u064a\u0627\u0631\u0627\u062a\u060c \u0645\u0627 \u064a\u062c\u0639\u0644\u0647\u0627 \u0648\u062c\u0647\u0629 \u0645\u062b\u0627\u0644\u064a\u0629 \u0644\u0644\u0639\u0627\u064a\u0654\u0644\u0627\u062a \u0648\u0627\u0644\u0632\u0648\u0627\u0631 \u0627\u0644\u0628\u0627\u062d\u062b\u064a\u0646 \u0639\u0646 \u062a\u062c\u0631\u0628\u0629 \u0631\u0645\u0636\u0627\u0646\u064a\u0629 \u0645\u0645\u064a\u0632\u0629 \u0639\u0644\u0649 \u0634\u0627\u0637\u064a\u0654 \u0627\u0644\u0628\u062d\u0631. \u062a\u062c\u0631\u0628\u0629 \u0631\u0645\u0636\u0627\u0646\u064a\u0629 \u0645\u062a\u0643\u0627\u0645\u0644\u0629\u0648\u062a\u0634\u0645\u0644 \u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0629\u060c \u0627\u0644\u062a\u064a \u062a\u0633\u062a\u0645\u0631 \u062d\u062a\u0649 \u0646\u0647\u0627\u064a\u0629 \u0634\u0647\u0631 \u0631\u0645\u0636\u0627\u0646\u060c \u062a\u062c\u0631\u0628\u0629 \u0631\u0645\u0636\u0627\u0646\u064a\u0629 \u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u062a\u062c\u0645\u0639 \u0627\u0644\u062c\u0648\u0627\u0646\u0628 \u0627\u0644\u062b\u0642\u0627\u0641\u064a\u0629 \u0648\u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0648\u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629\u060c \u0628\u0645\u0634\u0627\u0631\u0643\u0629 \u0648\u0627\u0633\u0639\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0633\u0631 \u0627\u0644\u0645\u0646\u062a\u062c\u0629 \u0627\u0644\u062a\u064a \u062a\u0639\u0631\u0636 \u0627\u0644\u0645\u0627\u0654\u0643\u0648\u0644\u0627\u062a \u0627\u0644\u0634\u0639\u0628\u064a\u0629 \u0648\u0627\u0644\u0645\u0634\u0631\u0648\u0628\u0627\u062a \u0627\u0644\u0631\u0645\u0636\u0627\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u062a\u0635\u062f\u0631 \u0645\u0648\u0627\u064a\u0654\u062f \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0643\u0631\u064a\u0645 \u0639\u0628\u0631 \u0627\u0654\u0631\u0643\u0627\u0646 \u0645\u062e\u0635\u0635\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u062