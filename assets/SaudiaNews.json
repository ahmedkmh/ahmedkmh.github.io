\u0d2e\u0d41\u200b\u0d16\u0d4d\u0d2f\u200b\u0d2a\u0d4d\u0d30\u200b\u0d2d\u0d3e\u200b\u0d37\u200b\u0d23\u200b\u0d35\u0d41\u0d02 \u0d2c\u0d47\u0d3e\u200b\u0d27\u200b\u0d35\u200b\u0d24\u0d4d\u0d15\u200b\u0d30\u200b\u0d23 \u0d15\u0d4d\u0d32\u0d3e\u200b\u0d38\u0d41\u0d02 \u0d28\u200b\u0d2f\u0d3f\u200b\u0d1a\u0d4d\u0d1a\u0d41. \u0d2c\u0d3f.\u200b\u0d21\u0d3f.\u200b\u0d15\u0d46 \u0d15\u0d41\u200b\u0d35\u0d48\u200b\u0d24\u0d4d\u0d24\u0d4d \u0d2a\u0d4d\u0d30\u200b\u0d24\u0d3f\u200b\u0d28\u0d3f\u200b\u0d27\u0d3f \u0d28\u200b\u0d33\u0d3f\u200b\u0d28\u0d3e\u200b\u0d15\u0d4d\u0d37\u200b\u0d7b \u0d15\u0d3e\u200b\u0d38\u200b\u0d7c\u200b\u0d15\u0d47\u0d3e\u200b\u0d1f\u0d4d, \u0d2c\u200b\u0d39\u0d4d\u0d31\u0d48\u200b\u0d7b \u0d2a\u0d4d\u0d30\u200b\u0d24\u0d3f\u200b\u0d28\u0d3f\u200b\u0d27\u0d3f \u0d38\u200b\u0d28\u0d47\u0d3e\u200b\u0d1c\u0d4d \u0d2d\u0d3e\u200b\u0d38\u0d4d\u0d15\u200b\u0d7c, \u0d31\u0d3f\u200b\u0d2f\u0d3e\u200b\u0d26\u0d3f\u200b\u0d32\u0d46 \u0d38\u0d3e\u200b\u0d2e\u0d42\u200b\u0d39\u0d3f\u200b\u0d15 \u0d2a\u0d4d\u0d30\u200b\u0d35\u200b\u0d7c\u200b\u0d24\u0d4d\u0d24\u200b\u0d15\u200b\u0d30\u0d3e\u200b\u0d2f \u0d36\u0d3f\u200b\u0d39\u0d3e\u200b\u0d2c\u0d4d \u0d15\u0d46\u0d3e\u200b\u0d1f\u0d4d\u0d1f\u0d41\u200b\u0d15\u0d3e\u200b\u0d1f\u0d4d, \u0d24\u0d46\u0d3e\u200b\u0d2e\u0d4d\u0d2e\u0d3f\u200b\u0d1a\u0d4d\u0d1a\u200b\u0d7b \u0d15\u0d41\u200b\u0d1f\u0d4d\u0d1f\u200b\u0d28\u0d3e\u200b\u0d1f\u0d4d, \u0d28\u0d3f\u200b\u0d39\u0d3e\u200b\u0d38\u0d4d \u0d2a\u0d3e\u200b\u0d28\u0d42\u200b\u0d7c, \u0d30\u0d3e\u200b\u0d1c\u0d3e \u0d38\u0d3e\u200b\u0d39\u0d3f\u200b\u0d2c\u0d4d, \u0d31\u0d3f\u200b\u0d2f\u0d3e\u200b\u0d38\u0d4d \u0d35\u200b\u0d23\u0d4d\u0d1f\u0d42\u200b\u0d7c, \u0d05\u200b\u0d37\u200b\u0d31\u200b\u0d2b\u0d4d \u0d2a\u0d3e\u200b\u0d32\u200b\u0d15\u0d4d\u0d15\u0d3e\u200b\u0d1f\u0d4d, \u0d37\u0d46\u200b\u0d30\u0d40\u200b\u0d2b\u0d4d, \u0d05\u200b\u0d2c\u0d4d\u200b\u200b\u0d26\u0d41\u200b\u0d7d \u0d28\u0d3e\u200b\u0d38\u200b\u0d7c \u0d0e\u200b\u0d28\u0d4d\u0d28\u0d3f\