u0631 2603 \u0627\u0654\u064a\u0627\u0645 \u0639\u0644\u0649 \u0645\u0644\u0639\u0628 \u0632\u0639\u0628\u064a\u0644 \u0641\u064a \u062f\u0628\u064a\u060c \u0627\u0644\u0627\u0654\u062d\u062f\u060c \u0641\u064a \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0653\u0633\u064a\u0627 2. \u0648\u0643\u0627\u0646\u062a \u0627\u0653\u062e\u0631 \u0645\u0648\u0627\u062c\u0647\u0629 \u0644\u0639\u0628\u0647\u0627 \u0627\u0644\u0646\u0635\u0631 \u0639\u0644\u0649 \u0645\u0644\u0639\u0628 \u0632\u0639\u0628\u064a\u0644 4 \u0645\u0627\u0631\u0633 2019\u060c \u062d\u064a\u0646\u0645\u0627 \u062d\u0644\u064e\u0651 \u0636\u064a\u0641\u064b\u0627 \u0639\u0644\u0649 \u0627\u0644\u0648\u0635\u0644 \u0641\u064a \u062f\u0648\u0631 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0645\u0646 \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0653\u0633\u064a\u0627\u060c \u0648\u062e\u0633\u0631 \u062d\u064a\u0646\u0647\u0627 \u0628\u0646\u062a\u064a\u062c\u0629 0\u06401. \u0648\u062a\u0627\u0654\u0647\u0644 \u0627\u0644\u0646\u0635\u0631 \u0627\u0655\u0644\u0649 \u0631\u0628\u0639 \u0646\u0647\u0627\u064a\u0654\u064a \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0653\u0633\u064a\u0627 2\u060c \u0628\u0639\u062f\u0645\u0627 \u0646\u062c\u062d \u0641\u064a \u062a\u0635\u062f\u0631 \u0645\u062c\u0645\u0648\u0639\u062a\u0647 \u0628\u0627\u0644\u0639\u0644\u0627\u0645\u0629 \u0627\u0644\u0643\u0627\u0645\u0644\u0629\u060c \u062b\u0645 \u062a\u062c\u0627\u0648\u0632 \u0646\u0638\u064a\u0631\u0647 \u0627\u0654\u0631\u0643\u0627\u062f\u0627\u062c \u0627\u0644\u062a\u0631\u0643\u0645\u0627\u0646\u0633\u062a\u0627\u0646\u064a \u0641\u064a \u062f\u0648\u0631 \u0627\u0644\u064016. \u0648\u062a\u0635\u062f\u0631 \u0627\u0644\u0648\u0635\u0644 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0628\u0631\u0635\u064a\u062f 14 \u0646\u0642\u0637\u0629 \u0645\u0646 \u0633\u062a \u0645\u062