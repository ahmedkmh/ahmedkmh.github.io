a\u0633\u064a.. \u0647\u0630\u0647 \u0627\u0644\u0645\u0631\u0651\u0629 \u0645\u0646 \u0628\u0627\u0628 \u0627\u0644\u062a\u0645\u0631\u064a\u0631\u0627\u062a \u0627\u0644\u062d\u0627\u0633\u0645\u0629", "description": "\u0633\u0637\u0651\u0631 \u0627\u0644\u0627\u0654\u0633\u0637\u0648\u0631\u0629 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a\u0629 \u0644\u064a\u0648\u0646\u064a\u0644 \u0645\u064a\u0633\u064a \u0641\u0635\u0644\u0627\u064b \u062a\u0627\u0631\u064a\u062e\u064a\u0627\u064b \u062c\u062f\u064a\u062f\u0627\u064b \u0641\u064a \u0645\u0633\u064a\u0631\u062a\u0647 \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644\u064a\u0629 \u0627\u0644\u062d\u0627\u0641\u0644\u0629\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0654\u0635\u0628\u062d \u0627\u0654\u0648\u0644 \u0644\u0627\u0639\u0628 \u064a\u0646\u062c\u062d \u0641\u064a \u0635\u0646\u0627\u0639\u0629 10 \u0627\u0654\u0647\u062f\u0627\u0641 \u0643\u0627\u0645\u0644\u0629 \u0641\u064a \u0628\u0637\u0648\u0644\u0627\u062a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 \u0645\u0646\u0630 \u0639\u0627\u0645 1966.<!--TgQPHd||[]--><br />\u0648\u062c\u0627\u0621 \u0627\u0644\u0627\u0655\u0646\u062c\u0627\u0632 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a \u0645\u062a\u0632\u064a\u0646\u0627\u064b \u0628\u0645\u064a\u0632\u0629 \u0641\u0631\u064a\u062f\u0629 \u0648\u0646\u0627\u062f\u0631\u0629\u061b \u062d\u064a\u062b \u062a\u0628\u064a\u0646 \u0627\u0654\u0646 \u062c\u0645\u064a\u0639 \u0627\u0644\u062a\u0645\u0631\u064a\u0631\u0627\u062a \u0627\u0644\u062d\u0627\u0633\u0645\u0629 \u0627\u0644\u0639\u0634\u0631 \u0627\u0644\u062a\u064a \u0642\u062f\u0645\u0647\u0627 \"\u0627\u0644\u0628\u0631\u063a\u0648\u062b\" \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0644\u0645 \u064a\u062a\u0643\u0631\u0631 \u0641\u064a\u0647\u0627 \u0627\u0633\u0645 \u0627\u0654\u064a \u0644\u0627\u0639\u0628\u060c \u0628\u0644 \u0630\u0647\u0628\u062a \u0627\u0655\u0644