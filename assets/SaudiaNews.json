0646\u0627\u0639\u0629 \u0627\u0644\u062a\u0627\u0631\u064a\u062e \u0641\u064a \u0628\u0637\u0648\u0644\u0629 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026\u060c \u0628\u0639\u062f\u0645\u0627 \u062d\u062c\u0632 \u0628\u0637\u0627\u0642\u0629 \u0627\u0644\u062a\u0627\u0654\u0647\u0644 \u0627\u0655\u0644\u0649 \u0627\u0644\u062f\u0648\u0631 \u0631\u0628\u0639 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0628\u0641\u0648\u0632\u0647 \u0627\u0644\u0645\u0633\u062a\u062d\u0642 \u0639\u0644\u0649 \u0645\u0646\u062a\u062e\u0628 \u0643\u0646\u062f\u0627 \u0628\u062b\u0644\u0627\u062b\u064a\u0629 \u0646\u0638\u064a\u0641\u0629\u060c \u0641\u064a \u0627\u0655\u0646\u062c\u0627\u0632 \u062c\u062f\u064a\u062f \u064a\u0631\u0633\u062e \u0645\u0643\u0627\u0646\u0629 \"\u0627\u0654\u0633\u0648\u062f \u0627\u0644\u0627\u0654\u0637\u0644\u0633\" \u0643\u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0645\u0646\u062a\u062e\u0628\u0627\u062a \u0627\u0644\u0628\u0637\u0648\u0644\u0629.<br /><br />\u0648\u0633\u062c\u0644 \u0639\u0632 \u0627\u0644\u062f\u064a\u0646 \u0627\u0654\u0648\u0646\u0627\u062d\u064a \u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0644\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u0641\u064a \u0627\u0644\u062f\u0642\u064a\u0642\u062a\u064a\u0646 50 \u064882\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u062e\u062a\u062a\u0645 \u0633\u0641\u064a\u0627\u0646 \u0631\u062d\u064a\u0645\u064a \u0627\u0644\u062b\u0644\u0627\u062b\u064a\u0629 \u0628\u0647\u062f\u0641 \u0641\u064a \u0627\u0644\u062f\u0642\u064a\u0642\u0629 98\u060c \u0644\u064a\u0642\u0648\u062f \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0655\u0644\u0649 \u0645\u0648\u0627\u0635\u0644\u0629 \u0645\u0634\u0648\u0627\u0631\u0647 \u0641\u064a \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644 \u0628\u062b\u0642\u0629 \u0643\u0628\u064a\u0631\u0629.<br /><br />\u0648\u0648\u0641\u0642\u064b\u0627 \u0644\u0634\u0628\u0643\u0629 \"Opta\" \u0644\u0644\u0627\u0655\u062d\u0635\u0627\u064a\u0654\u064a\u0627\u062a\u060c \u0627\u0654\u0635\u0628\u062d \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0645\u063a\u0631\u0628 \u0627\u0654\u0648\u0644 \u0645\u0646\u062a\u062e\u0628 \u0639\u0631\u0628\u064a \u0648\u0627\u0655\u0641\u0631\u064a\u0642\u064a \u0641\u064a \u062a\u0627\u0631\u064a\u062e \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 \u064a\u0646\u062c\u062d \u0641\u064a \u0628\u0644\u0648\u063a \u0627\u0644\u062f\u0648\u0631 \u0631\u0628\u0639 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0641\u064a \u0646\u0633\u062e\u062a\u064a\u0646 \u0645\u062e\u062a\u0644\u0641\u062a\u064a\u0646\u060c \u0628\u0639\u062f\u0645\u0627 \u0633\u0628\u0642 \u0644\u0647 \u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0627\u0655\u0646\u062c\u0627\u0632 \u0630\u0627\u062a\u0647 \u0641\u064a \u0645\u0648\u0646\u062f\u064a\u0627\u0644 2022\u060c \u0644\u064a\u0648\u0654\u0643\u062f \u0627\u0633\u062a\u0645\u0631\u0627\u0631\u064a\u0629 \u0627\u0644\u0645\u0634\u0631\u0648\u0639 \u0627\u0644\u0643\u0631\u0648\u064a \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u0639\u0644\u0649 \u0627\u0644\u0633\u0627\u062d\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629.<br /><br />\u0648\u0644\u0645 \u062a\u062a\u0648\u0642\u0641 \u0627\u0655\u0646\u062c\u0627\u0632\u0627\u062a \"\u0627\u0654\u0633\u0648\u062f \u0627\u0644\u0627\u0654\u0637\u0644\u0633\" \u0639\u0646\u062f \u0647\u0630\u0627 \u0627\u0644\u062d\u062f\u060c \u0627\u0655\u0630 \u0639\u0632\u0632 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u0631\u0642\u0645\u0647 \u0627\u0644\u0642\u064a\u0627\u0633\u064a \u0643\u0627\u0654\u0643\u062b\u0631 \u0645\u0646\u062a\u062e\u0628 \u0639\u0631\u0628\u064a \u062a\u0633\u062c\u064a\u0644\u064b\u0627 \u0644\u0644\u0627\u0654\u0647\u062f\u0627\u0641 \u0641\u064a \u0646\u0633\u062e\u0629 \u0648\u0627\u062d\u062f\u0629 \u0645\u0646 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0628\u0639\u062f\u0645\u0627 \u0631\u0641\u0639 \u0631\u0635\u064a\u062f\u0647 \u0627\u0655\u0644\u0649 10 \u0627\u0654\u0647\u062f\u0627\u0641 \u0641\u064a \u0645\u0648\u0646\u062f\u064a\u0627\u0644 2026\u060c \u0645\u062a\u062c\u0627\u0648\u0632\u064b\u0627 \u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0633\u0627\u0628\u0642 \u0627\u0644\u0645\u0633\u062c\u0644 \u0628\u0627\u0633\u0645 \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u062c\u0632\u0627\u064a\u0654\u0631\u060c \u0627\u0644\u0630\u064a \u0627\u0654\u062d\u0631\u0632 7 \u0627\u0654\u0647\u062f\u0627\u0641 \u0641\u064a \u0646\u0633\u062e\u0629 2014.<br /><br />\u0643\u0645\u0627 \u0641\u0631\u0636 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u0647\u064a\u0645\u0646\u062a\u0647 \u0639\u0644\u0649 \u0633\u062c\u0644 \u0627\u0644\u0645\u0646\u062a\u062e\u0628\u0627\u062a \u0627\u0644\u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0629 \u0641\u064a \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0627\u0644\u0627\u0655\u0642\u0635\u0627\u064a\u0654\u064a\u0629 \u0644\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644\u060c \u0628\u0639\u062f\u0645\u0627 \u0628\u0627\u062a \u064a\u0645\u062a\u0644\u0643 \u0646\u0635\u0641 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0646\u062a\u0635\u0627\u0631\u0627\u062a \u0627\u0644\u0642\u0627\u0631\u0629 \u0627\u0644\u0633\u0645\u0631\u0627\u0621 \u0641\u064a \u062a\u0644\u0643 \u0627\u0644\u0645\u0631\u062d\u0644\u0629\u060c \u0645\u062d\u0642\u0642\u064b\u0627 4 \u0627\u0646\u062a\u0635\u0627\u0631\u0627\u062a \u0645\u0646 \u0627\u0654\u0635\u0644 8\u060c \u0628\u064a\u0646\u0645\u0627 \u062d\u0642\u0642\u062a \u0645\u0646\u062a\u062e\u0628\u0627\u062a \u0627\u0644\u0643\u0627\u0645\u064a\u0631\u0648\u0646 \u0648\u0627\u0644\u0633\u0646\u063a\u0627\u0644 \u0648\u063a\u0627\u0646\u0627 \u0648\u0645\u0635\u0631 \u0627\u0646\u062a\u0635\u0627\u0631\u064b\u0627 \u0648\u0627\u062d\u062f\u064b\u0627 \u0644\u0643\u0644 \u0645\u0646\u0647\u0627.<br /><br />\u0648\u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0641\u0646\u064a\u060c \u0642\u062f\u0645 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u0648\u0627\u062d\u062f\u0629 \u0645\u0646 \u0627\u0654\u0643\u062b\u0631 \u0645\u0628\u0627\u0631\u064a\u0627\u062a\u0647 \u0643\u0641\u0627\u0621\u0629 \u0647\u062c\u0648\u0645\u064a\u064b\u0627\u060c \u0628\u0639\u062f\u0645\u0627 \u0646\u062c\u062d \u0641\u064a \u062a\u062d\u0648\u064a\u0644 60% \u0645\u0646 \u062a\u0633\u062f\u064a\u062f\u0627\u062a\u0647 \u0627\u0655\u0644\u0649 \u0627\u0654\u0647\u062f\u0627\u0641\u060c \u0628\u062a\u0633\u062c\u064a\u0644 3 \u0627\u0654\u0647\u062f\u0627\u0641 \u0645\u0646 \u0627\u0654\u0635\u0644 5 \u062a\u0633\u062f\u064a\u062f\u0627\u062a\u060c \u0648\u0647\u064a \u0627\u0654\u0639\u0644\u0649 \u0646\u0633\u0628\u0629 \u062a\u062d\u0648\u064a\u0644 \u0644\u0644\u062a\u0633\u062f\u064a\u062f\u0627\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0647\u062f\u0627\u0641 \u064a\u0633\u062c\u0644\u0647\u0627 \u0645\u0646\u062a\u062e\u0628 \u0641\u064a \u0645\u0628\u0627\u0631\u0627\u0629 \u0628\u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0627\u0644\u0627\u0655\u0642\u0635\u0627\u064a\u0654\u064a\u0629 \u0644\u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 \u0645\u0646\u0630 \u0639\u0627\u0645 1966\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u0627\u0655\u062d\u0635\u0627\u064a\u0654\u064a\u0627\u062a \"Opta\".<br /><br />\u0648\u0634\u0647\u062f\u062a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0654\u064a\u0636\u064b\u0627 \u062a\u0627\u0654\u0644\u0642 \u0627\u0655\u0628\u0631\u0627\u0647\u064a\u0645 \u062f\u064a\u0627\u0632\u060c \u0627\u0644\u0630\u064a \u0648\u0627\u0635\u0644 \u062a\u0642\u062f\u064a\u0645 \u0645\u0633\u062a\u0648\u064a\u0627\u062a\u0647 \u0627\u0644\u0645\u0645\u064a\u0632\u0629\u060c \u0644\u064a\u0635\u0628\u062d \u0627\u