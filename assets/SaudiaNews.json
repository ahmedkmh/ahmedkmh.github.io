33\u0627\u0644\u0629 \u0648\u064f\u062c\u0651\u0647\u062a \u0627\u0655\u0644\u0649 \u0634\u0631\u0643\u0627\u062a \u0627\u0644\u0634\u062d\u0646\u060c \u062a\u064f\u0639\u0644\u0646 \u0639\u0646 \u062a\u0648\u0641\u0651\u0631 \u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0644\u062d\u0627\u0644\u0629 \u0627\u0644\u062a\u064a \u062a\u064f\u0645\u0643\u0651\u0646 \u0627\u0644\u0645\u064f\u0637\u0627\u0644\u0628\u064a\u0646 \u0645\u0646 \u0645\u062a\u0627\u0628\u0639\u0629 \u062d\u0627\u0644\u0629 \u0637\u0644\u0628\u0627\u062a \u0631\u062f \u0627\u0644\u0627\u0654\u0645\u0648\u0627\u0644. \u0648\u0641\u064a \u0642\u0631\u0627\u0631 \u0635\u0627\u062f\u0631 \u0639\u0646 <a href=\"https://www.alyaum.com/articles/6646895/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%A5%D8%B3%D9%82%D8%A7%D8%B7-%D8%B1%D8%B3%D9%88%D9%85-%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D8%A8%D8%A3%D9%85%D8%B1-%D8%A7%D9%84%D9%82%D8%B6%D8%A7%D8%A1-%D9%85%D9%86-%D9%8A%D8%AD%D8%B5%D9%84-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D9%85%D9%84%D9%8A%D8%A7%D8%B1%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D8%B3%D8%AA%D8%B1%D8%AF%D8%A9\" target=\"_blank\">\u0645\u062d\u0643\u0645\u0629 \u0627\u0644\u062a\u062c\u0627\u0631\u0629 \u0627\u0644\u062f\u0648\u0644\u064a\u0629</a> \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0643\u0627\u0646 \u0645\u0646 \u0627\u0644\u0645\u062a\u0648\u0642\u0639 \u0627\u0654\u0646 \u062a\u0628\u062f\u0627\u0654 \u0627\u0644\u0648\u0643\u0627\u0644\u0629 \u0639\u0645\u0644\u064a\u0627\u062a \u0631\u062f \u0627\u0644\u0627\u0654\u0645\u0648\u0627\u0644 \u0641\u064a \u062d\u0648\u0627\u0644\u064a 11 \u0645\u0627\u064a\u0648\u060c \u0648\u0644\u0645 \u064a\u064f\u0630\u0643\u0631 \u0633\u0628\u0628 \u0644\u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u062a\u0627\u0631\u064a\u062e. \u0648\u064a\u0635\u0644 \u062d\u062c\u0645 \u0627\u0644\u0645\u0628\u0627\u0644\u063a \u0627\u0644\u062a\u064a \u062a\u0639\u062a\u0