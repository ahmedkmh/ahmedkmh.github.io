8%B9-%D8%B1%D8%A6%D9%8A%D8%B3-%D9%88%D8%B2%D8%B1%D8%A7%D8%A1-%D8%A8%D8%A7%D9%83%D8%B3%D8%AA%D8%A7%D9%86\" target=\"_blank\">\u0631\u064a\u0654\u064a\u0633 \u0648\u0632\u0631\u0627\u0621 \u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0628\u0627\u0643\u0633\u062a\u0627\u0646</a> \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629\u060c \u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u062d\u062f\u060c \u0635\u0627\u062d\u0628 \u0627\u0644\u0633\u0645\u0648 <a href=\"https://www.alyaum.com/articles/6652886/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%88%D8%B2%D9%8A%D8%B1-%D8%A7%D9%84%D8%AE%D8%A7%D8%B1%D8%AC%D9%8A%D8%A9-%D9%8A%D8%B5%D9%84-%D8%A5%D9%84%D9%89-%D8%A5%D8%B3%D9%84%D8%A7%D9%85-%D8%A2%D8%A8%D8%A7%D8%AF-%D9%84%D9%84%D9%85%D8%B4%D8%A7%D8%B1%D9%83%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%A7%D8%AC%D8%AA%D9%85%D8%A7%D8%B9-%D8%A7%D9%84%D9%88%D8%B2%D8%A7%D8%B1%D9%8A-%D8%A7%D9%84%D8%B1%D8%A8%D8%A7%D8%B9%D9%8A\" target=\"_blank\">\u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0641\u064a\u0635\u0644 \u0628\u0646 \u0641\u0631\u062d\u0627\u0646</a> \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0644\u0647 <a href=\"https://www.alyaum.com/articles/6652939/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A8%D8%AD%D8%AB-%D8%AA%D8%B7%D9%88%D8%B1%D8%A7%D8%AA-%D8%A7%D9%84%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D9%88%D8%B2%D9%8A%D8%B1-%D8%A7%D9%84%D8%AE%D8%A7%D8%B1%D8%AC%D9%8A%D8%A9-%D9%8A%D8%B4%D8%A7%D8%B1%D9%83-%D9%81%D9%8A-%D8%A7%D9%84%D8%A7%D8%AC%D8%AA%D9%85%D8%A7%D8%B9-%D8%A7%D9%84%D9%88%D8%B2%D8%A7%D8%B1%D9%8A-%D8%A7%D9%84%D8%B1%D8%A8%D8%A7%D8%B9%D9%8A-%D8%A8%D8%A8%D8%A7%D9%83%D8%B3%D8%AA%D8%A7%D9%86\" target=\"_blank\">\u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629</a>\u060c \u0648\u0630\u0644\u0643 \u062e\u0644\u0627\u0644 \u0632\u064a\u0627\u0631\u0629 \u0633\u0645\u0648\u0647 \u0627\u0655\u0644\u0649 \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0627\u0655\u0633\u0644\u0627\u0645 \u0627\u0653\u0628\u0627\u062f \u0644\u0644\u0645\u0634\u0627\u0631\u0643\u0629 \u0641\u064a \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u0648\u0632\u0627\u0631\u064a \u0627\u0644\u0631\u0628\u0627\u0639\u064a.<br />\u0648\u0646\u0642\u0644 \u0633\u0645\u0648\u0647 \u0641\u064a \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u0627\u0633\u062a\u0642\u0628\u0627\u0644 \u062a\u062d\u064a\u0627\u062a \u062e\u0627\u062f\u0645 \u0627\u0644\u062d\u0631\u0645\u064a\u0646 \u0627\u0644\u0634\u0631\u064a\u0641\u064a\u0646 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0653\u0644 \u0633\u0639\u0648\u062f\u060c \u0648\u0635\u0627\u062d\u0628 \u0627\u0644\u0633\u0645\u0648 \u0627\u0644\u0645\u0644\u0643\u064a \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0645\u062d\u0645\u062f \u0628\u0646 \u0633\u0644\u0645\u0627\u0646 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0653\u0644 \u0633\u0639\u0648\u062f \u0648\u0644\u064a \u0627\u0644\u0639\u0647\u062f \u0631\u064a\u0654\u064a\u0633 \u0645\u062c\u0644\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 -\u062d\u0641\u0638\u0647\u0645\u0627 \u0627\u0644\u0644\u0647- \u0644\u062f\u0648\u0644\u062a\u0647\u060c \u0648\u062a\u0645\u0646\u064a\u0627\u062a\u0647\u0645\u0627 \u0644\u062d\u0643\u0648\u0645\u0629 \u062c\u0645\u0647\u0648\u0631\u064a\u0629 <a href=\"https://www.alyaum.com/articles/6621020/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A8%D8%A7%D9%83%D8%B3%D8%AA%D8%A7%D9%86-%D8%AA%D8%B9%D9%84%D9%86-%D9%85%D9%82%D8%AA%D9%84-23-%D9%85%D9%86-%D8%AC%D9%86%D9%88%D8%AF%D9%87%D8%A7-%D9%88200-%D8%A3%D9%81%D8%BA%D8%A7%D9%86%D9%8A-%D9%88%D8%AA%D8%AA%D9%88%D8%B9%D8%AF-%D8%A8-%D8%B1%D8%AF-%D9%82%D9%88%D9%8A\" target=\"_blank\">\u0628\u0627\u0643\u0633\u062a\u0627\u0646</a> \u0627\u0644\u0627\u0655\u0633\u064