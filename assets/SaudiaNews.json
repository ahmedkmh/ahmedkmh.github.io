0645\u0627 \u062a\u0627\u0654\u0647\u0644 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0628\u0639\u062f \u062a\u0635\u062f\u0631\u0647 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0628\u0631\u0635\u064a\u062f 10 \u0646\u0642\u0627\u0637\u060c \u0639\u0642\u0628 \u0641\u0648\u0632\u0647 \u0641\u064a \u0645\u0628\u0627\u0631\u0627\u062a\u064a\u0646 \u0648\u062a\u0639\u0627\u062f\u0644\u0647 \u0641\u064a \u0627\u0654\u0631\u0628\u0639 \u0627\u0654\u062e\u0631\u0649\u060c \u0648\u0641\u064a \u062b\u0645\u0646 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u062a\u062c\u0627\u0648\u0632 \u0633\u0628\u0627\u0647\u0627\u0646 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u062d\u064a\u062b \u062a\u0639\u0627\u062f\u0644 \u0645\u0639\u0647 \u0630\u0647\u0627\u0628\u0627\u064b 2-2 \u0642\u0628\u0644 \u0627\u0644\u0641\u0648\u0632 \u0627\u0655\u064a\u0627\u0628\u0627\u064b 1-0\u060c \u062b\u0645 \u0648\u0627\u062c\u0647 \u0627\u0644\u062d\u0633\u064a\u0646 \u0627\u0655\u0631\u0628\u062f \u0627\u0644\u0627\u0654\u0631\u062f\u0646\u064a \u0641\u064a \u0631\u0628\u0639 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0648\u0641\u0627\u0632 \u0639\u0644\u064a\u0647 3-1 .<br /><br />\u0648\u0642\u062f\u0645 \u0627\u0644\u0646\u0635\u0631 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0633\u0645 \u0645\u0633\u062a\u0648\u064a\u0627\u062a \u0643\u0628\u064a\u0631\u0629 \u0648\u0646\u062a\u0627\u064a\u0654\u062c \u0645\u0645\u064a\u0632\u0629\u060c \u0633\u0648\u0627\u0621\u064b \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0645\u062d\u0644\u064a \u0627\u0644\u0630\u064a \u064a\u062a\u0631\u0628\u0639 \u0639\u0644\u0649 \u0635\u062f\u0627\u0631\u062a\u0647 \u0627\u0654\u0648 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0628\u0637\u0648\u0644\u0629\u060c \u0641\u0647\u0648 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0648\u062d\u064a\u062f \u0627\u0644\u0630\u064a \u0644\u0645 \u064a\u062e\u0633\u0631 \u0627\u0654\u0648 \u064a\u062a\u0639\u0627\u062f\u0644 \u062e\u0644\u0627\u0644\u0647\u0627 \u0641\u064a \u0627\u0654\u064a \u0645\u0628\u0627\u0631\u0627\u0629\u060c \u0648\u064a\u0633\u0639\u0649 \u0647\u0630\u0627 \u0627\u0644\u0645\u0633\u0627\u0621 \u062c\u0627\u0647\u062f\u0627\u064b \u0644\u0645\u0648\u0627\u0635\u0644\u0629 \u0633\u0644\u0633\u0644\u0629 \u0627\u0646\u062a\u0635\u0627\u0631\u0627\u062a\u0647 \u0648\u0628\u0644\u0648\u063a \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0627\u0644\u0630\u064a \u0633\u064a\u0642\u0627\u0645 \u0639\u0644\u0649 \u0645\u0644\u0639\u0628\u0647 .<br /><br />\u0648\u064a\u0628\u0631\u0632 \u0641\u064a \u0635\u0641\u0648\u0641 \u0627\u0644\u0646\u0635\u0631 \u0642\u0627\u064a\u0654\u062f\u0647 \u0627\u0644\u0628\u0631\u062a\u063a\u0627\u0644\u064a \u0643\u0631\u064a\u0633\u062a\u064a\u0627\u0646\u0648 \u0631\u0648\u0646\u0627\u0644\u062f\u0648 \u0648\u0645\u0648\u0627\u0637\u0646\u0647 \u062c\u0648\u0627\u0648 \u0641\u064a\u0644\u064a\u0643\u0633 \u0648\u0627\u0644\u0633\u0646\u063a\u0627\u0644\u064a \u0633\u0627\u062f\u064a\u0648 \u0645\u0627\u0646\u064a\u060c \u0648\u0627\u0644\u0641\u0631\u0646\u0633\u064a \u0645\u062d\u0645\u062f \u0633\u064a\u0645\u0627\u0643\u0627\u0646 \u0648\u0645\u0648\u0627\u0637\u0646\u0647 \u0643\u064a\u0646\u063a\u0633\u0644\u064a \u0643\u0648\u0645\u0627\u0646 \u0648\u0627\u0644\u0628\u0631\u0627\u0632\u064a\u0644\u064a \u0627\u0655\u0646\u062c\u064a\u0644\u0648 \u062c\u0627\u0628\u0631\u064a\u064a\u0644 \u0648\u0627\u0644\u0643\u0631\u0648\u0627\u062a\u064a \u0645\u0627\u0631\u0633\u064a\u0644\u0648 \u0628\u0631\u0648\u0632\u0648\u0641\u064a\u062a\u0634\u060c \u0648\u0627\u0654\u064a\u0645\u0646 \u064a\u062d\u064a\u0649 \u0648\u0639\u0628\u062f\u0627\u0644\u0627\u0655\u0644\u0647 \u0627\u0644\u0639\u0645\u0631\u064a .<br /><br />\u0627\u0654\u0645\u0627 \u0627\u0644\u0627\u0654\u0647\u0644\u064a\u060c \u0641\u0631\u063a\u0645 \u0645\u0633\u062a\u0648\u064a\u0627\u062a\u0647 \u0627\