\u0644\u0645 \u064a\u062a\u0627\u0654\u062e\u0631 \u0627\u0644\u0635\u062f\u0649 \u0627\u0644\u0633\u0644\u0628\u064a \u062f\u0627\u062e\u0644 \u0627\u0654\u0631\u0648\u0642\u0629 \u0627\u0644\u062b\u0646\u0627\u064a\u0654\u064a \u0627\u0644\u0634\u064a\u0639\u064a\u060c \u062d\u064a\u062b \u0633\u0627\u0631\u0639\u062a \u0627\u0644\u0645\u0627\u0643\u064a\u0646\u0629 \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u0629 \u0644\u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0648\u062d\u0631\u0643\u0629 \u0627\u0654\u0645\u0644 \u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u00ab\u062a\u0633\u064a\u064a\u0633\u00bb \u0627\u0644\u062d\u0642\u064a\u0642\u0629 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629\u060c \u0641\u0641\u064a \u0645\u0648\u0642\u0641 \u064a\u0639\u0643\u0633 \u062d\u062c\u0645 \u0627\u0644\u0627\u0655\u0631\u0628\u0627\u0643\u060c \u0627\u0639\u062a\u0628\u0631 \u0627\u0644\u0645\u0639\u0627\u0648\u0646 \u0627\u0644\u0633\u064a\u0627\u0633\u064a \u0644\u0644\u0631\u064a\u0654\u064a\u0633 \u0646\u0628\u064a\u0647 \u0628\u0631\u064a \u0627\u0644\u0646\u0627\u064a\u0654\u0628 \u0639\u0644\u064a \u062d\u0633\u0646 \u062e\u0644\u064a\u0644 \u0627\u0654\u0646 \u062d\u0633\u0645 \u0635\u0641\u0629 \u0634\u064a\u0628\u0627\u0646\u064a \u0639\u0628\u0631 \u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \u064a\u0641\u062a\u0642\u0631 \u0644\u0644\u0627\u0654\u0635\u0648\u0644. \u0641\u064a \u0645\u062d\u0627\u0648\u0644\u0629 \u0648\u0627\u0636\u062d\u0629 \u0644\u0644\u0627\u0644\u062a\u0641\u0627\u0641 \u0639\u0644\u0649 \u0635\u0644\u0628 \u0627\u0644\u0627\u0654\u0632\u0645\u0629 \u0627\u0644\u0645\u062a\u0645\u062b\u0644 \u0641\u064a \u00ab\u0628\u0637\u0644\u0627\u0646 \u0627\u0644\u062a\u0645\u062b\u064a\u0644\u00bb.\u0648\u0641\u064a \u0630\u0627\u062a \u0627\u0644\u0633\u064a\u0627\u0642\u060c \u0642\u0627\u0644 \u0646\u0627\u064a\u0654\u0628 \u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0645\u062d\u0645\u062f \u0631\u0639\u062f \u0627\u0655\u0646\u06