28\u0640\"\u0627\u0644\u0633\u0627\u0641\u0627\u0646\u0627\"\u060c \u0639\u0646 \u0627\u0654\u0646 \u0642\u0648\u0627\u062a <a href=\"https://www.alyaum.com/articles/6660295/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D9%84%D8%B3%D9%88%D8%AF%D8%A7%D9%86-235-%D9%82%D8%AA%D9%8A%D9%84%D8%A7-%D8%A8%D9%8A%D9%86-%D8%A7%D9%84%D9%83%D9%88%D8%A7%D8%AF%D8%B1-%D8%A7%D9%84%D8%B7%D8%A8%D9%8A%D8%A9-%D8%A8%D9%86%D9%8A%D8%B1%D8%A7%D9%86-%D8%A7%D9%84%D8%AF%D8%B9%D9%85-%D8%A7%D9%84%D8%B3%D8%B1%D9%8A%D8%B9\" target=\"_blank\">\u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639</a> \u062a\u0633\u0639\u0649 \u0627\u0655\u0644\u0649 \u062a\u0642\u0633\u064a\u0645 <a href=\"https://www.alyaum.com/articles/6662572/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%B3%D8%A7%D8%B9%D8%AF%D8%A7%D8%AA-%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D9%88%D8%AF%D8%A7%D9%86-1594-%D8%B3%D9%84%D8%A9-%D8%BA%D8%B0%D8%A7%D8%A6%D9%8A%D8%A9-%D9%882000-%D9%83%D8%B1%D8%AA%D9%88%D9%86-%D8%AA%D9%85%D8%B1\" target=\"_blank\">\u0627\u0644\u0633\u0648\u062f\u0627\u0646</a>\u060c \u0645\u0648\u0654\u0643\u062f\u064b\u0627 \u0648\u062c\u0648\u062f \u0642\u0627\u062f\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0642\u0648\u0627\u062a \u064a\u0631\u0641\u0636\u0648\u0646 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062d\u0631\u0628 \u0648\u0641\u0643\u0631\u0629 \u062a\u0642\u0633\u064a\u0645 \u0627\u0644\u0628\u0644\u0627\u062f.</p><p>\u0648\u0642\u0627\u0644 \"\u0627\u0644\u0633\u0627\u0641\u0627\u0646\u0627\" \u0641\u064a \u0645\u0642\u0627\u0628\u0644\u0629 \u062e\u0627\u0635\u0629 \u0645\u0639 \u0642\u0646\u0627\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629\u060c \u0627\u0655\u0646 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u064a\u0633\u0639\u0649 \u0644\u0636\u0645 \u0643\u0631\u062f\u0641\u0627\u0646 \u0648\u062f\u0627\u0631\u0641\u0648\u0631\u060c \u0645\u0634\u064a\u0631\u064b\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u062d\u0631\u0628 \u0627\u0644\u062d\u0627\u0644\u064a\u0629 \u062a\u062c\u0627\u0648\u0632\u062a \u0627\u0654\u0647\u062f\u0627\u0641\u0647\u0627 \u0648\u0627\u0654\u0635\u0628\u062d\u062a \u062a\u0647\u062f\u062f \u0648\u062d\u062f\u0629 <a href=\"https://www.alyaum.com/articles/6662318/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D9%84%D8%A3%D9%85%D9%85-%D8%A7%D9%84%D9%85%D8%AA%D8%AD%D8%AF%D8%A9-%D8%AA%D8%B7%D9%84%D9%82-%D9%86%D8%AF%D8%A7%D8%A1-%D8%A5%D9%86%D8%B3%D8%A7%D9%86%D9%8A%D8%A7-%D9%84%D8%AF%D8%B9%D9%85-204-%D9%85%D9%84%D9%8A%D9%88%D9%86-%D8%B4%D8%AE%D8%B5-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D9%88%D8%AF%D8%A7%D9%86\" target=\"_blank\">\u0627\u0644\u0633\u0648\u062f\u0627\u0646 </a>\u0628\u0634\u0643\u0644 \u0645\u0628\u0627\u0634\u0631.</p><p>\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646 \u0628\u0639\u0636 \u0627\u0644\u0642\u064a\u0627\u062f\u0627\u062a \u062f\u0627\u062e\u0644 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0627\u0654\u0635\u0628\u062e\u062a \u0645\u0642\u062a\u0646\u0639\u0629 \u0628\u0639\u062f\u0645 \u062c\u062f\u0648\u0649 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062d\u0631\u0628\u060c \u0644\u0627\u0641\u062a\u064b\u0627 \u0627\u0655\u0644\u0649 \u0648\u062c\u0648\u062f \u062a\u0628\u0627\u064a\u0646\u0627\u062a \u062f\u0627\u062e\u0644\u064a\u0629 \u0628\u0634\u0627\u0654\u0646 \u0645\u0633\u062a\u0642\u0628\u0644 \u0627\u0644\u0635\u0631\u0627\u0639 \u0648\u0645\u0633\u0627\u0631 \u0627\u0644\u0642\u0648\u0627\u062a \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u0645\u0642\u0628\u0644\u0629.</p><h2>\u062a\u0641\u0643\u0643 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639</h2><p>\u0648\u0627\u0654\u0636\u0627\u0641 \"\u0627\u0644\u0633\u0627\u0641\u0627\u0646\u0627\" \u0627\u0654\u0646 \u0639\u0628\u062f \u0627\u0644\u0631\u062d\u064a\u0645 \u062f\u0642\u0644\u0648\u060c \u0634\u0642\u064a\u0642 \u0642\u0627\u064a\u0654\u062f \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0645\u062d\u0645\u062f \u062d\u0645\u062f\u0627\u0646 \u062f\u0642\u0644\u0648 \"\u062d\u0645\u064a\u062f\u062a\u064a\"\u060c \u064a\u062a\u0648\u0644\u0649 \u0639\u0645\u0644\u064a\u064b\u0627 \u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0639\u0627\u0631\u0643 \u0648\u0627\u0644\u0634\u0648\u0654\u0648\u0646 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0642\u0648\u0627\u062a\u060c \u0645\u0634\u064a\u0631\u064b\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0646\u0641\u0648\u0630\u0647 \u0627\u0644\u0645\u062a\u0632\u0627\u064a\u062f \u062a\u0633\u0628\u0628 \u0641\u064a \u062e\u0644\u0627\u0641\u0627\u062a \u062d\u0627\u062f\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0642\u064a\u0627\u062f\u0629.</p><p>\u0648\u0642\u0627\u0644 \u0627\u0655\u0646 \u062d\u0645\u064a\u062f\u062a\u064a \u0646\u0641\u0633\u0647 \u062d\u0630\u0631 \u0634\u0642\u064a\u0642\u0647 \u0641\u064a \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0645\u0646\u0627\u0633\u0628\u0629 \u0645\u0646 \u0627\u0654\u0646 \u0637\u0631\u064a\u0642\u0629 \u0627\u0655\u062f\u0627\u0631\u062a\u0647 \u0642\u062f \u062a\u0648\u0654\u062f\u064a \u0627\u0655\u0644\u0649 \u062a\u0641\u0643\u0643 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639\u060c \u0641\u064a \u0638\u0644 \u062a\u0635\u0627\u0639\u062f \u0627\u0644\u062a\u0648\u062a\u0631\u0627\u062a \u0648\u0627\u0644\u0627\u0646\u0642\u0633\u0627\u0645\u0627\u062a \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629 \u0628\u064a\u0646 \u0627\u0644\u0642\u0627\u062f\u0629 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u064a\u0646.</p><p>\u0648\u0627\u0654\u0648\u0636\u062d \u0627\u0644\u0642\u064a\u0627\u062f\u064a \u0627\u0644\u0645\u0646\u0634\u0642 \u0627\u0654\u0646 \u062a\u0647\u0645\u064a\u0634 \u0639\u0628\u062f \u0627\u0644\u0631\u062d\u064a\u0645 \u062f\u0642\u0644\u0648 \u0644\u0628\u0639\u0636 \u0627\u0644\u0642\u0627\u062f\u0629 \u0643\u0627\u0646 \u0633\u0628\u0628\u064b\u0627 \u0645\u0628\u0627\u0634\u0631\u064b\u0627 \u0641\u064a \u0627\u0646\u0634\u0642\u0627\u0642 \u0639\u062f\u062f \u0645\u0646\u0647\u0645 \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629\u060c \u0648\u0627\u0654\u0646 \u062d\u0627\u0644\u0629 \u0627\u0644\u0627\u0633\u062a\u064a\u0627\u0621 \u062f\u0627\u062e\u0644 \u0635\u0641\u0648\u0641 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u062a\u062a\u0632\u0627\u064a\u062f \u0645\u0639 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062d\u0631\u0628 \u0648\u0627\u0644\u062e\u0633\u0627\u064a\u0654\u0631 \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0648\u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629.<br /> </p><div data-oembed-url=\"https://x.com/AlArabiya/status/2056180470778401134\"><blockquote align=\"center\" class=\"twitter-tweet\" data-dnt=\"true\"><p dir=\"rtl\" lang=\"ar\">\u0627\u0644\u0642\u064a\u0627\u062f\u064a \u0627\u0644\u0645\u0646\u0634\u0642 \u0639\u0646 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \"\u0639\u0644\u064a \u0631\u0632\u0642 \u0627\u0644\u0633\u0627\u0641\u0627\u0646\u0627\" \u0644\u0640 \"\u0627\u0644\u0639\u0631\u0628\u064a\u0629\": \u0639\u0628\u062f\u0627\u0644\u0631\u062d\u064a\u0645 \u062f\u0642\u0644\u0648 \u064a\u062a\u0648\u0644\u0649 \u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0645\u0639\u0627\u0631\u0643 \u0648\u0627\u0644\u0634\u0648\u0654\u0648\u0646 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 <a href=\"https://t.co/Y3nIvq4kIT\">pic.twitter.com/Y3nIvq4kIT</a></p>\u2014 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 (@AlArabiya) <a href=\"https://twitter.com/AlArabiya/status/2056180470778401134?ref_src=twsrc%5Etfw\">May 18, 2026</a></blockquote> </div><h2>\u062f\u0645\u0627\u0631 \u0648\u0645\u0639\u0627\u0646\u0627\u0629 \u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629</h2><p>\u0648\u062a\u062d\u062f\u062b \u0627\u0644\u0633\u0627\u0641\u0627\u0646\u0627 \u0639\u0646 \u0628\u062f\u0627\u064a\u0627\u062a \u0627\u0644\u062d\u0631\u0628\u060c \u0642\u0627\u064a\u0654\u0644\u064b\u0627 \u0627\u0655\u0646 \u0642\u0648\u0627\u062a \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0647\u0627\u062c\u0645\u062a \u0627\u0644\u0645\u0631\u0627\u0641\u0642 \u0627\u0644\u0639\u0627\u0645\u0629 \u0639\u0646\u062f \u0627\u0646\u062f\u0644\u0627\u0639 \u0627\u0644\u062d\u0631\u0628\u060c \u0643\u0645\u0627 \u0641\u062a\u062d\u062a \u0643\u0644 \u0627\u0644\u0633\u062c\u0648\u0646.</p><p>\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646\u0647 \u0642\u0627\u062a\u0644 \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0641\u064a \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u062d\u0631\u0628\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u063a\u064a\u0631 \u0645\u0648\u0642\u0641\u0647 \u0644\u0627\u062d\u0642\u064b\u0627 \u0628\u0633\u0628\u0628 \u062d\u062c\u0645 \u0627\u0644\u062f\u0645\u0627\u0631 \u0648\u0627\u0644\u0645\u0639\u0627\u0646\u0627\u0629 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629\u060c \u0648\u0642\u0627\u0644 \u0627\u0655\u0646\u0647 \u0644\u0645 \u064a\u062a\u062d\u0645\u0644 \u0631\u0648\u0654\u064a\u0629 \u0627\u0644\u062d\u0631\u0628 \u0648\u062a\u0628\u0639\u0627\u062a\u0647\u0627\u060c \u0645\u0648\u0654\u0643\u062f\u0627 \u0627\u0654\u0646\u0647 \u0627\u0639\u062a\u064f\u0642\u0644 \u0641\u064a \u0628\u062f\u0627\u064a\u0629 \u0627\u0644\u062d\u0631\u0628 \u0645\u0646 \u0642\u0628\u0644 \u0642\u0648\u0627\u062a \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0646\u0641\u0633\u0647\u0627.</p><p>\u0643\u0645\u0627 \u0643\u0634\u0641 \u0639\u0646 \u0627\u0654\u0646\u0647 \u0642\u0636\u0649 \u062e\u0645\u0633 \u0633\u0646\u0648\u0627\u062a \u0641\u064a \u0627\u0644\u0633\u062c\u0646 \u0628\u0633\u0628\u0628 \u062e\u0644\u0627\u0641\u0627\u062a \u0633\u0627\u0628\u0642\u0629 \u0645\u0639 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639\u060c \u0645\u0646 \u062f\u0648\u0646 \u062a\u0642\u062f\u064a\u0645 \u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0655\u0636\u0627\u0641\u064a\u0629 \u0628\u0634\u0627\u0654\u0646 \u0637\u0628\u064a\u0639\u0629 \u062a\u0644\u0643 \u0627\u0644\u0642\u0636\u0627\u064a\u0627.</p><h2>\u062a\u062c\u0646\u064a\u062f \u0645\u0642\u0627\u062a\u0644\u064a\u0646 \u0645\u0646 \u062f\u0648\u0644 \u0627\u0644\u062c\u0648\u0627\u0631</h2><p>\u0648\u0642\u0627\u0644 \"\u0627\u0644\u0633\u0627\u0641\u0627\u0646\u0627\" \u0627\u0655\u0646 \u0642\u0648\u0627\u062a \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0641\u0631\u0636\u062a \u0633\u064a\u0637\u0631\u062a\u0647\u0627 \u0639\u0644\u0649 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0627\u062a \u0627\u0644\u0627\u0654\u0647\u0644\u064a\u0629 \u0641\u064a \u0628\u0639\u0636 \u0627\u0644\u0645\u0646\u0627\u0637\u0642 \u0628\u062a\u0647\u062f\u064a\u062f \u0627\u0644\u0633\u0644\u0627\u062d\u060c \u0645\u0634\u064a\u0631\u064b\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0630\u0644\u0643 \u0627\u0654\u062f\u0649 \u0627\u0655\u0644\u0649 \u0627\u0655\u0636\u0639\u0627\u0641 \u0627\u0644\u0628\u0646\u064a\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a\u0629 \u0648\u0632\u064a\u0627\u062f\u0629 \u0627\u0644\u0627\u0646\u0642\u0633\u0627\u0645\u0627\u062a \u062f\u0627\u062e\u0644 \u0627\u0644\u0645\u062c\u062a\u0645\u0639\u0627\u062a \u0627\u0644\u0645\u062d\u0644\u064a\u0629.<br /> </p><p>\u0648\u0643\u0634\u0641 \u0627\u0654\u064a\u0636\u064b\u0627 \u0639\u0646 \u0627\u0654\u0648\u0636\u0627\u0639 \u0648\u0635\u0641\u0647\u0627 \u0628\u0640\"\u0627\u0644\u0645\u0627\u0654\u0633\u0627\u0648\u064a\u0629\" \u062f\u0627\u062e\u0644 \u0633\u062c\u0646 \"\u062f\u0642\u0631\u064a\u0633\" \u0641\u064a \u0645\u062f\u064a\u0646\u0629 \u0646\u064a\u0627\u0644\u0627\u060c \u0645\u0634\u064a\u0631\u064b\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0645\u0639\u062a\u0642\u0644\u064a\u0646 \u064a\u0639\u064a\u0634\u0648\u0646 \u0638\u0631\u0648\u0641\u064b\u0627 \u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0635\u0639\u0628\u0629 \u0641\u064a \u0638\u0644 \u0646\u0642\u0635 \u0627\u0644\u063a\u0630\u0627\u0621 \u0648\u0627\u0644\u0631\u0639\u0627\u064a\u0629 \u0627\u0644\u0637\u0628\u064a\u0629 \u0648\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0643\u0627\u062a.</p><p>\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0644\u0642\u064a\u0627\u062f\u064a \u0627\u0644\u0645\u0646\u0634\u0642 \u0627\u0654\u0646 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u062a\u0639\u062a\u0645\u062f \u0628\u0634\u0643\u0644 \u0643\u0628\u064a\u0631 \u0639\u0644\u0649 \u062a\u062c\u0646\u064a\u062f \u0645\u0642\u0627\u062a\u0644\u064a\u0646 \u0645\u0646 \u062f\u0648\u0644 \u0627\u0644\u062c\u0648\u0627\u0631\u060c \u062e\u0635\u0648\u0635\u064b\u0627 \u0645\u0646 \u062a\u0634\u0627\u062f \u0648\u0627\u0655\u062b\u064a\u0648\u0628\u064a\u0627\u060c \u0645\u0648\u0636\u062d\u064b\u0627 \u0627\u0654\u0646 \u0627\u0644\u0645\u0642\u0627\u062a\u0644\u064a\u0646 \u0627\u0644\u0627\u0654\u062c\u0627\u0646\u0628 \u062f\u0627\u062e\u0644 \u0627\u0644\u0642\u0648\u0627\u062a \u064a\u0634\u0631\u0641 \u0639\u0644\u064a\u0647\u0645 \u062d\u0645\u064a\u062f\u062a\u064a \u0648\u0634\u0642\u064a\u0642\u0647 \u0628\u0634\u0643\u0644 \u0645\u0628\u0627\u0634\u0631.<br /><br /><br /> </p>", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["business", "top"], "datatype": "news", "pu