u0635\u0644 \u0628\u0646 \u0628\u0646\u062f\u0631 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0639\u0632\u064a\u0632 \u0627\u0654\u0645\u064a\u0631 \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u060c \u0627\u0644\u062c\u0645\u0639\u0629\u060c \u0627\u0644\u0645\u062d\u0633\u0646\u064a\u0646 \u0639\u0628\u0631 \u0627\u0644\u0645\u0646\u0635\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0644\u0644\u0639\u0645\u0644 \u0627\u0644\u062e\u064a\u0631\u064a (\u0627\u0655\u062d\u0633\u0627\u0646) \u062e\u0644\u0627\u0644 \u062d\u0641\u0644 \u0627\u0644\u062a\u0643\u0631\u064a\u0645 \u0627\u0644\u0633\u0646\u0648\u064a \u0627\u0644\u0631\u0627\u0628\u0639\u060c \u0627\u0644\u0630\u064a \u0627\u0654\u0642\u064a\u0645 \u0641\u064a \u0641\u0646\u062f\u0642 \u0627\u0644\u0631\u064a\u062a\u0632 \u0643\u0627\u0631\u0644\u062a\u0648\u0646 \u0628\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u060c \u0628\u062d\u0636\u0648\u0631 \u0639\u062f\u062f \u0645\u0646 \u0627\u0654\u0635\u062d\u0627\u0628 \u0627\u0644\u0645\u0639\u0627\u0644\u064a \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0648\u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0646\u060c \u0648\u062c\u0645\u0639 \u0645\u0646 \u0627\u0644\u0645\u062d\u0633\u0646\u064a\u0646\u060c \u062a\u0642\u062f\u064a\u0631\u064b\u0627 \u0645\u0646 \u0633\u0645\u0648 \u0648\u0644\u064a \u0627\u0644\u0639\u0647\u062f -\u0627\u0654\u064a\u062f\u0647 \u0627\u0644\u0644\u0647- \u0644\u0639\u0637\u0627\u0621\u0627\u062a \u0627\u0654\u0647\u0644 \u0627\u0644\u0628\u0631 \u0648\u0627\u0644\u0627\u0655\u062d\u0633\u0627\u0646\u060c \u0648\u0627\u0655\u0633\u0647\u0627\u0645\u0627\u062a\u0647\u0645 \u0641\u064a \u062f\u0639\u0645 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u062e\u064a\u0631\u064a\u0629 \u0641\u064a \u0645\u062e\u062a\u0644\u0641 \u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0645\u0645\u0644\u0643\u0629.\u0648\u0631\u0641\u0639 \u0633\u0645\u0648 \u0627\u0654\u06