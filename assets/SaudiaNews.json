u0627\u0644\u062c\u0645\u0639\u0629 \u0644\u064a\u0648\u0645 17 \u0631\u0645\u0636\u0627\u0646 \u0627\u0644\u062d\u0627\u0644\u064a\u060c \u0648\u0630\u0644\u0643 \u0636\u0645\u0646 \u0627\u0644\u062c\u062f\u0648\u0644\u0629 \u0627\u0644\u062f\u0648\u0631\u064a\u0629 \u0627\u0644\u0645\u0639\u062a\u0645\u062f\u0629 \u0644\u062a\u0646\u0638\u064a\u0645 \u0634\u0648\u0654\u0648\u0646 \u0627\u0644\u0627\u0655\u0645\u0627\u0645\u0629 \u0648\u0627\u0644\u062e\u0637\u0627\u0628\u0629 \u0641\u064a \u0627\u0644\u062d\u0631\u0645\u064a\u0646 \u0627\u0644\u0634\u0631\u064a\u0641\u064a\u0646.\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0644\u0631\u064a\u0654\u0627\u0633\u0629 \u0627\u0654\u0646 \u0627\u0644\u0634\u064a\u062e \u062f. \u064a\u0627\u0633\u0631 \u0627\u0644\u062f\u0648\u0633\u0631\u064a \u0633\u064a\u062a\u0634\u0631\u0641 \u0628\u0627\u0655\u0645\u0627\u0645\u0629 \u0627\u0644\u0645\u0635\u0644\u064a\u0646 \u0648\u0627\u0655\u0644\u0642\u0627\u0621 \u062e\u0637\u0628\u0629 \u0627\u0644\u062c\u0645\u0639\u0629 \u0645\u0646 \u0639\u0644\u0649 \u0645\u0646\u0628\u0631 \u0627\u0644\u0645\u0633\u062c\u062f \u0627\u0644\u062d\u0631\u0627\u0645 \u0641\u064a \u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629\u060c \u0644\u064a\u0635\u062f\u062d \u0628\u0635\u0648\u062a\u0647 \u0641\u064a \u0627\u0654\u0631\u062c\u0627\u0621 \u0627\u0644\u0628\u064a\u062a \u0627\u0644\u0639\u062a\u064a\u0642.\u0648\u0641\u064a \u0631\u062d\u0627\u0628 \u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0645\u0635\u0637\u0641\u0649\u060c \u0633\u064a\u062a\u0648\u0644\u0649 \u0627\u0644\u0634\u064a\u062e \u062f. \u062d\u0633\u064a\u0646 \u0627\u0653\u0644 \u0627\u0644\u0634\u064a\u062e \u0627\u0655\u0645\u0627\u0645\u0629 \u0627\u0644\u0645\u0635\u0644\u064a\u0646 \u0648\u0627\u0655\u0644\u0642\u0627\u0621 \u062e\u0637\u0628\u0629 \u0627\u0644\u062c\u0645\u0639\u0629 \u0641\u064a \u0627\u0644\u0645\u0633\u062c\u062f \u0627\u0644\u0646\u0628\u0648\u064a \u0627\u0644\u0634\u0631\u0