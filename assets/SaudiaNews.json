3%D8%A8%D8%A7%D8%AA-%D9%85%D8%AF%D9%86%D9%8A%D8%A9\" target=\"_blank\">\u0627\u0644\u0633\u0648\u062f\u0627\u0646</a> \u0627\u0654\u0646 \u0642\u0648\u0627\u062a <a href=\"https://www.alyaum.com/articles/6671486/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D9%84%D8%A3%D9%85%D9%85-%D8%A7%D9%84%D9%85%D8%AA%D8%AD%D8%AF%D8%A9-%D9%88%D9%86%D8%A7%D8%AC%D9%88%D9%86-%D9%8A%D8%B1%D9%88%D9%88%D9%86-%D8%AA%D9%81%D8%A7%D8%B5%D9%8A%D9%84-%D8%AC%D8%B1%D8%A7%D8%A6%D9%85-%D8%A7%D9%84%D8%AF%D8%B9%D9%85-%D8%A7%D9%84%D8%B3%D8%B1%D9%8A%D8%B9-%D8%BA%D8%B1%D8%A8-%D8%A7%D9%84%D8%B3%D9%88%D8%AF%D8%A7%D9%86\" target=\"_blank\">\u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639</a> \u0646\u0641\u0651\u0630\u062a \u0639\u0645\u0644\u064a\u0627\u062a \u0642\u062a\u0644 \u062c\u0645\u0627\u0639\u064a \u0648\u0627\u0646\u062a\u0647\u0627\u0643\u0627\u062a \u062c\u0633\u064a\u0645\u0629 \u0641\u064a \u0645\u062f\u064a\u0646\u0629 <a href=\"https://www.alyaum.com/articles/6670416/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D9%84%D8%B9%D9%81%D9%88-%D8%A7%D9%84%D8%AF%D9%88%D9%84%D9%8A%D8%A9-%D8%AA%D8%AA%D9%87%D9%85-%D8%A7%D9%84%D8%AF%D8%B9%D9%85-%D8%A7%D9%84%D8%B3%D8%B1%D9%8A%D8%B9-%D8%A8%D8%A7%D8%B1%D8%AA%D9%83%D8%A7%D8%A8-%D8%AC%D8%B1%D8%A7%D8%A6%D9%85-%D8%B6%D8%AF-%D8%A7%D9%84%D8%A5%D9%86%D8%B3%D8%A7%D9%86%D9%8A%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D9%81%D8%A7%D8%B4%D8%B1\" target=\"_blank\">\u0627\u0644\u0641\u0627\u0634\u0631</a>\u060c \u0645\u0634\u064a\u0631\u0629\u064b \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0643\u0627\u062a \u062a\u0642\u062f\u0645 \u0645\u0632\u064a\u062f\u064b\u0627 \u0645\u0646 \u0627\u0644\u0627\u0654\u062f\u0644\u0629 \u0639\u0644\u0649 \u0645\u0648\u0654\u0634\u0631\u0627\u062a \u0648\u0642\u0648\u0639 \u0627\u0655\u0628\u0627\u062f\u0629 \u062c\u0645\u0627\u0639\u064a\u0629.<br />\u0648\u062d\u0630\u0651\u0631\u062a \