5%D8%B3%D8%AA%D9%85%D8%B1-452-%D8%A5%D8%B5%D8%A7%D8%A8%D8%A9-%D9%85%D8%A4%D9%83%D8%AF%D8%A9-%D8%A8%D9%81%D9%8A%D8%B1%D9%88%D8%B3-%D8%A5%D9%8A%D8%A8%D9%88%D9%84%D8%A7-%D9%81%D9%8A-%D8%A7%D9%84%D9%83%D9%88%D9%86%D8%BA%D9%88\">\u0641\u064a\u0631\u0648\u0633 \u0627\u0655\u064a\u0628\u0648\u0644\u0627</a> \u0641\u064a <a href=\"https://www.alyaum.com/articles/6665420/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D9%86%D9%87%D8%A7-63-%D9%88%D9%81%D8%A7%D8%A9-%D8%A7%D8%B1%D8%AA%D9%81%D8%A7%D8%B9-%D8%AD%D8%B5%D9%8A%D9%84%D8%A9-%D8%A5%D8%B5%D8%A7%D8%A8%D8%A7%D8%AA-%D8%A5%D9%8A%D8%A8%D9%88%D9%84%D8%A7-%D9%81%D9%8A-%D8%A7%D9%84%D9%83%D9%88%D9%86%D8%BA%D9%88-%D8%A7%D9%84%D8%AF%D9%8A%D9%85%D9%82%D8%B1%D8%A7%D8%B7%D9%8A%D8%A9\">\u0648\u0633\u0637 \u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0627</a>\u060c \u0645\u0639\u0644\u0646\u0629 \u062a\u0633\u062c\u064a\u0644 \u0646\u062d\u0648 500 \u0627\u0655\u0635\u0627\u0628\u0629 \u0645\u0648\u0654\u0643\u062f\u0629 \u062d\u062a\u0649 \u0627\u0644\u0627\u0653\u0646\u060c \u0641\u064a \u0648\u0642\u062a \u062a\u062a\u0632\u0627\u064a\u062f \u0641\u064a\u0647 \u0627\u0644\u0645\u062e\u0627\u0648\u0641 \u0645\u0646 \u0627\u062a\u0633\u0627\u0639 \u0646\u0637\u0627\u0642 \u0627\u0646\u062a\u0634\u0627\u0631 \u0627\u0644\u0645\u0631\u0636.<br /><br />\u0648\u0627\u0654\u0638\u0647\u0631\u062a \u0627\u0654\u062d\u062f\u062b \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0635\u0627\u062f\u0631\u0629 \u0639\u0646 \u0627\u0644\u0645\u0646\u0638\u0645\u0629 \u062a\u0633\u062c\u064a\u0644 452 \u0627\u0655\u0635\u0627\u0628\u0629 \u0645\u0648\u0654\u0643\u062f\u0629\u060c \u0628\u064a\u0646\u0647\u0627 82 \u062d\u0627\u0644\u0629 \u0648\u0641\u0627\u0629\u060c \u0641\u064a \u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0627\u0644\u0643\u0648\u0646\u063a\u0648 \u0627\u0644\u062f\u064a\u0645\u0642\u0631\u0627\u0637\u064a\u0629\u060c \u062d\u064a\u062b \u0638\u0647\u0631 \u0627\u0644\u0648\u0628\u0627\u0621 \u0642\u0628\u0644 \u062b\u0644\u0627\u062b\u0629 \u0627\u0654\u0633\u0627\u0628\u064a\u0639\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 19 \u0627\u0655\u0635\u0627\u0628\u0629 \u0645\u0648\u0654\u0643\u062f\u0629 \u0628\u064a\u0646\u0647\u0627 \u062d\u0627\u0644\u062a\u0627 \u0648\u0641\u0627\u0629 \u0641\u064a \u0627\u0654\u0648\u063a\u0646\u062f\u0627 \u0627\u0644\u0645\u062c\u0627\u0648\u0631\u0629.<h2>\u0627\u0655\u0635\u0627\u0628\u0627\u062a \u0641\u064a\u0631\u0648\u0633 \u0627\u0655\u064a\u0628\u0648\u0644\u0627</h2>\u0648\u0628\u0630\u0644\u0643 \u0627\u0631\u062a\u0641\u0639 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0627\u0655\u0635\u0627\u0628\u0627\u062a \u0627\u0644\u0645\u0648\u0654\u0643\u062f\u0629 \u0641\u064a \u0627\u0644\u0628\u0644\u062f\u064a\u0646 \u0627\u0655\u0644\u0649 471 \u062d\u0627\u0644\u0629\u060c \u0628\u064a\u0646\u0647\u0627 84 \u0648\u0641\u0627\u0629\u060c \u0628\u0632\u064a\u0627\u062f\u0629 \u0628\u0644\u063a\u062a 100 \u0627\u0655\u0635\u0627\u0628\u0629 \u064820 \u0648\u0641\u0627\u0629 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0633\u0627\u0628\u0642.<br /><br />\u0648\u062d\u0630\u0651\u0631\u062a \u0627\u0644\u0645\u0631\u0627\u0643\u0632 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0644\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u0627\u0636 \u0648\u0627\u0644\u0648\u0642\u0627\u064a\u0629 \u0645\u0646\u0647\u0627 (CDC) \u0645\u0646 \u0627\u0654\u0646 \u0627\u0644\u062a\u0641\u0634\u064a \u0627\u0644\u062d\u0627\u0644\u064a\u060c \u0627\u0644\u0630\u064a \u0635\u0646\u0641\u062a\u0647 \u0645\u0646\u0638\u0645\u0629 \u0627\u0644\u0635\u062d\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629 \u00ab\u062d\u0627\u0644\u0629 \u0637\u0648\u0627\u0631\u064a\u0654 \u0635\u062d\u064a\u0629 \u0639\u0627\u0645\u0629 \u062a\u062b\u064a\u0631 \u0642\u0644\u0642\u064b\u0627 \u062f\u0648\u0644\u064a\u064b\u0627\u00bb\u060c \u0642\u062f \u064a\u0635\u0644 \u0627\u0655\u0644\u0649 \u0646\u0637\u0627\u0642 \u0645\u0645\u0627\u062b\u0644 \u0644\u0644\u0648\u0628\u0627\u0621 \u0627\u0644\u0630\u064a \u0636\u0631\u0628 \u063a\u0631\u0628 \u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0627 \u0628\u064a\u0646 \u0639\u0627\u0645\u064a 2014 \u06482016 \u0648\u0627\u0654\u0648\u062f\u0649 \u0628\u062d\u064a\u0627\u0629 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 11 \u0627\u0654\u0644\u0641 \u0634\u062e\u0635\u060c \u0645\u0627 \u0644\u0645 \u062a\u064f\u062a\u062e\u0630 \u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0635\u0627\u0631\u0645\u0629 \u0644\u0644\u062d\u062f \u0645\u0646 \u0627\u0646\u062a\u0634\u0627\u0631\u0647.<br /><br />\u0648\u0642\u0627\u0644 \u0645\u0633\u0648\u0654\u0648\u0644 \u0627\u0644\u0648\u0642\u0627\u064a\u0629 \u0648\u0627\u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0648\u0628\u0627\u064a\u0654\u064a \u0641\u064a \u0627\u0644\u0648\u0643\u0627\u0644\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629\u060c \u062c\u064a\u0633\u0648\u0646 \u0627\u0653\u0634\u0631\u060c \u0627\u0655\u0646 \u0627\u0644\u0646\u0645\u0627\u0630\u062c \u0627\u0644\u0648\u0628\u0627\u064a\u0654\u064a\u0629 \u062a\u0634\u064a\u0631 \u0627\u0655\u0644\u0649 \u0627\u0655\u0645\u0643\u0627\u0646\u064a\u0629 \u0628\u0644\u0648\u063a \u0627\u0644\u0648\u0628\u0627\u0621 \u0647\u0630\u0627 \u0627\u0644\u062d\u062c\u0645 \u0641\u064a \u062d\u0627\u0644 \u063a\u064a\u0627\u0628 \u062a\u062f\u0627\u0628\u064a\u0631 \u0642\u0648\u064a\u0629 \u0644\u0644\u0635\u062d\u0629 \u0627\u0644\u0639\u0627\u0645\u0629.<br /><br /> <h2>\u0627\u0654\u0639\u0631\u0627\u0636 \u0641\u064a\u0631\u0648\u0633 \u0627\u0655\u064a\u0628\u0648\u0644\u0627</h2>\u0648\u064a\u062a\u0633\u0628\u0628 \u0641\u064a\u0631\u0648\u0633 \u0627\u0655\u064a\u0628\u0648\u0644\u0627\u060c \u0627\u0644\u0630\u064a \u064a\u0646\u062a\u0642\u0644 \u0639\u0628\u0631 \u0627\u0644\u0627\u062a\u0635\u0627\u0644 \u0627\u0644\u0645\u0628\u0627\u0634\u0631 \u0648\u0633\u0648\u0627\u064a\u0654\u0644 \u0627\u0644\u062c\u0633\u0645\u060c \u0641\u064a \u062d\u0645\u0649 \u0646\u0632\u0641\u064a\u0629 \u0642\u062f \u062a\u0643\u0648\u0646 \u0642\u0627\u062a\u0644\u0629\u060c \u0648\u0642\u062f \u0627\u0654\u0648\u062f\u0649 \u0628\u062d\u064a\u0627\u0629 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 15 \u0627\u0654\u0644\u0641 \u0634\u062e\u0635 \u0641\u064a \u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0627 \u062e\u0644\u0627\u0644 \u0627\u0644\u0639\u0642\u0648\u062f \u0627\u0644\u062e\u0645\u0633\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629.<br /><br />\u0648\u0643\u0627\u0646 \u062a\u0641\u0634\u064a \u0627\u0644\u0645\u0631\u0636 \u0642\u062f \u0627\u064f\u0654\u0639\u0644\u0646 \u0631\u0633\u0645\u064a\u064b\u0627 \u0641\u064a 15 \u0645\u0627\u064a\u0648 \u0627\u0644\u0645\u0627\u0636\u064a \u0628\u0627\u0655\u0642\u0644\u064a\u0645 \u0627\u0655\u064a\u062a\u0648\u0631\u064a \u0634\u0645\u0627\u0644 \u0634\u0631\u0642\u064a \u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0627\u0644\u0643\u0648\u0646\u063a\u0648 \u0627\u0644\u062f\u064a\u0645\u0642\u0631\u0627\u0637\u064a\u0629\u060c \u0627\u0644\u062a\u064a \u064a\u0646\u0627\u0647\u0632 \u0639\u062f\u062f \u0633\u0643\u0627\u0646\u0647\u0627 100 \u0645\u0644\u064a\u0648\u0646 \u0646\u0633\u0645\u0629\u060c \u0648\u062a\u0648\u0627\u062c\u0647 \u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629 \u0648\u0627\u0654\u0645\u0646\u064a\u0629 \u0646\u062a\u064a\u062c\u0629 \u0627\u0644\u0646\u0632\u0627\u0639\u0627\u062a \u0627\u0644\u0645\u0633\u0644\u062d\u0629 \u0627\u0644\u0645\u0633\u062a\u0645\u0631\u0629.<br /><br />\u0648\u064a\u064f\u0639\u062a\u0642\u062f \u0627\u0654\u0646 \u0627\u0644\u0641\u064a\u0631\u0648\u0633 \u0627\u0646\u062a\u0634\u0631 \u0628\u0635\u0645\u062a \u0644\u0627\u0654\u0633\u0627\u0628\u064a\u0639 \u0642\u0628\u0644 \u0627\u0643\u062a\u0634\u0627\u0641\u0647\u060c \u0648\u064a\u0631\u062c\u0639 \u0630\u0644\u0643 \u062c\u0632\u064a\u0654\u064a\u064b\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0633\u0644\u0627\u0644\u0629 \u00ab\u0628\u0648\u0646\u062f\u064a\u0628\u0648\u062c\u064a\u0648\u00bb \u0627\u0644\u0645\u0633\u0628\u0628\u0629 \u0644\u0644\u062a\u0641\u0634\u064a \u0627\u0644\u062d\u0627\u0644\u064a \u062a\u0628\u062f\u0627\u0654 \u0628\u0627\u0654\u0639\u0631\u0627\u0636 \u062a\u062a\u0634\u0627\u0628\u0647 \u0645\u0639 \u0627\u0644\u0627\u0655\u0646\u0641\u0644\u0648\u0646\u0632\u0627 \u0648\u0627\u0644\u0645\u0644\u0627\u0631\u064a\u0627 \u0648\u0627\u0644\u062a\u064a\u0641\u0648\u064a\u0654\u064a\u062f\u060c \u0645\u0627 \u0642\u062f \u064a\u0648\u0654\u062f\u064a \u0627\u0655\u0644\u0649 \u062a\u0627\u0654\u062e\u0631 \u062a\u0634\u062e\u064a\u0635 \u0627\u0644\u0627\u0655\u0635\u0627\u0628\u0627\u062a.<br /><br />\u0648\u0644\u0627 \u064a\u062a\u0648\u0627\u0641\u0631 \u062d\u062a\u0649 \u0627\u0644\u0627\u0653\u0646 \u0644\u0642\u0627\u062d \u0627\u0654\u0648 \u0639\u0644\u0627\u062c \u0645\u0639\u062a\u0645\u062f \u0644\u0647\u0630\u0647 \u0627\u0644\u0633\u0644\u0627\u0644\u0629\u060c \u0627\u0644\u0627\u0654\u0645\u0631 \u0627\u0644\u0630\u064a \u064a\u062c\u0639\u0644 \u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0648\u0642\u0627\u064a\u0629 \u0648\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u0639\u062f\u0648\u0649 \u0627\u0644\u0648\u0633\u064a\u0644\u0629 \u0627\u0644\u0627\u0654\u0633\u0627\u0633\u064a\u0629 \u0644\u0644\u062d\u062f \u0645\u0646 \u0627\u0646\u062a\u0634\u0627\u0631 \u0627\u0644\u0645\u0631\u0636.<h2>\u062c\u0647\u0648\u062f \u0627\u062d\u062a\u0648\u0627\u0621 \u0641\u064a\u0631\u0648\u0633 \u0627\u0655\u064a\u0628\u0648\u0644\u0627</h2>\u0648\u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u062c\u0647\u0648\u062f \u0627\u0644\u0627\u062d\u062a\u0648\u0627\u0621\u060c \u0627\u0654\u0637\u0644\u0642\u062a \u0645\u0646\u0638\u0645\u0629 \u0627\u0644\u0635\u062d\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629 \u0648\u0627\u0644\u0645\u0631\u0627\u0643\u0632 \u0627\u0644\u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0629 \u0644\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u0627\u0636 \u0648\u0627\u0644\u0648\u0642\u0627\u064a\u0629 \u0645\u0646\u0647\u0627 \u062e\u0637\u0629 \u0645\u0634\u062a\u0631\u0643\u0629 \u0628\u0642\u064a\u0645\u0629 518 \u0645\u0644\u064a\u0648\u0646 \u062f\u0648\u0644\u0627\u0631 \u0644\u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0655\u064a\u0628\u0648\u0644\u0627 \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u0634\u0647\u0631 \u0627\u0644\u0633\u062a\u0629 \u0627\u0644\u0645\u0642\u0628\u0644\u0629\u060c \u0645\u0639 \u0627\u0644\u062a\u0631\u0643\u064a\u0632 \u0639\u0644\u0649 \u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0645\u0631\u0627\u0642\u0628\u0629 \u0627\u0644\u0648\u0628\u0627\u064a\u0654\u064a\u0629 \u0648\u0627\u0644\u0627\u062e\u062a\u0628\u0627\u0631\u0627\u062a \u0627\u0644\u0645\u062e\u0628\u0631\u064a\u0629 \u0648\u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0648\u0642\u0627\u064a\u0629.<br /><br />\u0648\u0627\u0654\u0643\u062f \u0627\u0644\u0645\u062f\u064a\u0631 \u0627\u0644\u0639\u0627\u0645 \u0644\u0645\u0646\u0638\u0645\u0629 \u0627\u0644\u0635\u062d\u0629 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629\u060c \u062a\u064a\u062f\u0631\u0648\u0633 \u0627\u0654\u062f\u0647\u0627\u0646\u0648\u0645 \u063a\u064a\u0628\u0631\u064a\u064a\u0633\u0648\u0633\u060c \u0627\u0654\u0646 \u0627\u0644\u0648\u0628\u0627\u0621 \u064a\u062a\u0637\u0648\u0631 \u0628\u0633\u0631\u0639\u0629\u060c \u0645\u0634\u062f\u062f\u064b\u0627 \u0639\u0644\u0649 \u0627\u0654\u0647\u0645\u064a\u0629 \u0627\u062d\u062a\u0648\u0627\u064a\u0654\u0647 \u0641\u064a \u0628\u0648\u0654\u0631 \u0627\u0646\u062a\u0634\u0627\u0631\u0647 \u0627\u0644\u062d\u0627\u0644\u064a\u0629\u060c \u0648\u062f\u0639\u0645 \u0627\u0644\u062f\u0648\u0644 \u0627\u0644