{"status": "success", "totalResults": 5971, "results": [{"article_id": "a71f32db610ac2f55782236eaa7376f5", "link": "https://www.alyaum.com/articles/6657338/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A7%D9%84%D8%A5%D8%B9%D9%84%D8%A7%D9%86-%D8%B9%D9%86-%D8%A7%D9%83%D8%AA%D8%B4%D8%A7%D9%81-%D8%B6%D8%AE%D9%85-%D9%84%D9%84%D8%BA%D8%A7%D8%B2-%D8%A7%D9%84%D8%B7%D8%A8%D9%8A%D8%B9%D9%8A-%D9%82%D8%A8%D8%A7%D9%84%D8%A9-%D8%A5%D9%86%D8%AF%D9%88%D9%86%D9%8A%D8%B3%D9%8A%D8%A7", "title": "\u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0646 \u0639\u0646 \u0627\u0643\u062a\u0634\u0627\u0641 \u0636\u062e\u0645 \u0644\u0644\u063a\u0627\u0632 \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0642\u0628\u0627\u0644\u0629 \u0627\u0655\u0646\u062f\u0648\u0646\u064a\u0633\u064a\u0627", "description": "\u0627\u0654\u0639\u0644\u0646\u062a \u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0627\u0655\u064a\u0637\u0627\u0644\u064a\u0629 \u0627\u0644\u0639\u0645\u0644\u0627\u0642\u0629 \"\u0627\u0655\u064a\u0646\u064a\" \u0639\u0646 \u0627\u0643\u062a\u0634\u0627\u0641 \u0636\u062e\u0645 \u0644\u0644\u063a\u0627\u0632 \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0642\u0628\u0627\u0644\u0629 \u0633\u0648\u0627\u062d\u0644 <a href=\"https://www.alyaum.com/articles/6656576/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D9%82%D8%AA%D9%84-8-%D8%A3%D8%B4%D8%AE%D8%A7%D8%B5-%D8%AC%D8%B1%D8%A7%D8%A1-%D8%AA%D8%AD%D8%B7%D9%85-%D8%B7%D8%A7%D8%A6%D8%B1%D8%A9-%D9%87%D9%84%D9%8A%D9%83%D9%88%D8%A8%D8%AA%D8%B1-%D9%81%D9%8A-%D8%A5%D9%86%D8%AF%D9%88%D9%86%D9%8A%D8%B3%D9%8A%D8%A7\" target=\"_blank\">\u0627\u0655\u0646\u062f\u0648\u0646\u064a\u0633\u064a\u0627</a>.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \"\u0627\u0655\u064a\u0646\u064a\" \u0641\u064a \u0628\u064a\u0627\u0646 \u0627\u0654\u0635\u062f\u0631\u062a\u0647 \u0641\u064a \u0648\u0642\u062a \u0645\u062a\u0627\u0654\u062e\u0631 \u0627\u0654\u0645\u0633\u060c \u0627\u0654\u0646 \u0627\u0644\u062a\u0642\u062f\u064a\u0631\u0627\u062a \u0627\u0644\u0627\u0654\u0648\u0644\u064a\u0629 \u062a\u0634\u064a\u0631 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0646\u0642\u0637\u0629 \u0627\u0644\u0648\u0627\u0642\u0639\u0629 \u0639\u0644\u0649 \u0628\u064f\u0639\u062f \u0646\u062d\u0648 70 \u0643\u064a\u0644\u0648\u0645\u062a\u0631\u064b\u0627 \u0642\u0628\u0627\u0644\u0629 \u0633\u0648\u0627\u062d\u0644 <a href=\"https://www.alyaum.com/articles/6207739/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%B9%D8%A7%D8%B5%D9%85%D8%A9-%D8%AC%D8%AF%D9%8A%D8%AF%D8%A9-%D9%84%D8%A5%D9%86%D8%AF%D9%88%D9%86%D9%8A%D8%B3%D9%8A%D8%A7-%D9%85%D8%A7-%D9%87%D9%8A\" target=\"_blank\">\u0645\u0642\u0627\u0637\u0639\u0629 \u0643\u0627\u0644\u064a\u0645\u0627\u0646\u062a\u0627\u0646</a> \u0627\u0644\u0634\u0631\u0642\u064a\u0629\u060c \u062a\u062e\u062a\u0632\u0646 \u0646\u062d\u0648 \u062e\u0645\u0633\u0629 \u062a\u0631\u064a\u0644\u064a\u0648\u0646\u0627\u062a \u0642\u062f\u0645 \u0645\u0643\u0639\u0651\u0628 \u0645\u0646 \u0627\u0644\u063a\u0627\u0632 \u0648300 \u0645\u0644\u064a\u0648\u0646 \u0628\u0631\u0645\u064a\u0644 \u0645\u0646 \u0627\u0644\u0645\u0643\u062b\u0641\u0627\u062a\u060c \u0648\u0647\u064a \u0647\u064a\u062f\u0631\u0648\u0643\u0631\u0628\u0648\u0646 \u0633\u0627\u064a\u0654\u0644.<h2>\u0627\u0654\u0633\u0648\u0627\u0642 \u0645\u062d\u0644\u064a\u0629 \u0648\u062f\u0648\u0644\u064a\u0629</h2><br />\u0630\u0643\u0631\u062a\u060c \u0627\u0654\u0646 \u0627\u0644\u0627\u0643\u062a\u0634\u0627\u0641 \u0627\u0644\u062c\u062f\u064a\u062f \"\u064a\u062a\u064a\u062d \u0643\u0645\u064a\u0627\u062a \u0643\u0628\u064a\u0631\u0629 \u062c\u062f\u064a\u062f\u0629 \u0644\u0644\u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0644\u0645\u062d\u0644\u064a\u0629 \u0648\u0627\u0644\u062f\u0648\u0644\u064a\u0629\".<br /><br />\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u0627\u0655\u0646\u062f\u0648\u0646\u064a\u0633\u064a\u0629 \u0628\u0627\u0654\u0646 \u0627\u0644\u0627\u0643\u062a\u0634\u0627\u0641 \u0642\u062f \u064a\u0631\u0641\u0639 \u0627\u0644\u0627\u0655\u0646\u062a\u0627\u062c \u0627\u0644\u0627\u0654\u0642\u0635\u0649 \u0644\u0634\u0631\u0643\u0629 \"\u0627\u0655\u064a\u0646\u064a\" \u0627\u0655\u0644\u0649 2,000 \u0645\u0644\u064a\u0648\u0646 \u0642\u062f\u0645 \u0645\u0643\u0639\u0628 \u0642\u064a\u0627\u0633\u064a \u0641\u064a \u0627\u0644\u064a\u0648\u0645 \u0628\u062d\u0644\u0648\u0644 \u0639\u0627\u0645 2028\u060c \u062b\u0645 \u0627\u0655\u0644\u0649 3,000 \u0645\u0644\u064a\u0648\u0646 \u0642\u062f\u0645 \u0645\u0643\u0639\u0628 \u0642\u064a\u0627\u0633\u064a \u0641\u064a \u0627\u0644\u064a\u0648\u0645 \u0628\u0639\u062f \u0633\u0646\u062a\u064a\u0646.<br /><br />\u0648\u064a\u0628\u0644\u063a \u0627\u0644\u0627\u0655\u0646\u062a\u0627\u062c \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0627\u0644\u0631\u0627\u0647\u0646 \u0645\u0627 \u0628\u064a\u0646 600 \u0648700 \u0645\u0644\u064a\u0648\u0646 \u0642\u062f\u0645 \u0645\u0643\u0639\u0628 \u0642\u064a\u0627\u0633\u064a \u0641\u064a \u0627\u0644\u064a\u0648\u0645.<br /><br />\u0648\u0648\u0635\u0641 \u0648\u0632\u064a\u0631 \u0627\u0644\u0637\u0627\u0642\u0629 \u0648\u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0645\u0639\u062f\u0646\u064a\u0629 \u0627\u0644\u0627\u0655\u0646\u062f\u0648\u0646\u064a\u0633\u064a \u0628\u0627\u0647\u0644\u064a\u0644 \u0644\u0647\u0627\u062f\u0627\u0644\u064a\u0627\u060c \u0647\u0630\u0627 \u0627\u0644\u0627\u0643\u062a\u0634\u0627\u0641 \u0628\u0627\u0654\u0646\u0647 \"\u0647\u0627\u064a\u0654\u0644\"\u060c \u0642\u0627\u064a\u0654\u0644\u064b\u0627: \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u063a\u0627\u0632\u060c \u0633\u0646\u0646\u062a\u062c \u0628\u062d\u0644\u0648\u0644 \u0633\u0646\u0629 2028 \u0645\u0627 \u064a\u0642\u0631\u0628 \u0645\u0646 90 \u0627\u0654\u0644\u0641 \u0628\u0631\u0645\u064a\u0644\u064b\u0627 \u0645\u0646 \u0627\u0644\u0645\u0643\u062b\u0641\u0627\u062a \u064a\u0648\u0645\u064a\u064b\u0627\u060c \u0648\u0641\u064a \u0641\u062a\u0631\u0629 (2029-2030) \u064a\u0645\u0643\u0646 \u0627\u0654\u0646 \u064a\u0631\u062a\u0641\u0639 \u0627\u0644\u0627\u0655\u0646\u062a\u0627\u062c \u0627\u0655\u0644\u0649 150 \u0627\u0654\u0644\u0641 \u0628\u0631\u0645\u064a\u0644\".", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["lifestyle", "top"], "datatype": "news", "pubDate": "2026-04-21 11:49:00", "pubDateTZ": "UTC", "fetched_at": "2026-04-21 12:14:24", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "f7095430bd4a2ed283872c29a19d359b", "link": "https://www.alyaum.com/articles/6657342/%D8%A7%D9%84%D9%85%D9%8A%D8%AF%D8%A7%D9%86-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6%D9%8A/%D8%A7%D9%84%D8%AF%D9%88%D8%B1%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A/%D8%A8-13-%D9%85%D8%B3%D8%A7%D9%87%D9%85%D8%A9-%D8%AC%D8%A7%D9%84%D9%8A%D9%86%D9%88-%D9%8A%D9%86%D8%AB%D8%B1-%D8%B3%D8%AD%D8%B1%D9%87-%D9%85%D8%B9-%D8%A7%D9%84%D8%A3%D9%87%D9%84%D9%8A-%D9%81%D9%8A-%D8%A2%D8%B3%D9%8A%D8%A7", "title": "\u0628\u0640 13 \u0645\u0633\u0627\u0647\u0645\u0629.. \u062c\u0627\u0644\u064a\u0646\u0648 \u064a\u0646\u062b\u0631 \u0633\u062d\u0631\u0647 \u0645\u0639 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0641\u064a \u0627\u0653\u0633\u064a\u0627", "description": "\u0641\u064a \u0643\u0644 \u0628\u0637\u0648\u0644\u0629 \u0643\u0628\u0631\u0649\u060c \u062a\u0638\u0647\u0631 \u0627\u0654\u0633\u0645\u0627\u0621 \u062a\u0635\u0646\u0639 \u0627\u0644\u0641\u0627\u0631\u0642 \u062d\u064a\u0646 \u062a\u064f\u062d\u0627\u0635\u0631 \u0627\u0644\u0641\u0631\u0642 \u062a\u062d\u062a \u0636\u063a\u0637 \u0627\u0644\u0644\u062d\u0638\u0627\u062a \u0627\u0644\u062d\u0627\u0633\u0645\u0629\u060c \u0648\u0647\u0630\u0627 \u062a\u062d\u062f\u064a\u062f\u064b\u0627 \u0645\u0627 \u064a\u0641\u0639\u0644\u0647 \u0627\u0644\u0628\u0631\u0627\u0632\u064a\u0644\u064a \u062c\u0627\u0644\u064a\u0646\u0648 \u0628\u0642\u0645\u064a\u0635 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0641\u064a \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0653\u0633\u064a\u0627 \u0644\u0644\u0646\u062e\u0628\u0629\u060c \u062d\u064a\u062b \u0628\u0627\u062a \u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0645\u0641\u0627\u062a\u064a\u062d \u0627\u0644\u062d\u0644 \u0641\u064a \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0627\u062a \u0627\u0644\u0642\u0627\u0631\u064a\u0629 \u0627\u0644\u0643\u0628\u0631\u0649\u060c \u0648\u0648\u0627\u062d\u062f\u064b\u0627 \u0645\u0646 \u0627\u0654\u0643\u062b\u0631 \u0627\u0644\u0644\u0627\u0639\u0628\u064a\u0646 \u062a\u0627\u0654\u062b\u064a\u0631\u064b\u0627 \u0641\u064a \u0644\u062d\u0638\u0627\u062a \u0627\u0644\u062d\u0633\u0645.<br /><br />\u062c\u0627\u0644\u064a\u0646\u0648 \u0644\u0645 \u064a\u0643\u062a\u0641\u0650 \u0628\u0645\u062c\u0631\u062f \u0627\u0644\u062d\u0636\u0648\u0631 \u0641\u064a \u0627\u0644\u0645\u0634\u0647\u062f \u0627\u0644\u0627\u0653\u0633\u064a\u0648\u064a\u060c \u0628\u0644 \u062a\u062d\u0648\u0651\u0644 \u0627\u0655\u0644\u0649 \u0644\u0627\u0639\u0628 \u201c\u0627\u0644\u0645\u0648\u0627\u0639\u064a\u062f \u0627\u0644\u0643\u0628\u0631\u0649\u201d \u0628\u0627\u0645\u062a\u064a\u0627\u0632\u060c \u064a\u0638\u0647\u0631 \u062f\u0627\u064a\u0654\u0645\u064b\u0627 \u062d\u064a\u0646 \u064a\u0634\u062a\u062f \u0627\u0644\u062e\u0646\u0627\u0642 \u0648\u062a\u062a\u0639\u0642\u0651\u062f \u0627\u0644\u0633\u064a\u0646\u0627\u0631\u064a\u0648\u0647\u0627\u062a\u060c \u0644\u064a\u0645\u0646\u062d \u0641\u0631\u064a\u0642\u0647 \u0627\u0654\u0641\u0636\u0644\u064a\u0629 \u062d\u0627\u0633\u0645\u0629 \u0641\u064a \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0645\u0646\u0627\u0633\u0628\u0629. \u0648\u0628\u062c\u0627\u0646\u0628 \u062a\u0627\u0654\u0644\u0642\u0647 \u0627\u0644\u0644\u0627\u0641\u062a\u060c \u064a\u0628\u0631\u0632 \u0627\u0633\u0645 \u0632\u0645\u064a\u0644\u0647 \u062f\u0646\u062f\u0631\u0648\u0633\u0646 \u0643\u0627\u0654\u062d\u062f \u0627\u0644\u0639\u0646\u0627\u0635\u0631 \u0627\u0644\u062a\u064a \u062a\u064f\u0643\u0645\u0644 \u0627\u0644\u0645\u0646\u0638\u0648\u0645\u0629 \u0641\u064a \u0627\u0644\u0627\u0654\u0648\u0642\u0627\u062a \u0627\u0644\u0635\u0639\u0628\u0629\u060c \u062d\u064a\u062b \u064a\u0638\u0647\u0631\u0627\u0646 \u0645\u0639\u064b\u0627 \u0643\u062c\u0632\u0621 \u0645\u0646 \u0647\u0648\u064a\u0629 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0627\u0644\u0642\u0627\u0631\u064a\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0627\u0644\u0645\u0628\u0646\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0642\u0648\u0629 \u0627\u0644\u0630\u0647\u0646\u064a\u0629 \u0648\u0627\u0644\u0641\u0627\u0639\u0644\u064a\u0629 \u0627\u0644\u0647\u062c\u0648\u0645\u064a\u0629.<br /><br />\u0641\u064a \u0646\u0647\u0627\u064a\u0654\u064a \u0646\u0633\u062e\u0629 2025 \u0645\u0646 \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0653\u0633\u064a\u0627 \u0644\u0644\u0646\u062e\u0628\u0629\u060c \u0627\u0654\u0639\u0627\u062f \u062c\u0627\u0644\u064a\u0646\u0648 \u0627\u0655\u0644\u0649 \u0627\u0644\u0630\u0627\u0643\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0645\u0646 \u0627\u0654\u0643\u062b\u0631 \u0644\u062d\u0638\u0627\u062a\u0647 \u062a\u0627\u0654\u062b\u064a\u0631\u064b\u0627\u060c \u0639\u0646\u062f\u0645\u0627 \u0633\u062c\u0644 \u0647\u062f\u0641\u064b\u0627 \u0641\u064a \u0645\u0631\u0645\u0649 \u0641\u064a\u0633\u064a\u0644 \u0643\u0648\u0628\u064a\u060c \u0643\u0627\u0646 \u0628\u0645\u062b\u0627\u0628\u0629 \u0646\u0642\u0637\u0629 \u0627\u0644\u062a\u062d\u0648\u0644 \u0627\u0644\u062a\u064a \u0641\u062a\u062d\u062a \u0627\u0644\u0637\u0631\u064a\u0642 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0646\u062d\u0648 \u0627\u0654\u0648\u0644 \u062a\u062a\u0648\u064a\u062c \u0642\u0627\u0631\u064a \u0641\u064a \u062a\u0627\u0631\u064a\u062e\u0647\u060c \u0641\u064a \u0644\u062d\u0638\u0629 \u0648\u064f\u0635\u0641\u062a \u0628\u0627\u0654\u0646\u0647\u0627 \u0648\u0644\u0627\u062f\u0629 \u062d\u0642\u064a\u0642\u064a\u0629 \u0644\u0647\u064a\u0628\u0629 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0653\u0633\u064a\u0648\u064a\u064b\u0627.<br /><br />\u0648\u0644\u0645 \u064a\u0643\u0646 \u0630\u0644\u0643 \u0627\u0644\u0648\u0647\u062c \u0645\u062c\u0631\u062f \u0644\u062d\u0638\u0629 \u0639\u0627\u0628\u0631\u0629\u060c \u0627\u0655\u0630 \u0639\u0627\u062f \u062c\u0627\u0644\u064a\u0646\u0648 \u0645\u062c\u062f\u062f\u064b\u0627 \u0641\u064a \u0646\u0633\u062e\u0629 2026 \u0644\u064a\u0643\u062a\u0628 \u0641\u0635\u0644\u064b\u0627 \u062c\u062f\u064a\u062f\u064b\u0627 \u0645\u0646 \u0627\u0644\u062a\u0627\u0654\u0644\u0642\u060c \u0628\u0639\u062f\u0645\u0627 \u0633\u062c\u0644 \u0647\u062f\u0641\u064b\u0627 \u0639\u0627\u0644\u0645\u064a\u064b\u0627 \u0641\u064a \u0645\u0631\u0645\u0649 \u0641\u064a\u0633\u064a\u0644 \u0643\u0648\u0628\u064a \u0627\u0654\u064a\u0636\u064b\u0627\u060c \u0644\u064a\u0642\u0648\u062f \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0627\u0655\u0644\u0649 \u0627\u0644\u0641\u0648\u0632 \u0641\u064a \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0648\u064a\u062d\u062c\u0632 \u0628\u0637\