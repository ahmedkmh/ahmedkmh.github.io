7%D8%B3%D8%AA%D9%83%D8%B4%D8%A7%D9%81-%D8%AE%D9%84%D8%A7%D9%84-%D8%A7%D9%84%D8%B9%D8%B7%D9%84%D8%A9-%D8%A7%D9%84%D8%B5%D9%8A%D9%81%D9%8A%D8%A9\" target=\"_blank\">\u0627\u0644\u0639\u064f\u0644\u0627</a> \u0648\u0639\u0644\u0649 \u0627\u0645\u062a\u062f\u0627\u062f \u0637\u0631\u0642 \u0627\u0644\u0642\u0648\u0627\u0641\u0644 \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629 \u0627\u0644\u062a\u064a \u0631\u0628\u0637\u062a \u062c\u0646\u0648\u0628 <a href=\"https://www.alyaum.com/articles/6672822/%D8%A7%D9%84%D8%AB%D9%82%D8%A7%D9%81%D8%A9-%D9%88%D8%A7%D9%84%D9%81%D9%86/%D8%AB%D9%82%D8%A7%D9%81%D8%A9/%D9%85%D8%AA%D8%AD%D8%AC%D8%B1%D8%A7%D8%AA-%D8%A7%D9%84%D9%86%D9%81%D9%88%D8%AF-%D8%AA%D9%88%D8%AB%D9%82-%D8%A7%D9%84%D8%AA%D8%AD%D9%88%D9%84%D8%A7%D8%AA-%D8%A7%D9%84%D8%A8%D9%8A%D8%A6%D9%8A%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%AC%D8%B2%D9%8A%D8%B1%D8%A9-%D8%A7%D9%84%D8%B9%D8%B1%D8%A8%D9%8A%D8%A9-%D8%AE%D9%84%D8%A7%D9%84-600-%D8%A3%D9%84%D9%81-%D8%B9%D8%A7%D9%85\" target=\"_blank\">\u0627\u0644\u062c\u0632\u064a\u0631\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629</a> \u0641\u064a \u0628\u0644\u0627\u062f \u0627\u0644\u0634\u0627\u0645.<br />\u0648\u062a\u0636\u0645 \u0627\u0644\u0628\u0644\u062f\u0629 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 900 \u0645\u0646\u0632\u0644 \u0634\u064f\u064a\u0651\u062f\u062a \u0645\u0646 \u0627\u0644\u0637\u0648\u0628 \u0627\u0644\u0637\u064a\u0646\u064a\u060c \u064a\u0639\u0648\u062f \u062a\u0627\u0631\u064a\u062e \u062a\u0627\u0654\u0633\u064a\u0633\u0647\u0627 \u0627\u0655\u0644\u0649 \u0646\u062d\u0648 \u0633\u0628\u0639\u0629 \u0642\u0631\u0648\u0646\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u062a\u0635\u0628\u062d \u0645\u062d\u0637\u0629\u064b \u0631\u064a\u0654\u064a\u0633\u0629 \u0639\u0644\u0649 \u0637\u0631\u064a\u0642 \u0627\u0644\u062d\u062c \u0627\u0644\u0634\u0627\u0645\u064a\u060c \u0627\u0644\u0627\u0654\u0645\u0631 \u0627\u0644\u0630\u064a \u0627\u0654\u0643\u0633\u0628\u0647\u0627 \u0645\u0643\u0627\u0646\u0629\u0