8A%D9%88%D9%85/%D9%85%D8%B3%D8%A7%D8%A8%D9%82%D8%A9-%D8%B3%D9%86%D9%88%D9%8A%D8%A9-%D9%88%D8%AE%D8%B7%D8%B7-%D8%A5%D9%84%D8%B2%D8%A7%D9%85%D9%8A%D8%A9-%D8%AA%D8%AD%D9%88%D9%84-%D8%A7%D8%B3%D8%AA%D8%B1%D8%A7%D8%AA%D9%8A%D8%AC%D9%8A-%D9%84%D8%A3%D9%86%D8%AF%D9%8A%D8%A9-%D8%A7%D9%84%D8%B3%D9%84%D8%A7%D9%85%D8%A9-%D8%A7%D9%84%D9%85%D8%B1%D9%88%D8%B1%D9%8A%D8%A9-%D8%A8%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9\" target=\"_blank\">\u0644\u062c\u0646\u0629 \u0627\u0644\u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629</a>\u060c \u0627\u0644\u0633\u0627\u064a\u0654\u0642\u064a\u0646 \u0645\u0646 \u062e\u0637\u0648\u0631\u0629 \u0627\u0644\u0627\u0646\u0634\u063a\u0627\u0644 \u0628\u0627\u0644\u062c\u0648\u0627\u0644 \u0648\u0627\u0644\u0633\u0631\u0639\u0629 \u0627\u0644\u0645\u0641\u0631\u0637\u0629 \u062e\u0644\u0627\u0644 <a href=\"https://www.alyaum.com/articles/6651764/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D9%85%D9%86%D9%88%D8%B9%D8%A7%D8%AA/%D8%B5%D9%88%D8%B1-%D8%B4%D8%A7%D8%B7%D8%A6-%D8%A3%D9%85%D9%84%D8%AC-%D9%8A%D8%B3%D8%AA%D9%82%D8%B7%D8%A8-%D8%A7%D9%84%D9%85%D8%AA%D9%86%D8%B2%D9%87%D9%8A%D9%86-%D8%AE%D9%84%D8%A7%D9%84-%D8%A5%D8%AC%D8%A7%D8%B2%D8%A9-%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D9%81%D8%B7%D8%B1\" target=\"_blank\">\u0627\u0655\u062c\u0627\u0632\u0629 \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631</a>\u060c \u0645\u0648\u0654\u0643\u062f\u0629 \u0627\u0654\u0646 \u062d\u0648\u0627\u062f\u062b \u0627\u0644\u062f\u0647\u0633 \u062a\u0634\u0643\u0644 19% \u0645\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0648\u0641\u064a\u0627\u062a \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0645\u0646\u0637\u0642\u0629.<br /><br />\u0648\u0634\u062f\u062f\u062a \u0627\u0644\u0644\u062c\u0646\u0629 \u0639\u0644\u0649 \u0627\u0654\u0646 \u0644\u062d\u0638\u0627\u062a \u0627\u0644\u063a\u0641\u0644\u0629 \u0648\u0627\u0644\u062a\u0647\u0627\u0648\u0646 \u0627\u0654\u062b\u0646\u0627\u0621 \u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0642\u062f \u062a\u0646\u062a\u0647\u064a \u0628\u0643\u0648\u0627\u0631\u062b \u0645\u0627\u0654\u0633\u0627\u0648\u064a\u0629\u060c \u062a\u0632\u0627\u0645\u0646\u0627\u064b \u0645\u0639 \u0627\u0644\u0643\u062b\u0627\u0641\u0629 \u0627\u0644\u0639\u0627\u0644\u064a\u0629 \u0644\u062d\u0631\u0643\u0629 \u0627\u0644\u0645\u0634\u0627\u0629 \u0648<a href=\"https://www.alyaum.com/articles/6597246/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%84%D8%AE%D9%81%D8%B6-%D8%A7%D9%84%D8%A7%D8%B2%D8%AF%D8%AD%D8%A7%D9%85-10-%D8%AC%D9%87%D8%A7%D8%AA-%D8%AD%D9%83%D9%88%D9%85%D9%8A%D8%A9-%D8%AA%D8%B7%D9%84%D9%82-%D8%AF%D9%84%D9%8A%D9%84-%D8%AA%D9%86%D8%B8%D9%8A%D9%85-%D8%AD%D8%B1%D9%83%D8%A9-%D8%A7%D9%84%D8%B4%D8%A7%D8%AD%D9%86%D8%A7%D8%AA-%D8%A8%D8%A7%D9%84%D9%86%D8%B7%D8%A7%D9%82-%D8%A7%D9%84%D8%B9%D9%85%D8%B1%D8%A7%D9%86%D9%8A\" target=\"_blank\">\u0627\u0644\u0627\u0632\u062f\u062d\u0627\u0645 \u0627\u0644\u0645\u0631\u0648\u0631\u064a</a> \u0641\u064a \u0627\u0644\u0634\u0648\u0627\u0631\u0639.<br /><br /> <h2>\u0631\u0633\u0627\u064a\u0654\u0644 \u062a\u0648\u0639\u0648\u064a\u0629</h2><br />\u0628\u064a\u0651\u0646\u062a \u0641\u064a \u0631\u0633\u0627\u064a\u0654\u0644\u0647\u0627 \u0627\u0644\u062a\u0648\u0639\u0648\u064a\u0629 \u0627\u0654\u0646 \u0627\u0644\u0637\u0631\u064a\u0642 \u064a\u0643\u062a\u0638 \u062e\u0644\u0627\u0644 \u0627\u0644\u0639\u064a\u062f \u0628\u0627\u0644\u0627\u0654\u0637\u0641\u0627\u0644 \u0648\u0643\u0628\u0627\u0631 \u0627\u0644\u0633\u0646\u060c \u0645\u0639\u062a\u0628\u0631\u0629 \u0627\u0654\u0646 \u062d\u0645\u0627\u064a\u062a\u0647\u0645 \u0648\u0633\u0644\u0627\u0645\u062a\u0647\u0645 \u062a\u0645\u062b\u0644 \u00ab\u0627\u0654\u0645\u0627\u0646\u0629 \u0641\u064a \u0627\u0654\u0639\u064a\u0646 \u0627\u0644\u0633\u0627\u064a\u0654\u0642\u064a\u0646\u00bb.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0654\u0646 \u0644\u062d\u0638\u0629 \u062a\u0634\u062a\u062a \u0648\u0627\u062d\u062f\u0629 \u062e\u0644\u0641 \u0627\u0644\u0645\u0642\u0648\u062f \u062a\u0643\u0641\u064a \u0644\u0643\u0633\u0631 \u0641\u0631\u062d\u0629 \u0627\u0644\u0639\u0627\u064a\u0654\u0644\u0627\u062a\u060c \u0648\u062a\u062d\u0648\u064a\u0644 \u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0644\u0627\u062a \u0627\u0655\u0644\u0649 \u0645\u0627\u0653\u0633\u064d \u0644\u0627 \u062a\u064f\u0646\u0633\u0649.<br /><br />\u0648\u0643\u0634\u0641 \u0627\u0644\u062f\u0643\u062a\u0648\u0631 \u0645\u062d\u0645\u062f \u0627\u0644\u0646\u0639\u064a\u0645\u064a \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0644\u064a\u0629 \u0648\u0627\u0644\u062d\u0631\u0643\u0629 \u0627\u0644\u0646\u0634\u0637\u0629 \u062a\u0642\u0627\u0628\u0644 \u0628\u0648\u0627\u0642\u0639 \u0645\u0642\u0644\u0642 \u064a\u062a\u0645\u062b\u0644 \u0641\u064a \u062a\u0635\u0627\u0639\u062f \u0645\u0648\u0654\u0634\u0631\u0627\u062a \u062d\u0648\u0627\u062f\u062b \u0627\u0644\u062f\u0647\u0633 \u0628\u0634\u0643\u0644 \u0645\u0644\u062d\u0648\u0638.<br /><br /> <br /><br />\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0644\u0646\u0639\u064a\u0645\u064a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u062d\u0648\u0627\u062f\u062b \u0627\u0644\u0642\u0627\u062a\u0644\u0629 \u062a\u0642\u0639 \u0641\u064a \u00ab\u062b\u0648\u0627\u0646\u064d \u0645\u0639\u062f\u0648\u062f\u0629\u00bb\u060c \u0644\u0643\u0646 \u062a\u062f\u0627\u0639\u064a\u0627\u062a\u0647\u0627 \u062a\u063a\u064a\u0631 \u0645\u0633\u0627\u0631 \u062d\u064a\u0627\u0629 \u0627\u0654\u0633\u0631 \u0643\u0627\u0645\u0644\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0654\u0628\u062f.<h2>\u0627\u0644\u0633\u0631\u0639\u0629 \u0627\u0644\u0645\u0641\u0631\u0637\u0629</h2><br />\u0627\u0654\u0643\u062f \u0627\u0644\u0646\u0639\u064a\u0645\u064a \u0627\u0654\u0646 \u0627\u0644\u0633\u0631\u0639\u0629 \u0627\u0644\u0645\u0641\u0631\u0637\u0629 \u0648\u0627\u0644\u0627\u0646\u0634\u063a\u0627\u0644 \u0628\u0627\u0644\u0647\u0627\u062a\u0641 \u0627\u0644\u0645\u062d\u0645\u0648\u0644 \u064a\u062a\u0635\u062f\u0631\u0627\u0646 \u0627\u0644\u0642\u0627\u064a\u0654\u0645\u0629 \u0627\u0644\u0633\u0648\u062f\u0627\u0621 \u0644\u0645\u0633\u0628\u0628\u0627\u062a \u0627\u0644\u062d\u0648\u0627\u062f\u062b\u060c \u0648\u0627\u0635\u0641\u0627\u064b \u0627\u0655\u064a\u0627\u0647\u0645\u0627 \u0628\u0640 \u00ab\u0627\u0644\u062e\u0637\u0631\u064a\u0646 \u0627\u0644\u0644\u0630\u064a\u0646 \u064a\u0633\u0644\u0628\u0627\u0646 \u0641\u0631\u062d\u0629 \u0627\u0644\u0639\u064a\u062f\u00bb.<br /><br />\u0648\u0644\u0641\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0627\u0644\u062a\u0632\u0627\u0645 \u0627\u0644\u062a\u0627\u0645 \u0628\u0627\u0644\u0627\u0654\u0646\u0638\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629 \u0648\u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0648\u0627\u0639\u064a\u0629 \u064a\u0634\u0643\u0644\u0627\u0646 \u062d\u0627\u064a\u0654\u0637 \u0627\u0644\u0635\u062f \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0631\u0648\u0627\u062d \u0648\u0627\u0644\u0645\u0645\u062a\u0644\u0643\u0627\u062a.<br /><br />\u0648\u062f\u0639\u0627 \u0627\u0644\u0633\u0627\u064a\u0654\u0642\u064a\u0646 \u0627\u0655\u0644\u0649 \u0636\u0631\u0648\u0631\u0629 \u0627\u0644\u062a\u062d\u0644\u064a \u0628\u0627\u0644\u0647\u062f\u0648\u0621 \u0627\u0644\u062a\u0627\u0645 \u0648\u0627\u0644\u0627\u0646\u062a\u0628\u0627\u0647 \u0627\u0644\u0645\u0636\u0627\u0639\u0641 \u0644\u0644\u0645\u0634\u0627\u0629\u060c \u0644\u062a\u062c\u0627\u0648\u0632 \u0647\u0630\u0647 \u0627\u0644\u0641\u062a\u0631\u0629 \u0628\u0627\u0654\u0645\u0627\u0646. \u0645\u0637\u0627\u0644\u0628\u0627 \u0627\u0644\u062c\u0645\u064a\u0639 \u0628\u0627\u0644\u062a\u0645\u0647\u0644 \u0648\u062a\u062c\u0646\u0628 \u0627\u0644\u0645\u0634\u062a\u062a\u0627\u062a\u060c \u0644\u0636\u0645\u0627\u0646 \u0628\u064a\u064a\u0654\u0629 \u0645\u0631\u0648\u0631\u064a\u0629 \u0627\u0653\u0645\u0646\u0629 \u062a\u0639\u0632\u0632 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u062c\u062a\u0645\u0639 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0646\u0627\u0633\u0628\u0629 \u0627\u0644\u0633\u0639\u064a\u062f\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["business", "top"], "datatype": "news", "pubDate": "2026-03-23 09:39:00", "pubDateTZ": "UTC", "fetched_at": "2026-03-23 10:17:25", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "93e3b037f76f2a5b24aebb3693287bed", "link": "https://www.alyaum.com/articles/6651840/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B9%D8%A7%D8%AC%D9%84-%D8%A7%D9%84%D8%B3%D9%84%D8%A7%D9%85%D8%A9-%D8%A7%D9%84%D9%85%D8%B1%D9%88%D8%B1%D9%8A%D8%A9-%D8%A7%D9%84%D8%AC%D9%88%D8%A7%D9%84-%D9%88%D8%A7%D9%84%D8%B3%D8%B1%D8%B9%D8%A9-%D9%8A%D8%B1%D9%81%D8%B9%D8%A7%D9%86-%D9%88%D9%81%D9%8A%D8%A7%D8%AA-%D8%A7%D9%84%D8%AF%D9%87%D8%B3-%D8%A8%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%B9%D9%8A%D8%AF", "title": "\u0639\u0627\u062c\u0644 - \u201d\u0627\u0644\u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629\u201c.. \u0627\u0644\u062c\u0648\u0627\u0644 \u0648\u0627\u0644\u0633\u0631\u0639\u0629 \u064a\u0631\u0641\u0639\u0627\u0646 \u0648\u0641\u064a\u0627\u062a \u0627\u0644\u062f\u0647\u0633 \u0628\u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u0641\u064a \u0627\u0644\u0639\u064a\u062f", "description": "\u062d\u0630\u0631\u062a <a href=\"https://www.alyaum.com/articles/6621201/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%B3%D8%A7%D8%A8%D9%82%D8%A9-%D8%B3%D9%86%D9%88%D9%8A%D8%A9-%D9%88%D8%AE%D8%B7%D8%B7-%D8%A5%D9%84%D8%B2%D8%A7%D9%85%D9%8A%D8%A9-%D8%AA%D8%AD%D9%88%D9%84-%D8%A7%D8%B3%D8%AA%D8%B1%D8%A7%D8%AA%D9%8A%D8%AC%D9%8A-%D9%84%D8%A3%D9%86%D8%AF%D9%8A%D8%A9-%D8%A7%D9%84%D8%B3%D9%84%D8%A7%D9%85%D8%A9-%D8%A7%D9%84%D9%85%D8%B1%D9%88%D8%B1%D9%8A%D8%A9-%D8%A8%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9\" target=\"_blank\">\u0644\u062c\u0646\u0629 \u0627\u0644\u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629</a>\u060c \u0627\u0644\u0633\u0627\u064a\u0654\u0642\u064a\u0646 \u0645\u0646 \u062e\u0637\u0648\u0631\u0629 \u0627\u0644\u0627\u0646\u0634\u063a\u0627\u0644 \u0628\u0627\u0644\u062c\u0648\u0627\u0644 \u0648\u0627\u0644\u0633\u0631\u0639\u0629 \u0627\u0644\u0645\u0641\u0631\u0637\u0629 \u062e\u0644\u0627\u0644 <a href=\"https://www.alyaum.com/articles/6651764/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D9%85%D9%86%D9%88%D8%B9%D8%A7%D8%AA/%D8%B5%D9%88%D8%B1-%D8%B4%D8%A7%D8%B7%D8%A6-%D8%A3%D9%85%D9%84%D8%AC-%D9%8A%D8%B3%D8%AA%D9%82%D8%B7%D8%A8-%D8%A7%D9%84%D9%85%D8%AA%D9%86%D8%B2%D9%87%D9%8A%D9%86-%D8%AE%D9%84%D8%A7%D9%84-%D8%A5%D8%AC%D8%A7%D8%B2%D8%A9-%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D9%81%D8%B7%D8%B1\" target=\"_blank\">\u0627\u0655\u062c\u0627\u0632\u0629 \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631</a>\u060c \u0645\u0648\u0654\u0643\u062f\u0629 \u0627\u0654\u0646 \u062d\u0648\u0627\u062f\u062b \u0627\u0644\u062f\u0647\u0633 \u062a\u0634\u0643\u0644 19% \u0645\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0648\u0641\u064a\u0627\u062a \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629 \u0628\u0627\u0644\u0645\u0646\u0637\u0642\u0629.<br /><br />\u0648\u0634\u062f\u062f\u062a \u0627\u0644\u0644\u062c\u0646\u0629 \u0639\u0644\u0649 \u0627\u0654\u0646 \u0644\u062d\u0638\u0627\u062a \u0627\u0644\u063a\u0641\u0644\u0629 \u0648\u0627\u0644\u062a\u0647\u0627\u0648\u0646 \u0627\u0654\u062b\u0646\u0627\u0621 \u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0642\u062f \u062a\u0646\u062a\u0647\u064a \u0628\u0643\u0648\u0627\u0631\u062b \u0645\u0627\u0654\u0633\u0627\u0648\u064a\u0629\u060c \u062a\u0632\u0627\u0645\u0646\u0627\u064b \u0645\u0639 \u0627\u0644\u0643\u062b\u0627\u0641\u0629 \u0627\u0644\u0639\u0627\u0644\u064a\u0629 \u0644\u062d\u0631\u0643\u0629 \u0627\u0644\u0645\u0634\u0627\u0629 \u0648<a href=\"https://www.alyaum.com/articles/6597246/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%84%D8%AE%D9%81%D8%B6-%D8%A7%D9%84%D8%A7%D8%B2%D8%AF%D8%AD%D8%A7%D9%85-10-%D8%AC%D9%87%D8%A7%D8%AA-%D8%AD%D9%83%D9%88%D9%85%D9%8A%D8%A9-%D8%AA%D8%B7%D9%84%D9%82-%D8%AF%D9%84%D9%8A%D9%84-%D8%AA%D9%86%D8%B8%D9%8A%D9%85-%D8%AD%D8%B1%D9%83%D8%A9-%D8%A7%D9%84%D8%B4%D8%A7%D8%AD%D9%86%D8%A7%D8%AA-%D8%A8%D8%A7%D9%84%D9%86%D8%B7%D8%A7%D9%82-%D8%A7%D9%84%D8%B9%D9%85%D8%B1%D8%A7%D9%86%D9%8A\" target=\"_blank\">\u0627\u0644\u0627\u0632\u062f\u062d\u0627\u0645 \u0627\u0644\u0645\u0631\u0648\u0631\u064a</a> \u0641\u064a \u0627\u0644\u0634\u0648\u0627\u0631\u0639.<br /><br /> <h2>\u0631\u0633\u0627\u064a\u0654\u0644 \u062a\u0648\u0639\u0648\u064a\u0629</h2><br />\u0628\u064a\u0651\u0646\u062a \u0641\u064a \u0631\u0633\u0627\u064a\u0654\u0644\u0647\u0627 \u0627\u0644\u062a\u0648\u0639\u0648\u064a\u0629 \u0627\u0654\u0646 \u0627\u0644\u0637\u0631\u064a\u0642 \u064a\u0643\u062a\u0638 \u062e\u0644\u0627\u0644 \u0627\u0644\u0639\u064a\u062f \u0628\u0627\u0644\u0627\u0654\u0637\u0641\u0627\u0644 \u0648\u0643\u0628\u0627\u0631 \u0627\u0644\u0633\u0646\u060c \u0645\u0639\u062a\u0628\u0631\u0629 \u0627\u0654\u0646 \u062d\u0645\u0627\u064a\u062a\u0647\u0645 \u0648\u0633\u0644\u0627\u0645\u062a\u0647\u0645 \u062a\u0645\u062b\u0644 \u00ab\u0627\u0654\u0645\u0627\u0646\u0629 \u0641\u064a \u0627\u0654\u0639\u064a\u0646 \u0627\u0644\u0633\u0627\u064a\u0654\u0642\u064a\u0646\u00bb.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0654\u0646 \u0644\u062d\u0638\u0629 \u062a\u0634\u062a\u062a \u0648\u0627\u062d\u062f\u0629 \u062e\u0644\u0641 \u0627\u0644\u0645\u0642\u0648\u062f \u062a\u0643\u0641\u064a \u0644\u0643\u0633\u0631 \u0641\u0631\u062d\u0629 \u0627\u0644\u0639\u0627\u064a\u0654\u0644\u0627\u062a\u060c \u0648\u062a\u062d\u0648\u064a\u0644 \u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0644\u0627\u062a \u0627\u0655\u0644\u0649 \u0645\u0627\u0653\u0633\u064d \u0644\u0627 \u062a\u064f\u0646\u0633\u0649.<br /><br />\u0648\u0643\u0634\u0641 \u0627\u0644\u062f\u0643\u062a\u0648\u0631 \u0645\u062d\u0645\u062f \u0627\u0644\u0646\u0639\u064a\u0645\u064a \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0644\u064a\u0629 \u0648\u0627\u0644\u062d\u0631\u0643\u0629 \u0627\u0644\u0646\u0634\u0637\u0629 \u062a\u0642\u0627\u0628\u0644 \u0628\u0648\u0627\u0642\u0639 \u0645\u0642\u0644\u0642 \u064a\u062a\u0645\u062b\u0644 \u0641\u064a \u062a\u0635\u0627\u0639\u062f \u0645\u0648\u0654\u0634\u0631\u0627\u062a \u062d\u0648\u0627\u062f\u062b \u0627\u0644\u062f\u0647\u0633 \u0628\u0634\u0643\u0644 \u0645\u0644\u062d\u0648\u0638.<br /><br /> <br /><br />\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0644\u0646\u0639\u064a\u0645\u064a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u062d\u0648\u0627\u062f\u062b \u0627\u0644\u0642\u0627\u062a\u0644\u0629 \u062a\u0642\u0639 \u0641\u064a \u00ab\u062b\u0648\u0627\u0646\u064d \u0645\u0639\u062f\u0648\u062f\u0629\u00bb\u060c \u0644\u0643\u0646 \u062a\u062f\u0627\u0639\u064a\u0627\u062a\u0647\u0627 \u062a\u063a\u064a\u0631 \u0645\u0633\u0627\u0631 \u062d\u064a\u0627\u0629 \u0627\u0654\u0633\u0631 \u0643\u0627\u0645\u0644\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0654\u0628\u062f.<h2>\u0627\u0644\u0633\u0631\u0639\u0629 \u0627\u0644\u0645\u0641\u0631\u0637\u0629</h2><br />\u0627\u0654\u0643\u062f \u0627\u0644\u0646\u0639\u064a\u0645\u064a \u0627\u0654\u0646 \u0627\u0644\u0633\u0631\u0639\u0629 \u0627\u0644\u0645\u0641\u0631\u0637\u0629 \u0648\u0627\u0644\u0627\u0646\u0634\u063a\u0627\u0644 \u0628\u0627\u0644\u0647\u0627\u062a\u0641 \u0627\u0644\u0645\u062d\u0645\u0648\u0644 \u064a\u062a\u0635\u062f\u0631\u0627\u0646 \u0627\u0644\u0642\u0627\u064a\u0654\u0645\u0629 \u0627\u0644\u0633\u0648\u062f\u0627\u0621 \u0644\u0645\u0633\u0628\u0628\u0627\u062a \u0627\u0644\u062d\u0648\u0627\u062f\u062b\u060c \u0648\u0627\u0635\u0641\u0627\u064b \u0627\u0655\u064a\u0627\u0647\u0645\u0627 \u0628\u0640 \u00ab\u0627\u0644\u062e\u0637\u0631\u064a\u0646 \u0627\u0644\u0644\u0630\u064a\u0646 \u064a\u0633\u0644\u0628\u0627\u0646 \u0641\u0631\u062d\u0629 \u0627\u0644\u0639\u064a\u062f\u00bb.<br /><br />\u0648\u0644\u0641\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0627\u0644\u062a\u0632\u0627\u0645 \u0627\u0644\u062a\u0627\u0645 \u0628\u0627\u0644\u0627\u0654\u0646\u0638\u0645\u0629 \u0627\u0644\u0645\u0631\u0648\u0631\u064a\u0629 \u0648\u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0648\u0627\u0639\u064a\u0629 \u064a\u0634\u0643\u0644\u0627\u0646 \u062d\u0627\u064a\u0654\u0637 \u0627\u0644\u0635\u062f \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0631\u0648\u0627\u062d \u0648\u0627\u0644\u0645\u0645\u062a\u0644\u0643\u0627\u062a.<br /><br />\u0648\u062f\u0639\u0627 \u0627\u0644\u0633\u0627\u064a\u0654\u0642\u064a\u0646 \u0627\u0655\u0644\u0649 \u0636\u0631\u0648\u0631\u0629 \u0627\u0644\u062a\u062d\u0644\u064a \u0628\u0627\u0644\u0647\u062f\u0648\u0621 \u0627\u0644\u062a\u0627\u0645 \u0648\u0627\u0644\u0627\u0646\u062a\u0628\u0627\u0647 \u0627\u0644\u0645\u0636\u0627\u0639\u0641 \u0644\u0644\u0645\u0634\u0627\u0629\u060c \u0644\u062a\u062c\u0627\u0648\u0632 \u0647\u0630\u0647 \u0627\u0644\u0641\u062a\u0631\u0629 \u0628\u0627\u0654\u0645\u0627\u0646. \u0645\u0637\u0627\u0644\u0628\u0627 \u0627\u0644\u062c\u0645\u064a\u0639 \u0628\u0627\u0644\u062a\u0645\u0647\u0644 \u0648\u062a\u062c\u0646\u0628 \u0627\u0644\u0645\u0634\u062a\u062a\u0627\u062a\u060c \u0644\u0636\u0645\u0627\u0646 \u0628\u064a\u064a\u0654\u0629 \u0645\u0631\u0648\u0631\u064a\u0629 \u0627\u0653\u0645\u0646\u0629 \u062a\u0639\u0632\u0632 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u062c\u062a\u0645\u0639 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0646\u0627\u0633\u0628\u0629 \u0627\u0644\u0633\u0639\u064a\u062f\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["business", "top"], "datatype": "news", "pubDate": "2026-03-23 09:39:00", "pubDateTZ": "UTC", "fetched_at": "2026-03-23 09:47:40", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID P