link": "https://www.alyaum.com/articles/6651422/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%8A%D8%AA%D8%A8%D8%B1%D8%A3-%D9%85%D9%86-%D9%82%D8%B5%D9%81-%D8%AD%D9%82%D9%84-%D8%A8%D8%A7%D8%B1%D8%B3-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A-%D9%88%D9%8A%D8%A4%D9%83%D8%AF-%D8%B9%D8%AF%D9%85-%D8%AA%D9%83%D8%B1%D8%A7%D8%B1%D9%87", "title": "\u062a\u0631\u0627\u0645\u0628 \u064a\u062a\u0628\u0631\u0627\u0654 \u0645\u0646 \u0642\u0635\u0641 \u062d\u0642\u0644 \u0628\u0627\u0631\u0633 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0648\u064a\u0648\u0654\u0643\u062f \u0639\u062f\u0645 \u062a\u0643\u0631\u0627\u0631\u0647", "description": "\u0648\u0633\u0637 \u062a\u0635\u0627\u0639\u062f \u0627\u0644\u0645\u062e\u0627\u0648\u0641 \u0645\u0646 \u0627\u0644\u0627\u0654\u0636\u0631\u0627\u0631 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a\u0629 \u0627\u0644\u0646\u0627\u062c\u0645\u0629 \u0639\u0646 \u0627\u0644\u062d\u0631\u0628\u060c \u0627\u0654\u0643\u062f \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a <a href=\"https://www.alyaum.com/articles/6651070/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D8%AF%D9%88%D9%84-%D8%AD%D9%84%D9%81-%D8%A7%D9%84%D9%86%D8%A7%D8%AA%D9%88-%D8%A7%D8%B1%D8%AA%D9%83%D8%A8%D8%AA-%D8%AE%D8%B7%D8%A3-%D8%BA%D8%A8%D9%8A%D8%A7-%D8%A8%D8%B4%D8%A3%D9%86-%D9%85%D8%B6%D9%8A%D9%82-%D9%87%D8%B1%D9%85%D8%B2\" target=\"_blank\">\u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u0628</a> \u0627\u0655\u0646 \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 <a href=\"https://www.alyaum.com/articles/6651296/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%8A%D8%AA%D9%88%D8%B9%D8%AF-%D8%A8%D8%AA%D8%AF%D9%85%D9%8A%D8%B1-%D8%AD%D9%82%D9%84-%D8%A8%D8%A7%D8%B1%D8%B3-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A-%D8%AD%D8%A7%D9%84-%D8%A7%D8%B3%D8%AA%D9%87%D8%AF%D8%A7%D9%81-%D9%85%D9%86%D8%B4%D8%A2%D8%AA-%D8%A7%D9%84%D8%BA%D8%A7%D8%B2-%D8%A7%D9%84%D9%82%D8%B7%D8%B1%D9%8A%D8%A9\" target=\"_blank\">\u062d\u0642\u0644 \u0628\u0627\u0631\u0633</a> \u0627\u0644\u062c\u0646\u0648\u0628\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0644\u0644\u063a\u0627\u0632 \u0644\u0646 \u064a\u062a\u0643\u0631\u0631\u060c \u0644\u0643\u0646\u0647 \u0647\u062f\u062f \u0628\u062a\u062f\u0645\u064a\u0631\u0647 \u0627\u0655\u0630\u0627 \u0644\u0645 \u062a\u0643\u0641\u0651 \u0637\u0647\u0631\u0627\u0646 \u0639\u0646 \u0636\u0631\u0628 \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u0642\u0637\u0631\u064a\u0629 \u0644\u0644\u063a\u0627\u0632 \u0627\u0644\u0645\u0633\u0627\u0644.<br />\u0648\u0631\u062f\u0651\u062a \u0627\u0655\u064a\u0631\u0627\u0646 \u0628\u062a\u062d\u0630\u064a\u0631\u0647\u0627 \u0645\u0646 \u0627\u0654\u0646\u0647\u0627 \u0644\u0646 \u062a\u0645\u0627\u0631\u0633 \u0627\u0654\u064a \u0636\u0628\u0637 \u0644\u0644\u0646\u0641\u0633 \u0627\u0655\u0630\u0627 \u0627\u0633\u062a\u064f\u0647\u062f\u0650\u0641\u064e\u062a \u0645\u062c\u062f\u062f\u064b\u0627 \u0645\u0646\u0634\u0627\u0653\u062a\u0647\u0627 \u0644\u0644\u0637\u0627\u0642\u0629.<br />\u0648\u062c\u0627\u0621 \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u0646\u0641\u0637\u064a\u0629 \u0644\u064a\u0641\u0627\u0642\u0645 \u0627\u0647\u062a\u0632\u0627\u0632 \u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0644\u0646\u0641\u0637 \u0627\u0654\u0635\u0644\u064b\u0627 \u0628\u0641\u0639\u0644 \u0627\u0655\u063a\u0644\u0627\u0642 \u0627\u0655\u064a\u0631\u0627\u0646 \u0645\u0636\u064a\u0642 \u0647\u0631\u0645\u0632 \u0627\u0644\u062d\u064a\u0648\u064a.<h2>\u0648\u0627\u0634\u0646\u0637\u0646 \u0644\u0645 \u062a\u0643\u0646 \u062a\u0639\u0644\u0645 \u0628\u0627\u0644\u0642\u0635\u0641</h2>\u0648\u0627\u0654\u0643\u062f <a href=\"https://www.alyaum.com/articles/6651264/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%AA%D8%B1%D8%A7%D9%85%D8%A8-%D9%8A%D8%B9%D9%84%D9%82-%D9%82%D8%A7%D9%86%D9%88%D9%86-%D8%AC%D9%88%D9%86%D8%B2-60-%D9%8A%D9%88%D9%85%D8%A7-%D9%87%D9%84-%D9%8A%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D9%82%D8%B1%D8%A7%D8%B1-%D9%84%D8%A3%D8%B3%D9%88%D8%A7%D9%82-%D8%A7%D9%84%D9%86%D9%81%D8%B7\" target=\"_blank\">\u062a\u0631\u0627\u0645\u0628</a> \u0627\u0654\u0646 \u0648\u0627\u0634\u0646\u0637\u0646 \u0644\u0645 \u062a\u0643\u0646 \u062a\u0639\u0644\u0645 \u0634\u064a\u064a\u0654\u0627 \u0633\u0644\u0641\u064b\u0627 \u0639\u0646 \u0647\u062c\u0648\u0645 \u0642\u0648\u0627\u062a \u0627\u0644\u0627\u062d\u062a\u0644\u0627\u0644 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 \u0639\u0644\u0649 \u062d\u0642\u0644 \u0628\u0627\u0631\u0633 \u0627\u0644\u062c\u0646\u0648\u0628\u064a \u0627\u0644\u0630\u064a \u064a\u0648\u0641\u0651\u0631 \u0644\u0627\u0655\u064a\u0631\u0627\u0646 \u0646\u062d\u0648 70% \u0645\u0646 \u0627\u0644\u063a\u0627\u0632 \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0627\u0644\u0630\u064a \u062a\u0633\u062a\u0647\u0644\u0643\u0647 \u0645\u062d\u0644\u064a\u064b\u0627\u060c \u0644\u0643\u0646\u0647 \u0642\u0627\u0644 \u0627\u0655\u0646\u0647 \u0637\u0644\u0628 \u0645\u0646 \u0631\u064a\u0654\u064a\u0633 \u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0643\u064a\u0627\u0646 \u0628\u0646\u064a\u0627\u0645\u064a\u0646 \u0646\u062a\u0627\u0646\u064a\u0627\u0647\u0648 \u0627\u0644\u0643\u0641 \u0639\u0646 \u0645\u0647\u0627\u062c\u0645\u0629 \u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u0637\u0627\u0642\u0629 \u0641\u064a \u0627\u064a\u0631\u0627\u0646.<br />\u0648\u0627\u0636\u0627\u0641: \"\u0646\u062d\u0646 \u0645\u0646\u0633\u062c\u0645\u0627\u0646 \u0628\u0634\u0643\u0644 \u0631\u0627\u064a\u0654\u0639\u060c \u062b\u0645\u0629 \u062a\u0646\u0633\u064a\u0642 \u0628\u064a\u0646\u0646\u0627\u060c \u0644\u0643\u0646 \u0641\u064a \u0628\u0639\u0636 \u0627\u0644\u0627\u0654\u062d\u064a\u0627\u0646 \u064a\u0641\u0639\u0644 \u0634\u064a\u064a\u0654\u0627 \u062a\u0639\u0627\u0631\u0636\u0647 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629\".<br /> <br />\u0648\u0642\u0627\u0644 \u0646\u062a\u0627\u0646\u064a\u0627\u0647\u0648 \u0627\u0655\u0646 \u0642\u0648\u0627\u062a\u0647 \u062a\u062d\u0631\u0651\u0643\u062a \u0628\u0645\u0641\u0631\u062f\u0647\u0627 \u0641\u064a \u0642\u0635\u0641 \u062d\u0642\u0644 \u0628\u0627\u0631\u0633.<br />\u0648\u0627\u0654\u0636\u0627\u0641: \"\u0637\u0644\u0628 \u0645\u0646\u0627 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u062a\u0631\u0627\u0645\u0628 \u062a\u0639\u0644\u064a\u0642 \u0627\u0654\u064a\u0651 \u0647\u062c\u0648\u0645 \u062c\u062f\u064a\u062f \u0648\u0646\u062d\u0646 \u0646\u0645\u062a\u062b\u0644 \u0644\u0637\u0644\u0628\u0647.<h2>\u062a\u0647\u062f\u064a\u062f\u0627\u062a \u062a\u0631\u0627\u0645\u0628 \u0648\u0631\u062f \u0627\u0655\u064a\u0631\u0627\u0646</h2>\u0648\u0633\u0628\u0642 \u062a\u0635\u0631\u064a\u062d \u062a\u0631\u0627\u0645\u0628 \u062a\u0647\u062f\u064a\u062f\u0647 \"\u0628\u062a\u0641\u062c\u064a\u0631 \u062d\u0642\u0644 \u063a\u0627\u0632 \u0628\u0627\u0631\u0633 \u0627\u0644\u062c\u0646\u0648\u0628\u064a \u0628\u0627\u0654\u0643\u0645\u0644\u0647 \u0628\u0642\u0648\u0629 \u0647\u0627\u064a\u0654\u0644\u0629\" \u0645\u0627 \u0644\u0645 \u062a\u062a\u0648\u0642\u0651\u0641 \u0637\u0647\u0631\u0627\u0646 \u0639\u0646 \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0642\u0637\u0631\u064a\u0629\u060c \u0644\u0643\u0646\u0647 \u0627\u0654\u0648\u0636\u062d \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0646\u0641\u0633\u0647 \u0627\u0654\u0646\u0647 \u0644\u0627 \u062e\u0637\u0637 \u0631\u0627\u0647\u0646\u0627 \u0644\u0646\u0634\u0631 \u062c\u0646\u0648\u062f \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646.<br />\u0648\u0631\u062f\u0651\u062a \u0627\u0655\u064a\u0631\u0627\u0646 \u0639\u0644\u0649 \u0627\u0644\u062a\u0647\u062f\u064a\u062f \u0628\u0627\u0644\u0645\u062b\u0644\u060c \u0648\u0646\u0642\u0644\u062a \u0648\u0643\u0627\u0644\u0629 \u0627\u0654\u0646\u0628\u0627\u0621 \u0641\u0627\u0631\u0633 \u0639\u0646 \"\u0645\u0642\u0631 \u062e\u0627\u062a\u0645 \u0627\u0644\u0627\u0654\u0646\u0628\u064a\u0627\u0621\"\u060c \u0627\u0644\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a\u064a\u0629 \u0644\u0644\u062c\u064a\u0634\u060c \u0627\u0654\u0646 \"\u0627\u0644\u0647\u062c\u0645\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0628\u0646\u064a\u0629 \u0627\u0644\u062a\u062d\u062a\u064a\u0629 \u0644\u0644\u0637\u0627\u0642\u0629 \u0644\u0646 \u062a\u062a\u0648\u0642\u0641 \u062d\u062a\u0649 \u062a\u062f\u0645\u064a\u0631\u0647\u0627 \u0628\u0627\u0644\u0643\u0627\u0645\u0644 \u0627\u0655\u0630\u0627 \u062a\u0643\u0631\u0631\u062a \u0627\u0644\u0636\u0631\u0628\u0627\u062a \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629.<br />\u0648\u062d\u0630\u0651\u0631 \u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0639\u0628\u0627\u0633 \u0639\u0631\u0627\u0642\u062c\u064a \u0645\u0646 \u0627\u0654\u0646 \u0637\u0647\u0631\u0627\u0646 \u0644\u0646 \u062a\u0645\u0627\u0631\u0633 \u0627\u0654\u064a \u0636\u0628\u0637 \u0644\u0644\u0646\u0641\u0633 \u0627\u0655\u0630\u0627 \u062a\u0639\u0631\u0636\u062a \u0645\u0646\u0634\u0627\u0653\u062a\u0647\u0627 \u0644\u0644\u0637\u0627\u0642\u0629 \u0644\u0644\u0647\u062c\u0648\u0645 \u0645\u062c\u062f\u062f\u0627 \u0641\u064a \u0627\u0644\u062d\u0631\u0628 \u0645\u0639 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0648\u0627\u0655