9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B7%D9%82%D8%B3-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D9%85%D8%AA%D9%88%D8%B3%D8%B7%D8%A9-%D8%A5%D9%84%D9%89-%D8%BA%D8%B2%D9%8A%D8%B1%D8%A9-%D8%B9%D9%84%D9%89-%D9%85%D8%AD%D8%A7%D9%81%D8%B8%D8%A7%D8%AA-%D8%AC%D9%86%D9%88%D8%A8-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6\"> \u0627\u0644\u062d\u0627\u0644\u0629 \u0627\u0644\u0645\u0637\u0631\u064a\u0629</a> \u0627\u0644\u062a\u064a \u062a\u0634\u0647\u062f\u0647\u0627 \u0627\u0644\u0639\u0627\u0635\u0645\u0629\u060c \u0636\u0645\u0646 \u062e\u0637\u0637\u0647\u0627 \u0627\u0644\u0645\u0633\u062a\u0645\u0631\u0629 \u0644\u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u062c\u0627\u0647\u0632\u064a\u0629 \u062e\u0644\u0627\u0644 \u0645\u0648\u0633\u0645 \u0627\u0644\u0627\u0654\u0645\u0637\u0627\u0631.<br /> </p><p>\u0648\u0627\u0654\u0648\u0636\u062d\u062a <a href=\"https://www.alyaum.com/articles/6651912/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B5%D9%88%D8%B1-%D8%A3%D9%86%D8%B4%D8%B7%D8%A9-%D9%88%D8%B9%D8%B1%D9%88%D8%B6-%D9%85%D8%AA%D9%86%D9%88%D8%B9%D8%A9-%D8%AD%D8%AF%D8%A7%D8%A6%D9%82-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D9%88%D9%88%D8%A7%D8%AD%D8%A7%D8%AA%D9%87%D8%A7-%D8%AA%D8%AD%D8%AA%D9%81%D9%8A-%D8%A8%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D9%81%D8%B7%D8%B1\">\u0627\u0644\u0627\u0654\u0645\u0627\u0646\u0629 </a>\u0627\u0654\u0646 \u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u062a\u0639\u0645\u0644 \u0639\u0644\u0649 \u0645\u062f\u0627\u0631 \u0627\u0644\u0633\u0627\u0639\u0629 \u0644\u0645\u0628\u0627\u0634\u0631\u0629 \u0627\u0644\u0628\u0644\u0627\u063a\u0627\u062a \u0648\u0645\u0639\u0627\u0644\u062c\u0629 \u062a\u062c\u0645\u0639\u0627\u062a \u0627\u0644\u0645\u064a\u0627\u0647\u060c \u0628\u0645\u0627 \u064a\u0636\u0645\u0646 \u0633\u0631\u0639\u0629 \u0627\u0644\u0627\u0633\u0