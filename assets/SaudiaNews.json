%D8%B7%D8%A7%D8%B1-%D8%BA%D8%B2%D9%8A%D8%B1%D8%A9-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D9%88%D8%A7%D9%84%D8%A3%D8%B1%D8%B5%D8%A7%D8%AF-%D8%A7%D9%84%D9%81%D8%B1%D8%B5-%D9%85%D8%AA%D8%A7%D8%AD%D8%A9-%D9%84%D9%84%D9%85%D8%B2%D9%8A%D8%AF\" target=\"_blank\">\u0627\u0654\u0645\u0637\u0627\u0631 \u063a\u0632\u064a\u0631\u0629</a> \u0639\u0644\u0649 \u0645\u0646\u0637\u0642\u0629 \u0646\u062c\u0631\u0627\u0646\u060c \u062a\u0634\u0645\u0644 \u0645\u062f\u064a\u0646\u0629 \u0646\u062c\u0631\u0627\u0646\u060c \u0648\u0645\u062d\u0627\u0641\u0638\u0627\u062a \u0628\u062f\u0631 \u0627\u0644\u062c\u0646\u0648\u0628\u060c \u0648\u062b\u0627\u0631\u060c \u0648\u062d\u0628\u0648\u0646\u0627\u060c \u0648\u062e\u0628\u0627\u0634\u060c \u0648\u064a\u062f\u0645\u0629\u060c \u0645\u0635\u062d\u0648\u0628\u0629 \u0628\u0631\u064a\u0627\u062d \u0634\u062f\u064a\u062f\u0629 \u0627\u0644\u0633\u0631\u0639\u0629\u060c \u0648\u0627\u0646\u0639\u062f\u0627\u0645 \u0641\u064a \u0645\u062f\u0649 \u0627\u0644\u0631\u0648\u0654\u064a\u0629 \u0627\u0644\u0627\u0654\u0641\u0642\u064a\u0629\u060c \u0648\u062a\u0633\u0627\u0642\u0637 \u0627\u0644\u0628\u0631\u062f\u060c \u0648\u062c\u0631\u064a\u0627\u0646 \u0627\u0644\u0633\u064a\u0648\u0644\u060c \u0648\u0635\u0648\u0627\u0639\u0642 \u0631\u0639\u062f\u064a\u0629.<br /><br />\u0648\u0628\u064a\u064e\u0651\u0646 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0654\u0646 \u0627\u0644\u062d\u0627\u0644\u0629 \u0633\u062a\u0633\u062a\u0645\u0631 \u062d\u062a\u0649 \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062d\u0627\u062f\u064a\u0629 \u0639\u0634\u0631\u0629 \u0645\u0633\u0627\u0621\u064b.<br /> <h2>\u0645\u0648\u062c\u0629 \u0636\u0628\u0627\u0628</h2>\u0645\u0646 \u0646\u0627\u062d\u064a\u0629 \u0627\u0654\u062e\u0631\u0649\u060c \u0646\u0628\u0651\u0647 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u064a\u0648\u0645 \u0645\u0646 \u0645\u0648\u062c\u0629 <a href=\"https://www.alyaum.com/articles/6651669/%D8%A7%D9%84%D8%A