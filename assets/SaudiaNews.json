641\u0633\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u064024 \u0645\u0646 \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0644\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646 \u00ab\u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646\u00bb\u060c \u0648\u0627\u0646\u062a\u0647\u0649 \u0646\u0635\u0631\u0627\u0648\u064a\u0627\u064b \u0628\u0646\u062a\u064a\u062c\u0629 \u062b\u0644\u0627\u062b\u0629 \u0627\u0654\u0647\u062f\u0627\u0641 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641\u060c \u0644\u064a\u0636\u0639 \u062d\u062f\u0627\u064b \u0644\u0633\u0644\u0633\u0644\u0629 \u062f\u0641\u0627\u0639\u064a\u0629 \u0645\u0645\u064a\u0632\u0629 \u062d\u0642\u0642\u0647\u0627 \u00ab\u0627\u0644\u0639\u0627\u0644\u0645\u064a\u00bb \u0641\u064a \u0627\u0644\u0627\u0654\u0633\u0627\u0628\u064a\u0639 \u0627\u0644\u0645\u0627\u0636\u064a\u0629.\u0648\u062f\u062e\u0644 \u0627\u0644\u0646\u0635\u0631 \u0627\u0644\u0644\u0642\u0627\u0621 \u0628\u0633\u0644\u0633\u0644\u0629 \u0628\u0644\u063a\u062a 7 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0645\u062a\u062a\u0627\u0644\u064a\u0629 \u062d\u0627\u0641\u0638 \u062e\u0644\u0627\u0644\u0647\u0627 \u0639\u0644\u0649 \u0646\u0638\u0627\u0641\u0629 \u0634\u0628\u0627\u0643\u0647\u060c \u0641\u064a \u0631\u0642\u0645 \u064a\u0639\u0643\u0633 \u0627\u0644\u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0627\u0644\u062f\u0641\u0627\u0639\u064a \u0648\u0627\u0644\u0627\u0646\u0636\u0628\u0627\u0637 \u0627\u0644\u062a\u0643\u062a\u064a\u0643\u064a \u0627\u0644\u0630\u064a \u0638\u0647\u0631 \u0628\u0647 \u0627\u0644\u0641\u0631\u064a\u0642 \u062e\u0644\u0627\u0644 \u0627\u0644\u062c\u0648\u0644\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629.\u0648\u062c\u0627\u0621 \u0643\u0633\u0631 \u0627\u0644\u0633\u0644\u0633\u0644\u0629 \u0639\u0646 \u0637\u0631\u064a\u0642 \u0645\u062f\u0627\u0641\u0639 \u0627\u0644\u0646\u0635\u0631 \u0639\u0628\u062f\u0627\u0644\u0627\u0655\u0644\u0647 \