644\u062c\u0645\u0627\u0639\u064a\u0629 \u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0647\u0644\u0627\u0644 \u0645\u0633\u0627\u0621 \u064a\u0648\u0645 \u063a\u062f \u0627\u0644\u062e\u0645\u064a\u0633 \u0639\u0646\u062f \u0627\u0633\u062a\u064a\u0654\u0646\u0627\u0641\u0647\u0627 \u0628\u0639\u062f \u0627\u0644\u0631\u0627\u062d\u0629 \u0627\u0644\u062a\u064a \u062d\u0635\u0644 \u0639\u0644\u064a\u0647\u0627 \u0627\u0644\u0644\u0627\u0639\u0628\u0648\u0646 \u062e\u0644\u0627\u0644 \u0627\u0644\u062a\u0648\u0642\u0641 \u0627\u0644\u062f\u0648\u0644\u064a\u060c \u0628\u0646\u062a\u0627\u064a\u0654\u062c \u0627\u0644\u0627\u062e\u062a\u0628\u0627\u0631\u0627\u062a \u0627\u0644\u062a\u064a \u0633\u064a\u062e\u0636\u0639 \u0644\u0647\u0627 \u0639\u0644\u0649 \u0645\u0648\u0636\u0639 \u0627\u0655\u0635\u0627\u0628\u062a\u0647.<br /><br />\u0635\u0627\u062d\u0628 \u0627\u0644\u0640 27 \u0639\u0627\u0645\u064b\u0627 \u0643\u0627\u0646 \u0642\u062f \u0634\u0647\u0631 \u0628\u0627\u0655\u0635\u0627\u0628\u0629 \u0641\u064a \u0627\u0655\u0635\u0628\u0639 \u0642\u062f\u0645\u0647 \u062e\u0644\u0627\u0644 \u0627\u0644\u062a\u062f\u0631\u064a\u0628\u0627\u062a \u0644\u064a\u063a\u064a\u0628 \u0639\u0644\u0649 \u0627\u0655\u062b\u0631\u0647\u0627 \u0627\u0654\u0645\u0627\u0645: \u0627\u0644\u0634\u0628\u0627\u0628\u060c \u0627\u0644\u0646\u062c\u0645\u0629\u060c \u0627\u0644\u062a\u0639\u0627\u0648\u0646\u060c \u0627\u0644\u0641\u062a\u062d \u0648\u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0641\u064a \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0648\u0643\u0627\u0654\u0633 \u0627\u0644\u0645\u0644\u0643.<br /><br />\u0648\u0634\u0627\u0631\u0643 \u0627\u0644\u0644\u0627\u0639\u0628 \u0628\u0642\u0645\u064a\u0635 \u0646\u0627\u062f\u064a \u0627\u0644\u0647\u0644\u0627\u0644 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062c\u0627\u0631\u064a \u0628\u0640 (29) \u0645\u0628\u0627\u0631\u0627\u0629 \u0635\u0646\u0639 \u062e\u0644\u0627\u0644\u0647\u0627 \u0647\u062f\u0641\u064a\u0646 \u0628\u0648\u0627\u0642\u0639 (1569) \u062f\u0642\u064a\u0642\u0629 \u0644\u0639\u0628.<br /><br />\u0648\u0641\u064a \u0633\u064a\u0627\u0642 \u0627\u0653\u062e\u0631\u060c \u064a\u0633\u062a\u0636\u064a\u0641 \u0641\u0631\u064a\u0642 \u0627\u0644\u0647\u0644\u0627\u0644 \u0646\u0638\u064a\u0631\u0647 \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0639\u0646\u062f \u0627\u0644\u062a\u0627\u0633\u0639\u0629 \u0645\u0646 \u0645\u0633\u0627\u0621 \u064a\u0648\u0645 \u0627\u0644\u0633\u0628\u062a 4 \u0627\u0654\u0628\u0631\u064a\u0644 \u0636\u0645\u0646 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 (27) \u0645\u0646 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646.<br /><br />\u0648\u064a\u062d\u062a\u0644 \u0641\u0631\u064a\u0642 \u0627\u0644\u0647\u0644\u0627\u0644 \u0642\u0628\u0644 \u0641\u062a\u0631\u0629 \u0627\u0644\u062a\u0648\u0642\u0641 \u0627\u0644\u062f\u0648\u0644\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0646\u064a \u0628\u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0631\u0635\u064a\u062f (64) \u0646\u0642\u0637\u0629 \u0628\u0641\u0627\u0631\u0642 \u0646\u0642\u0637\u062a\u064a\u0646 \u0639\u0646 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0635\u0627\u062d\u0628 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0644\u062b \u0648\u062b\u0644\u0627\u062b\u0629 \u0646\u0642\u0627\u0637 \u0639\u0646 \u0627\u0644\u0646\u0635\u0631 \u0627\u0644\u0645\u062a\u0635\u062f\u0631.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-03-25 19:34:00", "pubDateTZ": "UTC", "fetched_at": "2026-03-25 20:06:53", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "