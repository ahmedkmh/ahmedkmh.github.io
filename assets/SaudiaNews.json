u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629\u060c \u0641\u064a \u0645\u0643\u062a\u0628 \u0633\u0645\u0648\u0647 \u0628\u062f\u064a\u0648\u0627\u0646 \u0627\u0644\u0627\u0655\u0645\u0627\u0631\u0629 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u062b\u0646\u064a\u0646\u060c \u0645\u062f\u064a\u0631 \u0639\u0627\u0645 \u0641\u0631\u0639 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0628\u0634\u0631\u064a\u0629 \u0648\u0627\u0644\u062a\u0646\u0645\u064a\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0628\u0627\u0644\u0645\u0646\u0637\u0642\u0629\u060c \u0645\u062d\u0645\u062f \u0628\u0646 \u0633\u0639\u0648\u062f \u0627\u0644\u0633\u0645\u0627\u0631\u064a\u060c \u064a\u0631\u0627\u0641\u0642\u0647 \u0639\u062f\u062f \u0645\u0646 \u0645\u0646\u0633\u0648\u0628\u064a \u0627\u0644\u0641\u0631\u0639 \u0627\u0644\u0645\u062a\u0645\u064a\u0632\u064a\u0646\u060c \u0628\u0645\u0646\u0627\u0633\u0628\u0629 \u062a\u062d\u0642\u064a\u0642 \u0641\u0631\u0639 \u0627\u0644\u0648\u0632\u0627\u0631\u0629 \u0628\u0627\u0644\u0645\u0646\u0637\u0642\u0629 (\u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0627\u0654\u0648\u0644) \u0641\u064a \u062c\u0627\u064a\u0654\u0632\u0629 \u0627\u0644\u062a\u0645\u064a\u0651\u0632 \u0627\u0644\u0645\u0648\u0654\u0633\u0633\u064a \u0644\u0639\u0627\u0645 2025\u0645\u060c \u0639\u0646 \u0641\u064a\u0654\u0629 (\u0627\u0644\u0641\u0631\u0639 \u0627\u0644\u0645\u062a\u0645\u064a\u0651\u0632)\u060c \u0648\u0630\u0644\u0643 \u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0641\u0631\u0648\u0639 \u0627\u0644\u0648\u0632\u0627\u0631\u0629.\u0648\u0647\u0646\u0627\u0654 \u0633\u0645\u0648 \u0627\u0654\u0645\u064a\u0631 \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u0645\u0646\u0633\u0648\u0628\u064a \u0627\u0644\u0641\u0631\u0639 \u0628\u0647\u0630\u0647 \u0627\u0644\u0645\u0646\u0627\u0633\u0628\u0629\u060c \u0645\u0648\u