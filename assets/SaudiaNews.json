5\u0631\u0643\u0632 \u0627\u0644\u0627\u0654\u0637\u0631\u0627\u0641 \u0627\u0644\u0635\u0646\u0627\u0639\u064a\u0629 \u0648\u0627\u0655\u0639\u0627\u062f\u0629 \u0627\u0644\u062a\u0627\u0654\u0647\u064a\u0644 \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u0639\u062f\u0646 \u062e\u062f\u0645\u0627\u062a\u0647 \u0627\u0644\u0637\u0628\u064a\u0629 \u0627\u0644\u0645\u062a\u0646\u0648\u0639\u0629 \u0644\u0640(659) \u0645\u0633\u062a\u0641\u064a\u062f\u064b\u0627 \u0645\u0645\u0646 \u0641\u0642\u062f\u0648\u0627 \u0627\u0654\u0637\u0631\u0627\u0641\u0647\u0645 \u0645\u0646 \u0627\u0654\u0628\u0646\u0627\u0621<a href=\"https://www.alyaum.com/articles/6660706/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%B9%D8%A8%D8%B1%D8%A7-%D8%B9%D9%86-%D8%B9%D9%86-%D8%B4%D9%83%D8%B1%D9%87-%D9%88%D8%AA%D9%82%D8%AF%D9%8A%D8%B1%D9%87-%D9%84%D9%84%D9%82%D9%8A%D8%A7%D8%AF%D8%A9-%D9%85%D8%AD%D8%A7%D9%81%D8%B8-%D8%AD%D8%B6%D8%B1%D9%85%D9%88%D8%AA-%D9%8A%D8%B4%D9%8A%D8%AF-%D8%A8%D8%AC%D9%87%D9%88%D8%AF-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D9%81%D9%8A-%D8%AF%D8%B9%D9%85-%D8%A7%D9%84%D9%8A%D9%85%D9%86\"> \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u064a\u0645\u0646\u064a</a> \u0627\u0644\u0634\u0642\u064a\u0642 \u062e\u0644\u0627\u0644 \u0634\u0647\u0631 \u0627\u0654\u0628\u0631\u064a\u0644 2026\u0645\u061b \u0648\u0630\u0644\u0643 \u0628\u062f\u0639\u0645 \u0645\u0646<a href=\"https://www.alyaum.com/articles/6660379/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D9%85%D9%84%D9%83-%D8%B3%D9%84%D9%85%D8%A7%D9%86-%D9%84%D9%84%D8%A5%D8%BA%D8%A7%D8%AB%D8%A9-%D9%8A%D8%B9%D9%8A%D8%AF-%D8%AA%D8%A3%D9%87%D9%8A%D9%84-%D9%85%D8%A8%D9%86%D9%89-%D8%A7%D9%84%D8%B3%D9%88%D9%82-%D8%A7%D9%84%D9%85%D8%B1%D9%83%D8%B2%D9%8A-%D9%81%D9%8A-%D8%A7%D9%84%D9%85%D9%83%D9%84%D8%A7\"> \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629</a> \u0648\u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629.<br /><br />\u0648\u062c\u0631\u0649 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0634\u0631\u0648\u0639 \u062a\u0642\u062f\u064a\u0645 (1,945) \u062e\u062f\u0645\u0629\u060c \u0628\u0644\u063a\u062a \u0646\u0633\u0628\u0629 \u0627\u0644\u0630\u0643\u0648\u0631 (66%) \u0648\u0627\u0644\u0627\u0655\u0646\u0627\u062b (34%)\u060c \u0628\u064a\u0646\u0645\u0627 \u0634\u0643\u0651\u0644\u062a \u0646\u0633\u0628\u0629 \u0627\u0644\u0646\u0627\u0632\u062d\u064a\u0646 (56%) \u0648\u0627\u0644\u0645\u0642\u064a\u0645\u064a\u0646 (44%) \u0645\u0646 \u0627\u0655\u062c\u0645\u0627\u0644\u064a \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646\u060c \u0648\u062a\u0648\u0632\u0651\u0639\u062a \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0628\u064a\u0646 \u062a\u0635\u0646\u064a\u0639 \u0648\u062a\u0631\u0643\u064a\u0628 \u0648\u062a\u0627\u0654\u0647\u064a\u0644 \u0627\u0644\u0627\u0654\u0637\u0631\u0627\u0641 \u0627\u0644\u0635\u0646\u0627\u0639\u064a\u0629 \u0648\u0627\u0644\u0639\u0644\u0627\u062c \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0648\u0627\u0644\u0627\u0633\u062a\u0634\u0627\u0631\u0627\u062a \u0627\u0644\u062a\u062e\u0635\u0635\u064a\u0629.<br /> <h2>\u0645\u0631\u0643\u0632 \u0627\u0644\u063a\u0633\u064a\u0644 \u0627\u0644\u0643\u0644\u0648\u064a \u0641\u064a \u0627\u0644\u063a\u064a\u0636\u0629</h2>\u0648\u0627\u0635\u0644 \u0645\u0631\u0643\u0632 \u0627\u0644\u063a\u0633\u064a\u0644 \u0627\u0644\u0643\u0644\u0648\u064a \u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u0627\u0644\u063a\u064a\u0636\u0629 \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u0627\u0644\u0645\u0647\u0631\u0629 <a href=\"https://www.alyaum.com/articles/6659658/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%B4%D8%B1%D9%88%D8%B9-%D9%85%D8%B3%D8%A7%D9%85-%D9%8A%D9%88%D8%A7%D8%B5%D9%84-%D8%AA%D8%B7%D9%87%D9%8A%D8%B1-%D8%A7%D9%84%D9%8A%D9%85%D9%86-%D8%A5%D8%B2%D8%A7%D9%84%D8%A9-%D8%A2%D9%84%D8%A7%D9%81-%D8%A7%D9%84%D8%A3%D9%84%D8%BA%D8%A7%D9%85-%D9%84%D8%AD%D9%85%D8%A7%D9%8A%D8%A9-%D8%A7%D9%84%D9%85%D8%AF%D9%86%D9%8A%D9%8A%D9%86\">\u0627\u0644\u064a\u0645\u0646\u064a\u0629</a>\u060c \u062a\u0642\u062f\u064a\u0645 \u062e\u062f\u0645\u0627\u062a\u0647 \u0627\u0644\u0637\u0628\u064a\u0629 \u0644\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646 \u0628\u062f\u0639\u0645 \u0633\u062e\u064a \u0645\u0646 \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629 \u0648\u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629.<br /><br />\u0648\u0627\u0633\u062a\u0642\u0628\u0644 \u0627\u0644\u0645\u0631\u0643\u0632 \u062e\u0644\u0627\u0644 \u0634\u0647\u0631 \u0627\u0654\u0628\u0631\u064a\u0644 2026\u0645 (134) \u0645\u0631\u064a\u0636\u064b\u0627\u060c \u0628\u064a\u0646\u0647\u0645 (55) \u0645\u0631\u064a\u0636\u064b\u0627 \u062d\u0635\u0644\u0648\u0627 \u0639\u0644\u0649 (389) \u062c\u0644\u0633\u0629 \u063a\u0633\u064a\u0644 \u0643\u0644\u0648\u064a \u0645\u062c\u062f\u0648\u0644\u0629\u060c \u0648(10) \u062c\u0644\u0633\u0627\u062a \u0627\u0655\u0633\u0639\u0627\u0641\u064a\u0629\u060c \u0628\u064a\u0646\u0645\u0627 \u062a\u0644\u0642\u0649 (79) \u0645\u0631\u064a\u0636\u064b\u0627 \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u0639\u0627\u064a\u0646\u0629 \u0648\u0627\u0644\u0641\u062d\u0648\u0635\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0629 \u0641\u064a \u0639\u064a\u0627\u062f\u0629 \u0627\u0654\u0645\u0631\u0627\u0636 \u0627\u0644\u0643\u0644\u0649\u060c \u062d\u064a\u062b \u0628\u0644\u063a\u062a \u0646\u0633\u0628\u0629 \u0627\u0644\u0630\u0643\u0648\u0631 (65%)\u060c \u0648\u0646\u0633\u0628\u0629 \u0627\u0644\u0627\u0655\u0646\u0627\u062b (35%)\u060c \u0648\u0634\u0643\u0644\u062a \u0646\u0633\u0628\u0629 \u0627\u0644\u0646\u0627\u0632\u062d\u064a\u0646 (13%)\u060c \u0648\u0627\u0644\u0645\u0642\u064a\u0645\u064a\u0646 (86%)\u060c \u0648\u0627\u0644\u0644\u0627\u062c\u064a\u0654\u064a\u0646 (1%).<br /><br />\u0648\u064a\u0627\u0654\u062a\u064a \u0630\u0644\u0643 \u0627\u0645\u062a\u062f\u0627\u062f\u064b\u0627 \u0644\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0642\u062f\u0645\u0647\u0627 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0639\u0628\u0631 \u0630\u0631\u0627\u0639\u0647\u0627 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629\u061b \u0644\u0631\u0641\u0639 \u0627\u0655\u0645\u0643\u0627\u0646\u0627\u062a \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u0635\u062d\u064a \u0648\u0627\u0644\u0645\u062d\u0627\u0648\u0644\u0629 \u0645\u0646 \u062a\u062e\u0641\u064a\u0641 \u0645\u0639\u0627\u0646\u0627\u0629 \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u064a\u0645\u0646\u064a \u0627\u0644\u0634\u0642\u064a\u0642.<br /> <h2>\u0633\u0644\u0627\u0644 \u063a\u0630\u0627\u064a\u0654\u064a\u0629 \u0641\u064a \u0627\u0654\u0628\u064a\u0646</h2>\u0648\u0632\u0651\u0639 \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629 \u0648\u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0627\u0654\u0645\u0633 \u0627\u0644\u0627\u0654\u0648\u0644 (600) \u0633\u0644\u0629 \u063a\u0630\u0627\u064a\u0654\u064a\u0629 \u0644\u0644\u0627\u0654\u0633\u0631\u0629 \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u0627\u062d\u062a\u064a\u0627\u062c\u064b\u0627 \u0641\u064a \u0645\u062e\u064a\u0645 \u062c\u0648\u0644 \u0627\u0644\u0633\u0627\u062f\u0629 \u0645\u064a\u0643\u0644\u0627\u0646 \u0628\u0645\u062f\u064a\u0631\u064a\u0629 \u062e\u0646\u0641\u0631 \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u0627\u0654\u0628\u064a\u0646\u060c \u0627\u0633\u062a\u0641\u0627\u062f \u0645\u0646\u0647\u0627 (4,200) \u0641\u0631\u062f \u0628\u0648\u0627\u0642\u0639 (600) \u0627\u0654\u0633\u0631\u0629\u060c \u0636\u0645\u0646 \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0645\u0646 \u0645\u0634\u0631\u0648\u0639 \u0627\u0644\u062a\u062f\u062e\u0644\u0627\u062a \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a\u0629 \u0627\u0644\u0637\u0627\u0631\u064a\u0654\u0629 \u0641\u064a \u0627\u0644\u064a\u0645\u0646 \u0644\u0644\u0639\u0627\u0645 2026\u0645.<br /><br />\u0648\u064a\u0627\u0654\u062a\u064a \u0630\u0644\u0643 \u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0648\u0627\u0644\u0628\u0631\u0627\u0645\u062c \u0627\u0644\u0627\u0655\u063a\u0627\u062b\u064a\u0629 \u0648\u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0642\u062f\u0645\u0647\u0627 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0639\u0628\u0631 \u0630\u0631\u0627\u0639\u0647\u0627 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a \u0645\u0631\u0643\u0632 \u0627\u0644\u0645\u0644\u0643 \u0633\u0644\u0645\u0627\u0646 \u0644\u0644\u0627\u0655\u063a\u0627\u062b\u0629\u061b \u0644\u0645\u0633\u0627\u0639\u062f\u0629 \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u064a\u0645\u0646\u064a \u0627\u0644\u0634\u0642\u064a\u0642 \u062c\u0631\u0627\u0621 \u0627\u0644\u0627\u0654\u0632\u0645\u0629 \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u064a\u0645\u0631 \u0628\u0647\u0627.<br /><br /><br />", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["top", "health"], "datatype": "news", "pubDate": "2026-05-10 01:45: