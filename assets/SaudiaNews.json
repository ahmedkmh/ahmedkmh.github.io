c\u0627\u0647 \u0627\u0644\u0642\u0627\u0639\u062f\u0629 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 <a href=\"https://www.alyaum.com/articles/6651555/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A8%D8%B1%D9%8A%D8%B7%D8%A7%D9%86%D9%8A%D8%A7-%D8%AA%D8%B3%D9%85%D8%AD-%D9%84%D8%A3%D9%85%D8%B1%D9%8A%D9%83%D8%A7-%D8%A8%D8%A7%D8%B3%D8%AA%D8%AE%D8%AF%D8%A7%D9%85-%D9%82%D9%88%D8%A7%D8%B9%D8%AF%D9%87%D8%A7-%D9%81%D9%8A-%D8%B6%D8%B1%D8%A8-%D9%85%D9%88%D8%A7%D9%82%D8%B9-%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9-%D8%AA%D9%87%D8%AF%D8%AF-%D9%85%D8%B6%D9%8A%D9%82-%D9%87%D8%B1%D9%85%D8%B2\" target=\"_blank\">\u0627\u0644\u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0629</a> \u0627\u0644\u0645\u0634\u062a\u0631\u0643\u0629 \u0641\u064a \u062c\u0632\u064a\u0631\u0629 \u062f\u064a\u064a\u063a\u0648 \u063a\u0627\u0631\u0633\u064a\u0627 \u0628\u0627\u0644\u0645\u062d\u064a\u0637 \u0627\u0644\u0647\u0646\u062f\u064a. \u0648\u0641\u0642 \u0645\u0627 \u0646\u0642\u0644\u062a \u0635\u062d\u064a\u0641\u0629 \"\u0648\u0648\u0644 \u0633\u062a\u0631\u064a\u062a \u062c\u0648\u0631\u0646\u0627\u0644\" \u0639\u0646 \u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0646 \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u064a\u0646.<br /><br />\u0648\u0630\u0643\u0631 \u0627\u0644\u062a\u0642\u0631\u064a\u0631 \u0627\u0654\u0646 \u0627\u0654\u064a\u0627 \u0645\u0646 <a href=\"https://www.alyaum.com/articles/6651565/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D8%B5%D8%B1%D8%B9-%D9%85%D8%A7-%D9%84%D8%A7-%D9%8A%D9%82%D9%84-%D8%B9%D9%86-10-%D8%A3%D8%B4%D8%AE%D8%A7%D8%B5-%D8%AC%D8%B1%D8%A7%D8%A1-%D8%AD%D8%B1%D9%8A%D9%82-%D8%A8%D9%85%D8%B5%D9%86%D8%B9-%D9%81%D9%8A-%D9%83%D9%88%D8%B1%D9%8A%D8%A7-%D8%A7%D9%84%D8%AC%D9%86%D9%88%D8%A8%D9%8A%D8%A9\" target=\"_blank\">\u0627\u0644\u0635\u0627\u0631\u0648\u062e\u064a\u0646</a> \u0644\u0645 \u064a\u0635\u0628 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u0630\u064a \u064a\u0628\u0639\u062f \u0646\u062d\u0648 \u0627\u0654\u0631\u0628\u0639\u0629 \u0627\u0653\u0644\u0627\u0641 \u0643\u064a\u0644\u0648\u0645\u062a\u0631 \u0639\u0646 \u0627\u0644\u0627\u0654\u0631\u0627\u0636\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629\u060c \u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0627\u0655\u0637\u0644\u0627\u0642 \u062a\u0643\u0634\u0641 \u0639\u0646 \u0627\u0645\u062a\u0644\u0627\u0643 \u0637\u0647\u0631\u0627\u0646 \u0635\u0648\u0627\u0631\u064a\u062e \u0630\u0627\u062a \u0645\u062f\u0649 \u0627\u0654\u0637\u0648\u0644 \u0645\u0645\u0627 \u0643\u0627\u0646 \u064a\u0639\u062a\u0642\u062f \u0633\u0627\u0628\u0642\u064b\u0627\u060c \u0648\u0631\u0641\u0636 \u0627\u0644\u0628\u0646\u062a\u0627\u063a\u0648\u0646 \u0627\u0644\u062a\u0639\u0644\u064a\u0642 \u0639\u0644\u0649 \u0627\u0644\u062a\u0642\u0631\u064a\u0631.<br /><br />\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0627\u0644\u0635\u062d\u064a\u0641\u0629 \u0627\u0654\u0646 \u0627\u0654\u062d\u062f \u0627\u0644\u0635\u0627\u0631\u0648\u062e\u064a\u0646 \u062a\u0639\u0637\u0644 \u0627\u0654\u062b\u0646\u0627\u0621 \u062a\u062d\u0644\u064a\u0642\u0647\u060c \u0628\u064a\u0646\u0645\u0627 \u0627\u0633\u062a\u064f\u0647\u062f\u0641 \u0627\u0644\u0627\u0653\u062e\u0631 \u0628\u0635\u0627\u0631\u0648\u062e \u0627\u0639\u062a\u0631\u0627\u0636\u064a \u0627\u064f\u0654\u0637\u0644\u0642 \u0645\u0646 \u0633\u0641\u064a\u0646\u0629 \u062d\u0631\u0628\u064a\u0629 \u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629\u060c \u0644\u0643\u0646 \u0644\u0645 \u064a\u062a\u0636\u062d \u0645\u0627 \u0627\u0655\u0630\u0627 \u0627\u0644\u0635\u0627\u0631\u0648\u062e \u0642\u062f \u0627\u064f\u0654\u0635\u064a\u0628 \u0627\u0654\u0645 \u0644\u0627.<br /><br /> <br /><br />\u0648\u0642\u0627\u0639\u062f\u0629 \u062f\u064a\u064a\u063a\u0648 \u063a\u0627\u0631\u0633\u064a\u0627 \u0641\u064a \u062c\u0632\u0631 \u062a