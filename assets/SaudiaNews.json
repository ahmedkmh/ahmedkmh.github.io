25/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A8%D8%B1%D8%B9%D8%A7%D9%8A%D8%A9-%D8%AA%D8%B1%D9%83%D9%8A-%D8%A2%D9%84-%D8%A7%D9%84%D8%B4%D9%8A%D8%AE-%D8%AA%D9%88%D9%82%D9%8A%D8%B9-%D8%B9%D9%82%D8%AF-%D8%A5%D9%86%D8%AA%D8%A7%D8%AC-%D8%A8%D9%8A%D9%86-%D9%87%D9%8A%D8%A6%D8%A9-%D8%A7%D9%84%D8%AA%D8%B1%D9%81%D9%8A%D9%87-%D9%88MBC-%D9%85%D8%B5%D8%B1\"> \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0644\u062a\u0631\u0641\u064a\u0647</a> (GEA)\u060c \u062f\u0644\u064a\u0644<a href=\"https://www.alyaum.com/articles/6651171/%D8%A7%D9%84%D8%AB%D9%82%D8%A7%D9%81%D8%A9-%D9%88%D8%A7%D9%84%D9%81%D9%86/%D8%AF%D8%B1%D8%A7%D9%85%D8%A7/%D9%81%D8%B9%D8%A7%D9%84%D9%8A%D8%A7%D8%AA-%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D9%81%D8%B7%D8%B1-%D8%A3%D9%83%D8%B1%D9%85-%D8%AD%D8%B3%D9%86%D9%8A-%D9%8A%D9%82%D8%AF%D9%85-%D9%85%D8%B3%D8%B1%D8%AD%D9%8A%D8%A9-%D9%85%D8%A7-%D8%AA%D8%B5%D8%BA%D8%B1%D9%88%D9%86%D8%A7%D8%B4-%D9%81%D9%8A-%D8%AC%D8%AF%D8%A9\"> \u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631</a> \u0644\u0647\u0630\u0627 \u0627\u0644\u0639\u0627\u0645\u060c \u0627\u0644\u0630\u064a \u064a\u062a\u0636\u0645\u0646 \u0645\u062c\u0645\u0648\u0639\u0629 \u0648\u0627\u0633\u0639\u0629 \u0645\u0646 \u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0648\u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0648\u0627\u0644\u0639\u0631\u0648\u0636 \u0627\u0644\u0645\u0633\u0631\u062d\u064a\u0629 \u0627\u0644\u062a\u064a \u0633\u062a\u0642\u0627\u0645 \u0641\u064a \u0639\u062f\u062f \u0645\u0646 \u0645\u062f\u0646 \u0648\u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0645\u0645\u0644\u0643\u0629\u060c \u0627\u062d\u062a\u0641\u0627\u0621\u064b \u0628\u0647\u0630\u0647 \u0627\u0644\u0645\u0646\u0627\u0633\u0628\u0629.<br /><br />\u0648\u064a\u0633\u062a\u0639\u0631\u0636 \u0627\u0644\u062f\u0644\u064a\u0644 \u0627\u0655\u0642\u0627\u0645\u0629 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0639\u0631\u0648\u0636 \u0627\u0644\u0645\u0633\u0631\u062d\u064a\u0629\u060c \u0645\u0646 \u0627\u0654\u0628\u0631\u0632\u0647\u0627<a href=\"https://www.alyaum.com/articles/6648028/%D8%A7%D9%84%D8%AB%D9%82%D8%A7%D9%81%D8%A9-%D9%88%D8%A7%D9%84%D9%81%D9%86/%D8%AA%D9%84%D9%8A%D9%81%D8%B2%D9%8A%D9%88%D9%86/%D9%86%D8%A7%D9%82%D8%AF-%D9%81%D9%86%D9%8A-%D9%84-%D8%A7%D9%84%D9%8A%D9%88%D9%85%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9%D8%A7%D9%84%D9%85%D8%AD%D8%B1%D9%83-%D8%A7%D9%84%D8%AA%D8%AC%D8%A7%D8%B1%D9%8A-%D8%A7%D9%84%D8%A3%D9%82%D9%88%D9%89-%D9%84%D9%84%D9%81%D9%8A%D9%84%D9%85-%D8%A7%D9%84%D9%85%D8%B5%D8%B1%D9%8A\"> \u0627\u0644\u0645\u0633\u0631\u062d\u064a\u0629 \u0627\u0644\u0645\u0635\u0631\u064a\u0629</a> \"\u0645\u0627 \u062a\u0635\u063a\u0631\u0648\u0646\u0627\u0634\" \u0627\u0644\u062a\u064a \u062a\u064f\u0639\u0631\u0636 \u0639\u0644\u0649 \u0627\u0644\u0645\u0633\u0631\u062d \u0627\u0644\u0639\u0631\u0628\u064a \u0641\u064a \u062c\u062f\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 \u0645\u0646 22 \u0627\u0655\u0644\u0649 24 \u0645\u0627\u0631\u0633.<br /> <h2>\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631</h2>\u0648\u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u0627\u0644\u062a\u062c\u0627\u0631\u0628 \u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0627\u0644\u0645\u0635\u0627\u062d\u0628\u0629 \u0644\u0627\u062d\u062a\u0641\u0627\u0644\u0627\u062a \u0627\u0644\u0639\u064a\u062f\u060c \u062a\u0633\u062a\u0642\u0628\u0644 \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0648\u062c\u0647\u0627\u062a \u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0632\u0648\u0627\u0631\u0647\u0627 \u0628\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u062e\u0627\u0635\u0629\u060c \u062d\u064a\u062b \u062a\u0642\u062f\u0645 \u0645\u0646\u0637\u0642\u0629 \"\u0628\u0648\u0644\u064a\u0641\u0627\u0631\u062f \u0648\u0648\u0631\u0644\u062f\" \u0641\u064a \u0627\u0644\u0631\u064a\u0627\u0636 \u062a\u062c\u0627\u0631\u0628 \u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0645\u062a\u0646\u0648\u0639\u0629 \u062a\u0639\u0643\u0633 \u062d\u0636\u0627\u0631\u0627\u062a \u0648\u062b\u0642\u0627\u0641\u0627\u062a \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0644\u0639\u062f\u064a\u062f \u0645\u0646 \u0627\u0644\u0639\u0631\u0648\u0636 \u0648\u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u0645\u062e\u0635\u0635\u0629 \u0644\u0627\u0654\u064a\u0627\u0645 \u0627\u0644\u0639\u064a\u062f.<br /><br />\u0643\u0645\u0627 \u062a\u0642\u062f\u0645 \u0645\u0646\u0637\u0642\u0629 \"\u0641\u064a\u0627 \u0631\u064a\u0627\u0636\" \u062a\u062c\u0631\u0628\u0629 \u0641\u0627\u062e\u0631\u0629 \u062a\u062c\u0645\u0639 \u0628\u064a\u0646 \u0627\u0654\u0631\u0642\u0649 \u0627\u0644\u0645\u0637\u0627\u0639\u0645 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629 \u0648\u062f\u0648\u0631 \u0627\u0644\u0633\u064a\u0646\u0645\u0627 \u0627\u0644\u0641\u0627\u062e\u0631\u0629 \u0648\u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0627\u0644\u062a\u0631\u0641\u064a\u0647\u064a\u0629\u060c \u0636\u0645\u0646 \u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u062d\u062a\u0641\u0627\u0644\u064a\u0629 \u0645\u0645\u064a\u0632\u0629 \u062e\u0644\u0627\u0644 \u0627\u0654\u0648\u0644 \u0627\u0654\u064a\u0627\u0645 \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631.<br /> <h2>\u062a\u062c\u0627\u0631\u0628 \u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0645\u062a\u0646\u0648\u0639\u0629</h2>\u0648\u064a\u062a\u0636\u0645\u0646 \u062f\u0644\u064a\u0644 \u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631 \u0627\u0644\u0639\u062f\u064a\u062f \u0645\u0646 \u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u0631\u0649 \u0627\u0644\u062a\u064a \u0633\u062a\u0642\u0627\u0645 \u0641\u064a \u0645\u062e\u062a\u0644\u0641 \u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0645\u0645\u0644\u0643\u0629\u060c \u0648\u062a\u0634\u0645\u0644 \u0639\u0631\u0648\u0636\u064b\u0627 \u062d\u064a\u0629 \u0648\u0627\u0654\u0646\u0634\u0637\u0629 \u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0645\u062e\u0635\u0635\u0629 \u0644\u0644\u0639\u0627\u064a\u0654\u0644\u0627\u062a \u0648\u0627\u0644\u0627\u0654\u0637\u0641\u0627\u0644\u060c \u0628\u0645\u0627 \u064a\u0639\u0632\u0632 \u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0641\u0631\u062d \u0648\u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0644 \u0648\u064a\u0645\u0646\u062d \u0627\u0644\u0632\u0648\u0627\u0631 \u062a\u062c\u0627\u0631\u0628 \u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0645\u062a\u0646\u0648\u0639\u0629 \u062e\u0644\u0627\u0644 \u0627\u0654\u064a\u0627\u0645 \u0627\u0644\u0639\u064a\u062f.<br /><br />\u0648\u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646\u0647 \u064a\u0645\u0643\u0646 \u0627\u0644\u0627\u0637\u0644\u0627\u0639 \u0639\u0644\u0649 \u062f\u0644\u064a\u0644 \u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0645\u0646 <a href=\"https://cdn.gea.gov.sa/Eid-Alfitr26/Eid_AlFitr_Booklet.pdf\" target=\"_blank\">\u0647\u0646\u0627 </a>.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["top"], "datatype": "news", "pubDate": "2026-03-19 04:03:00", "pubDateTZ": "UTC", "fetched_at": "2026-03-19 04:30:08", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "77eb1143ae2282926acdccc7c0b27fa7", "link": "https://www.alyaum.com/articles/6651294/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D9%88%D9%85%D8%B5%D8%B1-%D8%AA%D9%88%D9%82%D8%B9%D8%A7%D9%86-%D8%A7%D8%AA%D9%81%D8%A7%D9%82%D9%8A%D8%A9-%D8%A5%D8%B9%D9%81%D8%A7%D8%A1-%D8%A7%D9%84%D8%AC%D9%88%D8%A7%D8%B2%D8%A7%D8%AA-%D8%A7%D9%84%D8%AF%D8%A8%D9%84%D9%88%D9%85%D8%A7%D8%B3%D9%8A%D8%A9-%D9%85%D9%86-%D8%A7%D9%84%D8%AA%D8%A3%D8%B4%D9%8A%D8%B1%D8%A9", "title": "\u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0648\u0645\u0635\u0631 \u062a\u0648\u0642\u0639\u0627\u0646 \u0627\u062a\u0641\u0627\u0642\u064a\u0629 \u0627\u0655\u0639\u0641\u0627\u0621 \u0627\u0644\u062c\u0648\u0627\u0632\u0627\u062a \u0627\u0644\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a\u0629 \u0645\u0646 \u0627\u0644\u062a\u0627\u0654\u0634\u064a\u0631\u0629", "description": "\u0648\u0642\u0639 \u0635\u0627\u062d\u0628 \u0627\u0644\u0633\u0645\u0648 \u0627\u0644\u0627\u0654\u0645\u064a\u0631 \u0641\u064a\u0635\u0644 \u0628\u0646 \u0641\u0631\u062d\u0627\u0646 \u0628\u0646 \u0639\u0628\u062f\u0627\u0644\u0644\u0647 <a href=\"https://www.alyaum.com/articles/6651269/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%88%D8%B2%D9%8A%D8%B1-%D8%A7%D9%84%D8%AE%D8%A7%D8%B1%D8%AC%D9%8A%D8%A9-%D9%86%D8%AD%D8%AA%D9%81%D8%B8-%D8%A8%D8%AD%D9%82-%D8%A7%D9%84%D8%B1%D8%AF-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%A7%D8%B9%D8%AA%D8%AF%D8%A7%D8%A1%D8%A7%D8%AA-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9\">\u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629</a>\u060c \u0648\u0648\u0632\u064a\u0631 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0648\u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0627\u0644\u062f\u0648\u0644\u064a \u0648\u0627\u0644\u0645\u0635\u0631\u064a\u064a\u0646 \u0628\u0627\u0644\u062e\u0627\u0631\u062c<a href=\"https://www.alyaum.com/articles/6651291/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%88%D8%B2%D9%8A%D8%B1-%D8%A7%D9%84%D8%AE%D8%A7%D8%B1%D8%AC%D9%8A%D8%A9-%D9%8A%D8%A8%D8%AD%D8%AB-%D8%A7%D9%84%D8%AA%D8%B5%D8%B9%D9%8A%D8%AF-%D8%A7%D9%84%D8%A5%D9%8A%D8%B1%D8%A7%D9%86%D9%8A-%D9%85%D8%B9-%D9%86%D8%B8%D8%B1%D8%A7%D8%A6%D9%87-%D9%81%D9%8A-%D9%85%D8%B5%D8%B1-%D9%88%D8%A8%D8%A7%D9%83%D8%B3%D8%AA%D8%A7%D9%86-%D9%88%D8%AA%D8%B1%D9%83%D9%8A%D8%A7\"> \u0628\u062f\u0631 \u0639\u0628\u062f \u0627\u0644\u0639\u0627\u0637\u064a</a>\u060c \u0641\u064a \u0627\u0644\u0631\u064a\u0627\u0636 \u0627\u0644\u064a\u0648\u0645\u060c \u0627\u062a\u0641\u0627\u0642\u064a\u0629 \u0628\u0634\u0627\u0654\u0646 \u0627\u0644\u0627\u0655\u0639\u0641\u0627\u0621 \u0627\u0644\u0645\u062a\u0628\u0627\u062f\u0644 \u0645\u0646 \u062a\u0627\u0654\u0634\u064a\u0631\u0629 \u0627\u0644\u0627\u0655\u0642\u0627\u0645\u0629 \u0627\u0644\u0642\u0635\u064a\u0631\u0629 \u0644\u062d\u0627\u0645\u0644\u064a \u062c\u0648\u0627\u0632\u0627\u062a \u0627\u0644\u0633\u0641\u0631 \u0627\u0644\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a\u0629 \u0648\u0627\u0644\u062e\u0627\u0635\u0629 \u0648\u0627\u0644\u062e\u062f\u0645\u0629 \u0628\u064a\u0646 \u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0648\u062d\u0643\u0648\u0645\u0629 \u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0645\u0635\u0631 \u0627\u0644\u0639\u0631\u0628\u064a\u0629.<br /><br />\u0648\u064a\u0627\u0654\u062a\u064a \u062a\u0648\u0642\u064a\u0639 \u0627\u0644\u0627\u062a\u0641\u0627\u0642\u064a\u0629 \u0641\u064a \u0627\u0655\u0637\u0627\u0631 <a href=\"https://www.alyaum.com/articles/6651286/%D