0642\u064a \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0645\u0639 \u0627\u0644\u062e\u0644\u0648\u062f\u060c \u0641\u064a \u0645\u062d\u0637\u0629 \u062c\u062f\u064a\u062f\u0629 \u0645\u0646 \u062a\u0627\u0631\u064a\u062e \u0627\u0654\u0639\u0631\u0642 \u0627\u0644\u0628\u0637\u0648\u0644\u0627\u062a \u0627\u0644\u0643\u0631\u0648\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629.<br /><br />\u0648\u062a\u062d\u0645\u0644 \u0627\u0644\u0628\u0637\u0648\u0644\u0629\u060c \u0627\u0644\u062a\u064a \u062a\u064f\u0639\u062f \u0645\u0646 \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0627\u062a \u0627\u0644\u0645\u062d\u0644\u064a\u0629\u060c \u0633\u062c\u0644\u0627\u064b \u062d\u0627\u0641\u0644\u0627\u064b \u0628\u0627\u0644\u0627\u0655\u0646\u062c\u0627\u0632\u0627\u062a \u0648\u0627\u0644\u0627\u0654\u0631\u0642\u0627\u0645 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u0629\u060c \u062d\u064a\u062b \u064a\u062a\u0635\u062f\u0631 \u0627\u0644\u0647\u0644\u0627\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0642\u0627\u064a\u0654\u0645\u0629 \u0627\u0644\u0627\u0654\u0646\u062f\u064a\u0629 \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u062a\u062a\u0648\u064a\u062c\u064b\u0627 \u0628\u0631\u0635\u064a\u062f 9 \u0627\u0654\u0644\u0642\u0627\u0628\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u0645\u0627 \u0627\u0654\u0635\u062f\u0631\u062a\u0647 \u0644\u062c\u0646\u0629 \u062a\u0648\u062b\u064a\u0642 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0643\u0631\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\u060c \u0645\u0648\u0654\u0643\u062f\u0627\u064b \u0645\u0643\u0627\u0646\u062a\u0647 \u0643\u0627\u0654\u062d\u062f \u0627\u0654\u0639\u0645\u062f\u0629 \u0627\u0644\u0645\u0633\u062a\u062f\u064a\u0631\u0629 \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629\u060c \u062e\u0627\u0635\u0629 \u0641\u064a \u0627\u0644\u0633\u0646\u0648\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0627\u0644\u062a\u064a \u0634\u0647\u062f\u062a \u0639\u0648\u062f\u062a\u0647 \u0627\u0644\u0642\u0648\u064a\u0629 \u0644\u0645\u0646\u0635\u0627\u062a \u0627\u0644\u062a\u062a\u0648\u064a\u062c.<br /><br />\u0648\u064a\u0627\u0654\u062a\u064a \u062e\u0644\u0641\u0647 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0628\u06408 \u0628\u0637\u0648\u0644\u0627\u062a\u060c \u0648\u0647\u0648 \u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0645\u0646\u0627\u0641\u0633\u064a\u0646 \u062a\u0627\u0631\u064a\u062e\u064a\u064b\u0627 \u0641\u064a \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629\u060c \u0645\u0627 \u064a\u0636\u0641\u064a \u0637\u0627\u0628\u0639\u064b\u0627 \u062e\u0627\u0635\u064b\u0627 \u0639\u0644\u0649 \u0645\u0648\u0627\u062c\u0647\u062a\u0647 \u0627\u0644\u0645\u0631\u062a\u0642\u0628\u0629 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0647\u0644\u0627\u0644\u060c \u062d\u064a\u062b \u062a\u062c\u0645\u0639 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0628\u064a\u0646 \u0627\u062b\u0646\u064a\u0646 \u0645\u0646 \u0627\u0654\u0643\u062b\u0631 \u0627\u0644\u0641\u0631\u0642 \u062a\u062a\u0648\u064a\u062c\u064b\u0627 \u0648\u0634\u0639\u0628\u064a\u0629.<br /><br />\u0648\u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0644\u062b\u060c \u064a\u062d\u0636\u0631 \u0627\u0644\u0646\u0635\u0631 \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0628\u0631\u0635\u064a\u062f 5 \u0627\u0654\u0644\u0642\u0627\u0628\u060c \u0645\u062a\u0633\u0627\u0648\u064a\u064b\u0627 \u0645\u0639 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u060c \u0627\u0644\u0630\u064a \u064a\u0633\u0639\u0649 \u0628\u062f\u0648\u0631\u0647 \u0644\u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0627\u0654\u0645\u062c\u0627\u062f\u0647 \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0639\u0628\u0631 \u0628\u0648\u0627\u0628\u0629 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u062d\u064a\u0646 \u064a\u0648\u0627\u062c\u0647 \u0641\u0