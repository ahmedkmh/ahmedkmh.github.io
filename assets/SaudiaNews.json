\u062a\u0633\u0627\u0631\u0639 \u0648\u062a\u0635\u0639\u064a\u062f \u0627\u0644\u062a\u0637\u0648\u0631\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u0646\u0637\u0642\u0629.\u0648\u0646\u0642\u0644\u062a \u0648\u0643\u0627\u0644\u0629 \u0627\u0644\u0627\u0654\u0646\u0628\u0627\u0621 \u0627\u0644\u0627\u0655\u0645\u0627\u0631\u0627\u062a\u064a\u0629 (\u0648\u0627\u0645) \u0639\u0646 \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u062a\u0627\u0654\u0643\u064a\u062f\u0647\u0627 \u0639\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0627 \u0627\u0644\u0642\u0631\u0627\u0631 \u062c\u0627\u0621 \u0628\u0646\u0627\u0621 \u0639\u0644\u0649 \u062a\u0642\u064a\u064a\u0645 \u0634\u0627\u0645\u0644 \u0648\u062f\u0642\u064a\u0642 \u0644\u0644\u0645\u062e\u0627\u0637\u0631 \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0648\u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629\u060c \u0648\u0628\u0627\u0644\u062a\u0646\u0633\u064a\u0642 \u0627\u0644\u062a\u0627\u0645 \u0645\u0639 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0645\u0639\u0646\u064a\u0629 \u0645\u062d\u0644\u064a\u064b\u0627 \u0648\u062f\u0648\u0644\u064a\u064b\u0627\u060c \u0645\u0634\u062f\u062f\u0629 \u0639\u0644\u0649 \u0627\u0654\u0646 \u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0627\u0654\u062c\u0648\u0627\u0621 \u0648\u0627\u0644\u0633\u064a\u0627\u062f\u0629 \u0627\u0644\u062c\u0648\u064a\u0629 \u0644\u062f\u0648\u0644\u0629 \u0627\u0644\u0627\u0655\u0645\u0627\u0631\u0627\u062a \u062a\u064f\u0639\u062f \u0627\u0654\u0648\u0644\u0648\u064a\u0629 \u0642\u0635\u0648\u0649.\u062a\u0648\u0641\u064a\u0631 \u0627\u0644\u0627\u0655\u0633\u0643\u0627\u0646 \u0648\u0627\u0644\u0627\u0655\u0639\u0627\u0634\u0629 \u0644\u0644\u0645\u0633\u0627\u0641\u0631\u064a\u0646\u0643\u0645\u0627 \u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0654\u0646\u0647\u0627 \u0633\u062a\u0633\u062a\u0645\u0631 \u0641\u064a \u0627\u0655\u0637\u064