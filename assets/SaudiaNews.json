4\u0627\u0654\u0645\u062f\"\u060c \u0645\u0634\u062f\u062f\u064b\u0627 \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0646\u0641\u0633\u0647 \u0639\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0627\u0646\u062a\u0635\u0627\u0631 \u0639\u0644\u0649 \u0637\u0647\u0631\u0627\u0646 \u0644\u0645 \u064a\u062a\u062d\u0642\u0642 \u0628\u0639\u062f \"\u0628\u0634\u0643\u0644 \u0643\u0627\u0641\".\u0627\u0644\u062a\u0635\u0631\u064a\u062d\u0627\u062a \u0627\u0644\u062a\u064a \u0627\u0654\u062f\u0644\u0649 \u0628\u0647\u0627 \u062a\u0631\u0627\u0645\u0628 \u062e\u0644\u0627\u0644 \u062a\u062c\u0645\u0639 \u0644\u0644\u0627\u0654\u0639\u0636\u0627\u0621 \u0627\u0644\u062c\u0645\u0647\u0648\u0631\u064a\u064a\u0646 \u0641\u064a \u0627\u0644\u0643\u0648\u0646\u062c\u0631\u0633 \u0627\u0654\u0642\u064a\u0645 \u0641\u064a \u0646\u0627\u062f\u064a\u0647 \u0644\u0644\u062c\u0648\u0644\u0641 \u0641\u064a \u062f\u0648\u0631\u0627\u0644 \u0628\u0648\u0644\u0627\u064a\u0629 \u0641\u0644\u0648\u0631\u064a\u062f\u0627\u060c \u0632\u0627\u062f\u062a \u0627\u0644\u0636\u0628\u0627\u0628\u064a\u0629 \u0641\u064a\u0645\u0627 \u064a\u062a\u0635\u0644 \u0628\u0627\u0644\u062c\u062f\u0648\u0644 \u0627\u0644\u0632\u0645\u0646\u064a \u0644\u0644\u0646\u0632\u0627\u0639\u060c \u0628\u0639\u062f\u0645\u0627 \u0642\u0627\u0644 \u0644\u0634\u0628\u0643\u0629 \"\u0633\u064a \u0628\u064a \u0627\u0633\" \u0627\u0655\u0646 \u0627\u0644\u062d\u0631\u0628 \"\u0634\u0627\u0631\u0641\u062a \u0639\u0644\u0649 \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0621\".\u0648\u0642\u0627\u0644 \u062a\u0631\u0627\u0645\u0628 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u062a\u062c\u0645\u0639 \u0641\u064a \u0641\u0644\u0648\u0631\u064a\u062f\u0627: \"\u0644\u0642\u062f \u0627\u0646\u0637\u0644\u0642\u0646\u0627 \u0641\u064a \u0631\u062d\u0644\u0629 \u0635\u063a\u064a\u0631\u0629 \u0644\u0627\u0654\u0646\u0646\u0627 \u0634\u0639\u0631\u0646\u0627 \u0628\u0627\u0654\u0646 \u0639\u0644\u064a\u0646\u0627 \u0641\u0639\u0644 \u0630\u0644\u0643 \u0644\u0644\u062a\u062e\u0644\u0635 \u0645\u0646 \u0628\u0639\u0636 \u0627\u0644\u0627\u0654\u0634\u062e\u0627\u0635\u060c \u0648\u0627\u0654\u0639\u062a\u0642\u062f \u0627\u0654\u0646\u0643\u0645 \u0633\u062a\u0631\u0648\u0646 \u0627\u0654\u0646\u0647\u0627 \u0633\u062a\u0643\u0648\u0646 \u0631\u062d\u0644\u0629 \u0642\u0635\u064a\u0631\u0629 \u0627\u0644\u0627\u0654\u0645\u062f\".\u062a\u062f\u0645\u064a\u0631 \u0627\u0644\u0628\u062d\u0631\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629\u0648\u062a\u0637\u0631\u0642 \u062a\u0631\u0627\u0645\u0628 \u0645\u062c\u062f\u062f\u064b\u0627 \u0627\u0655\u0644\u0649 \u062a\u062f\u0645\u064a\u0631 \u0627\u0644\u0628\u062d\u0631\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0648\u0633\u0644\u0627\u062d \u0627\u0644\u062c\u0648\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0648\u0643\u0630\u0644\u0643 \u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0655\u064a\u0631\u0627\u0646 \u0627\u0644\u0635\u0627\u0631\u0648\u062e\u064a.\u0644\u0643\u0646 \u062a\u0631\u0627\u0645\u0628 \u0627\u0644\u0630\u064a \u0643\u0627\u0646\u062a \u062a\u0635\u0631\u064a\u062d\u0627\u062a\u0647 \u0644\u0634\u0628\u0643\u0629 \"\u0633\u064a \u0628\u064a \u0627\u0633\" \u0627\u0654\u062f\u062a \u0627\u0655\u0644\u0649 \u062a\u0631\u0627\u062c\u0639 \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0646\u0641\u0637 \u0648\u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0644\u0628\u0648\u0631\u0635\u0629\u060c \u0627\u0654\u0634\u0627\u0631 \u0627\u0655\u0644\u0649 \u0648\u062c\u0648\u0628 \u0628\u0630\u0644 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0648\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0645\u0632\u064a\u062f\u064b\u0627 \u0645\u0646 \u0627\u0644\u062c\u0647\u0648\u062f. #\u062a\u0631\u0627\u0645\u0628: \u062f\u0645\u0631\u0646\u0627 46 \u0633\u0641\u064a\u0646\u06