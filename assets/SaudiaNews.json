A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/10-%D8%AE%D8%AF%D9%85%D8%A7%D8%AA-%D9%84%D9%88%D8%B2%D8%A7%D8%B1%D8%A9-%D8%A7%D9%84%D8%AE%D8%A7%D8%B1%D8%AC%D9%8A%D8%A9-%D9%8A%D9%85%D9%83%D9%86-%D8%A7%D9%84%D8%A7%D8%B3%D8%AA%D9%81%D8%A7%D8%AF%D8%A9-%D9%85%D9%86%D9%87%D8%A7-%D8%B9%D8%A8%D8%B1-%D8%AA%D8%B7%D8%A8%D9%8A%D9%82-%D8%AA%D9%88%D9%83%D9%84%D9%86%D8%A7\" target=\"_blank\">\u062a\u0648\u0643\u0644\u0646\u0627</a>\u060c \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u062a\u0646\u0642\u0644 \u0627\u0644\u0630\u0643\u064a \u0641\u064a \u0645\u0648\u0633\u0645 \u0627\u0644\u062d\u062c.<br /><br />\u0648\u064a\u0645\u0643\u0646 \u0627\u0644\u0627\u0633\u062a\u0641\u0627\u062f\u0629 \u0645\u0646 \u0627\u0644\u062a\u0646\u0642\u0644 \u0627\u0644\u0630\u0643\u064a \u0641\u064a \u0627\u0644\u062d\u062c \u0639\u0628\u0631 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0627\u0644\u0648\u0637\u0646\u064a \u0627\u0644\u0634\u0627\u0645\u0644 \u062a\u0648\u0643\u0644\u0646\u0627:<br /><br />\u064a\u0645\u0643\u0646\u0643 \u0627\u0633\u062a\u0639\u0631\u0627\u0636 \u062c\u0645\u064a\u0639 \u062a\u0635\u0627\u0631\u064a\u062d \u062d\u062c 1447\u0647\u0640 \u0645\u0628\u0627\u0634\u0631\u0629 \u0639\u0628\u0631 \u062a\u0637\u0628\u064a\u0642 \u062a\u0648\u0643\u0644\u0646\u0627 \u0628\u0633\u0647\u0648\u0644\u0629 \u0636\u0645\u0646 \u0627\u0644\u062a\u0643\u0627\u0645\u0644 \u0627\u0644\u062a\u0642\u0646\u064a \u0645\u0639 \"\u0645\u0646\u0635\u0629 \u062a\u0635\u0631\u064a\u062d\":<h2>\u0627\u0654\u0646\u0648\u0627\u0639 \u0627\u0644\u062a\u0635\u0627\u0631\u064a\u062d \u0627\u0644\u0645\u062a\u0627\u062d\u0629</h2><ul><li>\u062a\u0635\u0631\u064a\u062d \u0627\u0644\u062d\u0627\u062c</li><li>\u062a\u0635\u0631\u064a\u062d \u0627\u0644\u0639\u0645\u0644</li><li>\u062a\u0635\u0631\u064a\u062d \u0645\u0631\u0643\u0628\u0629</li><li>\u062a\u0635\u0631\u064a\u062d \u0645\u062a\u0637\u0648\u0639</li><li>\u062a\u0635\u0631\u064a\u062d \u062f\u062e\u0648\u0644 \u0645\u0643\u0629</li></ul><h2> <br />\u062e\u0637\u0648\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062d\u0627\u062c \u0641\u064a \u0627\u0644\u062a\u0637\u0628\u064a\u0642:</h2><h3>\u0644\u0644\u062a\u0633\u062c\u064a\u0644 \u0627\u0628\u062f\u0627\u0654 \u0639\u0628\u0631 \u0627\u0644\u0645\u0646\u0635\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0627\u0644\u0645\u0648\u062d\u062f\u0629 (\u0646\u0641\u0627\u0630)</h3>\u0633\u062c\u0644 \u0627\u0644\u062f\u062e\u0648\u0644\u060c \u0648\u0641\u064a \u062d\u0627\u0644 \u0643\u0646\u062a \u0645\u0633\u062a\u062e\u062f\u0645\u0627\u064b \u062c\u062f\u064a\u062f\u0627\u064b:<ul><li>\u0627\u0655\u0646\u0634\u0627\u0621 \u062d\u0633\u0627\u0628 \u0648\u0627\u0655\u062f\u062e\u0627\u0644 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a</li><li>\u0627\u0655\u0646\u0634\u0627\u0621 \u0631\u0645\u0632 \u0634\u062e\u0635\u064a</li><li>\u062a\u0648\u062b\u064a\u0642 \u0627\u0644\u0647\u0648\u064a\u0629 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062e\u0635\u0627\u064a\u0654\u0635 \u0627\u0644\u062d\u064a\u0648\u064a\u0629</li></ul><h3>\u062e\u0637\u0648\u0627\u062a \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u0632\u0627\u064a\u0654\u0631 \u0641\u064a \u062a\u0637\u0628\u064a\u0642 \u062a\u0648\u0643\u0644\u0646\u0627 \u0639\u0646 \u0637\u0631\u064a\u0642 \u0646\u0641\u0627\u0630:</h3><ul><li>\u0627\u062e\u062a\u064a\u0627\u0631 \u062a\u0633\u062c\u064a\u0644 \u0627\u0644\u062f\u062e\u0648\u0644 \u0639\u0646 \u0637\u0631\u064a\u0642 \u0646\u0641\u0627\u0630</li><li>\u0627\u0655\u062f\u062e\u0627\u0644 \u0631\u0642\u0645 \u0627\u0644\u0647\u0648\u064a\u0629</li><li>\u0627\u0655\u062f\u062e\u0627\u0644 \u0627\u0644\u0631\u0645\u0632 \u0627\u0644\u0634\u062e\u0635\u064a \u0627\u0644\u062e\u0627\u0635 \u0628\u062a\u0637\u0628\u064a\u0642 \u0646\u0642\u0627\u0630</li></ul><h2>\u062a\u0637\u0628\u064a\u0642 \u062a\u0648\u0643\u0644\u0646\u0627</h2><br />\u0648\u064a\u0648\u0627\u0635\u0644 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0627\u0644\u0648\u0637\u0646\u064a \u0627\u0644\u0634\u0627\u0645\u0644 \"<a href=\"https://www.alyaum.com/articles/6580389/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%AA%D9%83%D9%86%D9%88%D9%84%D9%88%D8%AC%D9%8A%D8%A7/%D8%A7%D9%84%D8%AE%D8%AF%D9%85%D8%A7%D8%AA-%D8%A7%D9%84%D8%B1%D9%82%D9%85%D9%8A%D8%A9-%D8%A7%D9%84%D9%85%D9%86%D8%AA%D8%AF%D9%89-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A-%D9%84%D9%84%D8%A5%D8%B9%D9%84%D8%A7%D9%85-%D9%8A%D8%B3%D8%AA%D8%B9%D8%B1%D8%B6-%D9%86%D8%AC%D8%A7%D8%AD-%D8%AA%D8%B7%D8%A8%D9%8A%D9%82-%D8%AA%D9%88%D9%83%D9%84%D9%86%D8%A7\" target=\"_blank\">\u062a\u0648\u0643\u0644\u0646\u0627</a>\" \u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0628<a href=\"https://www.alyaum.com/articles/6576206/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%B3%D9%8A%D8%A7%D8%AD%D8%A9-%D9%88%D8%B3%D9%81%D8%B1/%D9%84%D9%84%D8%AA%D8%B3%D9%87%D9%8A%D9%84-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D9%85%D8%B3%D8%AA%D9%81%D9%8A%D8%AF%D9%8A%D9%86-%D8%A5%D8%AF%D8%B1%D8%A7%D8%AC-%D9%81%D8%B9%D8%A7%D9%84%D9%8A%D8%A7%D8%AA-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D8%B6%D9%85%D9%86-%D8%AA%D9%88%D9%83%D9%84%D9%86%D8%A7\" target=\"_blank\">\u0627\u0644\u062a\u0643\u0627\u0645\u0644 \u0627\u0644\u0631\u0642\u0645\u064a</a> \u0648\u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0645\u0639 \u0645\u064f\u062e\u062a\u0644\u0641 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629\u060c \u0648\u062a\u0632\u064a\u062f \u0639\u0646 650 \u062e\u062f\u0645\u0629 \u062d\u0643\u0648\u0645\u064a\u0629 \u0641\u064a \u062a\u0637\u0628\u064a\u0642 \u0648\u0627\u062d\u062f \u0627\u0653\u0645\u0646 \u0648\u0645\u0648\u062b\u0648\u0642\u060c \u0628\u0645\u0627 \u064a\u0639\u0643\u0633 \u062a\u062c\u0631\u0628\u0629 \u0631\u0642\u0645\u064a\u0629 \u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u0648\u0633\u0647\u0644\u0629\u060c \u062a\u06