0628 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0627\u0644\u0627\u0655\u0645\u0627\u0631\u0627\u062a\u064a\u060c \u0648\u0641\u0631\u064a\u0642\u064a \u0645\u0627\u062a\u0634\u064a\u062f\u0627 \u0632\u064a\u0644\u0641\u064a\u0627 \u0648\u0641\u064a\u0633\u064a\u0644 \u0643\u0648\u0628\u064a \u0645\u0646 \u0627\u0644\u064a\u0627\u0628\u0627\u0646.<br /><br />\u0648\u0628\u0630\u0644\u0643 \u062a\u062d\u062f\u062f\u062a \u0645\u0648\u0627\u062c\u0647\u062a\u0627 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u060c \u062d\u064a\u062b \u064a\u0644\u062a\u0642\u064a \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0645\u0639 \u0641\u064a\u0633\u064a\u0644 \u0643\u0648\u0628\u064a \u0641\u064a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649\u060c \u0648\u0627\u0644\u0645\u0642\u0631\u0631 \u0627\u0655\u0642\u0627\u0645\u062a\u0647\u0627 \u0645\u0633\u0627\u0621 \u064a\u0648\u0645 \u0627\u0644\u0627\u0655\u062b\u0646\u064a\u0646 20 \u0627\u0654\u0628\u0631\u064a\u0644 \u0639\u0646\u062f \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u0633\u0627\u0628\u0639\u0629 \u0648\u0627\u0644\u0631\u0628\u0639.<br /><br />\u0627\u0654\u0645\u0627 \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629\u060c \u0641\u0633\u062a\u062c\u0645\u0639 \u0628\u064a\u0646 \u0634\u0628\u0627\u0628 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0627\u0644\u0627\u0655\u0645\u0627\u0631\u0627\u062a\u064a \u0648\u0645\u0627\u062a\u0634\u064a\u062f\u0627 \u0632\u064a\u0644\u0641\u064a\u0627\u060c \u0648\u0630\u0644\u0643 \u0645\u0633\u0627\u0621 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 21 \u0627\u0654\u0628\u0631\u064a\u0644 \u0641\u064a \u0627\u0644\u062a\u0648\u0642\u064a\u062a \u0630\u0627\u062a\u0647\u060c \u0645\u0646 \u0627\u0654\u062c\u0644 \u062d\u062c\u0632 \u0628\u0637\u0627\u0642\u0629 \u0627\u0644\u0639\u0628\u0648\u0631 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0627\u0655\u0644\