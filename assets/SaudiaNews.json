">\u0627\u0644\u0641\u0631\u0648\u0633\u064a\u0629 </a>\u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\u060c \u0628\u0639\u062f \u0627\u0654\u0646 \u0627\u0654\u0639\u0627\u062f\u062a \u062a\u0642\u062f\u064a\u0645 \u0646\u0641\u0633\u0647\u0627 \u0628\u0635\u0641\u062a\u0647\u0627 \u0645\u0648\u0627\u0642\u0639 \u062a\u062d\u062a\u0636\u0646 \u0627\u0654\u0646\u0634\u0637\u0629 \u062a\u0639\u0644\u064a\u0645\u064a\u0629 \u0648\u062a\u0631\u0641\u064a\u0647\u064a\u0629 \u0648\u062b\u0642\u0627\u0641\u064a\u0629\u060c \u062a\u062a\u064a\u062d \u0644\u0644\u0632\u0627\u064a\u0654\u0631 \u0627\u0644\u0627\u0642\u062a\u0631\u0627\u0628 \u0645\u0646 \u0639\u0627\u0644\u0645 \u0627\u0644\u062c\u064a\u0627\u062f \u0641\u064a \u0628\u064a\u064a\u0654\u0629 \u062a\u0633\u062a\u0644\u0647\u0645 \u0627\u0654\u0635\u0627\u0644\u0629 \u0627\u0644\u0645\u0643\u0627\u0646 \u0648\u062a\u0627\u0631\u064a\u062e\u0647.<br /><br />\u062a\u0641\u062a\u062d \u0647\u0630\u0647 \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0654\u0628\u0648\u0627\u0628\u0647\u0627 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0639\u0627\u064a\u0654\u0644\u0627\u062a \u0648\u0627\u0644\u0645\u0647\u062a\u0645\u064a\u0646 <a href=\"https://www.alyaum.com/articles/6563299/%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6%D8%A9/%D9%84%D8%B9%D8%A8%D8%A7%D8%AA-%D9%85%D8%AE%D8%AA%D9%84%D9%81%D8%A9/%D8%AC%D9%88%D9%84%D8%A7%D8%AA-%D8%A7%D9%84%D8%AC%D9%8A%D8%A7%D8%AF-%D8%A7%D9%84%D8%B9%D8%B1%D8%A8%D9%8A%D8%A9-%D8%AC%D9%88%D9%84%D8%A9-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6-%D8%B9%D9%84%D8%A7%D9%85%D8%A9-%D9%81%D8%A7%D8%B1%D9%82%D8%A9-%D9%81%D9%8A-%D8%B9%D8%A7%D9%84%D9%85-%D8%B9%D8%B1%D9%88%D8%B6-%D8%A7%D9%84%D8%AE%D9%8A%D9%84-%D8%A7%D9%84%D8%B9%D8%B1%D8%A8%D9%8A%D8%A9-%D8%A7%D9%84%D8%A3%D8%B5%D9%8A%D9%84%D8%A9\">\u0628\u0627\u0644\u062e\u064a\u0644</a>\u061b \u0644\u062a\u0642\u062f\u064a\u0645 \u0628\u0627\u0642\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u062a\u064a \u062a\u062a\u0646\u0648\u0639 \u0628\u064a\u0646 \u0631\u0643\u0648\u0628 \u0627\u0644\u062c\u064a\u0627\u062f\u060c \u0648\u0645\u062a\u0627\u0628\u0639\u0629 \u0627\u0644\u0639\u0631\u0648\u0636\u060c \u0648\u0627\u0644\u062a\u0639\u0631\u0641 \u0639\u0644\u0649 \u0637\u0631\u0642 \u0627\u0644\u062a\u0631\u0628\u064a\u0629 \u0648\u0627\u0644\u0631\u0639\u0627\u064a\u0629\u060c \u0648\u0627\u0644\u0627\u0637\u0644\u0627\u0639 \u0639\u0644\u0649 \u0633\u0644\u0627\u0644\u0627\u062a \u0627\u0644\u062e\u064a\u0644 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0648\u0635\u0641\u0627\u062a\u0647\u0627\u060c \u0628\u0645\u0627 \u064a\u062b\u0631\u064a \u062a\u062c\u0631\u0628\u0629 \u0627\u0644\u0632\u0627\u064a\u0654\u0631 \u0648\u064a\u0642\u0631\u0628\u0647 \u0645\u0646 \u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0645\u0648\u0631\u0648\u062b\u0627\u062a \u0627\u0644\u0648\u0637\u0646\u064a\u0629.<br /> <h2>\u0645\u0631\u0627\u0628\u0637 \u0627\u0644\u062e\u064a\u0644 \u0641\u064a \u0627\u0644\u0637\u0627\u064a\u0654\u0641</h2>\u0648\u0633\u0627\u0639\u062f\u062a \u0627\u0644\u0627\u0654\u062c\u0648\u0627\u0621 \u0627\u0644\u0645\u0639\u062a\u062f\u0644\u0629 \u0627\u0644\u062a\u064a \u062a\u0634\u062a\u0647\u0631 \u0628\u0647\u0627 \u0627\u0644\u0637\u0627\u064a\u0654\u0641\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u062a\u0633\u0627\u0639 \u0627\u0644\u0645\u0633\u0627\u062d\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0639\u064a\u0629 \u0627\u0644\u0645\u062d\u064a\u0637\u0629\u060c \u0639\u0644\u0649 \u062a\u0646\u0627\u0645\u064a \u062d\u0636\u0648\u0631 \u0647\u0630\u0647 \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0636\u0645\u0646 \u062e\u0627\u0631\u0637\u0629 \u0627\u0644\u062c\u0630\u0628 \u0627\u0644\u0633\u064a\u0627\u062d\u064a\u060c \u0627\u0655\u0630 \u062a\u062a\u0646\u0627\u063a\u0645 \u0627\u0644\u0627\u0655\u0637\u0644\u0627\u0644\u0627\u062a \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629 \u0645\u0639 \u0627\u0644\u0637\u0627\u0628\u0639 \u0627\u0644\u0639\u0645\u0631\u0627\u0646\u064a \u0627\u0644\u0645\u0633\u062a\u0644\u0647\u0645 \u0645\u0646 \u0627\u0644\u0628\u064a\u064a\u0654\u0629 \u0627\u0644\u0645\u062d\u0644\u064a\u0629\u060c \u0644\u062a\u0648\u0641\u0631 \u0627\u0654\u062c\u0648\u0627\u0621 \u0645\u0644\u0627\u064a\u0654\u0645\u0629 \u0644\u0642\u0636\u0627\u0621 \u0627\u0654\u0648\u0642\u0627\u062a \u0639\u0627\u064a\u0654\u0644\u064a\u0629 \u0641\u064a \u0627\u0654\u062d\u0636\u0627\u0646 \u0627\u0644\u0637\u0628\u064a\u0639\u0629.<br /> <br />\u0648\u062d\u0631\u0635\u062a \u0627\u0644\u0639\u062f\u064a\u062f \u0645\u0646 \u0627\u0644\u0645\u0631\u0627\u0628\u0637 \u0639\u0644\u0649 \u062a\u0648\u0633\u064a\u0639 \u0646\u0637\u0627\u0642 \u062e\u062f\u0645\u0627\u062a\u0647\u0627 \u0628\u0627\u0655\u0636\u0627\u0641\u0629 \u0645\u0631\u0627\u0641\u0642 \u0645\u062a\u0646\u0648\u0639\u0629\u060c \u062a\u0634\u0645\u0644 \u0645\u064a\u0627\u062f\u064a\u0646 \u0644\u0644\u062a\u062f\u0631\u064a\u0628\u060c \u0648\u0645\u0633\u0627\u0631\u0627\u062a \u0645\u062e\u0635\u0635\u0629 \u0644\u0644\u0627\u0645\u062a\u0637\u0627\u0621\u060c \u0648\u0645\u062c\u0627\u0644\u0633 \u0628\u0637\u0627\u0628\u0639 \u062a\u0631\u0627\u062b\u064a\u060c \u0648\u0645\u0642\u0627\u0647\u064a\u060c \u0648\u062c\u0644\u0633\u0627\u062a \u062e\u0627\u0631\u062c\u064a\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0628\u0631\u0627\u0645\u062c \u0645\u0648\u0633\u0645\u064a\u0629 \u0648\u0648\u0631\u0634 \u062a\u062b\u0642\u064a\u0641\u064a\u0629 \u062a\u0639\u0631\u0641 \u0628\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0641\u0631\u0648\u0633\u064a\u0629 \u0648\u0645\u0643\u0627\u0646\u0629 \u0627\u0644\u062c\u0648\u0627\u062f \u0627\u0644\u0639\u0631\u0628\u064a\u060c \u0627\u0644\u0627\u0654\u0645\u0631 \u0627\u0644\u0630\u064a \u0645\u0646\u062d\u0647\u0627 \u0628\u0639\u062f\u064b\u0627 \u062b\u0642\u0627\u0641\u064a\u064b\u0627 \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u062