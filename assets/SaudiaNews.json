\u0627\u0644\u0644\u062b\u0629\u060c \u0642\u062f \u062a\u062f\u062e\u0644 \u0627\u0644\u0628\u0643\u062a\u064a\u0631\u064a\u0627 \u0627\u0644\u0636\u0627\u0631\u0629 \u0627\u0655\u0644\u0649 \u0645\u062c\u0631\u0649 \u0627\u0644\u062f\u0645 \u0627\u0654\u0648 \u0627\u0644\u062c\u0647\u0627\u0632 \u0627\u0644\u0647\u0636\u0645\u064a\u060c \u0645\u0627 \u0642\u062f \u064a\u0633\u0628\u0628 \u0627\u0644\u062a\u0647\u0627\u0628\u0627\u062a \u062a\u0648\u0654\u062b\u0631 \u0639\u0644\u0649 \u0635\u062d\u0629 \u0627\u0644\u0627\u0654\u0645\u0639\u0627\u0621.\u0643\u0645\u0627 \u062a\u0634\u064a\u0631 \u0627\u0654\u0628\u062d\u0627\u062b \u0645\u0646 \u062c\u0627\u0645\u0639\u0629 \u0647\u0627\u0631\u0641\u0627\u0631\u062f \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0634\u062e\u0627\u0635 \u0627\u0644\u0645\u0635\u0627\u0628\u064a\u0646 \u0628\u0627\u0654\u0645\u0631\u0627\u0636 \u0627\u0644\u0644\u062b\u0629 \u0644\u062f\u064a\u0647\u0645 \u062e\u0637\u0631 \u0627\u0654\u0639\u0644\u0649 \u0628\u0646\u0633\u0628\u0629 \u062a\u0631\u0627\u0648\u062d \u0628\u064a\u0646 17 \u064821 \u0641\u064a \u0627\u0644\u0645\u064a\u0654\u0629 \u0644\u0644\u0627\u0655\u0635\u0627\u0628\u0629 \u0628\u0633\u0644\u0627\u064a\u0654\u0644 \u0627\u0644\u0642\u0648\u0644\u0648\u0646 \u0645\u0627 \u0642\u0628\u0644 \u0627\u0644\u0633\u0631\u0637\u0627\u0646\u064a\u0629. \u0631\u0627\u064a\u0654\u062d\u0629 \u0627\u0644\u0641\u0645 \u0627\u0644\u0643\u0631\u064a\u0647\u0629 \u0627\u0644\u0645\u0633\u062a\u0645\u0631\u0629 \u0642\u062f \u062a\u0631\u062a\u0628\u0637 \u0631\u0627\u064a\u0654\u062d\u0629 \u0627\u0644\u0641\u0645 \u0627\u0644\u0645\u0632\u0645\u0646\u0629 \u0628\u0628\u0643\u062a\u064a\u0631\u064a\u0627 \u062a\u0633\u0645\u0649 Fusobacterium nucleatum\u060c \u0648\u0647\u064a \u0628\u0643\u062a\u064a\u0631\u064a\u0627 \u0645\u0648\u062c\u0648\u062f\u0629 \u0641\u064a \u0627\u0644\u0641\u0645 \u0648\u062a\u0631\u062a\u0628\u0637 \u0627\u0654\u064a\u0636\u0627\u064b \u0628\u0627\u0654\u0645\u0631\u0627\u0636 \u0627\u0644\u0644\u062b\u0629.\u0648\u0642\u062f \u0648\u062c\u062f\u062a \u0647\u0630\u0647 \u0627\u0644\u0628\u0643\u062a\u064a\u0631\u064a\u0627 \u0628\u062a\u0631\u0643\u064a\u0632\u0627\u062a \u0645\u0631\u062a\u0641\u0639\u0629 \u062f\u0627\u062e\u0644 \u0628\u0639\u0636 \u0627\u0654\u0648\u0631\u0627\u0645 \u0633\u0631\u0637\u0627\u0646 \u0627\u0644\u0627\u0654\u0645\u0639\u0627\u0621\u060c \u0648\u064a\u0639\u062a\u0642\u062f \u0627\u0644\u0639\u0644\u0645\u0627\u0621 \u0627\u0654\u0646\u0647\u0627 \u0642\u062f \u062a\u0633\u0627\u0639\u062f \u0627\u0644\u062e\u0644\u0627\u064a\u0627 \u0627\u0644\u0633\u0631\u0637\u0627\u0646\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u062a\u0647\u0631\u0628 \u0645\u0646 \u0627\u0644\u062c\u0647\u0627\u0632 \u0627\u0644\u0645\u0646\u0627\u0639\u064a.\u0637\u0628\u0642\u0629 \u0628\u064a\u0636\u0627\u0621 \u0627\u0654\u0648 \u0635\u0641\u0631\u0627\u0621 \u0639\u0644\u0649 \u0627\u0644\u0644\u0633\u0627\u0646\u0638\u0647\u0648\u0631 \u0637\u0628\u0642\u0629 \u0628\u064a\u0636\u0627\u0621 \u0627\u0654\u0648 \u0635\u0641\u0631\u0627\u0621 \u0639\u0644\u0649 \u0627\u0644\u0644\u0633\u0627\u0646 \u063a\u0627\u0644\u0628\u0627\u064b \u0645\u0627 \u064a\u0646\u062a\u062c \u0639\u0646 \u062a\u0631\u0627\u0643\u0645 \u0627\u0644\u0628\u0643\u062a\u064a\u0631\u064a\u0627 \u0627\u0654\u0648 \u0627\u0644\u062e\u0644\u0627\u064a\u0627 \u0627\u0644\u0645\u064a\u062a\u0629 \u0627\u0654\u0648 \u0628\u0642\u0627\u064a\u0627 \u0627\u0644\u0637\u0639\u0627\u0645\u060c \u0648\u0642\u062f \u064a\u0643\u0648\u0646 \u0645\u0631\u062a\u0628\u0637\u0627\u064b \u0628\u0633\u0648\u0621 \u0646\u0638\u0627\u0641\u0629 \u0627\u0644\u0641\u0645 \u0627\u0654\u0648 \u0627\u0644\u062c\u0641\u0627\u0641.\u0648\u064a\u0631\u0649 \u0628\u0639\u0636 \u0627\u0644\u0628\u0627\u062d\u062b\u064a\u0646 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u0637\u0628\u0642\u0629 \u0642\u062f \u062a\u0639\u0643\u0633 \