u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0627\u0644\u0627\u0653\u0633\u064a\u0648\u064a", "description": "\u064a\u062e\u0648\u0636 \u0627\u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0645\u062d\u0637\u0629 \u062c\u062f\u064a\u062f\u0629 \u0648\u0645\u0647\u0645\u0629 \u0641\u064a \u062a\u0627\u0631\u064a\u062e\u0647 \u0627\u0644\u0642\u0627\u0631\u064a\u060c \u0628\u0639\u062f\u0645\u0627 \u0646\u062c\u062d \u0641\u064a \u0628\u0644\u0648\u063a \u0627\u0644\u062f\u0648\u0631 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0645\u0646 \u0628\u0637\u0648\u0644\u0629 \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0653\u0633\u064a\u0627 \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u0631\u0627\u0628\u0639\u0629\u060c \u0641\u064a \u0627\u0655\u0646\u062c\u0627\u0632 \u064a\u0639\u0643\u0633 \u0627\u0644\u0627\u0633\u062a\u0645\u0631\u0627\u0631\u064a\u0629 \u0627\u0644\u0643\u0628\u064a\u0631\u0629 \u0644\u062d\u0636\u0648\u0631\u0647 \u0628\u064a\u0646 \u0646\u062e\u0628\u0629 \u0627\u0654\u0646\u062f\u064a\u0629 \u0627\u0644\u0642\u0627\u0631\u0629 \u0639\u0628\u0631 \u0645\u0631\u0627\u062d\u0644 \u0632\u0645\u0646\u064a\u0629 \u0645\u062e\u062a\u0644\u0641\u0629.<br /><br />\u062a\u0639\u0648\u062f \u0627\u0654\u0648\u0644\u0649 \u0645\u0634\u0627\u0631\u0643\u0627\u062a \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0627\u0644\u0628\u0627\u0631\u0632\u0629 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u062f\u0648\u0631 \u0627\u0655\u0644\u0649 \u0646\u0633\u062e\u0629 1985-1986\u060c \u062d\u064a\u0646 \u0642\u062f\u0651\u0645 \u0627\u0644\u0641\u0631\u064a\u0642 \u0645\u0633\u062a\u0648\u064a\u0627\u062a \u0645\u0645\u064a\u0632\u0629 \u0648\u062a\u0645\u0643\u0646 \u0645\u0646 \u0627\u0644\u0648\u0635\u0648\u0644 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u0629\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u062d\u0642\u0642 \u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0635\u0627\u0641\u0629\u060c \u0641\u064a \u0645\u0634\u0627\u0631\u0643\u0629 \u0631\u0633\u062e\u062a \u0627\u0633\u0645\u0647 \u0645\u0628\u0643\u0631\u064b\u0627 \u0643\u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0645\u0645\u062b\u0644\u064a \u0627\u0644\u0643\u0631\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0633\u0627\u062d\u0629 \u0627\u0644\u0627\u0653\u0633\u064a\u0648\u064a\u0629.<br /><br />\u0648\u0641\u064a \u0646\u0633\u062e\u0629 2012\u060c \u0639\u0627\u062f \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0644\u064a\u0648\u0654\u0643\u062f \u0642\u0648\u062a\u0647 \u0627\u0644\u0642\u0627\u0631\u064a\u0629\u060c \u062d\u064a\u062b \u0646\u062c\u062d \u0641\u064a \u062a\u062c\u0627\u0648\u0632 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0648\u0627\u0644\u0648\u0635\u0648\u0644 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u0629\u060c \u0644\u0643\u0646\u0647 \u0627\u0643\u062a\u0641\u0649 \u0645\u062c\u062f\u062f\u064b\u0627 \u0628\u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0646\u064a \u0628\u0639\u062f \u0627\u0654\u062f\u0627\u0621 \u0642\u0648\u064a \u0637\u0648\u0627\u0644 \u0645\u0634\u0648\u0627\u0631\u0647 \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629\u060c \u0645\u0627 \u0639\u0643\u0633 \u062a\u0637\u0648\u0631 \u0627\u0644\u0641\u0631\u064a\u0642 \u0645\u0646 \u062d\u064a\u062b \u0627\u0644\u062a\u0646\u0638\u064a\u0645 \u0627\u0644\u0641\u0646\u064a \u0648\u0627\u0644\u0627\u0646\u0636\u0628\u0627\u0637 \u0627\u0644\u062a\u0643\u062a\u064a\u0643\u064a.<br /><br />\u0627\u0654\u0645\u0627 \u0627\u0644\u062a\u062d\u0648\u0644 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a \u0627\u0644\u0627\u0654\u0647\u0645 \u0641\u062c\u0627\u0621 \u0641\u064a \u0646\u0633\u062e\u0629 2025\u060c \u0639\u0646\u062f\u0645\u0627 \u0646\u062c\u062d \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0641\u064a \u0627\u0644\u062a\u062a\u0648\u064a\u062c \u0628\u0644\u0642\u0628 \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0653\u0633\u064a\u0627 \u0644\u0627\u0654\u0648\u0644 \u0645\u0631\u0629 \u0641\u064a \u062a\u0627\u0631\u064a\u062e\u0647\u060c \u0644\u064a\u0643\u0633\u0631 \u0639\u0642\u062f\u0629 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u0627\u062a \u0648\u064a\u062d\u0642\u0642 \u0627\u0655\u0646\u062c\u0627\u0632\u064b\u0627 \u063a\u064a\u0631 \u0645\u0633\u0628\u0648\u0642\u060c \u0639\u0632\u0632 \u0645\u0643\u0627\u0646\u062a\u0647 \u0628\u064a\u0646 \u0643\u0628\u0627\u0631 \u0627\u0654\u0646\u062f\u064a\u0629 \u0627\u0644\u0642\u0627\u0631\u0629\u060c \u0648\u0627\u0654\u062b\u0628\u062a \u0642\u062f\u0631\u062a\u0647 \u0639\u0644\u0649 \u0627\u0644\u0648\u0635\u0648\u0644 \u0627\u0655\u0644\u0649 \u0627\u0644\u0642\u0645\u0629 \u0627\u0644\u0627\u0653\u0633\u064a\u0648\u064a\u0629.<br /><br />\u0648\u0641\u064a \u0627\u0644\u0646\u0633\u062e\u0629 \u0627\u0644\u062d\u0627\u0644\u064a\u0629 2026\u060c \u0648\u0627\u0635\u0644 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0628\u0642\u064a\u0627\u062f\u0629 \u0645\u062f\u0631\u0628\u0647 \u0627\u0644\u0627\u0654\u0644\u0645\u0627\u0646\u064a \u0645\u0627\u062a\u064a\u0627\u0633 \u064a\u0627\u064a\u0633\u0644\u0647 \u0645\u0633\u064a\u0631\u062a\u0647 \u0627\u0644\u0642\u0627\u0631\u064a\u0629 \u0627\u0644\u0645\u0645\u064a\u0632\u0629\u060c \u062d\u064a\u062b \u062a\u0645\u0643\u0646 \u0645\u0646 \u0628\u0644\u0648\u063a \u0627\u0644\u062f\u0648\u0631 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0628\u0639\u062f \u062a\u0641\u0648\u0642\u0647 \u0639\u0644\u0649 \u0641\u0631\u064a\u0642 \u062c\u0648\u0647\u0648\u0631 \u0627\u0644\u0645\u0627\u0644\u064a\u0632\u064a \u0641\u064a \u0645\u0628\u0627\u0631\u0627\u0629 \u0642