988/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%B7%D9%82%D8%B3-%D8%A7%D9%84%D8%AC%D9%85%D8%B9%D8%A9-%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D8%B1%D8%B9%D8%AF%D9%8A%D8%A9-%D9%88%D8%B1%D9%8A%D8%A7%D8%AD-%D9%85%D8%AB%D9%8A%D8%B1%D8%A9-%D9%84%D9%84%D8%A3%D8%AA%D8%B1%D8%A8%D8%A9-%D8%B9%D9%84%D9%89-%D8%A3%D8%AC%D8%B2%D8%A7%D8%A1-%D9%85%D9%86-12-%D9%85%D9%86%D8%B7%D9%82%D8%A9\"> \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0644\u0627\u0654\u0631\u0635\u0627\u062f</a> \u0627\u0654\u0646 \u062a\u0634\u0647\u062f \u0645\u0646\u0637\u0642\u0629 <a href=\"https://www.alyaum.com/articles/6653966/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%A3%D8%B9%D9%84%D9%89-39-%D9%85%D8%A6%D9%88%D9%8A%D8%A9-%D8%AA%D9%88%D9%82%D8%B9%D8%A7%D8%AA-%D8%AF%D8%B1%D8%AC%D8%A7%D8%AA-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D8%A9-%D9%88%D8%A7%D9%84%D8%B8%D9%88%D8%A7%D9%87%D8%B1-%D8%A7%D9%84%D8%AC%D9%88%D9%8A%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9\">\u0645\u0643\u0629 \u0627\u0644\u0645\u0643\u0631\u0645\u0629</a> \u0647\u0637\u0648\u0644 <a href=\"https://www.alyaum.com/articles/6653989/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%AA%D9%86%D8%A8%D9%8A%D9%87-%D9%85%D9%86-%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D9%88%D8%B3%D9%8A%D9%88%D9%84-%D9%88%D8%B5%D9%88%D8%A7%D8%B9%D9%82-%D8%B1%D8%B9%D8%AF%D9%8A%D8%A9-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D9%85%D8%AF%D9%8A%D9%86%D8%A9-%D8%A7%D9%84%D9%85%D9%86%D9%88%D8%B1%D8%A9-%D9%88%D8%A7%D9%84%D8%A8%D8%A7%D8%AD%D8%A9\">\u0627\u0654\u0645\u0637\u0627\u0631 </a>\u0645\u062a\u0648\u0633\u0637\u0629\u060c \u062a\u0634\u0645\u0644 \u0645\u062d\u0627\u0641\u0638\u0627\u062a \u0627\u0644\u0637\u0627\u064a\u0654\u0641 \u0648\u0645\u064a\u0633\u0627\u0646 \u0648\u0627\u0654\u0636\u0645 \u0648\u06