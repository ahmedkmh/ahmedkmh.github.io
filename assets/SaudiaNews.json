\u064a\u0631\u0643\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 (\u0627\u0654\u0645 \u0627\u0654\u0644 \u0627\u0654\u0633).<br /><br />\u0648\u0641\u0627\u062c\u0627\u0654 \u0631\u062d\u064a\u0644 \u0645\u0627\u0633\u0643\u064a\u0631\u0627\u0646\u0648 \u0627\u0644\u0628\u0627\u0644\u063a 41 \u0639\u0627\u0645\u0627 \u0648\u0627\u0644\u0630\u064a \u062a\u0639\u0627\u0642\u062f \u0645\u0639 \u0627\u0655\u0646\u062a\u0631 \u0645\u064a\u0627\u0645\u064a \u0641\u064a \u0646\u0648\u0641\u0645\u0628\u0631 2024 \u0648\u064a\u0645\u062a\u062f \u0639\u0642\u062f\u0647 \u062d\u062a\u0649 2027\u060c \u0639\u0634\u0627\u0642 \u0627\u0644\u0646\u0627\u062f\u064a.<br /><br />\u0642\u0627\u0644 \u0644\u0627\u0639\u0628 \u0627\u0644\u0648\u0633\u0637 \u0648\u0632\u0645\u064a\u0644 \u0645\u064a\u0633\u064a \u0627\u0644\u0633\u0627\u0628\u0642 \u0641\u064a \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0648\u0628\u0631\u0634\u0644\u0648\u0646\u0629 \u0627\u0644\u0627\u0655\u0633\u0628\u0627\u0646\u064a \u0641\u064a \u0628\u064a\u0627\u0646\u064d \u0644\u0644\u0646\u0627\u062f\u064a \"\u0633\u0627\u0654\u062d\u062a\u0641\u0638 \u062f\u0627\u064a\u0654\u0645\u0627 \u0628\u0630\u0643\u0631\u0649 \u0646\u062c\u0645\u062a\u0646\u0627 \u0627\u0644\u0627\u0648\u0644\u0649 (\u0644\u0642\u0628 \u0627\u0644\u062f\u0648\u0631\u064a)\u060c \u0648\u0627\u0654\u064a\u0646\u0645\u0627 \u0643\u0646\u062a\u060c \u0633\u0627\u0654\u0638\u0644 \u0627\u0654\u062a\u0645\u0646\u0649 \u0644\u0644\u0646\u0627\u062f\u064a \u0643\u0644 \u0627\u0644\u062a\u0648\u0641\u064a\u0642 \u0641\u064a \u0627\u0644\u0645\u0633\u062a\u0642\u0628\u0644\".<br /><br />\u0648\u0642\u0627\u0644 \u062e\u0648\u0631\u062e\u064a \u0645\u0627\u0633\u060c \u0645\u0627\u0644\u0643 \u0646\u0627\u062f\u064a \u0627\u0655\u0646\u062a\u0631 \u0645\u064a\u0627\u0645\u064a \u0641\u064a \u0641\u0644\u0648\u0631\u064a\u062f\u0627 \"\u0633\u064a\u0638\u0644 \u062e\u0627\u0641\u064a\u064a\u0631 \u062c\u0632\u0621\u0627 \u0644\u0627 \u064a\u062a\u062c\u0632\u0627\u0654 \u0645\u0646 \u062a\u0627\u0631\u064a\u062e \u0647\u0630\u0627 \u0627\u0644\u0646\u0627\u062f\u064a\u060c \u0648\u0633\u064a\u0638\u0644 \u0644\u0647 \u0645\u0643\u0627\u0646\u0629 \u062e\u0627\u0635\u0629 \u0641\u064a \u0639\u0627\u064a\u0654\u0644\u0629 \u0627\u0655\u0646\u062a\u0631 \u0645\u064a\u0627\u0645\u064a\".<br /><br />\u0648\u0627\u0654\u0639\u0644\u0646 \u0627\u0655\u0646\u062a\u0631 \u0645\u064a\u0627\u0645\u064a \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u063a\u064a\u064a\u0631\u0645\u0648 \u0647\u0648\u064a\u0648\u0633\u060c \u0627\u0644\u0645\u062f\u0631\u0628 \u0627\u0644\u0633\u0627\u0628\u0642 \u0644\u0645\u0646\u062a\u062e\u0628 \u0628\u0648\u0644\u064a\u0641\u064a\u0627\u060c \u0633\u064a\u062a\u0648\u0644\u0649 \u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0641\u0631\u064a\u0642 \u0641\u064a \u0627\u0644\u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u0645\u0642\u0628\u0644\u0629.<br /><br />\u0648\u0628\u0639\u062f \u0633\u0628\u0639 \u062c\u0648\u0644\u0627\u062a\u060c \u064a\u062d\u062a\u0644 \u0627\u0655\u0646\u062a\u0631 \u0645\u064a\u0627\u0645\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0644\u062b \u0641\u064a \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u0645\u0646 \u0627\u0644\u062f\u0648\u0631\u064a.<br /><br />\u0648\u0627\u0646\u0636\u0645 \u0645\u064a\u0633\u064a \u0627\u0655\u0644\u0649 \u0627\u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u0639\u0627\u0645 2023 \u0645\u0646 \u0628\u0627\u0631\u064a\u0633 \u0633\u0627\u0646 \u062c\u0631\u0645\u0627\u0646 \u0627\u0644\u0641\u0631\u0646\u0633\u064a\u060c \u062d\u064a\u062b \u064a\u0644\u0639\u0628 \u0627\u0644\u0641\u0627\u064a\u0654\u0632 \u0628\u0645\u0648\u0646\u062f\u064a\u0627\u0644 \u0642\u0637\u0631 2022 \u0648\u0627