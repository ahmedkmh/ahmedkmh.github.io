u064a\u0646\u063a\u0647\u0627\u0645 \u0645\u0646 \u0645\u0646\u062a\u062e\u0628 \u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627 \u0648\u0647\u0627\u0644\u0627\u0646\u062f \u0645\u0646 \u0627\u0644\u0646\u0631\u0648\u064a\u062c\u060c \u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u062b\u0646\u0627\u064a\u0654\u064a \u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627 \u0648\u0645\u0628\u0627\u0628\u064a \u064a\u0644\u0627\u062d\u0642\u0648\u0646 \u0645\u064a\u0633\u064a \u062d\u062a\u0649 \u0627\u0653\u062e\u0631 \u0644\u062d\u0638\u0629 \u0641\u064a \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644. <br /><br />\u0648\u064a\u0648\u0627\u0635\u0644 \u0642\u0627\u064a\u0654\u062f \u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u062a\u0639\u0632\u064a\u0632 \u0627\u0654\u0631\u0642\u0627\u0645\u0647 \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0627\u0644\u062d\u0627\u0644\u064a\u0629\u060c \u0628\u0639\u062f\u0645\u0627 \u0631\u0641\u0639 \u0631\u0635\u064a\u062f\u0647 \u0627\u0644\u062a\u0647\u062f\u064a\u0641\u064a \u0627\u0655\u0644\u0649 8 \u0627\u0654\u0647\u062f\u0627\u0641 \u0628\u0627\u0644\u062a\u0633\u0627\u0648\u064a \u0645\u0639 \u0643\u064a\u0644\u064a\u0627\u0646 \u0645\u0628\u0627\u0628\u064a \u0648\u0648\u0627\u0635\u0644 \u062a\u0627\u0654\u062b\u064a\u0631\u0647 \u0627\u0644\u0643\u0628\u064a\u0631 \u0645\u0639 \u201c\u0627\u0644\u062a\u0627\u0646\u063a\u0648\u201d\u060c \u0644\u064a\u0645\u0646\u062d \u0646\u0641\u0633\u0647 \u0641\u0631\u0635\u0629 \u062c\u062f\u064a\u062f\u0629 \u0644\u0644\u0627\u0642\u062a\u0631\u0627\u0628 \u0645\u0646 \u0642\u0645\u0629 \u0647\u062f\u0627\u0641\u064a \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u064a\u0646.<br /><br /><br />\u0648\u062a\u0642\u0644\u0635\u062a \u062f\u0627\u064a\u0654\u0631\u0629 \u0627\u0644\u0645\u0646\u0627\u0641\u0633\u064a\u0646 \u0639\u0644\u0649 \u0635\u062f\u0627\u0631\u0629 \u0627\u0644\u0647\u062f\u0627\u0641\u064a\u0646 \u0645\u0639 \u062e\u0631\u0648\u062c \u0639\u062f\u062f \u0645\u0646 \u0627\u0644\u0645\u0646\u062a\u062e\u0628\u0627\u062a\u060c \u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u0645\u0628\u0627\u0628\u064a \u0648\u0643\u064a\u0646 \u0648\u0628\u064a\u0644\u064a\u0646\u063a\u0647\u0627\u0645 \u0644\u0627 \u064a\u0632\u0627\u0644\u0648\u0646 \u064a\u0645\u0644\u0643\u0648\u0646 \u0641\u0631\u0635\u0629 \u062a\u0639\u0632\u064a\u0632 \u0627\u0654\u0631\u0642\u0627\u0645\u0647\u0645 \u062e\u0644\u0627\u0644 \u0645\u0628\u0627\u0631\u0627\u0629 \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0644\u062b \u0648\u0627\u0644\u0631\u0627\u0628\u0639 \u060c \u0642\u0628\u0644 \u062d\u0633\u0645 \u062a\u0631\u062a\u064a\u0628 \u0647\u062f\u0627\u0641\u064a \u0627\u0644\u0646\u0633\u062e\u0629 \u0627\u0644\u062d\u0627\u0644\u064a\u0629.<br /><br /><br /><br />\u0648\u064a\u0645\u0644\u0643 \u0645\u064a\u0633\u064a \u0633\u062c\u0644\u064b\u0627 \u062d\u0627\u0641\u0644\u064b\u0627 \u0641\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0628\u0639\u062f\u0645\u0627 \u0633\u062c\u0644 \u0641\u064a \u0639\u062f\u0629 \u0646\u0633\u062e \u0645\u0646 \u0627\u0644\u0628\u0637\u0648\u0644\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0645\u0633\u0627\u0647\u0645\u0627\u062a\u0647 \u0627\u0644\u0643\u0628\u064a\u0631\u0629 \u0641\u064a \u0635\u0646\u0627\u0639\u0629 \u0627\u0644\u0627\u0654\u0647\u062f\u0627\u0641\u060c \u0644\u064a\u0648\u0654\u0643\u062f \u062d\u0636\u0648\u0631\u0647 \u0643\u0627\u0654\u062d\u062f \u0627\u0654\u0643\u062b\u0631 \u0627\u0644\u0644\u0627\u0639\u0628\u064a\u0646 \u062a\u0627\u0654\u062b\u064a\u0631\u064b\u0627 \u0641\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629.<br /><br />\u0648\u0645\u0639 \u0627\u0642\u062a\u0631\u0627\u0628 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\