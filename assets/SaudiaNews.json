9%84%D8%AC%D9%88%D9%8A%D8%A9-%D9%81%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9\">\u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0644\u0627\u0654\u0631\u0635\u0627\u062f</a> \u0639\u0646 \u0628\u062f\u0621 \u0627\u0655\u0635\u062f\u0627\u0631 \u062e\u0631\u0627\u064a\u0654\u0637 \u0645\u0646\u0627\u062e\u064a\u0629 \u0645\u062a\u062e\u0635\u0635\u0629 \u0644\u062a\u0648\u0632\u064a\u0639\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0637\u0627\u0631\u060c \u0636\u0645\u0646 \u062c\u0647\u0648\u062f\u0647 \u0627\u0644\u0631\u0627\u0645\u064a\u0629 \u0627\u0655\u0644\u0649 \u062a\u0637\u0648\u064a\u0631 \u0627\u0654\u062f\u0648\u0627\u062a \u0627\u0644\u0631\u0635\u062f \u0648\u0627\u0644\u062a\u062d\u0644\u064a\u0644 \u0627\u0644\u0645\u0646\u0627\u062e\u064a\u060c \u0648\u062a\u0639\u0632\u064a\u0632 \u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u0627\u0655\u0646\u0630\u0627\u0631 \u0627\u0644\u0645\u0628\u0643\u0631.<br /><br />\u0648\u0627\u0654\u0635\u062f\u0631 <a href=\"https://www.alyaum.com/articles/6653888/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%AF%D9%85%D8%A7%D9%85-16-%D9%85%D8%A6%D9%88%D9%8A%D8%A9-%D8%A8%D9%8A%D8%A7%D9%86-%D8%AF%D8%B1%D8%AC%D8%A7%D8%AA-%D8%A7%D9%84%D8%AD%D8%B1%D8%A7%D8%B1%D8%A9-%D8%A7%D9%84%D8%B5%D8%BA%D8%B1%D9%89-%D8%B9%D9%84%D9%89-%D8%A8%D8%B9%D8%B6-%D9%85%D8%AF%D9%86-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9\">\u0627\u0644\u0645\u0631\u0643\u0632 </a>\u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0627\u0655\u0637\u0627\u0631 \u062e\u0631\u064a\u0637\u0629 \u0645\u0646\u0627\u062e\u064a\u0629 \u0644\u062a\u0648\u0632\u064a\u0639\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0637\u0627\u0631 \u0644\u0634\u0647\u0631 \u0627\u0654\u0628\u0631\u064a\u0644 \u0644\u0644\u0641\u062a\u0631\u0629 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u0629 (1998 \u2013 2025\u0645)\u060c \u0628\u0627\u0644\u0627\u063