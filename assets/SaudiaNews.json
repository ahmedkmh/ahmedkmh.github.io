nk\">\u062a\u062d\u062f\u064a \u0627\u0644\u0627\u0655\u0644\u0642\u0627\u0621 \u0644\u0644\u0627\u0654\u0637\u0641\u0627\u0644</a>\"\u060c \u0648\u0647\u064a \u0645\u0633\u0627\u0628\u0642\u0629 \u062f\u0648\u0644\u064a\u0629 \u062a\u0633\u062a\u0647\u062f\u0641 \u0627\u0644\u0627\u0654\u0637\u0641\u0627\u0644 \u0627\u0644\u0646\u0627\u0637\u0642\u064a\u0646 \u0628\u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0645\u0646 \u062c\u0645\u064a\u0639 \u0627\u0654\u0646\u062d\u0627\u0621 \u0627\u0644\u0639\u0627\u0644\u0645\u060c \u0645\u0646 \u0639\u0645\u0631 5 \u0627\u0655\u0644\u0649 12 \u0639\u0627\u0645\u064b\u0627\u060c \u0648\u062a\u064f\u0633\u062a\u0642\u0628\u0644 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0627\u062a \u062d\u062a\u0649 30 \u064a\u0648\u0646\u064a\u0648 \u0627\u0644\u0645\u0642\u0628\u0644.<br />\u0648\u062a\u064f\u0639\u0646\u0649 \u0628\u062a\u0646\u0645\u064a\u0629 \u0645\u0647\u0627\u0631\u0627\u062a \u0627\u0644\u0627\u0655\u0644\u0642\u0627\u0621 \u0648\u0627\u0644\u062a\u0639\u0628\u064a\u0631 \u0644\u062f\u064a\u0647\u0645\u060c \u0628\u062a\u0642\u062f\u064a\u0645 \u0646\u0635\u0648\u0635 \u0634\u0639\u0631\u064a\u0629 \u0641\u0635\u064a\u062d\u0629 \u0641\u064a \u0645\u0642\u0627\u0637\u0639 \u0645\u0631\u064a\u0654\u064a\u0629 \u0642\u0635\u064a\u0631\u0629.<br />\u0648\u062a\u0647\u062f\u0641 \u0627\u0644\u0645\u0633\u0627\u0628\u0642\u0629 \u0627\u0655\u0644\u0649 \u0627\u0655\u0628\u0631\u0627\u0632 \u062c\u0645\u0627\u0644 \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0628\u0627\u0654\u062f\u0627\u0621 \u0627\u0644\u0627\u0654\u0637\u0641\u0627\u0644\u060c \u0648\u062a\u0639\u0632\u064a\u0632 \u062d\u0636\u0648\u0631\u0647\u0627 \u0641\u064a \u0627\u0644\u0645\u0646\u0635\u0627\u062a \u0627\u0644\u062a\u0641\u0627\u0639\u0644\u064a\u0629\u060c \u0648\u062a\u0645\u0643\u064a\u0646 \u0627\u0644\u062c\u0645\u0647\u0648\u0631 \u0645\u0646 \u0627\u0644\u062a\u0639\u0631\u0651