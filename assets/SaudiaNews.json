cloudinary/image/upload/w_1920,h_1080,c_fill,q_auto,g_center/cnnarabic/2026/03/01/images/324683.jpg", "video_url": null, "source_id": "cnn_sa", "source_name": "Cnn Arabic", "source_priority": 42, "source_url": "https://arabic.cnn.com", "source_icon": "https://n.bytvi.com/cnn_sa.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "d0240de9d454d6a057b71e66141b2e74", "link": "https://www.alwatan.com.sa/article/1177941", "title": "\u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0655\u0639\u0644\u0627\u0645 \u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0631\u0633\u0645\u064a\u0629 \u062a\u0639\u0644\u0646 \u0627\u063a\u062a\u064a\u0627\u0644 \u062e\u0627\u0645\u0646\u064a\u0654\u064a", "description": "\u0627\u0654\u0639\u0644\u0646\u062a \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0655\u0639\u0644\u0627\u0645 \u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0631\u0633\u0645\u064a\u0629\u060c \u0627\u0644\u0627\u0654\u062d\u062f\u060c \u0627\u063a\u062a\u064a\u0627\u0644 \u0627\u0644\u0645\u0631\u0634\u062f \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0639\u0644\u064a \u062e\u0627\u0645\u0646\u064a\u0654\u064a \u0641\u064a \u063a\u0627\u0631\u0627\u062a \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629.\u0648\u0630\u0643\u0631\u062a \u0648\u0643\u0627\u0644\u0629 \"\u0641\u0627\u0631\u0633\" \u0644\u0644\u0627\u0654\u0646\u0628\u0627\u0621 \u0627\u0654\u0646 \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0627\u0654\u0639\u0644\u0646\u062a \u062d\u0627\u0644\u0629 \u0627\u0644\u062d\u062f\u0627\u062f 40 \u064a\u0648\u0645\u0627\u064b \u0639\u0644\u0649 \u0627\u063a\u062a\u064a\u0627\u0644 \u062e\u0627\u0645\u0646\u064a\u0654\u064a.\u0645\u0646 \u0647\u0648 \u0639\u0644\u064a \u062e\u0627\u0645\u0646\u064a\u0654\u064a\u061f\u0639\u0644\u064a \u062d\u0633\u064a\u0646\u064a \u062e\u0627\u0645\u0646\u064a\u0654\u064a\u060c \u0648\u0644\u062f \u0641\u064a 19 \u0627\u0654\u0628\u0631\u064a\u0644 1939 \u0628\u0645\u062f\u064a\u0646\u0629 \u0645\u0634\u0647\u062f \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0644\u0639\u0627\u064a\u0654\u0644\u0629 \u0645\u062a\u062f\u064a\u0646\u0629 \u0645\u0646 \u0627\u0654\u0635\u0648\u0644 \u0627\u0653\u0630\u0631\u0628\u064a\u062c\u0627\u0646\u064a\u0629. \u0648\u0643\u0627\u0646 \u062e\u0627\u0645\u0646\u064a\u0654\u064a \u064a\u0634\u063a\u0644 \u0645\u0646\u0635\u0628 \u0627\u0644\u0645\u0631\u0634\u062f \u0627\u0644\u0627\u0654\u0639\u0644\u0649 \u0644\u0644\u062b\u0648\u0631\u0629 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646 \u0645\u0646\u0630 \u0639\u0627\u0645 1989\u060c \u0648\u0647\u0648 \u062b\u0627\u0646\u064a \u0634\u062e\u0635 \u064a\u062a\u0648\u0644\u0649 \u0647\u0630\u0627 \u0627\u0644\u0645\u0646\u0635\u0628 \u0628\u0639\u062f \u0645\u0648\u0654\u0633\u0633 \u0627\u0644\u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0627\u0644\u062e\u0645\u064a\u0646\u064a.\u0648\u0643\u0627\u0646 \u0645\u0646 \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0641\u064a \u0627\u0644\u062b\u0648\u0631\u0629 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629 \u0639\u0627\u0645 1979 \u0636\u062f \u0646\u0638\u0627\u0645 \u0627\u0644\u0634\u0627\u0647\u060c \u0648\u062a\u0648\u0644\u0649 \u0631\u064a\u0654\u0627\u0633\u0629 \u0627\u0644\u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0644\u0641\u062a\u0631\u062a\u064a\u0646 \u0645\u062a\u062a\u0627\u0644\u064a\u062a\u064a\u0646 \u0645\u0646 \u0639\u0627\u0645 1981 \u062d\u062a\u0649 1989. \u062b\u0645 \u062e\u0644\u0641 \u0627\u0644\u062e\u0645\u064a\u0646\u064a \u0643\u0645\u0631\u0634\u062f \u0627\u0654\u0639\u0644\u0649 \u0641\u064a 4 \u064a\u0648\u0646\u064a\u0648 1989\u060c \u0648\u0638\u0644 \u0641\u064a \u0645\u0646\u0635\u0628\u0647 \u062d\u062a\u0649 \u0648\u0641\u0627\u062a\u0647 \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631 2026. \u0648\u062c\u0627\u0621 \u0645\u0642\u062a\u0644\u0647 \u062e\u0644\u0627\u0644 \u062a\u0635\u0639\u064a\u062f \u0639\u0633\u0643\u0631\u064a \u0648\u0627\u0633\u0639\u060c \u062d\u064a\u062b \u0627\u0654\u0639\u0644\u0646 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u064a \u062d\u064a\u0646\u0647\u0627 \u0627\u0654\u0646 \u0627\u0644\u0647\u062c\u0648\u0645 \u0627\u0633\u062a\u0647\u062f\u0641 \u0643\u0628\u0627\u0631 \u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0646 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u064a\u0646.\u062e\u0644\u0641\u0627\u0621 \u0645\u062d\u062a\u0645\u0644\u0648\u0646\u0645\u0639 \u062e\u0644\u0648 \u0627\u0644\u0645\u0646\u0635\u0628\u060c \u062a\u062a\u0648\u062c\u0647 \u0627\u0644\u0627\u0654\u0646\u0638\u0627\u0631 \u0646\u062d\u0648 \u0627\u0654\u0633\u0645\u0627\u0621 \u0645\u0631\u0634\u062d\u0629 \u0645\u0646\u0647\u0627 \u0627\u0628\u0646\u0647 \u0645\u062c\u062a\u0628\u0649 \u062e\u0627\u0645\u0646\u064a\u0654\u064a \u0648\u0634\u062e\u0635\u064a\u0627\u062a \u062f\u064a\u0646\u064a\u0629 \u0648\u0633\u064a\u0627\u0633\u064a\u0629 \u0627\u0654\u062e\u0631\u0649 \u0645\u062b\u0644 \u0635\u0627\u062f\u0642 \u0644\u0627\u0631\u064a\u062c\u0627\u0646\u064a \u0648\u062d\u0633\u0646 \u0627\u0644\u062e\u0645\u064a\u0646\u064a.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0627\u063a\u062a\u064a\u0627\u0644", "\u0625\u0639\u0644\u0627\u0646", "\u0639\u0644\u064a \u062e\u0627\u0645\u0646\u0626", "\u0627\u0644\u0645\u063