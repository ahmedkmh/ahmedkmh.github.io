43\u062b\u064a\u0631 \u0645\u0646 \u0627\u0644\u0632\u0648\u0627\u0631 \u0631\u062d\u0644\u062a\u0647\u0645 \u0644\u0627\u0633\u062a\u0643\u0634\u0627\u0641 \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629.<br />\u0648\u0644\u0627 \u062a\u0642\u0641 \u0627\u0644\u0628\u0644\u062f\u0629 \u0627\u0644\u0642\u062f\u064a\u0645\u0629 \u0639\u0646\u062f \u062d\u062f\u0648\u062f \u0643\u0648\u0646\u0647\u0627 \u0645\u0648\u0642\u0639\u064b\u0627 \u062a\u0627\u0631\u064a\u062e\u064a\u064b\u0627\u060c \u0628\u0644 \u062a\u0642\u062f\u0645 \u0644\u0632\u0648\u0627\u0631\u0647\u0627 \u062a\u062c\u0631\u0628\u0629\u064b \u064a\u062a\u062f\u0627\u062e\u0644 \u0641\u064a\u0647\u0627 \u0627\u0644\u0645\u0643\u0627\u0646 \u0645\u0639 \u0627\u0644\u062d\u0643\u0627\u064a\u0629\u060c \u0641\u064a\u0635\u0628\u062d \u0627\u0644\u062a\u062c\u0648\u0644 \u0628\u064a\u0646 \u0627\u0654\u062d\u064a\u0627\u064a\u0654\u0647\u0627 \u0648\u0633\u0627\u062d\u0627\u062a\u0647\u0627 \u0648\u0627\u0654\u0633\u0648\u0627\u0642\u0647\u0627 \u062c\u0632\u0621\u064b\u0627 \u0645\u0646 \u0627\u0643\u062a\u0634\u0627\u0641 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0639\u064f\u0644\u0627\u060c \u0644\u0627 \u0645\u062c\u0631\u062f \u0627\u0644\u0645\u0631\u0648\u0631 \u0628\u0645\u0639\u0627\u0644\u0645\u0647\u0627.<br /> <br />\u0648\u064a\u0645\u0646\u062d \u0647\u0630\u0627 \u0627\u0644\u062a\u0643\u0648\u064a\u0646 \u0627\u0644\u0639\u0645\u0631\u0627\u0646\u064a \u0627\u0644\u0632\u0627\u064a\u0654\u0631 \u0641\u0631\u0635\u0629\u064b \u0644\u0644\u062a\u0639\u0631\u0641 \u0627\u0655\u0644\u0649 \u0645\u0644\u0627\u0645\u062d \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u062a\u064a \u062a\u0634\u0643\u0644\u062a \u0639\u0628\u0631 \u0627\u0644\u0642\u0631\u0648\u0646\u060c \u0648\u0645\u0627 \u062a\u062d\u0645\u0644\u0647 \u0645\u0646 \u062a\u0641\u0627\u0635\u064a\u0644 \u062a\u0639\u0643\u0633 \u0647\u0648\u064a\u0629 \u0627\u0644\u0645\u0643\u0627\u0646 \u0648\u0627\u0654\u0633\u0644\u0648\u0628 \u0627\u0644\u062d\u064a\u0627\u0629 \u0641\u064a\u0647.<h2>\u0627\u0644\u062a\u0641\u0627\u0639\u0644 \u0645\u0639 \u0627\u0644\u0645\u0648\u0631\u0648\u062b \u0627\u0644\u0645\u062d\u0644\u064a</h2>\u0648\u062a\u0646\u0628\u0636 \u0627\u0644\u0628\u0644\u062f\u0629 \u0627\u0644\u0642\u062f\u064a\u0645\u0629 \u0627\u0644\u064a\u0648\u0645 \u0628\u062a\u062c\u0627\u0631\u0628 \u0645\u062a\u0646\u0648\u0639\u0629 \u062a\u062c\u0645\u0639 \u0627\u0644\u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a\u0629\u060c \u0648\u0627\u0644\u062d\u0631\u0641 \u0627\u0644\u064a\u062f\u0648\u064a\u0629\u060c \u0648\u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u0645\u062d\u0644\u064a\u0629\u060c \u0648\u0627\u0644\u0645\u0639\u0627\u0631\u0636\u060c \u0648\u0627\u0644\u0641\u0639\u0627\u0644\u064a\u0627\u062a \u0627\u0644\u062b\u0642\u0627\u0641\u064a\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0644\u0645\u0642\u0627\u0647\u064a \u0648\u0627\u0644\u0645\u0637\u0627\u0639\u0645\u060c \u0628\u0645\u0627 \u064a\u062a\u064a\u062d \u0644\u0644\u0632\u0627\u064a\u0654\u0631 \u0627\u0644\u062a\u0641\u0627\u0639\u0644 \u0645\u0639 \u0627\u0644\u0645\u0648\u0631\u0648\u062b \u0627\u0644\u0645\u062d\u0644\u064a \u0641\u064a \u0628\u064a\u064a\u0654\u0629 \u062a\u0627\u0631\u064a\u062e\u064a\u0629 \u062a\u062d\u062a\u0641\u0638 \u0628\u0627\u0654\u0635\u0627\u0644\u062a\u0647\u0627\u060c \u0648\u062a\u0642\u062f\u0645\u0647 \u0641\u064a \u0635\u0648\u0631\u0629 \u0645\u0639\u0627\u0635\u0631\u0629.<br />\u0648\u062e\u0644\u0627\u0644 \u0627\u0654\u0645\u0633\u064a\u0627\u062a \u0627\u0644\u0635\u064a\u0641\u060c \u062a\u062a\u062c\u0647 \u0627\u0644\u062d\u0631\u0643\u0629 \u0627\u0644\u0633\u064a\u0627\u062d\u064a\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0628\u0644\u062f\u0629 \u0627\u0644\u0642\u062f\u064a\u0645\u0629 \u0645\u0639 \u0627\u0639\u062a\u062f\u0627\u0644 \u0627\u0644\u0627\u0654\u062c\u0648\u0627\u0621\u060c \u0644\u062a\u062a\u062d\u0648\u0644 \u0627\u0654\u0632\u0642\u062a\u0647\u0627 \u0648\u0633\u0627\u062d\u0627\u062a\u0647\u0627 \u0627\u0655\u0644\u0649 \u0645\u0633\u0627\u062d\u0627\u062a \u062a\u062d\u062a\u0636\u0646 \u062c\u0648\u0644\u0627\u062a \u0627\u0644\u0645\u0634\u064a\u060c \u0648\u0627\u0644\u062a\u0633\u0648\u0642\u060c \u0648\u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u062b\u0642\u0627\u0641\u064a\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0644\u0645\u0642\u0627\u0647\u064a \u0648\u0627\u0644\u0645\u0637\u0627\u0639\u0645\u060c \u0641\u064a \u0627\u0654\u062c\u0648\u0627\u0621 \u062a\u0645\u062a\u062f \u062d\u062a\u0649 \u0633\u0627\u0639\u0627\u062a \u0627\u0644\u0644\u064a\u0644\u060c \u0648\u062a\u0645\u0646\u062d \u0627\u0644\u0632\u0627\u064a\u0654\u0631 \u062a\u062c\u0631\u0628\u0629\u064b \u0645\u062e\u062a\u0644\u0641\u0629 \u062a\u062c\u0645\u0639 \u0627\u0639\u062a\u062f\u0627\u0644 \u0627\u0644\u0637\u0642\u0633 \u0648\u062c\u0645\u0627\u0644 \u0627\u0644\u0645\u0643\u0627\u0646.<br /> <h2>\u062a\u062c\u0627\u0631\u0628 \u062b\u0642\u0627\u0641\u064a\u0629 \u0648\u062a\u0631\u0627\u062b\u064a\u0629 \u0648\u0633\u064a\u0627\u062d\u064a\u0629</h2>\u0648\u0644\u0627 \u062a\u0642\u062a\u0635\u0631 \u0627\u0654\u0647\u0645\u064a\u0629 \u0627\u0644\u0628\u0644\u062f\u0629 \u0627\u0644\u0642\u062f\u064a\u0645\u0629 \u0627\u0644\u064a\u0648\u0645 \u0639\u0644\u0649 \u0643\u0648\u0646\u0647\u0627 \u0627\u0654\u062d\u062f \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0645\u0639\u0627\u0644\u0645 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u0629 \u0641\u064a \u0627\u0644\u0639\u064f\u0644\u0627\u060c \u0628\u0644 \u0627\u0654\u0635\u0628\u062d\u062a \u0648\u062c\u0647\u0629 \u0645\u062a\u0643\u0627\u0645\u0644\u0629 \u062a\u0633\u062a\u0648\u0639\u0628 \u0627\u0647\u062a\u0645\u0627\u0645\u0627\u062a \u0627\u0644\u0632\u0648\u0627\u0631 \u0639\u0644\u0649 \u0627\u062e\u062a\u0644\u0627\u0641\u0647\u0627\u060c \u0628\u0645\u0627 \u062a\u0648\u0641\u0631\u0647 \u0645\u0646 \u062a\u062c\u0627\u0631\u0628 \u062b\u0642\u0627\u0641\u064a\u0629 \u0648\u062a\u0631\u0627\u062b\u064a\u0629 \u0648\u0633\u064a\u0627\u062d\u064a\u0629\u060c \u0648\u0645\u0627 \u062a\u0645\u0646\u062d\u0647 \u0645\u0646 \u0641\u0631\u0635\u0629 \u0644\u0644\u062a\u0639\u0631\u0641 \u0639\u0644\u0649 \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629 \u0641\u064a \u0628\u064a\u064a\u0654\u062a\u0647 \u0627\u0644\u0627\u0654\u0635\u064a\u0644\u0629.<br />\u0648\u062a\u0628\u0642\u0649 \u0627\u0644\u0628\u0644\u062f\u0629 \u0627\u0644\u0642\u062f\u064a\u0645\u0629 \u0627\u0655\u062d\u062f\u0649 \u0627\u0654\u0628\u0631\u0632 \u0645\u062d\u0637\u0627\u062a \u0627\u0644\u0632\u064a\u0627\u0631\u0629 \u0641\u064a \u0645\u062d\u0627\u0641\u0638\u0629 \u0627\u0644\u0639\u064f\u0644\u0627\u060c \u0627\u0655\u0630 \u062a\u062c\u0645\u0639 \u0627\u0655\u0631\u062b\u0647\u0627 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a \u0648\u062a\u062c\u0627\u0631\u0628\u0647\u0627 \u0627\u0644\u0645\u062a\u0646\u0648\u0639\u0629\u060c \u0644\u062a\u0642\u062f\u0645 \u0646\u0645\u0648\u0630\u062c\u064b\u0627 \u062d\u064a\u064b\u0627 \u0644\u0645\u062f\u064a\u0646\u0629 \u0645\u0627 \u0632\u0627\u0644\u062a \u062a\u062d\u0641\u0638 \u0645\u0644\u0627\u0645\u062d \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0648\u062a\u0639\u064a\u0634 \u0628\u0631\u0648\u062d \u0627\u0644\u062d\u0627\u0636\u0631\u060c \u0641\u064a \u062a\u062c\u0631\u0628\u0629 \u062a\u062c\u0633\u062f \u0627\u0644\u062a\u0642\u0627\u0621 \u0627\u0644\u062a\u0627\u0631\u064a\u062e \u0628\u0627\u0644\u062d\u064a\u0627\u0629\u060c \u0648\u062a\u062c\u0639\u0644 \u0645\u0646 \u0632\u064a\u0627\u0631\u0629 \u0627\u0644\u0628\u0644\u062f\u0629 \u0631\u062d\u0644\u0629\u064b \u062a\u0639\u0628\u0631 \u0628\u0627\u0644\u0632\u0627\u064a\u0654\u0631 \u0628\u064a\u0646 \u0635\u0641\u062d\u0627\u062a \