u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0645\u0646\u062a\u062e\u0628\u064a \u0643\u0648\u0631\u064a\u0627 \u0627\u0644\u062c\u0646\u0648\u0628\u064a\u0629 \u0648\u0642\u0637\u0631\u060c \u0641\u064a \u0648\u0627\u062d\u062f\u0629 \u0645\u0646 \u0627\u0654\u0642\u0648\u0649 \u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0627\u0644\u0628\u0637\u0648\u0644\u0629.<br /><br />\u0648\u062a\u062d\u0645\u0644 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u062a\u062d\u062f\u064a\u064b\u0627 \u0645\u0628\u0643\u0631\u064b\u0627 \u0644\u0640\u00ab\u0627\u0644\u0627\u0654\u062e\u0636\u0631\u00bb \u0627\u0644\u0634\u0627\u0628\u060c \u0627\u0655\u0630 \u064a\u0648\u0627\u062c\u0647 \u0645\u0646\u062a\u062e\u0628\u064b\u0627 \u0643\u0648\u0631\u064a\u064b\u0627 \u062c\u0646\u0648\u0628\u064a\u064b\u0627 \u064a\u064f\u0639\u062f \u0645\u0646 \u0627\u0654\u0628\u0631\u0632 \u0627\u0644\u0642\u0648\u0649 \u0627\u0644\u0627\u0653\u0633\u064a\u0648\u064a\u0629 \u0641\u064a \u0627\u0644\u0641\u064a\u0654\u0627\u062a \u0627\u0644\u0633\u0646\u064a\u0629\u060c \u0648\u064a\u062f\u062e\u0644 \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0628\u0635\u0641\u062a\u0647 \u062d\u0627\u0645\u0644 \u0644\u0642\u0628 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u0641\u064a \u0627\u0644\u0646\u0633\u062e\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0644\u0639\u0627\u0628 \u0627\u0644\u0627\u0653\u0633\u064a\u0648\u064a\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0642\u0637\u0631\u064a \u0627\u0644\u0630\u064a \u064a\u0648\u0627\u0635\u0644 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0641\u064a \u062a\u0637\u0648\u064a\u0631 \u0645\u0646\u062a\u062e\u0628\u0627\u062a\u0647 \u0627\u0644\u0639\u0645\u0631\u064a\u0629.<br /><br />\u0648\u064a\u0639\u0648\u0651\u0644 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u062