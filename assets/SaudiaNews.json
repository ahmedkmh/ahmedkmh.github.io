{"status": "success", "totalResults": 4137, "results": [{"article_id": "5abaf48d4ad468d4382321ec43af043c", "link": "https://www.alyaum.com/articles/6674019/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A8%D9%88%D8%B1%D9%86%D9%85-%D9%8A%D8%B9%D9%84%D9%86-%D8%AA%D8%B4%D9%83%D9%8A%D9%84%D8%A9-%D8%A7%D9%84%D8%AD%D9%83%D9%88%D9%85%D9%8A%D8%A9-%D8%A7%D9%84%D8%A8%D8%B1%D9%8A%D8%B7%D8%A7%D9%86%D9%8A%D8%A9-%D8%A7%D9%84%D8%AC%D8%AF%D9%8A%D8%AF%D8%A9-%D9%88%D9%8A%D8%B3%D8%AA%D8%A8%D8%B9%D8%AF-%D9%88%D8%B2%D8%B1%D8%A7%D8%A1-%D8%B3%D8%AA%D8%A7%D8%B1%D9%85%D8%B1", "title": "\u0628\u0648\u0631\u0646\u0645 \u064a\u0639\u0644\u0646 \u062a\u0634\u0643\u064a\u0644\u0629 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u0629 \u0627\u0644\u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0648\u064a\u0633\u062a\u0628\u0639\u062f \u0648\u0632\u0631\u0627\u0621 \u0633\u062a\u0627\u0631\u0645\u0631", "description": "\u0627\u0654\u0639\u0644\u0646 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0628\u0631\u064a\u0637\u0627\u0646\u064a \u0627\u0644\u062c\u062f\u064a\u062f <a href=\"https://www.alyaum.com/articles/6671041/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%B3%D8%AA%D8%A7%D8%B1%D9%85%D8%B1-%D9%8A%D8%AD%D8%B0%D8%B1-%D8%AE%D9%84%D9%8A%D9%81%D8%AA%D9%87-%D8%A2%D9%86%D8%AF%D9%8A-%D8%A8%D9%88%D8%B1%D9%86%D9%85-%D8%B3%D9%8A%D9%88%D8%A7%D8%AC%D9%87-%D8%A7%D9%84%D8%B5%D8%B1%D8%A7%D8%B9%D8%A7%D8%AA-%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85%D9%8A%D8%A9\" target=\"_blank\">\u0627\u0653\u0646\u062f\u064a \u0628\u0648\u0631\u0646\u0645</a> \u062d\u0643\u0648\u0645\u062a\u0647 \u0627\u0644\u0627\u0655\u062b\u0646\u064a\u0646\u060c \u0645\u0633\u062a\u0628\u0639\u062f\u064b\u0627 \u0627\u0644\u0645\u0642\u0631\u0651\u0628\u064a\u0646 \u0645\u0646 \u0633\u0644\u0641\u0647 <a href=\"https://www.alyaum.com/articles/6668538/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%A7%D8%B3%D8%AA%D9%82%D8%A7%D9%84%D8%A9-%D9%83%D9%8A%D8%B1-%D8%B3%D8%AA%D8%A7%D8%B1%D9%85%D8%B1-%D8%AA%D8%B1%D8%A8%D9%83-%D8%A3%D8%AC%D9%86%D8%AF%D8%A9-%D8%A7%D9%84%D8%AA%D9%82%D8%A7%D8%B1%D8%A8-%D8%A8%D9%8A%D9%86-%D9%84%D9%86%D8%AF%D9%86-%D9%88%D8%A7%D9%84%D8%A7%D8%AA%D8%AD%D8%A7%D8%AF-%D8%A7%D9%84%D8%A3%D9%88%D8%B1%D9%88%D8%A8%D9%8A\" target=\"_blank\">\u0643\u064a\u0631 \u0633\u062a\u0627\u0631\u0645\u0631</a>\u060c \u0648\u0630\u0644\u0643 \u0628\u0639\u062f \u062a\u0648\u0644\u064a\u0647 \u0645\u0646\u0635\u0628\u0647 \u0633\u0627\u0628\u0639 \u0631\u064a\u0654\u064a\u0633 \u0648\u0632\u0631\u0627\u0621 <a href=\"https://www.alyaum.com/articles/6673267/%D8%A7%D9%84%D8%AD%D9%8A%D8%A7%D8%A9/%D8%AA%D9%83%D9%86%D9%88%D9%84%D9%88%D8%AC%D9%8A%D8%A7/%D8%A8%D8%B1%D9%8A%D8%B7%D8%A7%D9%86%D9%8A%D8%A7-%D8%AA%D8%AD%D9%82%D9%82-%D9%85%D8%B9-%D8%AA%D9%8A%D9%83-%D8%AA%D9%88%D9%83-%D8%A8%D8%B4%D8%A3%D9%86-%D8%AD%D9%85%D8%A7%D9%8A%D8%A9-%D8%A7%D9%84%D8%A3%D8%B7%D9%81%D8%A7%D9%84-%D9%85%D9%86-%D8%A7%D9%84%D9%85%D8%AD%D8%AA%D9%88%D9%89-%D8%A7%D9%84%D8%B6%D8%A7%D8%B1\" target=\"_blank\">\u0644\u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0627</a> \u0645\u0646\u0630 \u0639\u0627\u0645 2016.<br />\u0648\u0643\u0627\u0646 \u0628\u0648\u0631\u0646\u0645 \u062a\u0639\u0647\u062f \u0627\u0655\u062d\u062f\u0627\u062b \u062a\u063a\u064a\u064a\u0631 \u062c\u0630\u0631\u064a \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0645\u062a\u062d\u062f\u0629.<h2>\u0627\u0654\u0633\u0645\u0627\u0621 \u063a\u064a\u0631 \u0645\u062a\u0648\u0642\u0639\u0629</h2>\u0648\u0641\u064a \u062e\u0637\u0648\u0629 \u063a\u064a\u0631 \u0645\u062a\u0648\u0642\u0639\u0629\u060c \u0639\u064a\u0651\u0646 \u0648\u0632\u064a\u0631 \u0627\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u0633\u0627\u0628\u0642 \u062c\u0648\u0646 \u0647\u064a\u0644\u064a \u0627\u0644\u0630\u064a \u063a\u0627\u062f\u0631 \u062d\u0643\u0648\u0645\u0629 \u0633\u062a\u0627\u0631\u0645\u0631 \u0628\u0633\u0628\u0628 \u062e\u0644\u0627\u0641\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0645\u064a\u0632\u0627\u0646\u064a\u0629\u060c \u0641\u064a \u0645\u0646\u0635\u0628 \u0648\u0632\u064a\u0631 \u0627\u0644\u0645\u0627\u0644 \u062e\u0644\u0641\u0627 \u0644\u0631\u0627\u0634\u064a\u0644 \u0631\u064a\u0641\u0632.<br />\u0648\u062a\u0646\u062a\u0638\u0631 \u0647\u064a\u0644\u064a \u0645\u0647\u0645\u0629 \u0634\u0627\u0642\u0629 \u0646\u0638\u0631\u064b\u0627 \u0627\u0655\u0644\u0649 \u062a\u0628\u0627\u0637\u0648\u0654 \u0627\u0644\u0646\u0645\u0648 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a \u0648\u0627\u0644\u0636\u063a\u0648\u0637 \u0627\u0644\u062a\u064a \u062a\u064f\u0639\u0627\u0646\u064a\u0647\u0627 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0646\u062a\u064a\u062c\u0629 \u0627\u0631\u062a\u0641\u0627\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u062f\u064a\u0646.<br />\u0648\u0639\u064f\u064a\u0651\u0646 \u0648\u0632\u064a\u0631 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0648\u0644\u0627\u064a\u062a\u0647 \u0627\u0655\u062f \u0645\u064a\u0644\u064a\u0628\u0627\u0646\u062f \u0648\u0632\u064a\u0631\u064b\u0627 \u0644\u0644\u062e\u0627\u0631\u062c\u064a\u0629\u060c \u0627\u0654\u0645\u0627 \u0634\u0628\u0627\u0646\u0629 \u0645\u062d\u0645\u0648\u062f \u0627\u0644\u0645\u0639\u0631\u0648\u0641\u0629 \u0628\u0645\u0648\u0642\u0641\u0647\u0627 \u0627\u0644\u0645\u062a\u0634\u062f\u062f \u062a\u062c\u0627\u0647 \u0627\u0644\u0647\u062c\u0631\u0629\u060c \u0641\u0628\u0642\u064a\u062a \u0641\u064a \u0645\u0646\u0635\u0628\u0647\u0627 \u0648\u0632\u064a\u0631\u0629 \u0644\u0644\u062f\u0627\u062e\u0644\u064a\u0629.<br />\u0648\u0645\u0633\u0627\u0621 \u0627\u0644\u0627\u062b\u0646\u064a\u0646 \u0639\u064f\u064a\u0646 \u0648\u0632\u064a\u0631\u064b\u0627 \u0644\u0644\u062f\u0641\u0627\u0639 \u0648\u064a\u0633 \u0633\u062a\u0631\u064a\u062a\u064a\u0646\u062c \u0627\u0644\u0630\u064a \u0627\u0633\u062a\u0642\u0627\u0644 \u0645\u0646 \u0645\u0646\u0635\u0628\u0647 \u0648\u0632\u064a\u0631\u064b\u0627 \u0644\u0644\u0635\u062d\u0629 \u0641\u064a \u062d\u0643\u0648\u0645\u0629 \u0633\u062a\u0627\u0631\u0645\u0631\u060c \u0648\u0643\u0627\u0646 \u064a\u0639\u062a\u0632\u0645 \u0645\u0646\u0627\u0641\u0633\u0629 \u0628\u0648\u0631\u0646\u0645 \u0639\u0644\u0649 \u0632\u0639\u0627\u0645\u0629 \u062d\u0632\u0628 \u0627\u0644\u0639\u0645\u0627\u0644 \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u062a\u0631\u0627\u062c\u0639 \u0639\u0646 \u0630\u0644\u0643.<br />\u0648\u0627\u0633\u062a\u064f\u0628\u0639\u0650\u062f \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0645\u0642\u0631\u0651\u0628\u0648\u0646 \u0645\u0646 \u0643\u064a\u0631 \u0633\u062a\u0627\u0631\u0645\u0631\u060c \u0645\u062b\u0644 \u0648\u0632\u064a\u0631 \u0627\u0644\u0639\u062f\u0644 \u0648\u0646\u0627\u064a\u0654\u0628 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0648\u0644\u0627\u064a\u062a\u0647 \u062f\u064a\u0641\u064a\u062f \u0644\u0627\u0645\u064a\u060c \u0648\u0648\u0632\u064a\u0631\u0629 \u0627\u0644\u0645\u0627\u0644 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0648\u0644\u0627\u064a\u062a\u0647\u0627 \u0631\u0627\u0634\u064a\u0644 \u0631\u064a\u0641\u0632 \u0627\u0654\u0648 \u0628\u064a\u062a\u0631 \u0643\u0627\u064a\u0644 \u0648\u0632\u064a\u0631 \u0627\u0644\u062a\u062c\u0627\u0631\u0629 \u0627\u0644\u0633\u0627\u0628\u0642.<br /> <h2>\u0627\u0654\u0648\u0633\u0639 \u0639\u0645\u0644\u064a\u0629 \u062a\u063a\u064a\u064a\u0631 \u0641\u064a \u0627\u0644\u0628\u0644\u0627\u062f</h2>\u0648\u0627\u0654\u0635\u0628\u062d \u0628\u0648\u0631\u0646\u0645 \u064a\u0648\u0645 \u0627\u0644\u062c\u0645\u0639\u0629 \u0632\u0639\u064a\u0645\u064b\u0627 \u0644\u062d\u0632\u0628 \u0627\u0644\u0639\u0645\u0627\u0644 \u0628\u0639\u062f \u062d\u0635\u0648\u0644\u0647 \u06