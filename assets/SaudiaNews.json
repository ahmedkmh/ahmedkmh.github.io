NS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "0d11e9bd2aabea91bbfd9ad6197e0d19", "link": "https://www.alyaum.com/articles/6648352/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D8%A3%D8%B3%D9%88%D8%A7%D9%82-%D8%A7%D9%84%D8%A3%D8%B3%D9%87%D9%85/%D9%85%D8%A4%D8%B4%D8%B1-%D8%B3%D9%88%D9%82-%D8%A7%D9%84%D8%A3%D8%B3%D9%87%D9%85-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A%D8%A9-%D9%8A%D8%BA%D9%84%D9%82-%D9%85%D8%B1%D8%AA%D9%81%D8%B9%D8%A7-07-%D8%A7%D9%84%D9%8A%D9%88%D9%85-%D8%A7%D9%84%D8%AB%D9%84%D8%A7%D8%AB%D8%A7%D8%A1", "title": "\u0645\u0648\u0654\u0634\u0631 \u0633\u0648\u0642 \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u064a\u063a\u0644\u0642 \u0645\u0631\u062a\u0641\u0639\u0627 0.7% \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621", "description": "\u0627\u0631\u062a\u0641\u0639 \u0645\u0648\u0654\u0634\u0631 \u0633\u0648\u0642 \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a\u060c \u062a\u0627\u0633\u064a\u060c \u062a\u0639\u0627\u0645\u0644\u0627\u062a \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 \u0639\u0644\u0649 \u0627\u0631\u062a\u0641\u0627\u0639 \u0628\u0646\u0633\u0628\u0629 0.7% \u0639\u0646\u062f 10565 \u0646\u0642\u0637\u0629\u060c \u0648\u0628\u062a\u062f\u0627\u0648\u0644\u0627\u062a \u0628\u0644\u063a\u062a\u060c 5.7 \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644.\u0648\u0628\u062d\u0633\u0628 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\"\u060c \u0628\u0644\u063a\u062a \u0643\u0645\u064a\u0629 \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0627\u0644\u0645\u062a\u062f\u0627\u0648\u0644\u0629 \u0646\u062d\u0648 250.7 \u0645\u0644\u064a\u0648\u0646 \u0633\u0647\u0645\u060c \u0641\u064a\u0645\u0627 \u0628\u0644\u063a\u062a \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u0633\u0648\u0642\u064a\u0629 \u0646\u062d\u0648\u060c 9.3 \u062a\u0631\u064a\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644.\u0627\u0646\u062e\u0641\u0627\u0636 \u0627\u0654\u0633\u0647\u0645 161 \u0634\u0631\u0643\u0629\u0627\u0646\u062e\u0641\u0636\u062a \u0627\u0654\u0633\u0647\u0645 161 \u0634\u0631\u0643\u0629 \u0628\u0646\u0647\u0627\u064a\u0629 \u062a\u062f\u0627\u0648\u0644\u0627\u062a \u0627\u0644\u064a\u0648\u0645\u060c \u0641\u064a\u0645\u0627 \u0627\u0631\u062a\u0641\u0639\u062a 95\u060c \u0645\u0646 \u0628\u064a\u0646 268 \u0634\u0631\u0643\u0629 \u0645\u062f\u0631\u062c\u0629 \u0641\u064a \u0627\u0644\u0633\u0648\u0642 \u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a\u0629.\u0648\u0643\u0627\u0646\u062a \u0627\u0654\u0633\u0647\u0645 \u0634\u0631\u0643\u0627\u062a: \u064a\u0646\u0633\u0627\u0628\u060c \u0648\u0627\u0644\u063a\u0627\u0632\u060c \u0648\u0627\u0644\u0635\u0646\u0627\u0639\u0627\u062a \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u064a\u0654\u064a\u0629\u060c \u0648\u0633\u0627\u0628\u0643 \u0644\u0644\u0645\u063a\u0630\u064a\u0627\u062a \u0627\u0644\u0632\u0631\u0627\u0639\u064a\u0629\u060c \u0648\u0637\u064a\u0628\u0629\u060c \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u0627\u0631\u062a\u0641\u0627\u0639\u0627\u060c \u0641\u064a\u0645\u0627 \u0643\u0627\u0646\u062a \u0627\u0654\u0633\u0647\u0645: \u0633\u0647\u0644\u060c \u0648\u0627\u0654\u0645\u0627\u0643\u060c \u0648\u0639\u0644\u0645\u060c \u0648\u0627\u0654\u062f\u064a\u0633\u060c \u0648\u0631\u062a\u0627\u0644\u060c \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u0627\u0646\u062e\u0641\u0627\u0636\u0627.\u0627\u0644\u0633\u0648\u0642 \u0627\u0644\u0645\u0648\u0627\u0632\u064a\u0629\u0627\u0654\u063a\u0644\u0642 \u0645\u0648\u0654\u0634\u0631 \u0633\u0648\u0642 \u0627\u0644\u0627\u0654\u0633\u0