4\u0646\u0635\u0631 \u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u062d\u0627\u0633\u0645\u0629 \u0639\u0646\u062f \u0627\u0644\u062a\u0627\u0633\u0639\u0629 \u0645\u0646 \u0645\u0633\u0627\u0621 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u062e\u0645\u064a\u0633 \u0645\u0639 \u0636\u064a\u0641\u0647 \u0636\u0645\u0643 \u0627\u0644\u0630\u064a \u064a\u062a\u0648\u0644\u0649 \u0642\u064a\u0627\u062f\u062a\u0647 \u0627\u0644\u0641\u0646\u064a\u0629 \u0627\u0644\u0645\u062f\u0631\u0628 \u0627\u0644\u0628\u0631\u0627\u0632\u064a\u0644\u064a \u0641\u0627\u0628\u064a\u0648 \u0643\u0627\u0631\u064a\u0644\u064a.<br /><br />\u0648\u064a\u0648\u0627\u062c\u0647 \u0627\u0644\u0646\u0635\u0631 \u0639\u0642\u062f\u0629 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0627\u0654\u0646\u062f\u064a\u0629 \u0627\u0644\u062a\u064a \u0648\u0627\u062c\u0647\u0647\u0627 \u0648\u0643\u0627\u0646 \u064a\u064f\u062f\u0631\u0628\u0647\u0627 \u0627\u0644\u0628\u0631\u0627\u0632\u064a\u0644\u064a \u0643\u0627\u0631\u064a\u0644\u064a\u061b \u0627\u0655\u0630 \u0633\u0628\u0642 \u0648\u0648\u0627\u062c\u0647 \u0645\u0646 \u0642\u0628\u0644 \u0628\u0640 4 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u062d\u064a\u0646 \u0643\u0627\u0646 \u0645\u062f\u0631\u0628\u064b\u0627 \u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0645\u0631\u0629 \u0648\u0627\u0654\u062e\u0631\u0649 \u0645\u0639 \u0627\u0644\u0648\u062d\u062f\u0629.<br /><br />\u0648\u0644\u0645 \u064a\u0633\u062a\u0637\u0639 \u0627\u0644\u0646\u0635\u0631 \u0627\u0644\u0641\u0648\u0632 \u0641\u064a \u0627\u0654\u064a \u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0655\u0630 \u062e\u0633\u0631 \u0627\u062b\u0646\u062a\u064a\u0646 \u0648\u062a\u0639\u0627\u062f\u0644 \u0641\u064a \u0645\u062b\u0644\u0647\u0645\u0627 \u0641\u0643\u0627\u0646\u062a \u0627\u0644\u0628\u062f\u0627\u064a\u0629 \u0641\u064a \u0645\u0648\u0633\u0645 2018/19 \u062d\u064a\u0646 \u0643\u0627\u0646 \u0645\u062f\u0631\u0628\u064b\u0627 \u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0648\u062d\u062f\u0629 \u0648\u0641\u0627\u0632 \u062d\u064a\u0646\u0647\u0627 \u0628\u0647\u062f\u0641\u064a\u0646 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641 \u0636\u0645\u0646 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 (11) \u0645\u0646 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u062a\u0639\u0627\u062f\u0644 \u0641\u064a \u0645\u0628\u0627\u0631\u0627\u062a\u0647 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u062d\u064a\u0646 \u0643\u0627\u0646 \u064a\u062f\u0631\u0628 \u0641\u0631\u064a\u0642 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u062d\u064a\u0646\u0647\u0627 \u0628\u0645\u0648\u0633\u0645 20\u06309/2020 \u0628\u0627\u0644\u062c\u0648\u0644\u0629 (29) \u0645\u0646 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646.<br /><br />\u0648\u062a\u0643\u0631\u0631 \u0627\u0644\u062a\u0639\u0627\u062f\u0644 \u0641\u064a \u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062c\u0648\u0644\u0629 (15) \u0645\u0639 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0628\u0645\u0648\u0633\u0645 2020/21 \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0641\u0648\u0632 \u0641\u064a \u0627\u0653\u062e\u0631 \u0645\u0648\u0627\u062c\u0647\u0629 \u062c\u0645\u0639\u062a\u0647\u0645\u0627 \u0628\u0627\u0644\u062c\u0648\u0644\u0629 (30) \u0645\u0646 \u0627\u0644\u0645\u0648\u0633\u0645 \u0630\u0627\u062a\u0647 \u0628\u0647\u062f\u0641\u064a\u0646 \u0645\u0642\u0627\u0628\u0644 \u0647\u062f\u0641.<br /><br />\u0648\u064a\u062d\u062a\u0644 \u0641\u0631\u064a\u0642 \u0636\u0645\u0643 \u0642\u0628\u0644 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062e\u0627\u0645\u0633 \u0639\u0634\u0631 \u0628\u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0628\u0641\u0627\u0631\u0642 \u062b\u0644\u0627\u062b\u0629 \u0646\u0642\u0627\u0637 \u0639\u0646 \u0627\u0644\u062e\