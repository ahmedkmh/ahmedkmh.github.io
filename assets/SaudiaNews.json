62a\u062f\u064a\u0646.\u0648\u0642\u0627\u0644\u062a \u0641\u064a \u0628\u064a\u0627\u0646 \u0644\u0647\u0627 \u0635\u062f\u0631 \u0627\u0644\u064a\u0648\u0645: \"\u0627\u0655\u0646 \u0647\u0630\u0647 \u0627\u0644\u062c\u0647\u0648\u062f \u0627\u0644\u0645\u0628\u0627\u0631\u0643\u0629 \u0645\u0627 \u0643\u0627\u0646\u062a \u0644\u062a\u062a\u0645 \u0644\u0648\u0644\u0627 \u0641\u0636\u0644 \u0627\u0644\u0644\u0647 \u0648\u0639\u0648\u0646\u0647 \u0648\u062a\u0633\u062f\u064a\u062f\u0647\u060c \u062b\u0645 \u062d\u0631\u0635 \u0648\u0645\u062a\u0627\u0628\u0639\u0629 \u0648\u0644\u0627\u0629 \u0627\u0644\u0627\u0654\u0645\u0631 -\u0627\u0654\u064a\u062f\u0647\u0645 \u0627\u0644\u0644\u0647- \u0648\u0627\u0644\u062c\u0647\u0648\u062f \u0627\u0644\u0645\u062e\u0644\u0635\u0629 \u0627\u0644\u062a\u064a \u064a\u0628\u0630\u0644\u0647\u0627 \u0645\u0646\u0633\u0648\u0628\u0648 \u0627\u0644\u0642\u0637\u0627\u0639\u0627\u062a \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u0648\u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0643\u0627\u0641\u0629\".\u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629 \u0639\u0644\u0649 \u0627\u0654\u0645\u0646 \u0627\u0644\u0628\u0644\u0627\u062f \u0648\u0627\u0644\u0639\u0628\u0627\u062f\u0648\u0627\u0654\u0636\u0627\u0641\u062a: \"\u0627\u0655\u0646 \u0645\u0627 \u064a\u0642\u0648\u0645 \u0628\u0647 \u0627\u0654\u0628\u0646\u0627\u0648\u0654\u0646\u0627 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0648\u0646 \u0641\u064a \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0629 \u0639\u0644\u0649 \u0627\u0654\u0645\u0646 \u0627\u0644\u0628\u0644\u0627\u062f \u0648\u0627\u0644\u0639\u0628\u0627\u062f \u064a\u064f\u0639\u062f\u064f\u0651 \u0645\u0646 \u0627\u0654\u0641\u0636\u0644 \u0627\u0644\u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0635\u0627\u0644\u062d\u0629\u060c \u0648\u0645\u0646 \u0627\u0654\u062c\u0644\u0651 \u0627\u0644\u0642\u0631\u0628\u0627\u062a\u060c \u0648\u0645\u0645\u0627 \u064a\u0638\u0647\u0631 \u0627\u0654\u062b\u063