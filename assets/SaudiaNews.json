8%B1-%D8%A5%D9%86%D8%B0%D8%A7%D8%B1%D8%A7-%D8%A3%D8%AD%D9%85%D8%B1-%D9%84%D9%85%D9%88%D8%A7%D8%AC%D9%87%D8%A9-%D8%A7%D9%84%D9%81%D9%8A%D8%B6%D8%A7%D9%86%D8%A7%D8%AA-%D9%81%D9%8A-%D9%85%D9%82%D8%A7%D8%B7%D8%B9%D8%AA%D9%8A-%D8%A2%D9%86%D9%87%D9%88%D9%8A-%D9%88%D9%87%D9%88%D8%A8%D9%8A", "title": "\u0627\u0644\u0635\u064a\u0646 \u062a\u0635\u062f\u0631 \u0627\u0655\u0646\u0630\u0627\u0631\u064b\u0627 \u0627\u0654\u062d\u0645\u0631 \u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0641\u064a\u0636\u0627\u0646\u0627\u062a \u0641\u064a \u0645\u0642\u0627\u0637\u0639\u062a\u064a \u0627\u0653\u0646\u0647\u0648\u064a \u0648\u0647\u0648\u0628\u064a", "description": "<div style=\"text-align: justify;\">\u0627\u0654\u0635\u062f\u0631\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0645\u0648\u0627\u0631\u062f \u0627\u0644\u0645\u0627\u064a\u0654\u064a\u0629 \u0648\u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0648\u0637\u0646\u064a\u0629 \u0644\u0644\u0627\u0654\u0631\u0635\u0627\u062f \u0627\u0644\u062c\u0648\u064a\u0629 \u0628\u0627\u0644\u0635\u064a\u0646 \u0627\u0654\u0645\u0633 \u0627\u0655\u0646\u0630\u0627\u0631\u064b\u0627 \u0628\u0627\u0644\u0644\u0648\u0646 \u0627\u0644\u0627\u0654\u062d\u0645\u0631\u060c \u0648\u0647\u0648 \u0627\u0654\u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0645\u0646 \u0627\u0644\u0627\u0655\u0646\u0630\u0627\u0631\u060c \u0644\u0645\u0648\u0627\u062c\u0647\u0629 <a href=\"https://www.alyaum.com/articles/6663503/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AE%D9%84%D8%A7%D9%84-%D9%8A%D9%88%D9%85%D9%8A%D9%86-%D9%85%D9%82%D8%AA%D9%84-24-%D8%B4%D8%AE%D8%B5%D8%A7-%D8%A8%D8%B3%D8%A8%D8%A8-%D8%A7%D9%84%D9%81%D9%8A%D8%B6%D8%A7%D9%86%D8%A7%D8%AA-%D9%81%D9%8A-%D8%A3%D9%81%D8%BA%D8%A7%D9%86%D8%B3%D8%AA%D8%A7%D9%86\" target=\"_blank\">\u0627\u0644\u0641\u064a\u0636\u0627\u0646\u0627\u062a</a> \u0627\u0644\u0645\u0641\u0627\u062c\u064a\u0654\u0629 \u0648\u0633\u0637 \u0647\u0637\u0648\u0644 \u0627\u0654\u0645\u0637\u0627\u0631 \u063a\u0632\u064a\u0631\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0648\u0633\u0637\u0649 \u0648\u0627\u0644\u0634\u0631\u0642\u064a\u0629 \u0645\u0646 \u0627\u0644\u0635\u064a\u0646.<br /><br />\u0648\u062d\u0630\u0631\u062a \u0627\u0644\u0633\u0644\u0637\u0627\u062a \u0627\u0644\u0635\u064a\u0646\u064a\u0629 -\u0648\u0641\u0642\u064b\u0627 \u0644\u0648\u0643\u0627\u0644\u0629 \u0627\u0654\u0646\u0628\u0627\u0621 \u0627\u0644\u0635\u064a\u0646 \u0627\u0644\u062c\u062f\u064a\u062f\u0629 (\u0634\u064a\u0646\u062e\u0648\u0627)- \u0645\u0646 \u0627\u0654\u0646 \u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 \u063a\u0631\u0628\u064a \u0645\u0642\u0627\u0637\u0639\u0629 \u0627\u0653\u0646\u0647\u0648\u064a \u0648\u0634\u0631\u0642\u064a \u0645\u0642\u0627\u0637\u0639\u0629 \u0647\u0648\u0628\u064a \u062a\u0648\u0627\u062c\u0647 \u062e\u0637\u0631\u064e\u0627 \u0644\u062d\u062f\u0648\u062b<a href=\"https://www.alyaum.com/articles/6663034/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D8%B5%D8%B1%D8%B9-22-%D8%B4%D8%AE%D8%B5%D8%A7-%D9%88%D9%81%D9%82%D8%AF%D8%A7%D9%86-20-%D8%A2%D8%AE%D8%B1%D9%8A%D9%86-%D8%AC%D8%B1%D8%A7%D8%A1-%D9%81%D9%8A%D8%B6%D8%A7%D9%86%D8%A7%D8%AA-%D9%81%D9%8A-%D8%A7%D9%84%D8%B5%D9%8A%D9%86\" target=\"_blank\"> \u0641\u064a\u0636\u0627\u0646\u0627\u062a \u062c\u0628\u0644\u064a\u0629</a> \u0645\u0641\u0627\u062c\u064a\u0654\u0629\u060c \u0648\u0630\u0644\u0643 \u0645\u0646 \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062b\u0627\u0645\u0646\u0629 \u0645\u0633\u0627\u0621 \u0627\u0644\u0627\u0654\u062d\u062f \u0648\u062d\u062a\u0649 \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062b\u0627\u0645\u0646\u0629 \u0645\u0633\u0627\u0621 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u062b\u0646\u064a\u0646.<br /><br />\u0643\u0645\u0627 \u0627\u064f\u0654\u0635\u062f\u0631 \u0627\u0655\u0646\u0630\u0627\u0631 \u0628\u0627\u0644\u0644\u0648\u0646 \u0627\u0644\u0628\u0631\u062a\u0642\u0627\u0644\u064a\u060c \u0648\u0647\u0648 \u062b\u0627\u0646\u064a \u0627\u0654\u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0645\u0646 \u0627\u0644\u0627\u0655\u0646\u0630\u0627\u0631\u060c \u0644\u0627\u0654\u062c\u0632\u0627\u0621 \u0645\u0646 \u0645\u0642\u0627\u0637\u0639\u0627\u062a \u062a\u0634\u062c\u064a\u0627\u0646\u063a \u0648\u0627\u0653\u0646\u0647\u0648\u064a \u0648\u062c\u064a\u0627\u0646\u063a\u0634\u064a \u0648\u0647\u0648\u0628\u064a.</div><h2 style=\"text-align:justify\"><br />\u0639\u0627\u0635\u0641\u0629 \u0645\u0637\u0631\u064a\u0629 \u0645\u062a\u0648\u0642\u0639\u0629</h2><div style=\"text-align: justify;\"><br />\u0648\u0645\u0646 \u0627\u0644\u0645\u062a\u0648\u0642\u0639 \u0647\u0637\u0648\u0644 \u0627\u0654\u0645\u0637\u0627\u0631 \u063a\u0632\u064a\u0631\u0629 \u0627\u0655\u0644\u0649 \u063a\u0632\u064a\u0631\u0629 \u062c\u062f\u064b\u0627\u060c \u0639\u0644\u0649 \u062c\u0646\u0648\u0628\u064a \u062e\u0646\u0627\u0646 \u0648\u063a\u0631\u0628\u064a \u0648\u062c\u0646\u0648\u0628\u064a \u0627\u0653\u0646\u0647\u0648\u064a \u0648\u0634\u0645\u0627\u0644 \u063a\u0631\u0628\u064a \u0647\u0648\u0646\u0627\u0646 \u0648\u0634\u0645\u0627\u0644 \u0634\u0631\u0642\u064a \u062c\u064a\u0627\u0646\u063a\u0634\u064a \u0648\u0634\u0645\u0627\u0644 \u0634\u0631\u0642\u064a \u062a\u0634\u0648\u0646\u063a\u062a\u0634\u064a\u0646\u063a\u060c \u062d\u062a\u0649 \u0645\u0633\u0627\u0621 \u0627\u0644\u064a\u0648\u0645\u060c \u0641\u064a\u0645\u0627 \u062a\u0633\u062a\u0639\u062f \u0628\u0639\u0636 \u0627\u0644\u0645\u0646\u0627\u0637\u0642 \u0641\u064a \u062c\u0646\u0648\u0628 \u063a\u0631\u0628\u064a \u0627\u0653\u0646\u0647\u0648\u064a \u0648\u0634\u0631\u0642\u064a \u0647\u0648\u0628\u064a \u0644\u0639\u0648\u0627\u0635\u0641 \u0645\u0637\u0631\u064a\u0629 \u0634\u062f\u064a\u062f\u0629 \u0642\u062f \u062a\u0635\u0644 \u0627\u0655\u0644\u0649 \u0645\u0633\u062a\u0648\u064a\u0627\u062a \u0642\u064