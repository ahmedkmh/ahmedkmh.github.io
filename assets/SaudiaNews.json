8A%D8%AF%D8%A7%D9%86-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D8%B6%D9%8A/%D8%A7%D9%84%D8%AF%D9%88%D8%B1%D9%8A-%D8%A7%D9%84%D8%B3%D8%B9%D9%88%D8%AF%D9%8A/%D9%85%D9%88%D9%82%D9%81-%D9%85%D9%88%D8%B3%D9%89-%D8%AF%D9%8A%D9%85%D8%A8%D9%8A%D9%84%D9%8A-%D9%85%D9%86-%D9%85%D8%A8%D8%A7%D8%B1%D8%A7%D8%A9-%D8%A7%D9%84%D8%A7%D8%AA%D9%81%D8%A7%D9%82-%D9%88%D8%A7%D9%84%D8%B4%D8%A8%D8%A7%D8%A8", "title": "\u0645\u0648\u0642\u0641 \u0645\u0648\u0633\u0649 \u062f\u064a\u0645\u0628\u064a\u0644\u064a \u0645\u0646 \u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0648\u0627\u0644\u0634\u0628\u0627\u0628", "description": "\u064a\u0646\u062a\u0638\u0631 \u0627\u0644\u062c\u0647\u0627\u0632 \u0627\u0644\u0641\u0646\u064a \u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0628\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u0645\u062f\u0631\u0628 \u0633\u0639\u062f \u0627\u0644\u0634\u0647\u0631\u064a \u0646\u062a\u0627\u064a\u0654\u062c \u0627\u0644\u0641\u062d\u0648\u0635\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0629 \u0627\u0644\u062a\u064a \u062e\u0636\u0639 \u0644\u0647\u0627 \u0627\u0644\u0645\u062d\u062a\u0631\u0641 \u0627\u0644\u0641\u0631\u0646\u0633\u064a \u0628\u0635\u0641\u0648\u0641\u0647\u0645 \u0645\u0648\u0633\u0649 \u062f\u064a\u0645\u0628\u064a\u0644\u064a \u0645\u0633\u0627\u0621 \u064a\u0648\u0645 \u0627\u0654\u0645\u0633 \u0627\u0644\u0627\u0654\u062d\u062f \u0644\u062d\u0633\u0645 \u0645\u0648\u0642\u0641\u0647 \u0645\u0646 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0634\u0628\u0627\u0628 \u0627\u0644\u0645\u0642\u0628\u0644\u0629 \u0641\u064a \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646.\u0648\u0634\u0627\u0631\u0643 \u0627\u0644\u0644\u0627\u0639\u0628 \u0635\u0627\u062d\u0628 \u0627\u0644\u0640 (29) \u0639\u0627\u0645\u064b\u0627 \u0628\u0642\u0645\u064a\u0635 \u0646\u0627\u062f\u064a \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062c\u0627\u0631\u064a \u0628\u0640 (13) \u0645\u0628\u0627\u0631\u0627\u0629 \u0633\u062c\u0644 \u062e\u0644\u0627\u0644\u0647\u0627 (5) \u0627\u0654\u0647\u062f\u0627\u0641 \u0648\u0635\u0646\u0639 \u0647\u062f\u0641\u064b\u0627 \u062e\u0644\u0627\u0644 (1025) \u062f\u0642\u064a\u0642\u0629 \u0644\u0639\u0628.\u0648\u0645\u0646 \u0627\u0644\u0645\u0642\u0631\u0631 \u0627\u0654\u0646 \u064a\u0633\u062a\u0636\u064a\u0641 \u0641\u0631\u064a\u0642 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0646\u0638\u064a\u0631\u0647 \u0627\u0644\u0634\u0628\u0627\u0628 \u0639\u0646\u062f \u0627\u0644\u0639\u0627\u0634\u0631\u0629 \u0645\u0646 \u0645\u0633\u0627\u0621 \u064a\u0648\u0645 \u0627\u0644\u0633\u0628\u062a \u0627\u0644\u0645\u0642\u0628\u0644 \u0636\u0645\u0646 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 (25) \u0645\u0646 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0627\u0644\u0633\u0639\u0648\u062f\u064a.\u0648\u064a\u062d\u062a\u0644 \u0641\u0631\u064a\u0642 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0642\u0628\u0644 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0633\u0627\u0628\u0639 \u0628\u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u062f\u0648\u0631\u064a \u0631\u0648\u0634\u0646 \u0628\u0631\u0635\u064a\u062f (38) \u0646\u0642\u0637\u0629\u060c \u0641\u064a\u0645\u0627 \u064a\u062d\u062a\u0644 \u0641\u0631\u064a\u0642 \u0627\u0644\u0634\u0628\u0627\u0628 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0644\u062b \u0639\u0634\u0631 \u0628\u0631\u0635\u064a\u062f (25) \u0646\u0642\u0637\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": ["\u0627\u0644\u064a\u0648\u0645 \u0640 \u0627\u0644\u062f\u0645\u0627\u0645"], "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-03-02 01:28:00", "pubDateTZ": "UTC", "fetched_at": "2026-03-02 01:47:57", "image_url": "https://www.alyaum.com/uploads/images/2026/03/02/2865841.jpeg", "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "b56fa641e0ecde4f9ea138aa6b5d19c0", "link": "https://www.okaz.com.sa/politics/na/2238208", "title": "\u00ab\u062b\u0627\u0654\u0631\u0627\u064b\u00bb \u0644\u0645\u0642\u062a\u0644 \u062e\u0627\u0645\u0646\u064a\u0654\u064a.. \u0627\u0634\u062a\u0639\u0627\u0644 \u0627\u0644\u062c\u0628\u0647\u0629 \u0627\u0644\u0634\u0645\u0627\u0644\u064a\u0629 \u0648\u0635\u0648\u0627\u0631\u064a\u062e \u0639\u0644\u0649 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0648\u063a\u0627\u0631\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0636\u0627\u062d\u064a\u0629", "description": "\u0627\u0654\u0639\u0644\u0646 \u00ab\u062d\u0632\u0628 \u0627\u0644\u0644\u0647\u00bb \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a \u0641\u062c\u0631 \u0627\u0644\u064a\u0648\u0645 (\u0627\u0644\u0627\u062b\u0646\u064a\u0646) \u0627\u0654\u0646\u0647 \u0627\u0633\u062a\u0647\u062f\u0641 \u0628\u0635\u0648\u0627\u0631\u064a\u062e \u0646\u0648\u0639\u064a\u0629 \u0648\u0633\u0631\u0628 \u0645\u0646 \u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0627\u062a \u0645\u0648\u0642\u0639 \u00ab\u0645\u0634\u0645\u0627\u0631 \u0627\u0644\u0643\u0631\u0645\u0644\u00bb \u0644\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u0635\u0627\u0631\u0648\u062e\u064a \u0627\u0644\u062a\u0627\u0628\u0639 \u0644\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u062c\u0646\u0648\u0628 \u0645\u062f\u064a\u0646\u0629 \u062d\u064a\u0641\u0627.\u0648\u0627\u0654\u0648\u0636\u062d \u0627\u0644\u062d\u0632\u0628 \u0641\u064a \u0628\u064a\u0627\u0646 \u0627\u0654\u0646 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0646\u064f\u0641\u0630\u062a \u0645\u0646\u062a\u0635\u0641 \u0644\u064a\u0644 \u0627\u0644\u0627\u0654\u062d\u062f \u2013 \u0627\u0644\u0627\u062b\u0646\u064a\u0646 (2 \u0645\u0627\u0631\u0633 2026)\u060c \u0645\u0648\u0654\u0643\u062f\u0627\u064b \u0627\u0654\u0646 \u0627\u0644\u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u062c\u0627\u0621 \u00ab\u062b\u0627\u0654\u0631\u0627\u064b\u00bb \u0644\u0645\u0642\u062a\u0644 \u0627\u0644\u0645\u0631\u0634\u062f \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0639\u0644\u064a \u062e\u0627\u0645\u0646\u064a\u0654\u064a\u060c \u0648\u00ab\u062f\u0641\u0627\u0639\u0627\u064b \u0639\u0646 \u0644\u0628\u0646\u0627\u0646 \u0648\u0634\u0639\u0628\u0647\u00bb \u0648\u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u0627\u0644\u0631\u062f \u0639\u0644\u0649 \u0645\u0627 \u0648\u0635\u0641\u0647 \u0628\u0627\u0644\u0627\u0639\u062a\u062f\u0627\u0621\u0627\u062a \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 \u0627\u0644\u0645\u062a\u0643\u0631\u0631\u0629.\u00ab\u0631\u062f \u062a\u062d\u0630\u064a\u0631\u064a\u00bb \u0648\u00ab\u062d\u0642 \u0627\u0644\u062f\u0641\u0627\u0639\u00bb\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0644\u0628\u064a\u0627\u0646 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u0627\u063a\u062a\u064a\u0627\u0644\u0627\u062a \u0648\u0627\u0644\u0627\u0639\u062a\u062f\u0627\u0621\u0627\u062a\u060c \u0628\u062d\u0633\u0628 \u062a\u0639\u0628\u064a\u0631\u0647\u060c \u064a\u0645\u0646\u062d \u0627\u0644\u062d\u0632\u0628 \u00ab\u062d\u0642 \u0627\u0644\u0631\u062f \u0641\u064a \u0627\u0644\u0632\u0645\u0627\u0646 \u0648\u0627\u0644\u0645\u0643\u0627\u0646 \u0627\u0644\u0645\u0646\