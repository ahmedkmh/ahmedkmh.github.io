%AC%D9%86%D9%88%D8%A8-%D9%81%D8%B1%D9%86%D8%B3%D8%A7\">\u0641\u0631\u0646\u0633\u0627</a> \u0633\u062c\u0644\u062a \u062e\u0644\u0627\u0644 \u064a\u0648\u0646\u064a\u0648 2026 \u0627\u0654\u0639\u0644\u0649 \u0645\u062a\u0648\u0633\u0637 \u0644<a href=\"https://www.alyaum.com/articles/6670502/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D9%88%D8%AC%D8%A9-%D8%A7%D9%84%D8%AD%D8%B1-%D9%81%D9%8A-%D9%81%D8%B1%D9%86%D8%B3%D8%A7-%D8%AA%D8%B1%D9%81%D8%B9-%D8%AD%D8%A7%D9%84%D8%A7%D8%AA-%D8%A7%D9%84%D8%BA%D8%B1%D9%82-%D8%A5%D9%84%D9%89-%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-90-%D8%AD%D8%A7%D9%84%D8%A9\">\u062f\u0631\u062c\u0627\u062a \u0627\u0644\u062d\u0631\u0627\u0631\u0629</a> \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0634\u0647\u0631 \u0645\u0646\u0630 \u0628\u062f\u0621 \u062a\u0648\u062b\u064a\u0642 \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0627\u0654\u0631\u0635\u0627\u062f \u0627\u0644\u062c\u0648\u064a\u0629 \u0639\u0627\u0645 1947.<br /><br />\u0648\u0634\u0647\u062f\u062a \u0645\u0646\u0627\u0637\u0642 \u0639\u062f\u064a\u062f\u0629 \u0645\u0646 \u0627\u0644\u0628\u0644\u0627\u062f \u062f\u0631\u062c\u0627\u062a \u062d\u0631\u0627\u0631\u0629 \u062a\u062c\u0627\u0648\u0632\u062a 40 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629 \u062e\u0644\u0627\u0644 \u0645\u0648\u062c\u0627\u062a \u062d\u0631 \u0634\u062f\u064a\u062f\u0629.<h2>\u0645\u0648\u062c\u0629 \u0627\u0644\u062d\u0631 \u0641\u064a \u0641\u0631\u0646\u0633\u0627</h2>\u0648\u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0654\u0646 \u0645\u062a\u0648\u0633\u0637 \u062f\u0631\u062c\u0627\u062a \u0627\u0644\u062d\u0631\u0627\u0631\u0629 \u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0628\u0644\u0627\u062f \u0628\u0644\u063a 22.7 \u062f\u0631\u062c\u0629 \u0645\u064a\u0654\u0648\u064a\u0629\u060c \u0628\u0632\u064a\u0627\u062f\u0629 \u0642\u062f\u0631\u0647\u0627 3.8 \u062f\u0631\u062c\u0627\u062a \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0645\u062a\u0648\u0633\u0637 \u0627\u0644\u0641\u062a\u0631\u0629 \u0627\u0644\u0645\u0645\u062a\u062f\u0629 \u0628\u064a\u0646 \u0639\u0627\u0645\u064a 1991 \u06482020\u060c \u0645\u0627 \u064a\u062c\u0639\u0644 \u064a\u0648\u0646\u064a\u0648 2026 \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u062d\u0631\u0627\u0631\u0629 \u0641\u064a \u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0633\u062c\u0644\u0627\u062a \u0627\u0644\u0645\u0646\u0627\u062e\u064a\u0629 \u0627\u0644\u0641\u0631\u0646\u0633\u064a\u0629.<br /><br /> <br /><br />\u0643\u0627\u0646\u062a \u0627\u0654\u0639\u0644\u0646\u062a \u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0635\u062d\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0641\u064a <a href=\"https://www.alyaum.com/articles/6670629/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D8%AD%D8%B1%D8%A7%D8%A6%D9%82-%D8%A7%D9%84%D8%BA%D8%A7%D8%A8%D8%A7%D8%AA-%D8%AA%D8%AA%D8%B3%D8%A8%D8%A8-%D9%81%D9%8A-%D8%A5%D8%AC%D9%84%D8%A7%D8%A1-3000-%D8%B4%D8%AE%D8%B5-%D9%85%D9%86-%D8%AC%D9%86%D9%88%D8%A8-%D9%81%D8%B1%D9%86%D8%B3%D8%A7\" target=\"_blank\">\u0641\u0631\u0646\u0633\u0627</a>\u060c \u0627\u0631\u062a\u0641\u0627\u0639 \u0639\u062f\u062f \u0627\u0644\u0648\u0641\u064a\u0627\u062a \u0628\u0646\u0633\u0628\u0629 30% \u0641\u064a \u0627\u0644\u0628\u0644\u0627\u062f \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0645\u0646 22 \u0627\u0655\u0644\u0649 28 \u064a\u0648\u0646\u064a\u0648\u060c \u0648\u0628\u0646\u0633\u0628\u0629 62% \u0641\u064a \u0628\u0627\u0631\u064a\u0633 \u0648\u062d\u062f\u0647\u0627\u060c \u0648\u0630\u0644\u0643 \u0641\u064a \u0630\u0631\u0648\u0629 <a href=\"https://www.alyaum.com/articles/6670502/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%A7%D9%84%D9%85/%D9%85%D9%88%D8%AC%D8%A9-%D8%A7%D9%84%D8%AD%D8%B1-%D9%81%D9%8A-%D9%81%D8%B1%D9%86%D8%B3%D8%A7-%D8%AA%D8%B1%D9%81%D8%B9-%D8%AD%D8%A7%D9%84%D8%A7%D8%AA