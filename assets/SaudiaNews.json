7\u0654\u0645\u064a\u0646\u00bb \u062a\u062a\u062d\u0648\u0644 \u0644\u0644\u062e\u0633\u0627\u0631\u0629 \u0628\u064070.3 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0641\u064a 2025", "description": "\u062a\u062d\u0648\u0644\u062a \u0634\u0631\u0643\u0629 \u0627\u0644\u0635\u0642\u0631 \u0644\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u062a\u0639\u0627\u0648\u0646\u064a \u0644\u0644\u062e\u0633\u0627\u0631\u0629 \u0641\u064a 2025 \u0628\u064070.3 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644\u060c \u0645\u0642\u0627\u0628\u0644 \u0627\u0654\u0631\u0628\u0627\u062d \u0628\u064031.8 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0641\u064a 2024.\u0648\u0628\u062d\u0633\u0628 \u0628\u064a\u0627\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0644\u0649 \u0645\u0648\u0642\u0639 \"\u062a\u062f\u0627\u0648\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629\"\u060c \u064a\u0639\u0648\u062f \u0630\u0644\u0643 \u0628\u0634\u0643\u0644 \u0631\u064a\u0654\u064a\u0633\u064a \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0654\u0633\u0628\u0627\u0628 \u0627\u0644\u062a\u0627\u0644\u064a\u0629:\u2022 \u0627\u0646\u062e\u0641\u0636\u062a \u0646\u062a\u0627\u064a\u0654\u062c \u062e\u062f\u0645\u0627\u062a \u0627\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0628\u0645\u0642\u062f\u0627\u0631 100 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0646\u062a\u064a\u062c\u0629 \u0632\u064a\u0627\u062f\u0629 \u0627\u0644\u0645\u0637\u0627\u0644\u0628\u0627\u062a \u0627\u0644\u0645\u062a\u0643\u0628\u062f\u0629\u060c \u0648\u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0641 \u0628\u062a\u0643\u0627\u0644\u064a\u0641 \u0627\u0642\u062a\u0646\u0627\u0621 \u0627\u0644\u0648\u062b\u0627\u064a\u0654\u0642\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0645\u0643\u0648\u0646 \u0627\u0644\u062e\u0633\u0627\u0631\u0629 \u0641\u064a \u0642\u0637\u0627\u0639\u064a \u062a\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u0645\u0631\u0643\u0628\u0627\u062a \u0648\u0627\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u0637\u0628\u064a. \u0643\u0645\u0627 \u0627\u0646\u062e\u0641\u0636 \u062e\u0644\u0627\u0644 \u0627\u0644\u0639\u0627\u0645 \u0635\u0627\u0641\u064a \u062d\u0635\u0629 \u0627\u0644\u0641\u0627\u064a\u0654\u0636 \u0645\u0646 \u0645\u062c\u0645\u0639\u0627\u062a \u0627\u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0628\u0645\u0642\u062f\u0627\u0631 2.7 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644.\u2022 \u0627\u0646\u062e\u0641\u0636 \u062f\u062e\u0644 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u0627\u062a \u0628\u0645\u0642\u062f\u0627\u0631 5.7 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644 \u0646\u062a\u064a\u062c\u0629 \u0627\u0646\u062e\u0641\u0627\u0636 \u0645\u0639\u062f\u0644\u0627\u062a \u0627\u0644\u0639\u0648\u0627\u064a\u0654\u062f \u0639\u0644\u0649 \u0627\u0644\u0648\u062f\u0627\u064a\u0654\u0639\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0636\u0639\u0641 \u0627\u0654\u062f\u0627\u0621 \u0633\u0648\u0642 \u0627\u0644\u0627\u0654\u0633\u0647\u0645 \u0627\u0644\u0645\u062d\u0644\u064a\u0629 \u0627\u0644\u0645\u062f\u0631\u062c\u0629\u060c \u0648\u0627\u0644\u0630\u064a \u062a\u0627\u0654\u062b\u0631 \u0628\u0627\u0644\u0627\u0654\u0648\u0636\u0627\u0639 \u0627\u0644\u062c\u064a\u0648\u0633\u064a\u0627\u0633\u064a\u0629 \u062d\u0648\u0644 \u0627\u0644\u0639\u0627\u0644\u0645.\u2022 \u0627\u0631\u062a\u0641\u0639\u062a \u0627\u0644\u0645\u0635\u0627\u0631\u064a\u0641 \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u064a\u0629 \u0627\u0644\u0627\u0654\u062e\u0631\u0649 \u0628\u0645\u0642\u062f\u0627\u0631 5.9 \u0645\u0644\u064a\u0648\u0646 \u0631\u064a\u0627\u0644.\u0648\u0646\u0648\u0647\u062a \u0628\u062a\u0639\u0648\u064a\u0636 \u062c\u0632\u0621 \u0645\u0646 \u0647\u0630\u0647 \u0627\u0644\u0627\u0646\u062e\u0641\u0627\u0636\u0627\u062a \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0646\u062e\u0641\u0627\u06