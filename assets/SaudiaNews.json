\u064a\u0632 \u062c\u0648\u062f\u0629 \u0627\u0644\u062d\u064a\u0627\u0629</a> \u0648\u062a\u062d\u0633\u064a\u0646 \u0627\u0644\u0645\u0634\u0647\u062f \u0627\u0644\u062d\u0636\u0631\u064a \u0644\u0644\u0645\u062f\u064a\u0646\u0629.<br /><br />\u0648\u0627\u0654\u0648\u0636\u062d \u0631\u064a\u0654\u064a\u0633 \u0628\u0644\u062f\u064a\u0629 \u0627\u0644\u062f\u0645\u0627\u0645 \u0627\u0644\u0645\u0647\u0646\u062f\u0633 \u062d\u0627\u062a\u0645 \u0627\u0644\u063a\u0627\u0645\u062f\u064a \u0627\u0654\u0646 \u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u0646\u0641\u0630\u062a 6872 \u0632\u064a\u0627\u0631\u0629 \u0631\u0642\u0627\u0628\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0645\u0646\u0634\u0627\u0653\u062a \u0627\u0644\u062a\u062c\u0627\u0631\u064a\u0629. \u0645\u0634\u064a\u0631\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0647 <a href=\"https://www.alyaum.com/articles/6657397/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A3%D9%85%D8%A7%D9%86%D8%A9-%D8%A7%D9%84%D8%B9%D8%A7%D8%B5%D9%85%D8%A9-%D8%A7%D9%84%D9%85%D9%82%D8%AF%D8%B3%D8%A9-%D8%AA%D8%B1%D9%81%D8%B9-%D8%AC%D8%A7%D9%87%D8%B2%D9%8A%D8%A9-%D8%A7%D9%84%D8%B7%D8%B1%D9%82-%D9%88%D8%A7%D9%84%D9%85%D8%B1%D8%A7%D9%81%D9%82-%D8%A7%D8%B3%D8%AA%D8%B9%D8%AF%D8%A7%D8%AF%D8%A7-%D9%84%D9%84%D8%AD%D8%AC\" target=\"_blank\">\u0627\u0644\u062c\u0648\u0644\u0627\u062a </a>\u062a\u0627\u0654\u062a\u064a \u0636\u0645\u0646 \u0628\u0631\u0627\u0645\u062c \u0627\u0644\u0645\u062a\u0627\u0628\u0639\u0629 \u0627\u0644\u0645\u0633\u062a\u0645\u0631\u0629 \u0644\u0644\u062a\u0627\u0654\u0643\u062f \u0645\u0646 \u0627\u0644\u062a\u0632\u0627\u0645 \u0627\u0644\u0627\u0654\u0633\u0648\u0627\u0642 \u0628\u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0637\u0627\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629.<br /> <h2>\u0627\u0654\u0639\u0645\u0627\u0644 \u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u0645\u0643\u062b\u0641\u0629</h2>\u0648\u0644\u0641\u062a \u0627\u0644\u063a\u0627\u0645\u062f\u064a \u0627\u0655\u0644\u0649 \u062a\u0646\u0641\u064a\u0630 \u0633\u0644\u0633\u0644\u0629 \u0627\u0654\u0639\u0645\u0627\u0644 \u0645\u0643\u062b\u0641\u0629 \u0641\u064a <a href=\"https://www.alyaum.com/articles/6656964/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B4%D8%B1%D9%82%D9%8A%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D8%A7%D9%84%D8%AE%D9%81%D8%AC%D9%8A-%D8%A5%D8%B2%D8%A7%D9%84%D8%A9-%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-1300-%D9%85-%D9%85%D8%AE%D9%84%D9%81%D8%A7%D8%AA-%D9%88%D9%85%D8%B9%D8%A7%D9%84%D8%AC%D8%A9-%D8%A3%D9%83%D8%AB%D8%B1-%D9%85%D9%86-5-%D8%A2%D9%84%D8%A7%D9%81-%D9%85-%D9%85%D9%86-%D8%A7%D9%84%D8%B7%D8%B1%D9%82-\" target=\"_blank\">\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0646\u0638\u0627\u0641\u0629</a> \u0627\u0644\u0639\u0627\u0645\u0629\u060c \u0634\u0645\u0644\u062a \u0627\u0655\u0646\u062c\u0627\u0632 138,546 \u0639\u0645\u0644\u064a\u0629 \u0644\u062c\u0645\u0639 \u0648\u0646\u0642\u0644 \u0627\u0644\u0646\u0641\u0627\u064a\u0627\u062a.<br /><br />\u0648\u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646 \u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u0628\u0627\u0634\u0631\u062a 38,270 \u0639\u0645\u0644\u064a\u0629 \u0644\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0627\u0644\u0646\u0641\u0627\u064a\u0627\u062a \u0643\u0628\u064a\u0631\u0629 \u0627\u0644\u062d\u062c\u0645\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 35,528 \u0639\u0645\u0644\u064a\u0629 \u0644\u0631\u0641\u0639 \u0627\u0644\u0627\u0654\u0646\u0642\u0627\u0636 \u0645\u0646 \u0627\u0654\u062d\u064a\u0627\u0621 \u0627\u0644\u0645\u062f\u064a\u0646\u0629.<br /><br />\u0648\u0628\u064a\u0651\u0646\u062a \u0627\u0644\u0627\u0655\u062d\u0635\u0627\u0621\u0627\u062a \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u062a\u0646\u0641\u064a\u0630 95,032 \u0639\u0645\u0644\u064a\u0629 \u0644\u0627\u0644\u062a\u0642\u0627\u0637 \u0627\u0644\u0646\u0641\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u0628\u0639\u062b\u0631\u0629\u060c \u0645\u0627 \u064a\u0639\u0643\u0633 \u062d\u062c\u0645 \u0627\u0644\u062c\u0647\u0648\u062f \u0627\u0644\u0645\u0628\u0630\u0648\u0644\u0629 \u0644\u0644\u062d\u062f \u0645\u0646 \u0627\u0644\u0645\u0644\u0648\u062b\u0627\u062a \u0627\u0644\u0628\u0635\u0631\u064a\u0629.<h2>\u062c\u0647\u0648\u062f \u062a\u0646\u0638\u064a\u0641 \u0627\u0644\u0634\u0648\u0627\u0631\u0639 \u0648\u0627\u0644\u0637\u0631\u0642\u0627\u062a</h2>\u0648\u062a\u0632\u0627\u0645\u0646\u062a \u0647\u0630\u0647 \u0627\u0644\u062c\u0647\u0648\u062f \u0645\u0639 \u0627\u0655\u0646\u062c\u0627\u0632 5688 \u0643\u064a\u0644\u0648\u0645\u062a\u0631\u0627\u064b \u0645\u0646 \u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0643\u0646\u0633 \u0627\u0644\u0627\u0653\u0644\u064a\u060c \u06482184 \u0643\u064a\u0644\u0648\u0645\u062a\u0631\u0627\u064b \u0645\u0646 \u0627\u0644\u0643\u0646\u0633 \u0627\u0644\u064a\u062f\u0648\u064a \u0644\u0644\u0634\u0648\u0627\u0631\u0639 \u0648\u0627\u0644\u0637\u0631\u0642\u0627\u062a.<br /><br />\u0648\u0627\u0633\u062a\u0643\u0645\u0644\u062a \u0627\u0644\u0628\u0644\u062f\u064a\u0629 \u062c\u0647\u0648\u062f\u0647\u0627 \u0627\u0644\u0628\u064a\u064a\u0654\u064a\u0629 \u0639\u0628\u0631 \u062a\u0646\u0641\u064a\u0630 29,851 \u0639\u0645\u0644\u064a\u0629 \u0644\u062a\u0646\u0638\u064a\u0641 \u0648\u063a\u0633\u0644 \u0627\u0644\u062d\u0627\u0648\u064a\u0627\u062a \u0627\u0644\u0645\u0648\u0632\u0639\u0629 \u0641\u064a \u0627\u0644\u0627\u0654\u062d\u064a\u0627\u0621\u060c \u0633\u0639\u064a\u0627\u064b \u0644\u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0646\u0638\u0627\u0641\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0648\u062d\u0645\u0627\u064a\u0629 \u0635\u062d\u0629 \u0648\u0633\u0644\u0627\u0645\u0629 \u0627\u0644\u0645\u062c\u062a\u0645\u0639.<br /><br />\u0648\u0627\u0654\u0643\u062f \u0627\u0644\u0645\u0647\u0646\