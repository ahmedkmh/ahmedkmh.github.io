0655\u0644\u0649 \u0645\u0644\u0639\u0628 \u0627\u0654\u062a\u0644\u0627\u0646\u062a\u0627\u060c \u0645\u0633\u0627\u0621 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u062d\u064a\u062b \u064a\u0644\u062a\u0642\u064a \u0645\u0646\u062a\u062e\u0628 \u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627 \u0645\u0639 \u0646\u0638\u064a\u0631\u0647 \u0627\u0644\u0643\u0648\u0646\u063a\u0648 \u0627\u0644\u062f\u064a\u0645\u0642\u0631\u0627\u0637\u064a\u0629 \u0636\u0645\u0646 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u062f\u0648\u0631 \u0627\u0644\u064032 \u0645\u0646 \u0628\u0637\u0648\u0644\u0629 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026\u060c \u0641\u064a \u0645\u0648\u0627\u062c\u0647\u0629 \u064a\u0633\u0639\u0649 \u062e\u0644\u0627\u0644\u0647\u0627 \"\u0627\u0644\u0627\u0654\u0633\u0648\u062f \u0627\u0644\u062b\u0644\u0627\u062b\u0629\" \u0644\u0627\u0633\u062a\u0639\u0627\u062f\u0629 \u0628\u0631\u064a\u0642\u0647\u0645\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u062d\u0644\u0645 \"\u0627\u0644\u0641\u0647\u0648\u062f\" \u0628\u0645\u0648\u0627\u0635\u0644\u0629 \u0645\u063a\u0627\u0645\u0631\u062a\u0647\u0645 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a\u0629.<br /><br />\u0648\u0631\u063a\u0645 \u062a\u0635\u062f\u0631 \u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627 \u0645\u062c\u0645\u0648\u0639\u062a\u0647\u0627\u060c \u0641\u0627\u0655\u0646 \u0627\u0654\u062f\u0627\u0621\u0647\u0627 \u0641\u064a \u0627\u0644\u062f\u0648\u0631 \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u0645 \u064a\u0631\u0642 \u0627\u0655\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u062a\u0637\u0644\u0639\u0627\u062a\u060c \u0645\u0627 \u062f\u0641\u0639 \u0627\u0644\u0645\u062f\u0631\u0628 \u0627\u0644\u0627\u0654\u0644\u0645\u0627\u0646\u064a \u062a\u0648\u0645\u0627\u0633 \u062a\u0648\u062e\u064a\u0644 \u0627\u0655\u0644\u0649 \u0645\u0637\u0627\u0644\u0628\u0629 \u0644\u0627\u0639\u0628\u064a\u0647 \u0628\u0631\u0641\u0639 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0645\u0639 \u0627\u0646\u0637\u0644\u0627\u0642 \u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0627\u0644\u0627\u0655\u0642\u0635\u0627\u064a\u0654\u064a\u0629\u060c \u0627\u0644\u062a\u064a \u0644\u0627 \u062a\u0642\u0628\u0644 \u0627\u0654\u0646\u0635\u0627\u0641 \u0627\u0644\u062d\u0644\u0648\u0644.<br /><br />\u0648\u064a\u0639\u0648\u0644 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a \u0639\u0644\u0649 \u0647\u062f\u0627\u0641\u0647 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a \u0641\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 \u0647\u0627\u0631\u064a \u0643\u064a\u0646\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u062a\u0627\u0654\u0644\u0642 \u062c\u0648\u062f \u0628\u064a\u0644\u064a\u0646\u063a\u0647\u0627\u0645\u060c \u0627\u0644\u0630\u064a \u0627\u0654\u0643\u062f \u0639\u0642\u0628 \u0627\u0644\u062a\u0627\u0654\u0647\u0644 \u0627\u0654\u0646 \u0627\u0644\u0641\u0631\u064a\u0642 \u062a\u062c\u0627\u0648\u0632 \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0628\u0646\u062c\u0627\u062d\u060c \u0648\u0627\u0654\u0646 \u0627\u0644\u0647\u062f\u0641 \u0627\u0644\u062d\u0642\u064a\u0642\u064a \u064a\u0628\u062f\u0627\u0654 \u0627\u0644\u0627\u0653\u0646 \u0641\u064a \u0637\u0631\u064a\u0642 \u0627\u0644\u0645\u0646\u0627\u0641\u0633\u0629 \u0639\u0644\u0649 \u0627\u0644\u0644\u0642\u0628.<br /><br />\u0641\u064a \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u060c \u062a\u062e\u0648\u0636 \u0627\u0644\u0643\u0648\u0646\u063a\u0648 \u0627\u0644\u062f\u064a\u0645\u0642\u0631\u0627\u0637\u064a\u0629 \u0627\u0654\u0648\u0644 \u0645\u0628\u0627\u0631\u0627\u0629 \u0641\u064a \u062a\u0627\u0631\u064a\u062e\u0647\u0627 \u0628\u0627\u0644\u0627\u0654\u062f\u0648\u0627\u0631 \u0627\u0644\u0627\u0655\u0642\u0635\u0627\u064a\u0654\u064a\u0629 \u0644\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644\