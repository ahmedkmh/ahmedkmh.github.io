u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0645\u0639\u062f\u0646 \u0627\u0644\u0627\u0654\u0635\u0641\u0631.\u0648\u0627\u0631\u062a\u0641\u0639 \u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 21\u060c \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u062a\u062f\u0627\u0648\u0644\u064b\u0627 \u0628\u064a\u0646 \u0627\u0644\u0645\u0633\u062a\u0647\u0644\u0643\u064a\u0646\u060c \u0641\u064a \u0645\u0646\u062a\u0635\u0641 \u0627\u0644\u062a\u0639\u0627\u0645\u0644\u0627\u062a\u060c \u0648\u0633\u0637 \u062a\u0631\u0642\u0628 \u0627\u0644\u0645\u0633\u062a\u062b\u0645\u0631\u064a\u0646 \u0648\u0627\u0644\u0645\u0633\u062a\u0647\u0644\u0643\u064a\u0646 \u0644\u062a\u062d\u0631\u0643\u0627\u062a \u0627\u0644\u0633\u0648\u0642.\u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 21\u0633\u062c\u0644 \u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 21 \u0641\u064a \u0645\u0635\u0631\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c 7350 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0628\u064a\u0639\u060c \u06487300 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0634\u0631\u0627\u0621.\u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 24\u0628\u0644\u063a \u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 24 \u0641\u064a \u0645\u0635\u0631\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c 8400 \u062c\u0646\u064a\u0647 \u0644\u0644\u0634\u0631\u0627\u0621\u060c \u06488343 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0628\u064a\u0639.\u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 22\u0627\u0631\u062a\u0641\u0639 \u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 22 \u0641\u064a \u0645\u0635\u0631\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 \u0627\u0655\u0644\u0649: 7700 \u062c\u0646\u064a\u0647 \u0644\u0644\u0634\u0631\u0627\u0621\u060c \u06487647.5 \u062c\u0646\u064a\u0647 \u0644\u0644\u0628\u064a\u0639.\u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 18\u0633\u062c\u0644 \u0633\u0639\u0631 \u062c\u0631\u0627\u0645 \u0627\u0644\u0630\u0647\u0628 \u0639\u064a\u0627\u0631 18 \u0641\u064a \u0645\u0635\u0631\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c 6300 \u062c\u0646\u064a\u0647 \u0644\u0644\u0634\u0631\u0627\u0621\u060c \u06486257 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0628\u064a\u0639.\u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0630\u0647\u0628 \u0627\u0644\u064a\u0648\u0645 \u0641\u064a \u0645\u0635\u0631\u0633\u062c\u0644 \u0633\u0639\u0631 \u0627\u0644\u062c\u0646\u064a\u0647 \u0627\u0644\u0630\u0647\u0628 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 \u0641\u064a \u0645\u0635\u0631\u060c 58800 \u062c\u0646\u064a\u0647 \u0644\u0644\u0634\u0631\u0627\u0621\u060c \u064858400 \u062c\u0646\u064a\u0647\u0627 \u0644\u0644\u0628\u064a\u0639.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": ["\u0627\u0644\u064a\u0648\u0645 - \u0627\u0644\u062f\u0645\u0627\u0645"], "language": "arabic", "country": ["saudi arabia"], "category": ["business"], "datatype": "news", "pubDate": "2026-03-04 10:45:00", "pubDateTZ": "UTC", "fetched_at": "2026-03-04 11:19:14", "image_url": "https://www.alyaum.com/uploads/images/2026/03/04/2869082.jpg", "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_sta