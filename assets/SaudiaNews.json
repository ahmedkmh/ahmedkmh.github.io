0639\u0644\u0649 \u0627\u0644\u0646\u0633\u0628\u0629 \u0627\u0644\u0627\u0654\u0643\u0628\u0631 \u0645\u0646\u0647\u0627 \u0628\u0646\u062d\u0648 54.1% \u0628\u0640 3,058 \u0645\u0648\u0642\u0639\u0627\u064b\u060c \u062a\u0644\u062a\u0647\u0627 \u0627\u0644\u0645\u0639\u0627\u062f\u0646 \u0627\u0644\u0641\u0644\u0632\u064a\u0629 \u0628\u0646\u0633\u0628\u0629 42.9% \u0627\u0644\u062a\u064a \u062a\u062a\u0645\u062b\u0644 \u0641\u064a 2,423 \u0645\u0648\u0642\u0639\u0627\u064b \u0641\u064a \u062d\u064a\u0646 \u0628\u0644\u063a\u062a \u0646\u0633\u0628\u0629 \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u062a\u064a \u062a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u0645\u0639\u0627\u062f\u0646 \u0641\u0644\u0632\u064a\u0629 \u0648\u0644\u0627 \u0641\u0644\u0632\u064a\u0629 \u0645\u0639\u0627\u064b 3.0% \u0628\u0640 170 \u0645\u0648\u0642\u0639\u0627\u064b.\u0648\u0628\u064a\u064e\u0651\u0646\u062a \u0627\u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0654\u0646 \u0639\u062f\u062f \u0627\u0644\u0631\u062e\u0635 \u0627\u0644\u062a\u0639\u062f\u064a\u0646\u064a\u0629 \u0627\u0644\u0635\u0627\u062f\u0631\u0629 \u0627\u0631\u062a\u0641\u0639 \u0645\u0646 1,985 \u0631\u062e\u0635\u0629 \u0641\u064a \u0639\u0627\u0645 2016 \u0627\u0655\u0644\u0649 2,401 \u0631\u062e\u0635\u0629 \u0641\u064a \u0639\u0627\u0645 2024\u060c \u0645\u0633\u062c\u0644\u0627\u064b \u0646\u0645\u0648\u0651\u0627\u064b \u062a\u0631\u0627\u0643\u0645\u064a\u0651\u0627\u064b \u0646\u0633\u0628\u062a\u0647 21% \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 2024-2016\u060c \u0627\u0655\u0630 \u0634\u0643\u064e\u0651\u0644\u062a \u0631\u062e\u0635 \u0645\u062d\u0627\u062c\u0631 \u0645\u0648\u0627\u062f \u0627\u0644\u0628\u0646\u0627\u0621 \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0627\u0654\u0643\u0628\u0631 \u0641\u064a \u0639\u0627\u0645 2024 \u0628\u0640 1,481 \u0631\u062e\u0635\u0629\u060c \u062a\u0644\u062a\u0647\u0627 \u0631\u062e\u0635 \u0627\u0644\u0643\u0634\u0641 \u0628\