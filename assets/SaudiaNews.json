8%A6%D9%8A-%D8%A7%D9%84%D9%82%D8%A7%D8%AF%D8%B3%D9%8A%D8%A9", "title": "\u062a\u0637\u0648\u0631\u0627\u062a \u0627\u0655\u0635\u0627\u0628\u0629 \u062b\u0646\u0627\u064a\u0654\u064a \u0627\u0644\u0642\u0627\u062f\u0633\u064a\u0629", "description": "\u0627\u0654\u0646\u0647\u0649 \u062b\u0646\u0627\u064a\u0654\u064a \u0641\u0631\u064a\u0642 \u0627\u0644\u0642\u0627\u062f\u0633\u064a\u0629\u060c \u0627\u0644\u0627\u0655\u064a\u0637\u0627\u0644\u064a \u0645\u0627\u062a\u064a\u0648 \u0631\u062a\u064a\u062c\u064a \u0648\u0627\u0644\u0627\u0654\u0644\u0645\u0627\u0646\u064a \u062c\u0648\u0644\u064a\u0627\u0646 \u0641\u0627\u064a\u063a\u0644 \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0645\u0646 \u0628\u0631\u0646\u0627\u0645\u062c\u0647\u0645\u0627 \u0627\u0644\u0639\u0644\u0627\u062c\u064a \u0641\u064a \u0628\u0644\u0627\u062f\u0647\u0645\u0627 \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0639\u0648\u062f\u0627 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0644\u0627\u0633\u062a\u0643\u0645\u0627\u0644 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0639\u0644\u0627\u062c\u064a \u0648\u0627\u0644\u062a\u0627\u0654\u0639\u0647\u064a\u0644\u064a.<br /><br />\u0648\u0643\u0627\u0646 \u0631\u062a\u064a\u063a\u064a \u0642\u062f \u062a\u0639\u0631\u0636 \u0644\u0643\u0633\u0631 \u0641\u064a \u0627\u0644\u0645\u0641\u0635\u0644 \u0628\u064a\u0646\u0645\u0627 \u062a\u0639\u0631\u0636 \u0641\u0627\u064a\u063a\u0644 \u0644\u0627\u0655\u0635\u0627\u0628\u0629 \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0628\u0637\u0646 \u0648\u0627\u0642\u062a\u0631\u0628 \u0645\u0646 \u0627\u0644\u062a\u0639\u0627\u0641\u064a \u0645\u0646\u0647\u0627 \u0644\u0630\u0627 \u064a\u062e\u0648\u0636 \u0627\u0644\u062b\u0646\u0627\u064a\u0654\u064a \u062a\u062f\u0631\u064a\u0628\u0627\u062a\u0647\u0645\u0627 \u0627\u0644\u0645\u0646\u0641\u0631\u062f\u0629 \u0636\u0645\u0646 \u062e\u0637\u0629 \u0627\u0644\u0639\u0644\u0627\u062c \u0627\u0644\u0645\u0648\u0636\u0648\u0639\u0629 \u0644\u0647\u0645\u0627 \u062a\u0645\u0647\u064a\u062f\u064b\u0627 \u0644\u0639\u0648\u062f\u062a\u0647\u0645\u0627 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0629 \u0627\u0644\u062c\u0645\u0627\u0639\u064a\u0629.<br /><br />\u0648\u0634\u0627\u0631\u0643 \u0631\u062a\u064a\u063a\u064a \u0628\u0642\u0645\u064a\u0635 \u0627\u0644\u0642\u0627\u062f\u0633\u064a\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062c\u0627\u0631\u064a \u0628\u0640 (31) \u0645\u0628\u0627\u0631\u0627\u0629 \u0633\u062c\u0644 \u062e\u0644\u0627\u0644\u0647\u0627 (19) \u0647\u062f\u0641\u064b\u0627 \u0648\u0635\u0646\u0639 \u062b\u0644\u0627\u062b\u0629 \u0627\u0654\u0647\u062f\u0627\u0641 \u0644\u0632\u0645\u0644\u0627\u064a\u0654\u0647 \u0628\u0648\u0627\u0642\u0639 (2635) \u062f\u0642\u064a\u0642\u0629 \u0644\u0639\u0628\u060c \u0641\u064a\u0645\u0627 \u0634\u0627\u0631\u0643 \u0641\u0627\u064a\u063a\u0644 \u0628\u0642\u0645\u064a\u0635 \u0627\u0644\u0642\u0627\u062f\u0633\u064a\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0648\u0633\u0645 \u0630\u0627\u062a\u0647 \u0628\u0640 (28) \u0645\u0628\u0627\u0631\u0627\u0629 \u0633\u062c\u0644 \u062e\u0644\u0627\u0644\u0647\u0627 \u0647\u062f\u0641\u064b\u0627 \u0648\u0635\u0646\u0639 \u0627\u0654\u0631\u0628\u0639\u0629 \u0644\u0632\u0645\u0644\u0627\u064a\u0654\u0647 \u0628\u0648\u0627\u0642\u0639(2542) \u062f\u0642\u064a\u0642\u0629 \u0644\u0639\u0628.<br /><br />\u0648\u0641\u064a \u0633\u064a\u0627\u0642 \u0627\u0653\u062e\u0631\u060c \u064a\u0648\u0627\u0635\u0644 \u0627\u0644\u0642\u0627\u062f\u0633\u064a\u0629 \u062a\u062d\u0636\u064a\u0631\u0627\u062a\u0647 \u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0646\u0627\u062f\u064a \u0627\u0644\u0641\u064a\u062d\u0627\u0621 \u064a\u0648\u0645 \u063a\u062f \u0627\u0644\u0633\u0628\u062a \u0639\u0644\u0649 \u0645\u0644\u0639\u0628 \u0645\u062f\u064a\u0646\u062