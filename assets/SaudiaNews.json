9-%D8%B4%D8%AE%D8%B5%D9%8A%D9%86-%D9%88%D8%A5%D9%86%D9%82%D8%A7%D8%B0-9-%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D8%B1%D8%B9%D8%AF%D9%8A%D8%A9-%D8%BA%D8%B2%D9%8A%D8%B1%D8%A9-%D8%AA%D8%B6%D8%B1%D8%A8-%D8%B3%D9%84%D8%B7%D9%86%D8%A9-%D8%B9%D9%85%D8%A7%D9%86", "title": "\u0648\u0641\u0627\u0629 \u0634\u062e\u0635\u064a\u0646 \u0648\u0627\u0655\u0646\u0642\u0627\u0630 9.. \u0627\u0654\u0645\u0637\u0627\u0631 \u0631\u0639\u062f\u064a\u0629 \u063a\u0632\u064a\u0631\u0629 \u062a\u0636\u0631\u0628 \u0633\u0644\u0637\u0646\u0629 \u0639\u064f\u0645\u0627\u0646", "description": "\u0644\u0642\u064a \u0634\u062e\u0635\u0627\u0646 \u0645\u0635\u0631\u0639\u0647\u0645\u0627\u060c \u0627\u0654\u0645\u0633 \u0627\u0644\u0633\u0628\u062a\u060c \u062c\u0631\u0627\u0621 <a href=\"https://www.alyaum.com/articles/6651682/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D9%85/%D9%85%D8%B5%D8%AD%D9%88%D8%A8%D8%A9-%D8%A8%D8%B3%D9%8A%D9%88%D9%84-%D9%88%D8%A8%D8%B1%D8%AF-%D9%88%D8%B5%D9%88%D8%A7%D8%B9%D9%82-%D8%AA%D9%86%D8%A8%D9%8A%D9%87-%D9%85%D9%86-%D8%A3%D9%85%D8%B7%D8%A7%D8%B1-%D8%BA%D8%B2%D9%8A%D8%B1%D8%A9-%D8%B9%D9%84%D9%89-%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D8%A8%D8%A7%D8%AD%D8%A9\">\u0627\u0644\u0627\u0654\u0645\u0637\u0627\u0631 \u0627\u0644\u0631\u0639\u062f\u064a\u0629 </a>\u0627\u0644\u063a\u0632\u064a\u0631\u0629 \u0627\u0644\u062a\u064a \u0634\u0647\u062f\u062a\u0647\u0627 \u0639\u062f\u062f \u0645\u0646 \u0645\u062d\u0627\u0641\u0638\u0627\u062a<a href=\"https://www.alyaum.com/articles/6650056/%D8%A7%D9%84%D8%A3%D8%AE%D8%A8%D8%A7%D8%B1/%D8%A7%D9%84%D8%B9%D8%B1%D8%A8/%D8%A7%D9%84%D8%A8%D8%AF%D9%8A%D9%88%D9%8A-%D9%8A%D8%A4%D9%83%D8%AF-%D8%AA%D8%B6%D8%A7%D9%85%D9%86-%D9%85%D8%AC%D9%84%D8%B3-%D8%A7%D9%84%D8%AA%D8%B9%D8%A7%D9%88%D9%86-%D9%85%D8%B9-%D8%B3%D9%84%D8%B7%D9%86%D8%A9-%D8%B9%D9%85%D8%A7%D9%86-%D9%81%D9%8A-%D8%A5%D8%AC%D8%B1%D8%A7%D8%A1%D8%A7%D8%AA-%D8%AD%D9%85%D8%A7%D9%8A%D8%A9-%D8%A3%D9%85%D9%86%D9%87%D8%A7\"> \