{"status": "success", "totalResults": 2912, "results": [{"article_id": "8a2bc139d23476ac03405561f5c44008", "link": "https://www.alweeam.com.sa/1254652/2026/%D9%85%D8%A7%D8%B0%D8%A7-%D9%8A%D8%AD%D8%AF%D8%AB-%D8%A8%D8%B9%D8%AF-%D9%82%D8%A8%D9%88%D9%84-%D8%A7%D9%84%D8%A7%D8%B9%D8%AA%D8%B1%D8%A7%D8%B6-%D8%A7%D9%84%D9%85%D8%A7%D9%84%D9%8A-%D9%81%D9%8A-%D8%AD/", "title": "\u0645\u0627\u0630\u0627 \u064a\u062d\u062f\u062b \u0628\u0639\u062f \u0642\u0628\u0648\u0644 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636 \u0627\u0644\u0645\u0627\u0644\u064a \u0641\u064a \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646\u061f", "description": "\u0627\u0654\u0643\u062f \u0628\u0631\u0646\u0627\u0645\u062c \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646 \u0627\u0654\u0646 \u062a\u0642\u062f\u064a\u0645 \u0627\u0639\u062a\u0631\u0627\u0636 \u0645\u0627\u0644\u064a \u0639\u0644\u0649 \u0642\u064a\u0645\u0629 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0645\u0633\u062a\u062d\u0642 \u0644\u0644\u062f\u0648\u0631\u0629 \u0627\u0644\u062d\u0627\u0644\u064a\u0629 \u0644\u0627 \u064a\u0648\u0654\u062b\u0631 \u0639\u0644\u0649 \u0627\u0654\u0647\u0644\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f \u0641\u064a \u0627\u0644\u062f\u0641\u0639\u0627\u062a \u0627\u0644\u0645\u0642\u0628\u0644\u0629\u060c \u0645\u0634\u062f\u062f\u064b\u0627 \u0639\u0644\u0649 \u0627\u0654\u0646 \u0645\u0633\u0627\u0631 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636 \u0627\u0644\u0645\u0627\u0644\u064a \u064a\u062e\u062a\u0644\u0641 \u0627\u0655\u062c\u0631\u0627\u064a\u0654\u064a\u064b\u0627 \u0639\u0646 \u0645\u0633\u0627\u0631 \u062f\u0631\u0627\u0633\u0629 \u0627\u0644\u0627\u0654\u0647\u0644\u064a\u0629 \u0627\u0644\u0634\u0647\u0631\u064a\u0629 \u062f\u0627\u062e\u0644 \u0627\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0627\u0655\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u0644\u0644\u0628\u0631\u0646\u0627\u0645\u062c. \u0648\u0627\u0654\u0648\u0636\u062d \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c\u060c \u0639\u0628\u0631 \u0645\u0646\u0635\u0629 \u062e\u062f\u0645\u0629 \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646\u060c \u0627\u0654\u0646 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636 \u0627\u0644\u0645\u0627\u0644\u064a \u064a\u0642\u062a\u0635\u0631 \u0639\u0644\u0649 \u0645\u0631\u0627\u062c\u0639\u0629 \u0645\u062f\u0649 \u0645\u0637\u0627\u0628\u0642\u0629 \u0642\u064a\u0645\u0629 \u0627\u0644\u0645\u0628\u0644\u063a [...]\u062a\u0645 \u0646\u0634\u0631 \u0647\u0630\u0647 \u0627\u0644\u0645\u0642\u0627\u0644\u0629 \u0645\u0627\u0630\u0627 \u064a\u062d\u062f\u062b \u0628\u0639\u062f \u0642\u0628\u0648\u0644 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636 \u0627\u0644\u0645\u0627\u0644\u064a \u0641\u064a \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646\u061f \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u064a \u0639\u0644\u064a \u0635\u062d\u064a\u0641\u0629 \u0627\u0644\u0648\u064a\u0654\u0627\u0645.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0627\u0644\u0627\u0633\u062a\u0641\u0633\u0627\u0631 \u0639\u0646 \u0627\u0644\u062f\u0639\u0645", "\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0645\u0627\u0644\u064a", "\u0627\u0644\u062a\u063a\u064a\u064a\u0631 \u0641\u064a \u0627\u0644\u062f\u062e\u0644", "\u062a\u062d\u062f\u064a\u062b \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u0627\u0644\u062a\u062d\u0642\u0642 \u0645\u0646 \u0627\u0644\u0627\u0633\u062a\u062d\u0642\u0627\u0642", "\u0645\u0631\u0627\u062c\u0639\u0629 \u0627\u0644\u062f\u0639\u0645", "\u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a \u0627\u0644\u0633\u0639\u0648\u062f\u064a", "\u0627\u0639\u062a\u0631\u0627\u0636 \u0639\u0644\u0649 \u0642\u064a\u0645\u0629 \u0627\u0644\u062f\u0639\u0645", "\u0627\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u0645\u0631\u0627\u062c\u0639\u0629 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a", "\u0623\u0647\u0644\u064a\u0629 \u0627\u0644\u062f\u0641\u0639\u0627\u062a \u0627\u0644\u0645\u0642\u0628\u0644\u0629", "\u0627\u0644\u062a\u0623\u0643\u062f \u0645\u0646 \u062d\u0627\u0644\u0629 \u0627\u0644\u062f\u0641\u0639\u0629", "\u0627\u0644\u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0646\u0635\u064a\u0629 \u0644\u0644\u062f\u0639\u0645", "\u0646\u0642\u0635 \u0642\u064a\u0645\u0629 \u0627\u0644\u062f\u0639\u0645", "\u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062f\u0639\u0645", "\u0645\u062a\u0627\u0628\u0639\u0629 \u0627\u0644\u062f\u0641\u0639\u0627\u062a \u0627\u0644\u0645\u0627\u0644\u064a\u0629", "\u062f\u0631\u0627\u0633\u0629 \u0627\u0644\u0623\u0647\u0644\u064a\u0629 \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u0627\u0644\u0627\u0633\u062a\u0639\u0644\u0627\u0645 \u0639\u0646 \u0627\u0644\u062f\u0641\u0639\u0627\u062a", "\u0627\u0644\u0635\u0631\u0641 \u0641\u064a \u0627\u0644\u062f\u0641\u0639\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629", "\u0625\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0627\u0633\u062a\u0639\u0644\u0627\u0645", "\u062f\u0645\u062c \u0627\u0644\u0645\u0628\u0627\u0644\u063a \u0627\u0644\u0645\u0633\u062a\u062d\u0642\u0629", "\u062f\u0639\u0645 \u0627\u0644\u0623\u0633\u0631 \u0645\u062a\u0648\u0633\u0637\u0629 \u0627\u0644\u062f\u062e\u0644", "\u0645\u062a\u0627\u0628\u0639\u0629 \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u0622\u0644\u064a\u0629 \u0642\u0628\u0648\u0644 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636", "\u0625\u062f\u0627\u0631\u0629 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636\u0627\u062a", "\u0645\u0631\u0627\u062c\u0639\u0629 \u0627\u0644\u0642\u064a\u0645\u0629 \u0627\u0644\u0645\u0635\u0631\u0648\u0641\u0629", "\u0627\u0644\u0625\u0641\u0635\u0627\u062d \u0639\u0646 \u0627\u0644\u062f\u062e\u0644", "\u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0634\u0647\u0631\u064a", "\u062d\u0627\u0644\u0629 \u0627\u0644\u0623\u0647\u0644\u064a\u0629 \u0627\u0644\u0634\u0647\u0631\u064a\u0629", "\u0625\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636", "\u0645\u0646\u0635\u0629 \u062e\u062f\u0645\u0629 \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646", "\u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0645\u0627\u0644\u064a \u0627\u0644\u0645\u0633\u062a\u062d\u0642", "\u0627\u0644\u0627\u0633\u062a\u0639\u0644\u0627\u0645 \u0627\u0644\u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a", "\u062a\u0623\u0643\u064a\u062f \u0627\u0644\u0623\u0647\u0644\u064a\u0629", "\u062a\u0637\u0628\u064a\u0642 \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u0639\u062f\u0645 \u062a\u0623\u062b\u064a\u0631 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636 \u0627\u0644\u0645\u0627\u0644\u064a", "\u0645\u0646\u0635\u0629 \u0625\u0644\u0643\u062a\u0631\u0648\u0646\u064a\u0629", "\u0645\u0633\u0627\u0631 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636 \u0627\u0644\u0645\u0627\u0644\u064a", "\u0646\u0638\u0627\u0645 \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646", "\u0635\u0631\u0641 \u0627\u0644\u0623\u062b\u0631 \u0627\u0644\u0631\u062c\u0639\u064a", "\u0622\u0644\u064a\u0629 \u0635\u0631\u0641 \u0627\u0644\u062f\u0639\u0645", "\u0627\u0644\u0642\u064a\u0645 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0633\u062a\u062d\u0642\u0629", "\u0628\u0648\u0627\u0628\u0629 \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u0627\u062d\u062a\u0633\u0627\u0628 \u0627\u0644\u0627\u0633\u062a\u062d\u0642\u0627\u0642", "\u0645\u0646\u0635\u0629 \u0627\u0644\u062d\u0633\u0627\u0628 \u0627\u0644\u0634\u062e\u0635\u064a", "\u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636 \u0627\u0644\u0645\u0627\u0644\u064a \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u0645\u062a\u0627\u0628\u0639\u0629 \u0637\u0644\u0628 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636", "\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646", "\u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0645\u0633\u062a\u062d\u0642", "\u0636\u0645\u0627\u0646 \u0627\u0644\u0639\u062f\u0627\u0644\u0629 \u0641\u064a \u0627\u0644\u062f\u0639\u0645", "\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0645\u0627\u0644\u064a", "\u0627\u0644\u062a\u062d\u0642\u0642 \u0645\u0646 \u062d\u0633\u0627\u0628 \u0627\u0644\u062f\u0641\u0639\u0627\u062a", "\u062a\u062d\u062f\u064a\u062b \u062d\u0627\u0644\u0629 \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f", "\u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u062f\u0639\u0645 \u0627\u0644\u0623\u0633\u0631 \u0645\u062d\u062f\u0648\u062f\u0629 \u0627\u0644\u062f\u062e\u0644", "\u0645\u0631\u0643\u0632 \u062e\u062f\u0645\u0629 \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646", "\u0645\u0631\u0627\u062c\u0639\u0629 \u0642\u064a\u0645\u0629 \u0627\u0644\u062f\u0639\u0645", "\u0627\u0633\u062a\u0641\u0633\u0627\u0631\u0627\u062a \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f\u064a\u0646", "\u062a\u0637\u0628\u064a\u0642 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636 \u0627\u0644\u0645\u0627\u0644\u064a", "\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a", "\u062a\u0639\u0644\u064a\u0645\u0627\u062a \u0628\u0631\u0646\u0627\u0645\u062c \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0648\u0627\u0637\u0646", "\u062d\u0627\u0644\u0629 \u0627\u0644\u0645\u0633\u062a\u0641\u064a\u062f \u0645\u0624\u0647\u0644", "\u062a\u0642\u062f\u064a\u0645 \u0627\u0644\u0627\u0639\u062a\u0631\u0627\u0636", "\u062a\u062d\u062f\u064a\u062b \u0631\u0642\u0645 \u0627\u0644\u062c\u0648\u0627\u0644", "\u0645\u062a\u0627\