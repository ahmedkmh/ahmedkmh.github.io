0646 \u0645\u0634\u0643\u0644\u0627\u062a \u0635\u062d\u064a\u0629 \u0645\u0633\u062a\u0645\u0631\u0629. \u0648\u0644\u0645 \u062a\u0635\u062f\u0631 \u0628\u0639\u062f \u0627\u0654\u064a \u062a\u0635\u0631\u064a\u062d\u0627\u062a \u0631\u0633\u0645\u064a\u0629 \u0645\u0646 \u0648\u0648\u062f\u0632 \u0627\u0654\u0648 \u0641\u0631\u064a\u0642\u0647 \u062d\u0648\u0644 \u0627\u0644\u062d\u0627\u062f\u062b\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629.**media[2683285]**", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0627\u0639\u062a\u0642\u0627\u0644", "\u0641\u064a", "\u0645\u0631\u0648\u0639\u0629", "\u0639\u0627\u0644\u0645", "\u0627\u0644\u063a\u0648\u0644\u0641..", "\u0628\u0639\u062f", "\u0648\u0648\u062f\u0632", "\u0635\u062f\u0645\u0629", "\u062d\u0627\u062f\u062b\u0629", "\u062a\u0627\u064a\u062c\u0631", "\u0641\u0644\u0648\u0631\u064a\u062f\u0627"], "creator": ["\u0645\u062d\u0645\u062f  \u0627\u0644\u0635\u0627\u062d\u064a"], "language": "arabic", "country": ["saudi arabia"], "category": ["top", "lifestyle"], "datatype": "news", "pubDate": "2026-03-27 23:29:03", "pubDateTZ": "UTC", "fetched_at": "2026-03-27 23:48:19", "image_url": "https://www.okaz.com.sa/okaz/uploads/images/2026/03/28/2683279.webp", "video_url": null, "source_id": "okaz", "source_name": "\u0635\u062d\u064a\u0641\u0629 \u0639\u0643\u0627\u0638", "source_priority": 124260, "source_url": "https://www.okaz.com.sa", "source_icon": "https://n.bytvi.com/okaz.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}], "nextPage": "1774654143969345211"}