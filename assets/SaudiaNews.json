4\u0645\u0627\u0646\u0634\u0633\u062a\u0631 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0645\u0627\u064a\u0643\u0644 \u0643\u0627\u0631\u064a\u0643 \u0627\u0654\u0646 \u062a\u062a\u0636\u062d \"\u062e\u0644\u0627\u0644 \u0627\u0654\u064a\u0627\u0645\" \u0645\u0639\u0627\u0644\u0645 \u0645\u0633\u062a\u0642\u0628\u0644\u0647 \u0645\u0639 \u0646\u0627\u062f\u064a \"\u0627\u0644\u0634\u064a\u0627\u0637\u064a\u0646 \u0627\u0644\u062d\u0645\u0631\"\u060c \u0648\u0633\u0637 \u062a\u0642\u0627\u0631\u064a\u0631 \u062a\u0641\u064a\u062f \u0628\u0627\u0654\u0646\u0647 \u0633\u064a\u0648\u0642\u0651\u0639 \u0639\u0642\u062f\u0627 \u0644\u0645\u062f\u0629 \u0639\u0627\u0645\u064a\u0646 \u0644\u0644\u0628\u0642\u0627\u0621 \u0645\u0639 \u062b\u0627\u0644\u062b \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645.<br /><br />\u0648\u0636\u0645\u0650\u0646 \u0641\u0648\u0632 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0639\u0644\u0649 \u0646\u0648\u062a\u0646\u063a\u0647\u0627\u0645 \u0641\u0648\u0631\u064a\u0633\u062a 3-2 \u0627\u0644\u0627\u0654\u062d\u062f \u0641\u064a \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u0633\u0627\u0628\u0639\u0629 \u0648\u0627\u0644\u062b\u0644\u0627\u062b\u064a\u0646 \u0642\u0628\u0644 \u0627\u0644\u0627\u062e\u064a\u0631\u0629\u060c \u0627\u0646\u0647\u0627\u0621\u0647 \u0627\u0644\u0645\u0648\u0633\u0645 \u0641\u064a \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0644\u062b.<br /><br />\u0648\u0645\u0646 \u0627\u0644\u0645\u0646\u062a\u0638\u0631 \u0627\u0654\u0646 \u064a\u064f\u0643\u0627\u0641\u0627\u0654 \u0643\u0627\u0631\u064a\u0643 \u0639\u0644\u0649 \u062a\u0627\u0654\u062b\u064a\u0631\u0647 \u0645\u0646\u0630 \u062a\u0648\u0644\u064a\u0647 \u0627\u0644\u0645\u0647\u0645\u0629 \u0641\u064a \u064a\u0646\u0627\u064a\u0631 \u062e\u0644\u0641\u0627 \u0644\u0644\u0628\u0631\u062a\u063a\u0627\u0644\u064a \u0631\u0648\u0628\u0646 \u0627\u0654\u0645\u0648\u0631\u064a\u0645\u060c \u0639\u0628\u0631 \u062a\u0639\u064a\u064a\u0646\u0647 \u0645\u062f\u0631\u0628\u0627 \u062f\u0627\u064a\u0654\u0645\u0627 \u0644\u0644\u0641\u0631\u064a\u0642.<br /><br />\u0648\u0642\u0627\u0644 \u0644\u0627\u0639\u0628 \u0648\u0633\u0637 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0648\u0627\u0655\u0646\u062c\u0644\u062a\u0631\u0627 \u0627\u0644\u0633\u0627\u0628\u0642 \"\u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u064a\u0627\u0645 \u0627\u0644\u0642\u0644\u064a\u0644\u0629 \u0627\u0644\u0645\u0642\u0628\u0644\u0629 \u0633\u062a\u062a\u0636\u062d \u0627\u0644\u0635\u0648\u0631\u0629. \u0627\u0644\u064a\u0648\u0645 \u0643\u0627\u0646 \u0627\u0644\u0645\u0647\u0645 \u0647\u0648 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0648\u062a\u062d\u0642\u064a\u0642 \u0627\u0644\u0646\u062a\u064a\u062c\u0629 \u0627\u0644\u0635\u062d\u064a\u062d\u0629\u060c \u0648\u0643\u0630\u0644\u0643 \u0645\u0627 \u064a\u062a\u0639\u0644\u0642 \u0628\u0628\u0639\u0636 \u0627\u0644\u0627\u0654\u0641\u0631\u0627\u062f\".<br /><br />\u0648\u0627\u0654\u0636\u0627\u0641 \"\u0645\u0647\u0645\u0627 \u0643\u0627\u0646\u062a \u0627\u0644\u0627\u0654\u062e\u0628\u0627\u0631\u060c \u0627\u0654\u0646\u0627 \u0648\u0627\u062b\u0642 \u0645\u0646 \u0627\u0654\u0646\u0643\u0645 \u0633\u062a\u0639\u0631\u0641\u0648\u0646\u0647\u0627 \u062e\u0644\u0627\u0644 \u0627\u0654\u064a\u0627\u0645\".<br /><br />\u0648\u0641\u064a \u0643\u0644\u0645\u0629 \u0648\u062c\u0651\u0647\u0647\u0627 \u0627\u0655\u0644\u0649 \u0627\u0644\u062c\u0645\u0627\u0647\u064a\u0631 \u0628\u0639\u062f \u0627\u0653\u062e\u0631 \u0645\u0628\u0627\u0631\u0627\u0629 \u0644\u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0639\u0644\u0649 \u0627\u0654\u0631\u0636\u0647 \u0647\u0630\u0627 \u0627\u0644\u0645\u0648\u0633\u0645\u060c \u0627\u0654\u0644\u0645\u062d \u0643\u0627\u0631\u064a\u0643 \u0627\u0655\u0644\u0649 \u0628\u0642\u0627\u064a\u0654\u0647 \u0641\u064a \u0645\u0646\u0635\u0628\u0647.<br /><br />\u0648\u0642\u0627\u0644 \"\u0634\u0647\u062f\u0646\u0627 \u0644\u062d\u0638\u0627\u062a \u0643\u0628\u064a\u0631\u0629 \u062c\u062f\u0627\u060c \u0648\u0627\u0654\u0647\u062f\u0627\u0641\u0627 \u0643\u0628\u064a\u0631\u0629 \u0648\u0646\u062a\u0627\u064a\u0654\u062c \u0643\u0628\u064a\u0631\u0629 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0645\u0644\u0639\u0628 \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u0634\u0647\u0631 \u0627\u0644\u0642\u0644\u064a\u0644\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629\".<br /><br />\u0648\u062a\u0627\u0628\u0639 \"\u0646\u0627\u0654\u0645\u0644 \u0627\u0654\u0646 \u064a\u0643\u0648\u0646 \u0647\u0646\u0627\u0643 \u0627\u0644\u0645\u0632\u064a\u062f \u0645\u0646\u0647\u0627\".<br /><br />\u0648\u062d\u0642\u0642 \u0643\u0627\u0631\u064a\u0643 11 \u0641\u0648\u0632\u0627 \u0641\u064a 16 \u0645\u0628\u0627\u0631\u0627\u0629 \u0642\u0627\u062f \u0641\u064a\u0647\u0627 \u0627\u0644\u0641\u0631\u064a\u0642\u060c \u0641\u0636\u0645\u0646 \u0639\u0648\u062f\u0629 \u0645\u0627\u0646\u0634\u0633\u062a\u0631 \u064a\u0648\u0646\u0627\u064a\u062a\u062f \u0627\u0655\u0644\u0649 \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0654\u0648\u0631\u0648\u0628\u0627 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u0645\u0642\u0628\u0644 \u0628\u0639\u062f \u063a\u064a\u0627\u0628 \u062f\u0627\u0645 \u0639\u0627\u0645\u064a\u0646.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["saudi arabia"], "category": ["sports"], "datatype": "news", "pubDate": "2026-05-17 16:35:00", "pubDateTZ": "UTC", "fetched_at": "2026-05-17 16:47:06", "image_url": null, "video_url": null, "source_id": "alyaum", "source_name": "Alyaum", "source_priority": 933841, "source_url": "https://www.alyaum.com", "source_icon": "https://n.bytvi.com/alyaum.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ON