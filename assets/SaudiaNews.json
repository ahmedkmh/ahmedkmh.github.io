{"status": "success", "totalResults": 3181, "results": [{"article_id": "fc867ecd2e7fe475b4fb90c3a9c6893c", "link": "https://www.alyaum.com/articles/6671103/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%BA%D8%AF%D8%A7-%D9%81%D8%AA%D8%AD-%D8%A8%D8%A7%D8%A8-%D8%A7%D9%84%D8%A7%D8%B4%D8%AA%D8%B1%D8%A7%D9%83-%D9%81%D9%8A-%D8%B5%D9%83%D9%88%D9%83-%D8%B5%D8%AD-%D8%A5%D8%B5%D8%AF%D8%A7%D8%B1-%D9%8A%D9%88%D9%84%D9%8A%D9%88-%D8%A8%D8%B9%D8%A7%D8%A6%D8%AF-46", "title": "\u063a\u062f\u064b\u0627.. \u0641\u062a\u062d \u0628\u0627\u0628 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643 \u0641\u064a \u00ab\u0635\u0643\u0648\u0643 \u0635\u062d\u00bb \u0627\u0655\u0635\u062f\u0627\u0631 \u064a\u0648\u0644\u064a\u0648 \u0628\u0639\u0627\u064a\u0654\u062f 4.6%", "description": "\u0627\u0654\u0639\u0644\u0646 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u062f\u064a\u0646 \u0639\u0646 \u0641\u062a\u062d \u0628\u0627\u0628 \u0627\u0644\u0627\u0634\u062a\u0631\u0627\u0643 \u0641\u064a \"\u0635\u0643\u0648\u0643 \u0635\u062d\" \u0627\u0644\u0627\u062f\u062e\u0627\u0631\u064a\u0629 \u0644\u0634\u0647\u0631 \u064a\u0648\u0644\u064a\u0648\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u064f\u0642\u062f\u0645 \u0644\u0644\u0645\u0633\u062a\u062b\u0645\u0631\u064a\u0646 \u0627\u0644\u0627\u0654\u0641\u0631\u0627\u062f \u0639\u0627\u064a\u0654\u062f\u064b\u0627 \u0633\u0646\u0648\u064a\u064b\u0627 \u062b\u0627\u0628\u062a\u064b\u0627 \u0628\u0646\u0633\u0628\u0629 4.60% \u0639\u0628\u0631 \u0627\u0644\u0642\u0646\u0648\u0627\u062a \u0627\u0644\u0631\u0642\u0645\u064a\u0629 \u0644\u0644\u0645\u0648\u0654\u0633\u0633\u0627\u062a \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0627\u0644\u0645\u0639\u062a\u0645\u062f\u0629.<br /><br />\u0648\u064a\u0628\u062f\u0627\u0654 \u0627\u0644\u0627\u0643\u062a\u062a\u0627\u0628 \u063a\u062f\u064b\u0627 \u0627\u0644\u0627\u0655\u062b\u0646\u064a\u0646 6 \u064a\u0648\u0644\u064a\u0648\u060c \u0648\u064a\u0633\u062a\u0645\u0631 \u062d\u062a\u0649 \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062b\u0627\u0644\u062b\u0629 \u0639\u0635\u0631\u064b\u0627 \u064a\u0648\u0645 7 \u064a\u0648\u0644\u064a\u0648\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u062f\u064a\u0646. \u0648\u0643\u0645\u0627 \u0647\u0648 \u0627\u0644\u062d\u0627\u0644 \u0641\u064a \u0627\u0644\u0627\u0655\u0635\u062f\u0627\u0631\u0627\u062a \u0627\u0644\u0633\u0627\u0628\u0642\u0629\u060c \u0641\u0627\u0655\u0646 \u0647\u0630\u0647 \u0627\u0644\u0635\u0643\u0648\u0643 \u0627\u0644\u0645\u062a\u0648\u0627\u0641\u0642\u0629 \u0645\u0639 \u0627\u0644\u0634\u0631\u064a\u0639\u0629 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629 \u0645\u064f\u0642\u0648\u0651\u0645\u0629 <a href=\"https://www.alyaum.com/articles/6671066/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%AA%D8%A8%D8%A7%D9%8A%D9%86-%D8%B3%D8%B9%D8%B1-%D8%A7%D9%84%D8%B1%D9%8A%D8%A7%D9%84-%D8%A7%D9%84%D9%8A%D9%88%D9%85-%D8%A7%D9%84%D8%A3%D8%AD%D8%AF-%D9%85%D9%82%D8%A7%D8%A8%D9%84-%D8%A7%D9%84%D8%AC%D9%86%D9%8A%D9%87-%D9%81%D9%8A-%D8%A7%D9%84%D8%A8%D9%86%D9%88%D9%83-%D8%A7%D9%84%D9%85%D8%B5%D8%B1%D9%8A%D8%A9\" target=\"_blank\">\u0628\u0627\u0644\u0631\u064a\u0627\u0644 \u0627\u0644\u0633\u0639\u0648\u062f\u064a</a>\u060c \u0648\u062a\u0633\u062a\u062d\u0642 \u0628\u0639\u062f \u0639\u0627\u0645 \u0648\u0627\u062d\u062f\u060c \u0648\u062a\u064f\u062f\u0641\u0639 \u0639\u0627\u064a\u0654\u062f\u064b\u0627 \u062b\u0627\u0628\u062a\u064b\u0627 \u0639\u0646\u062f \u0627\u0644\u0627\u0633\u062a\u062d\u0642\u0627\u0642.<br /><br />\u0648\u0627\u0654\u0639\u0644\u0646 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u062f\u064a\u0646\u060c \u0627\u0654\u0646 \u0627\u0644\u062d\u062f \u0627\u0644\u0627\u0654\u062f\u0646\u0649 \u0644\u0644\u0627\u0643\u062a\u062a\u0627\u0628 \u0647\u0648 \u0627\u0654\u0644\u0641 \u0631\u064a\u0627\u0644 \u0633\u0639\u0648\u062f\u064a (266 <a href=\"https://www.alyaum.com/articles/6671070/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%B3%D8%B9%D8%B1-%D8%A7%D9%84%D8%AF%D9%88%D9%84%D8%A7%D8%B1-%D9%85%D9%82%D8%A7%D8%A8%D9%84-%D8%A7%D9%84%D8%AC%D9%86%D9%8A%D9%87-%D8%A7%D9%84%D9%8A%D9%88%D9%85-%D8%A7%D9%84%D8%A3%D8%AD%D8%AF-%D8%A7%D9%86%D8%AE%D9%81%D8%A7%D8%B6-%D9%81%D9%8A-%D8%A7%D9%84%D8%A8%D9%86%D9%88%D9%83-%D8%A7%D9%84%D9%85%D8%B5%D8%B1%D9%8A%D8%A9\" target=\"_blank\">\u062f\u0648\u0644\u0627\u0631\u064b\u0627 </a>\u0627\u0654\u0645\u0631\u064a\u0643\u064a\u064b\u0627)\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0628\u0644\u063a \u0627\u0644\u062d\u062f \u0627\u0644\u0627\u0654\u0642\u0635\u0649 \u0644\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 200 \u0627\u0654\u0644\u0641 \u0631\u064a\u0627\u0644 \u0644\u0644\u0641\u0631\u062f.<br /><br />\u064a\u064f\u062f\u0627\u0631 \u0628\u0631\u0646\u0627\u0645\u062c \"\u0635\u062d\" \u0645\u0646 \u0642\u0650\u0628\u0644 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0645\u0627\u0644\u064a\u0629 \u0639\u0628\u0631 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u0648\u0637\u0646\u064a \u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u062f\u064a\u0646\u060c \u0648\u0647\u0648 \u0645\u0635\u0645\u0645 \u0644\u062a\u0634\u062c\u064a\u0639 \u0627\u0644\u0627\u062f\u062e\u0627\u0631 \u0627\u0644\u0634\u062e\u0635\u064a \u0648\u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0634\u0645\u0648\u0644 \u0627\u0644\u0645\u0627\u0644\u064a. \u0648\u0627\u064f\u0654\u0637\u0644\u0642 \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0636\u0645\u0646 \u0628\u0631\u0646\u0627\u0645\u062c \u062a\u0637\u0648\u064a\u0631 \u0627\u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u0645\u0627\u0644\u064a \u0644\u0631\u0648\u0654\u064a\u0629 2030\u060c \u0648\u064a\u0647\u062f\u0641 \u0627\u0655\u0644\u0649 \u0631\u0641\u0639 \u0645\u0639\u062f\u0644 \u0627\u0644\u0627\u062f\u062e\u0627\u0631 \u0627\u0644\u0648\u0637\u0646\u064a \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0655\u0644\u0649 10% \u0628\u062d\u0644\u0648\u0644 \u0639\u0627\u0645 2030.<br /><br />\u0648\u0641\u064a \u0633\u064a\u0627\u0642 \u0645\u0646\u0641\u0635\u0644\u060c \u062c\u0645\u0639\u062a \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 10.57 \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644 \u0645\u0646 \u062e\u0644\u0627\u0644 \u0627\u0655\u0635\u062f\u0627\u0631 <a href=\"https://www.alyaum.com/articles/6668809/%D8%A7%D9%84%D8%A7%D9%82%D8%AA%D8%B5%D8%A7%D8%AF/%D9%85%D8%A7%D9%84-%D9%88%D8%A3%D8%B9%D9%85%D8%A7%D9%84/%D8%B5%D9%83%D9%88%D9%83-%D8%A7%D9%84%D9%85%D9%85%D9%84%D9%83%D8%A9-%D8%A5%D8%AF%D8%A7%D8%B1%D8%A9-%D8%A7%D9%84%D8%AF%D9%8A%D9%86-%D9%8A%D9%82%D9%81%D9%84-%D8%B7%D8%B1%D8%AD-%D9%8A%D9%88%D9%86%D9%8A%D9%88-%D8%A810576-%D9%85%D9%84%D9%8A%D8%A7%D8%B1-%D8%B1%D9%8A%D8%A7%D9%84\" target=\"_blank\">\u0635\u0643\u0648\u0643 \u0645\u062d\u0644\u064a\u0629</a> \u0641\u064a \u064a\u0648\u0646\u064a\u0648\u060c \u0628\u0632\u064a\u0627\u062f\u0629 \u0642\u062f\u0631\u0647\u0627 338.6% \u0639\u0646 2.42 \u0645\u0644\u064a\u0627\u0631 \u0631\u064a\u0627\u0644 \u0641\u064a \u0645\u0627\u064a\u0648.<br /><br />\u0648\u064a\u0627\u0654\u062a\u064a \u0647\u0630\u0627 \u0627\u0644\u0627\u0655\u0635\u062f\u0627\u0631 \u0627\u0644\u0627\u0654\u062e\u064a\u0631 \u0628\u0639\u062f \u062a\u0627\u0654\u0643\u064a\u062f \u0648\u0643\u0627\u0644\u0629 \"\u0645\u0648\u062f\u064a\u0632\" \u0644\u0644\u062a\u0635\u0646\u064a\u0641 \u0627\u0644\u0627\u064a\u0654\u062a\u0645\u0627\u0646\u064a \u0627\u0644\u0633\u064a\u0627\u062f\u064a \u0644\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u06