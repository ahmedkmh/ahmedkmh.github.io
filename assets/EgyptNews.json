47\u064a\u0631 \"\u0633\u0628\u064a\u062f\" \u0631\u0633\u0627\u0644\u0629 \u0627\u0655\u0644\u0649 \u0644\u0627\u0645\u064a\u0646 \u064a\u0627\u0645\u0627\u0644 \u0646\u062c\u0645 \u0645\u0646\u062a\u062e\u0628 \u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627 \u064a\u0637\u0627\u0644\u0628\u0647 \u0628\u0627\u0644\u0641\u0648\u0632 \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0641\u064a \u0646\u0647\u0627\u064a\u0654\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026 \u062d\u062a\u0649 \u0644\u0627 \u064a\u062a\u0648\u062c \u0644\u064a\u0648\u0646\u064a\u0644 \u0645\u064a\u0633\u064a \u0628\u0627\u0644\u0643\u0627\u0654\u0633 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0641\u064a \u062a\u0627\u0631\u064a\u062e\u0647.\u0648\u062a\u0644\u0639\u0628 \u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627 \u0628\u0642\u064a\u0627\u062f\u0629 \u0644\u0627\u0645\u064a\u0646 \u064a\u0627\u0645\u0627\u0644 \u0645\u0639 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0627\u0644\u062a\u064a \u064a\u0642\u0648\u062f\u0647\u0627 \u0644\u064a\u0648\u0646\u064a\u0644 \u0645\u064a\u0633\u064a \u0641\u064a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u0629 \u0644\u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026 \u064a\u0648\u0645 19 \u064a\u0648\u0644\u064a\u0648 \u0627\u0644\u0645\u0642\u0628\u0644. \u0648\u0627\u0654\u0631\u0633\u0644 \u0633\u0628\u064a\u062f\u060c \u0627\u0644\u0645\u0639\u0631\u0648\u0641 \u0628\u0627\u0654\u0646\u0647 \u0645\u0634\u062c\u0639 \u0644\u0644\u0646\u062c\u0645 \u0627\u0644\u0628\u0631\u062a\u063a\u0627\u0644\u064a \u0643\u0631\u064a\u0633\u062a\u064a\u0627\u0646\u0648 \u0631\u0648\u0646\u0627\u0644\u062f\u0648\u060c \u0642\u0627\u0644 \u062e\u0644\u0627\u0644\u0647\u0627: \u0627\u0654\u062e\u064a \u0644\u0627\u0645\u064a\u0646 \u064a\u0627\u0645\u0627\u0644 \u0647\u0630\u0647 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0644\u0643 \u0634\u062e\u0635\u064a\u0627\u064b\u060c \u0641\u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0629 \u062a\u0642\u0639 \u0639\u0644\u0649 \u0639\u0627\u062a\u0642\u0643. \u0627\u0654\u0631\u062c\u0648\u0643 \u0641\u0632 \u0641\u064a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a\u0629 \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646.\u0648\u062e\u062a\u0645: \u0627\u0654\u0631\u062c\u0648\u0643 \u0627\u0654\u0646\u0642\u0630\u0646\u064a \u0645\u0646 \u0627\u0644\u0645\u0635\u064a\u0628\u0629\u060c \u0644\u0627 \u0627\u0654\u0639\u0631\u0641 \u0645\u0627 \u0633\u0627\u0654\u0642\u0648\u0644\u0647 \u0644\u0648 \u0641\u0627\u0632 \u0645\u064a\u0633\u064a \u0628\u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 \u0645\u0631\u0629 \u0627\u0654\u062e\u0631\u0649. \u0627\u0654\u0631\u062c\u0648\u0643 \u0627\u0654\u0646\u0642\u0630\u0646\u0627 \u0646\u062d\u0646 \u0645\u0639\u0634\u0631 \u0645\u0634\u062c\u0639\u064a \u0631\u0648\u0646\u0627\u0644\u062f\u0648 \u0645\u0646 \u0627\u0644\u0643\u0627\u0631\u062b\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0631\u0648\u0646\u0627\u0644\u062f\u0648", "\u0633\u0628\u064a\u062f", "\u0644\u0627\u0645\u064a\u0646 \u064a\u0627\u0645\u0627\u0644", "\u0625\u0633\u0628\u0627\u0646\u064a\u0627", "\u0643\u0623\u0633 \u0627\u0644\u0639\u0627\u0644\u0645", "\u0627\u0644\u0623\u0631\u062c\u0646\u062a\u064a\u0646"], "creator": ["\u0627\u0644\u0639\u0631\u0628\u064a\u0629"], "language": "arabic", "country": ["egypt"], "category": ["sports"], "datatype": "news", "pubDate": "2026-07-15 23:43:53", "pubDateTZ": "UTC", "fetched_at": "2026-07-16 04:36:29", "image_url": "https://vid.alarabiya.net/images/2026/07/16/4ca39a2d-0b8d-43a6-91f0-b2653b9b578b/4ca39a2d-0b8d-43a6-91f0-b2653b9b578b_16x9_1200x676.jpg", "video_url": null, "source_id": "alarabiya", "source_name": "Alarabiya", "source_priority": 13507, "so