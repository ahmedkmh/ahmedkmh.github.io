4a\u0654\u0645\u0629", "description": "\u0628\u062f\u0627\u0654 \u0646\u0627\u062f\u064a \u0644\u064a\u0641\u0631\u0628\u0648\u0644 \u0627\u0644\u062a\u062d\u0631\u0643 \u0628\u0642\u0648\u0629 \u0641\u064a \u0633\u0648\u0642 \u0627\u0644\u0627\u0646\u062a\u0642\u0627\u0644\u0627\u062a \u0627\u0644\u0635\u064a\u0641\u064a\u0629 \u0645\u0646 \u0627\u0654\u062c\u0644 \u062a\u0639\u0648\u064a\u0636 \u0631\u062d\u064a\u0644 \u0627\u0644\u0646\u062c\u0645 \u0627\u0644\u0645\u0635\u0631\u064a \u0645\u062d\u0645\u062f \u0635\u0644\u0627\u062d\u060c \u0627\u0644\u0630\u064a \u062e\u0627\u0636 \u0645\u0628\u0627\u0631\u0627\u062a\u0647 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0628\u0642\u0645\u064a\u0635 '\u0627\u0644\u0631\u064a\u062f\u0632' \u0645\u0639 \u0646\u0647\u0627\u064a\u0629 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a \u0627\u0644\u0645\u0645\u062a\u0627\u0632 \u0644\u0645\u0648\u0633\u0645 2025-2026. \u0648\u0628\u062d\u0633\u0628 \u0645\u0627 \u0630\u0643\u0631\u062a\u0647 \u0635\u062d\u064a\u0641\u0629 '\u062a\u0644\u064a\u062c\u0631\u0627\u0641' \u0627\u0644\u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a\u0629\u060c \u0641\u0627\u0655\u0646 \u0627\u0655\u062f\u0627\u0631\u0629 \u0644\u064a\u0641\u0631\u0628\u0648\u0644 \u062a\u0636\u0639 \u0627\u0644\u062a\u0639\u0627\u0642\u062f \u0645\u0639 \u062c\u0646\u0627\u062d \u0627\u0654\u064a\u0645\u0646 \u062c\u062f\u064a\u062f \u0639\u0644\u0649 \u0631\u0627\u0654\u0633 \u0627\u0654\u0648\u0644\u0648\u064a\u0627\u062a\u0647\u0627 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u064a\u0631\u0643\u0627\u062a\u0648 \u0627\u0644\u0645\u0642\u0628\u0644\u060c \u062d\u064a\u062b \u064a\u0639\u062f \u0627\u0644\u0627\u0655\u064a\u0641\u0648\u0627\u0631\u064a \u0627\u0644\u0634\u0627\u0628 \u064a\u0627\u0646 \u062f\u064a\u0648\u0645\u0627\u0646\u062f\u064a\u060c \u0644\u0627\u0639\u0628 \u0644\u0627\u064a\u0628\u0632\u06