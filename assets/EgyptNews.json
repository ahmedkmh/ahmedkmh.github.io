4a \u0643\u0631\u0648\u0627\u062a\u064a\u060c \u064a\u0648\u0645 \u0627\u0644\u062e\u0645\u064a\u0633: \u0641\u064a \u0627\u0644\u0633\u0646\u0648\u0627\u062a \u0627\u0644\u0642\u0644\u064a\u0644\u0629 \u0627\u0644\u0645\u0627\u0636\u064a\u0629\u060c \u0643\u0646\u062a \u0627\u0654\u0639\u0627\u0646\u064a \u0645\u0646 \u0646\u0648\u0628\u0627\u062a \u0647\u0644\u0639 \u0634\u062f\u064a\u062f\u0629 \u0628\u0645\u062c\u0631\u062f \u062f\u062e\u0648\u0644\u064a \u0627\u0644\u0645\u0644\u0639\u0628. \u0644\u0645 \u0627\u0654\u062a\u062d\u062f\u062b \u0639\u0646 \u0627\u0644\u0627\u0654\u0645\u0631 \u0645\u0646 \u0642\u0628\u0644\u060c \u0644\u0643\u0646\u0646\u064a \u0643\u0646\u062a \u0627\u0654\u0639\u0627\u0646\u064a \u0628\u0627\u0644\u0641\u0639\u0644 \u0645\u0646 \u0646\u0648\u0628\u0627\u062a \u0647\u0644\u0639 \u062d\u0627\u062f\u0629.\u0648\u0643\u0627\u0646\u062a \u0627\u0644\u0644\u0627\u0639\u0628\u0629 \u0627\u0644\u0635\u0631\u0628\u064a\u0629\u060c \u0627\u0644\u062a\u064a \u0627\u0639\u062a\u0632\u0644\u062a \u0645\u0628\u0643\u0631\u0627\u064b \u0641\u064a \u0633\u0646 29 \u0633\u0646\u0629 \u0639\u0627\u0645 2016 \u0628\u0639\u062f \u0641\u0648\u0632\u0647\u0627 \u0628\u064015 \u0644\u0642\u0628\u0627\u064b\u060c \u0645\u0646 \u0628\u064a\u0646\u0647\u0627 \u0628\u0637\u0648\u0644\u0629 \u0641\u0631\u0646\u0633\u0627 \u0627\u0644\u0645\u0641\u062a\u0648\u062d\u0629 (\u0631\u0648\u0644\u0627\u0646 \u063a\u0627\u0631\u0648\u0633)\u060c \u0627\u0655\u062d\u062f\u0649 \u0645\u0633\u0627\u0628\u0642\u0627\u062a (\u063a\u0631\u0627\u0646\u062f \u0633\u0644\u0627\u0645) \u0627\u0644\u0627\u0654\u0631\u0628\u0639 \u0627\u0644\u0643\u0628\u0631\u0649 \u0639\u0627\u0645 2008\u060c \u0648\u0648\u0635\u0648\u0644\u0647\u0627 \u0627\u0655\u0644\u0649 \u0635\u062f\u0627\u0631\u0629 \u0627\u0644\u062a\u0635\u0646\u064a\u0641 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u060c \u062a\u062e\u0641\u064a \u0633\u0631\u0627\u064b \u0648\u0631\u0627\u0621 \u0631\u0648\u062d\u