u0644\u0633\u064a\u0627\u0633\u064a\u0629 \u062f\u0627\u062e\u0644 \u0627\u0655\u064a\u0631\u0627\u0646 \u062d\u064a\u062b \u0646\u062f\u062f\u0648\u0627 \u0628\u063a\u064a\u0627\u0628 \u0627\u0644\u0634\u0641\u0627\u0641\u064a\u0629 \u062d\u0648\u0644 \u0641\u062d\u0648\u0649 \u0627\u0644\u0627\u062a\u0635\u0627\u0644\u0627\u062a \u0648\u0627\u0644\u062a\u0648\u0627\u0641\u0642\u0627\u062a \u0627\u0644\u0627\u0654\u0648\u0644\u064a\u0629 \u0628\u064a\u0646 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u064a\u0646 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u064a\u0646 \u0648\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u0628.\u0648\u0641\u064a \u0627\u0654\u0648\u0644 \u0631\u062f\u0629 \u0641\u0639\u0644\u060c \u0642\u0627\u0644 \u0639\u0645\u062f\u0629 \u0637\u0647\u0631\u0627\u0646 \u0639\u0644\u064a \u0631\u0636\u0627 \u0632\u0627\u0643\u0627\u0646\u064a\u060c \u0648\u0647\u0648 \u0645\u0646 \u0627\u0654\u0642\u0637\u0627\u0628 \"\u0627\u0644\u062a\u064a\u0627\u0631 \u0627\u0644\u0627\u0654\u0635\u0648\u0644\u064a \u0627\u0644\u0645\u062a\u0634\u062f\u062f\"\u060c \u0627\u0655\u0646\u0647 \"\u0643\u0627\u0646 \u0645\u0646 \u0627\u0644\u0645\u0641\u062a\u0631\u0636 \u0627\u0654\u0646 \u062a\u0643\u0648\u0646 \u0637\u0627\u0648\u0644\u0629 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a \u0627\u0645\u062a\u062f\u0627\u062f\u0627\u064b \u0648\u062a\u0643\u0627\u0645\u0644\u0627\u064b \u0644\u062a\u062d\u0648\u0644\u0627\u062a \u0627\u0644\u0645\u064a\u062f\u0627\u0646 \u0627\u0644\u0639\u0633\u0643\u0631\u064a. \u0648\u0627\u0655\u0630\u0627 \u0643\u0627\u0646\u062a \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a \u062a\u062c\u0631\u064a \u062a\u062d\u062a \u0627\u0655\u0634\u0631\u0627\u0641 \u0627\u0644\u0645\u0631\u0634\u062f\u060c \u064a\u0646\u0628\u063a\u064a \u0627\u062a\u062e\u0627\u063