654\u0645\u064a\u0631\u0643\u064a\u0629 \u0645\u062d\u062a\u0645\u0644\u0629. \u0648\u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0642\u062f \u062a\u0633\u062a\u0647\u062f\u0641 \u0645\u062d\u0637\u0629 \u062f\u0645\u0627\u0648\u0646\u062f \u0644\u0644\u063a\u0627\u0632 \u0641\u064a \u062c\u0646\u0648\u0628 \u0634\u0631\u0642 \u0637\u0647\u0631\u0627\u0646\u060c \u0648\u0641\u0642 \u0645\u0627 \u0646\u0642\u0644\u062a \u0635\u062d\u064a\u0641\u0629 \"\u0648\u0648\u0644 \u0633\u062a\u0631\u064a\u062a \u062c\u0648\u0631\u0646\u0627\u0644\".\u0643\u0645\u0627 \u0627\u0654\u0648\u0636\u062d\u062a \u0627\u0654\u0646\u0647 \u0627\u0655\u0630\u0627 \u0646\u0641\u0630 \u062a\u0631\u0627\u0645\u0628 \u062a\u0647\u062f\u064a\u062f\u0647 \u0628\u0645\u0647\u0627\u062c\u0645\u0629 \u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629\u060c \u0641\u0645\u0646 \u0627\u0644\u0645\u0631\u062c\u062d \u0627\u0654\u0646 \u062a\u0633\u062a\u0647\u062f\u0641 \u0627\u0644\u0636\u0631\u0628\u0627\u062a \u0645\u062d\u0637\u0627\u062a \u062a\u0648\u0644\u064a\u062f \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621 \u0645\u0646 \u0627\u0644\u063a\u0627\u0632 \u0627\u0644\u0637\u0628\u064a\u0639\u064a. \u0639\u0644\u0645\u0627\u064b \u0627\u0654\u0646 \u062d\u0648\u0627\u0644\u064a 80% \u0645\u0646 \u062a\u0648\u0644\u064a\u062f \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646 \u064a\u0627\u0654\u062a\u064a \u0645\u0646 \u0627\u0644\u063a\u0627\u0632 \u0627\u0644\u0637\u0628\u064a\u0639\u064a\u060c \u0648\u0641\u0642\u0627 \u0644\u0644\u0648\u0643\u0627\u0644\u0629 \u0627\u0644\u062f\u0648\u0644\u064a\u0629 \u0644\u0644\u0637\u0627\u0642\u0629.\u0627\u0654\u0643\u0628\u0631 \u0645\u062d\u0637\u0627\u062a \u0627\u0644\u0637\u0627\u0642\u0629\u0648\u062a\u0634\u0645\u064