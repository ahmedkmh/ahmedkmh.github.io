 "description": "\u0627\u0655\u064a\u0644\u0627\u0641 \u0645\u0646 \u0627\u0644\u0642\u062f\u0633: \u062f\u062e\u0644\u062a \u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0645\u0646\u0639\u0637\u0641\u0627\u064b \u062f\u0645\u0648\u064a\u0627\u064b \u062c\u062f\u064a\u062f\u0627\u064b \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u062b\u0646\u064a\u0646\u060c \u0628\u0639\u062f\u0645\u0627 \u0627\u0654\u0639\u0644\u0646 \u0648\u0632\u064a\u0631 \u0627\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u064a\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0643\u0627\u062a\u0633 \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u0639\u0627\u0645 \u0644\u0640 \"\u062d\u0632\u0628 \u0627\u0644\u0644\u0647\"\u060c \u0646\u0639\u064a\u0645 \u0642\u0627\u0633\u0645\u060c \u0627\u0654\u0635\u0628\u062d \u0627\u0644\u0627\u0653\u0646 \"\u0647\u062f\u0641\u0627\u064b \u0644\u0644\u062a\u0635\u0641\u064a\u0629\". \u0648\u064a\u0627\u0654\u062a\u064a \u0647\u0630\u0627 \u0627\u0644\u062a\u0647\u062f\u064a\u062f \u0627\u0644\u0645\u0628\u0627\u0634\u0631 \u0639\u0642\u0628 \u0634\u0646 \u0627\u0644\u062c\u0645\u0627\u0639\u0629 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a\u0629 \u0627\u0644\u0645\u062f\u0639\u0648\u0645\u0629 \u0645\u0646 \u0637\u0647\u0631\u0627\u0646 \u0647\u062c\u0645\u0627\u062a \u0635\u0627\u0631\u0648\u062e\u064a\u0629 \u0639\u0644\u0649 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u060c \u0648\u0635\u0641\u062a\u0647\u0627 \u0628\u0627\u0654\u0646\u0647\u0627 \"\u062b\u0627\u0654\u0631 \u0644\u0645\u0642\u062a\u0644 \u0627\u0644\u0645\u0631\u0634\u062f \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0639\u0644\u064a \u062e\u0627\u0645\u0646\u064a\u0654\u064a\"\u060c \u0641\u064a \u0627\u0654\u0648\u0644 \u062e\u0631\u0642 \u0644\u0627\u062a\u0641\u0627\u0642 \u0648\u0642\u0641 \u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631 \u0627\u0644\u0645\u0628\u0631\u0645 \u0641\u064a \u0646\u0648\u0641\u0645\u0628\u0631 2024.\u063a\u0627\u0631\u0627\u062a \u0645\u062a\u0632\u0627\u0645\u0646\u0629 \u0648\u062a\u062d\u0630\u064a\u0631 \u0645\u0646 \"\u062b\u0645\u0646 \u0628\u0627\u0647\u0638\"\u0648\u0641\u064a \u0627\u0655\u062d\u0627\u0637\u0629 \u0635\u062d\u0627\u0641\u064a\u0629 \u0639\u0627\u062c\u0644\u0629\u060c \u0627\u0654\u0643\u062f \u0627\u0644\u0645\u062a\u062d\u062f\u062b \u0628\u0627\u0633\u0645 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u060c \u0627\u0655\u064a\u0641\u064a \u062f\u064a\u0641\u0631\u064a\u0646\u060c \u0627\u0654\u0646 \u0645\u064a\u0654\u0627\u062a \u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0627\u062a \u0627\u0644\u062a\u0627\u0628\u0639\u0629 \u0644\u0633\u0644\u0627\u062d \u0627\u0644\u062c\u0648 \u062a\u0634\u0646 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u0644\u062d\u0638\u0627\u062a \u0636\u0631\u0628\u0627\u062a \u0645\u0646\u0633\u0642\u0629 \u0641\u064a \u0644\u0628\u0646\u0627\u0646 \u0648\u0627\u0655\u064a\u0631\u0627\u0646 \u0628\u0627\u0644\u062a\u0632\u0627\u0645\u0646. \u0648\u062d\u0630\u0631 \u062f\u064a\u0641\u0631\u064a\u0646 \u0627\u0644\u062d\u0632\u0628 \u0642\u0627\u064a\u0654\u0644\u0627\u064b: \"\u0628\u062f\u0627\u0654 (\u062d\u0632\u0628 \u0627\u0644\u0644\u0647) \u0644\u064a\u0644\u0629 \u0627\u0654\u0645\u0633 \u0628\u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631.. \u062d\u0630\u0631\u0646\u0627\u0647 \u0648\u0633\u064a\u062f\u0641\u0639 \u062b\u0645\u0646 \u0630\u0644\u0643 \u0628\u0627\u0647\u0638\u0627\u064b\"\u060c \u0645\u0634\u064a\u0631\u0627\u064b \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0630\u0627\u062a\u0647 \u0627\u0655\u0644\u0649 \u0639\u062f\u0645 \u0648\u062c\u0648\u062f \u062e\u0637\u0637 \u062d\u0627\u0644\u064a\u0629 \u0644\u063a\u0632\u0648 \u0628\u0631\u064a\u060c \u0631\u063a\u0645 \u0643\u062b\u0627\u0641\u0629 \u0627\u0644\u0642\u0635\u0641 \u0627\u0644\u062c\u0648\u064a \u0627\u0644\u0630\u064a \u0627\u0633\u062a\u0647\u062f\u0641 \u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0646 \u0643\u0628\u0627\u0631\u0627\u064b \u0641\u064a \u0628\u064a\u0631\u0648\u062a \u0648\u0627\u0644\u062c\u0646\u0648\u0628.\u062d\u0635\u064a\u0644\u0629 \u0627\u0644\u062f\u0645\u0627\u0621 \u0648\u0627\u0644\u0631\u062f \u0627\u0644\u0635\u0627\u0631\u0648\u062e\u064a\u0645\u064a\u062f\u0627\u0646\u064a\u0627\u064b\u060c \u0643\u0634\u0641\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0635\u062d\u0629 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a\u0629 \u0641\u064a \u062d\u0635\u064a\u0644\u0629 \u0627\u0654\u0648\u0644\u064a\u0629 \u0639\u0646 \u0633\u0642\u0648\u0637 31 \u0642\u062a\u064a\u0644\u0627\u064b \u0648149 \u062c\u0631\u064a\u062d\u0627\u064b \u062c\u0631\u0627\u0621 \u0627\u0644\u063a\u0627\u0631\u0627\u062a \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 \u0627\u0644\u062a\u064a \u0627\u0633\u062a\u0647\u062f\u0641\u062a \u0645\u0646\u0627\u0637\u0642 \u0639\u062f\u0629 \u0641\u062c\u0631 \u0627\u0644\u064a\u0648\u0645\u060c \u0645\u0646 \u0628\u064a\u0646\u0647\u0627 \u0627\u0644\u0636\u0627\u062d\u064a\u0629 \u0627\u0644\u062c\u0646\u0648\u0628\u064a\u0629 \u0644\u0628\u064a\u0631\u0648\u062a. \u0648\u0641\u064a \u0627\u0644\u0645\u0642\u0627\u0628\u0644\u060c \u0627\u0654\u0639\u0644\u0646 \"\u062d\u0632\u0628 \u0627\u0644\u0644\u0647\" \u0641\u064a \u0628\u064a\u0627\u0646 \u0631\u0633\u0645\u064a \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0645\u0648\u0642\u0639 \"\u0645\u0634\u0645\u0627\u0631 \u0627\u0644\u0643\u0631\u0645\u0644\" \u0644\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u0635\u0627\u0631\u0648\u062e\u064a \u062c\u0646\u0648\u0628 \u0645\u062f\u064a\u0646\u0629 \u062d\u064a\u0641\u0627 \u0628\u0635\u0644\u064a\u0629 \u0645\u0646 \"\u0627\u0644\u0635\u0648\u0627\u0631\u064a\u062e \u0627\u0644\u0646\u0648\u0639\u064a\u0629\" \u0648\u0633\u0631\u0628 \u0645\u0646 \u0627\u0644\u0645\u0633\u064a\u0651\u0631\u0627\u062a\u060c \u0645\u0648\u0654\u0643\u062f\u0627\u064b \u0627\u0654\u0646 \u0627\u0644\u0647\u062c\u0648\u0645 \u064a\u0627\u0654\u062a\u064a \u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u0627\u0644\u0631\u062f \u0639\u0644\u0649 \u0627\u0644\u0627\u0639\u062a\u062f\u0627\u0621\u0627\u062a \u0627\u0644\u0645\u062a\u0643\u0631\u0631\u0629 \u0648\u062f\u0641\u0627\u0639\u0627\u064b \u0639\u0646 \u0644\u0628\u0646\u0627\u0646.\u0645\u0639\u0631\u0643\u0629 \u0647\u062c\u0648\u0645\u064a\u0629 \u0648\u0627\u0654\u064a\u0627\u0645 \u0642\u062a\u0627\u0644\u064a\u0629 \u0637\u0648\u064a\u0644\u0629\u0648\u0639\u0644\u0649 \u0635\u0639\u064a\u062f \u0627\u0644\u0627\u0633\u062a\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629\u060c \u062a\u0648\u0642\u0639 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0631\u0643\u0627\u0646 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u060c \u0627\u0644\u062c\u0646\u0631\u0627\u0644 \u0627\u0655\u064a\u0627\u0644 \u0632\u0627\u0645\u064a\u0631\u060c \"\u0627\u0654\u064a\u0627\u0645\u0627\u064b \u0639\u062f\u0629 \u0645\u0646 \u0627\u0644\u0642\u062a\u0627\u0644\" \u0627\u0644\u0639\u0646\u064a\u0641. \u0648\u0627\u0654\u0643\u062f \u0632\u0627\u0645\u064a\u0631 \u0641\u064a \u0645\u0642\u0637\u0639 \u0641\u064a\u062f\u064a\u0648 \u0646\u0634\u0631\u0647 \u0627\u0644\u062c\u064a\u0634: \"\u0627\u0654\u0637\u0644\u0642\u0646\u0627 \u0645\u0639\u0631\u0643\u0629 \u0647\u062c\u0648\u0645\u064a\u0629 \u0641\u064a \u0645\u0648\u0627\u062c\u0647\u0629 (\u062d\u0632\u0628 \u0627\u0644\u0644\u0647).. \u0627\u0644\u062c\u064a\u0634 \u0644\u064a\u0633 \u0641\u064a \u0627\u0644\u062e\u0637\u0648\u0637 \u0627\u0644\u062f\u0641\u0627\u0639\u064a\u0629 \u0641\u0642\u0637 \u0628\u0644 \u064a\u0646\u0637\u0644\u0642 \u0627\u0655\u0644\u0649 \u0627\u0644\u0647\u062c\u0648\u0645\". \u0648\u064a\u0639\u062f \u0647\u0630\u0627 \u0627\u0644\u062a\u0635\u0639\u064a\u062f \u0647\u0648 \u0627\u0644\u0635\u062f\u0645\u0629 \u0627\u0644\u0627\u0654\u0643\u0628\u0631 \u0644\u0642\u0637\u0627\u0639 \u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u0627\u0655\u0642\u0644\u064a\u0645\u064a \u0645\u0646\u0630 \u0627\u0654\u0634\u0647\u0631\u060c \u062d\u064a\u062b \u0627\u0654\u0639\u0627\u062f \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0655\u0644\u0649 \"\u0627\u0644\u0645\u0631\u0628\u0639 \u0635\u0641\u0631\" \u0645\u0639 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u0636\u0631\u0628\u0627\u062a \u0627\u0644\u0645\u062a\u0632\u0627\u0645\u0646\u0629 \u0641\u064a \u0627\u0644\u0639\u0645\u0642\u064a\u0646 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a \u0648\u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u064a\u0633\u0631\u0627\u0626\u064a\u0644 \u0643\u0627\u062a\u0633", "\u063a\u0627\u0631\u0627\u062a \u0644\u0628\u0646\u0627\u0646", "\u0646\u0639\u064a\u0645 \u0642\u0627\u0633\u0645"], "creator": ["elaph"], "language": "arabic", "country": ["egypt"], "category": ["lifestyle", "top"], "datatype": "news", "pubDate": "2026-03-02 10:43:38", "pubDateTZ": "UTC", "fetched_at": "2026-03-02 12:12:04", "image_url": "https://s1.elaph.com/resources/images/AWST/2026/03/week1/ba22da48051ec022f50509213befe97f.webp", "video_url": null, "source_id": "elaph", "source_name": "Elaph", "source_priority": 197218, "source_url": "https://elaph.com", "source_icon": "https://n.bytvi.com/elaph.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "10b6bd948c4ec16628d4f3b616b7d144", "link": "https://ww