0627\u0655\u0644\u0649 \u062a\u0639\u0632\u064a\u0632 \u062d\u0636\u0648\u0631\u0647\u0627 \u0641\u064a \u0645\u0627 \u064a\u064f\u0639\u0631\u0641 \u0628\"\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0627\u0644\u0641\u064a\u0632\u064a\u0627\u064a\u0654\u064a\"\u060c \u0627\u0644\u0630\u064a \u064a\u062f\u0645\u062c \u0628\u064a\u0646 \u0627\u0644\u0628\u0631\u0645\u062c\u064a\u0627\u062a \u0648\u0627\u0644\u0627\u0653\u0644\u0627\u062a\u060c \u0641\u064a \u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0644\u0627\u0655\u0646\u062a\u0627\u062c\u064a\u0629 \u0648\u0633\u0637 \u062a\u0631\u0627\u062c\u0639 \u0639\u062f\u062f \u0627\u0644\u0633\u0643\u0627\u0646 \u0641\u064a \u0633\u0646 \u0627\u0644\u0639\u0645\u0644.\u0627\u0654\u0632\u0645\u0629 \u062f\u064a\u0645\u0648\u063a\u0631\u0627\u0641\u064a\u0629 \u062a\u062f\u0641\u0639 \u0646\u062d\u0648 \u0627\u0644\u0627\u0654\u062a\u0645\u062a\u0629\u062a\u0648\u0627\u062c\u0647 \u0627\u0644\u064a\u0627\u0628\u0627\u0646 \u062a\u062d\u062f\u064a\u064b\u0627 \u0645\u062a\u0635\u0627\u0639\u062f\u064b\u0627 \u064a\u062a\u0645\u062b\u0644 \u0641\u064a \u062a\u0642\u0644\u0635 \u0627\u0644\u0642\u0648\u0649 \u0627\u0644\u0639\u0627\u0645\u0644\u0629\u060c \u0627\u0655\u0630 \u0627\u0646\u062e\u0641\u0636 \u0639\u062f\u062f \u0627\u0644\u0633\u0643\u0627\u0646 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u0640 14 \u0639\u0644\u0649 \u0627\u0644\u062a\u0648\u0627\u0644\u064a \u0641\u064a 2024\u060c \u0641\u064a\u0645\u0627 \u064a\u0634\u0643\u0644 \u0627\u0644\u0633\u0643\u0627\u0646 \u0641\u064a \u0633\u0646 \u0627\u0644\u0639\u0645\u0644 \u0646\u062d\u0648 59.6% \u0641\u0642\u0637 \u0645\u0646 \u0627\u0644\u0627\u0655\u062c\u0645\u0627\u0644\u064a\u060c \u0645\u0639 \u062a\u0648\u0642\u0639\u0627\u062a \u0628\u0627\u0646\u062e\u0641\u0627\u0636\u0647\u0645 \u0628\u0646\u062d\u0648 15 \u0645\u0644\u064a\u0648\u0646 \u0634\u062e\u0635 \u062e\u0644\u0627\u0644 \u0627\u0644\u0639\u0642\u062f\u064a\u0646 \u0627\u0644\u0645\u0642\u0628\u0644\u064a\u0646\u060c \u0628\u062d\u0633\u0628 \u062a\u0642\u0631\u064a\u0631 \u0646\u0634\u0631\u0647 \u0645\u0648\u0642\u0639 \"\u062a\u0643 \u0643\u0631\u0627\u0646\u0634\" \u0648\u0627\u0637\u0644\u0639\u062a \u0639\u0644\u064a\u0647 \"\u0627\u0644\u0639\u0631\u0628\u064a\u0629 Business\".\u0647\u0630\u0627 \u0627\u0644\u0648\u0627\u0642\u0639 \u062f\u0641\u0639 \u0627\u0644\u0634\u0631\u0643\u0627\u062a \u0627\u0655\u0644\u0649 \u062a\u0633\u0631\u064a\u0639 \u062a\u0628\u0646\u064a \u0627\u0644\u0627\u0654\u062a\u0645\u062a\u0629\u060c \u062d\u064a\u062b \u0627\u0654\u0638\u0647\u0631\u062a \u0627\u0633\u062a\u0637\u0644\u0627\u0639\u0627\u062a \u0627\u0654\u0646 \u0646\u0642\u0635 \u0627\u0644\u0639\u0645\u0627\u0644\u0629 \u0627\u0654\u0635\u0628\u062d \u0627\u0644\u0639\u0627\u0645\u0644 \u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a \u0648\u0631\u0627\u0621 \u0627\u0644\u062a\u0648\u062c\u0647 \u0646\u062d\u0648 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a.\u0647\u062f\u0641 \u0637\u0645\u0648\u062d: 30% \u0645\u0646 \u0627\u0644\u0633\u0648\u0642 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0648\u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0633\u064a\u0627\u0642\u060c \u0627\u0654\u0639\u0644\u0646\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f \u0648\u0627\u0644\u062a\u062c\u0627\u0631\u0629 \u0648\u0627\u0644\u0635\u0646\u0627\u0639\u0629 \u0641\u064a \u0645\u0627\u0631\u0633 2026 \u062e\u0637\u0629 \u0644\u0628\u0646\u0627\u0621 \u0642\u0637\u0627\u0639 \u0645\u062d\u0644\u064a \u0642\u0648\u064a \u0641\u064a \u0645\u062c\u0627\u0644 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0627\u0644\u0641\u064a\u0632\u064a\u0627\u064a\u0654\u064a\u060c \u0645\u0639 \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u062d\u0635\u