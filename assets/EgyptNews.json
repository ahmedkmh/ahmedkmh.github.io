29 1-1 \u0641\u064a \u062a\u0648\u0631\u0648\u0646\u062a\u0648.\u0643\u0627\u0646 \u062a\u0631\u0648\u062f\u0648 \u064a\u062f\u0639\u0645 \u0634\u0631\u064a\u0643\u062a\u0647 \u0627\u0644\u0645\u063a\u0646\u064a\u0629 \u0643\u0627\u062a\u064a \u0628\u064a\u0631\u064a\u060c \u0627\u0644\u062a\u064a \u0634\u0627\u0631\u0643\u062a \u0641\u064a \u062d\u0641\u0644 \u0627\u0644\u0627\u0641\u062a\u062a\u0627\u062d \u0627\u0644\u0630\u064a \u0633\u0628\u0642 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0641\u064a \u0627\u0655\u0646\u063a\u0644\u0648\u0648\u062f\u060c \u0648\u0628\u0639\u062f \u0627\u0644\u0639\u0631\u0636\u060c \u0634\u0627\u0647\u062f \u0627\u0644\u0627\u062b\u0646\u0627\u0646 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0645\u0646 \u0645\u0642\u0635\u0648\u0631\u0629 \u062e\u0627\u0635\u0629 \u0648\u0647\u0645\u0627 \u064a\u0645\u0633\u0643\u0627\u0646 \u0628\u0627\u0654\u064a\u062f\u064a \u0628\u0639\u0636\u0647\u0645\u0627.\u0638\u0647\u0631 \u062a\u0631\u0648\u062f\u0648 (54 \u0639\u0627\u0645\u0627\u064b) \u0648\u0628\u064a\u0631\u064a (41 \u0639\u0627\u0645\u0627\u064b) \u0633\u0648\u064a\u0627\u064b \u0641\u064a \u064a\u0648\u0644\u064a\u0648 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0648\u0641\u064a \u0645\u0637\u0644\u0639 \u0627\u0644\u0639\u0627\u0645\u060c \u0627\u0654\u0639\u0644\u0646\u062a \u0628\u064a\u0631\u064a \u0639\u0646 \u0639\u0644\u0627\u0642\u062a\u0647\u0645\u0627 \u0631\u0633\u0645\u064a\u0627\u064b \u0639\u0628\u0631 \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a.\u0641\u064a \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0633\u0627\u0631 \u062a\u0631\u0648\u062f\u0648 \u0648\u0628\u064a\u0631\u064a \u0645\u0639\u0627\u064b \u0639\u0644\u0649 \u0627\u0644\u0633\u062c\u0627\u062f\u0629 \u0627\u0644\u062d\u0645\u0631\u0627\u0621 \u0644\u0627\u0654\u0648\u0644 \u0645\u0631\u0629 \u064