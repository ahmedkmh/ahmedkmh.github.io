28 \u0627\u0644\u0639\u0631\u0627\u0642\u064a\u060c \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0633\u0628\u062a\u060c \u0646\u0632\u0627\u0631 \u0627\u0653\u0645\u064a\u062f\u064a \u0631\u064a\u0654\u064a\u0633\u0627\u064b \u062c\u062f\u064a\u062f\u0627\u064b \u0644\u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0627\u0644\u0639\u0631\u0627\u0642\u060c \u062d\u0633\u0628 \"TRT\u0639\u0631\u0628\u064a\". \u0627\u0653\u0645\u064a\u062f\u064a\u060c \u0645\u0631\u0634\u062d \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0648\u0637\u0646\u064a \u0627\u0644\u0643\u0631\u062f\u0633\u062a\u0627\u0646\u064a\u060c \u062a\u0645\u0643\u0646 \u0645\u0646 \u062d\u0633\u0645 \u0627\u0644\u0633\u0628\u0627\u0642 \u0641\u064a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0645\u0646 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u062a\u0635\u0648\u064a\u062a \u0628\u062d\u0635\u0648\u0644\u0647 \u0639\u0644\u0649 \u0627\u0654\u063a\u0644\u0628\u064a\u0629 \u0633\u0627\u062d\u0642\u0629 \u0628\u0644\u063a\u062a 227 \u0635\u0648\u062a\u0627\u064b\u060c \u0645\u062a\u0641\u0648\u0642\u0627\u064b \u0628\u0641\u0627\u0631\u0642 \u0643\u0628\u064a\u0631 \u0639\u0644\u0649 \u0645\u0646\u0627\u0641\u0633\u0647 \u0627\u0644\u0645\u0633\u062a\u0642\u0644 \u0645\u062b\u0646\u0649 \u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u0630\u064a \u0646\u0627\u0644 15 \u0635\u0648\u062a\u0627\u064b \u0641\u0642\u0637. \u064a\u0627\u0654\u062a\u064a \u0635\u0639\u0648\u062f \u0627\u0653\u0645\u064a\u062f\u064a (\u0627\u0644\u0645\u0648\u0644\u0648\u062f \u0641\u064a \u062f\u0647\u0648\u0643 \u0639\u0627\u0645 1968) \u0627\u0655\u0644\u0649 \u0642\u0645\u0629 \u0627\u0644\u0647\u0631\u0645 \u0627\u0644\u0633\u064a\u0627\u062f\u064a \u0627\u0644\u0639\u0631\u0627\u0642\u064a \u062a\u062a\u0648\u064a\u062c\u0627\u064b \u0644\u0645\u0633\u064a\u0631\u0629 \u0645\u0647\u0646\u064a\u0629 \u0637\u0648\u064a\u0644\u0629 \u0642\u0636\u0627\u0647\u0627 \u0641\u064a \"\u0645\u0637\u0628\u062e \u0627\u0644\u0642\u0631\u0627\u0631\"\u061b \u062d\u064a\u062b \u0639\u0645\u0644 \u0645\u0633\u062a\u0634\u0627\u0631\u0627\u064b \u0644\u062b\u0644\u0627\u062b\u0629 \u0631\u0648\u0654\u0633\u0627\u0621 \u0633\u0627\u0628\u0642\u064a\u0646 (\u062c\u0644\u0627\u0644 \u0637\u0627\u0644\u0628\u0627\u0646\u064a\u060c \u0648\u0641\u0648\u0654\u0627\u062f \u0645\u0639\u0635\u0648\u0645\u060c \u0648\u0628\u0631\u0647\u0645 \u0635\u0627\u0644\u062d)\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0634\u063a\u0644 \u0645\u0646\u0635\u0628 \u0648\u0632\u064a\u0631 \u0627\u0644\u0628\u064a\u064a\u0654\u0629 (2022-2024). \u0648\u064a\u064f\u0646\u0638\u0631 \u0627\u0655\u0644\u0649 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u062c\u062f\u064a\u062f \u0628\u0648\u0635\u0641\u0647 \u0634\u062e\u0635\u064a\u0629 \"\u062a\u0643\u0646\u0648\u0642\u0631\u0627\u0637\u064a\u0629\" \u062a\u0645\u062a\u0644\u0643 \u062f\u0631\u0627\u064a\u0629 \u0645\u0639\u0645\u0642\u0629 \u0628\u0627\u0644\u062a\u0648\u0627\u0632\u0646\u0627\u062a \u0627\u0644\u062d\u0633\u0627\u0633\u0629 \u0628\u064a\u0646 \u0628\u063a\u062f\u0627\u062f \u0648\u0627\u0654\u0631\u0628\u064a\u0644\u060c \u0648\u0645\u0648\u0654\u0645\u0646\u0627\u064b \u0628\u0646\u0647\u062c \"\u0634\u062f\u0629 \u0627\u0644\u0648\u0631\u062f\" \u0627\u0644\u0630\u064a \u0627\u0654\u0631\u0633\u0627\u0647 \u0627\u0644\u0631\u0627\u062d\u0644 \u062c\u0644\u0627\u0644 \u0637\u0627\u0644\u0628\u0627\u0646\u064a. \u0648\u0641\u0648\u0631 \u0627\u0655\u0639\u0644\u0627\u0646 \u0627\u0644\u0646\u062a\u0627\u064a\u0654\u062c\u060c \u0627\u0654\u062f\u0649 \u0627\u0653\u0645\u064a\u062f\u064a \u0627\u0644\u064a\u0645\u064a\u0646 \u0627\u0644\u062f\u0633\u062a\u0648\u0631\u064a\u0629 \u062a\u062d\u062a \u0642\u0628\u0629 \u0627\u0644\u0628\u0631\u0644\u0645\u0627\u0646\u060c \u0644\u064a\u062a\u0648\u0644\u0649 \u0645\u0647\u0627\u0645\u0647 \u0631\u0633\u0645\u064a\u0627\u064b \u062e\u0644\u0641\u0627\u064b \u0644\u0644\u0631\u064a\u0654\u064a\u0633 \u0639\u0628\u062f \u0627\u0644\u0644\u0637\u064a\u0641 \u0631\u0634\u064a\u062f. \u0648\u0645\u0646 \u0627\u0644\u0645\u062a\u0648\u0642\u0639 \u0627\u0654\u0646 \u064a\u0628\u062f\u0627\u0654 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u062c\u062f\u064a\u062f \u0645\u0634\u0627\u0648\u0631\u0627\u062a\u0647 \u0644\u062a\u0643\u0644\u064a\u0641 \u0645\u0631\u0634\u062d \u0627\u0644\u0643\u062a\u0644\u0629 \u0627\u0644\u0646\u064a\u0627\u0628\u064a\u0629 \u0627\u0644\u0627\u0654\u0643\u062b\u0631 \u0639\u062f\u062f\u0627\u064b \u0628\u062a\u0634\u0643\u064a\u0644 \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0647\u0644\u0629 \u0627\u0644\u062f\u0633\u062a\u0648\u0631\u064a\u0629 \u0627\u0644\u0645\u062d\u062f\u062f\u0629 \u0628\u0640 15 \u064a\u0648\u0645\u0627\u064b\u060c \u0648\u0633\u0637 \u0627\u0653\u0645\u0627\u0644 \u0634\u0639\u0628\u064a\u0629 \u0628\u0627\u0654\u0646 \u064a\u0633\u0627\u0647\u0645 \u0647\u0630\u0627 \u0627\u0644\u0627\u0633\u062a\u062d\u0642\u0627\u0642 \u0641\u064a \u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0627\u0644\u0633\u064a\u0627\u0633\u064a \u0648\u0627\u0644\u0627\u0642\u062a\u0635\u0627\u062f\u064a \u0641\u064a \u0627\u0644\u0628\u0644\u0627\u062f.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0627\u0646\u062a\u062e\u0627\u0628\u0627\u062a \u0627\u0644\u0631\u0626\u0627\u0633\u0629 \u0627\u0644\u0639\u0631\u0627\u0642\u064a\u0629", "\u0631\u0626\u064a\u0633 \u0627\u0644\u0639\u0631\u0627\u0642", "\u0639\u0628\u062f \u0627\u0644\u0644\u0637\u064a\u0641 \u0631\u0634\u064a\u062f", "\u0642\u0635\u0631 \u0627\u0644\u0633\u0644\u0627\u0645", "\u0639\u0631\u0628\u064a\u0629", "\u0627\u0644\u0639\u0631\u0627\u0642", "\u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0648\u0637\u0646\u064a \u0627\u0644\u0643\u0631\u062f\u0633\u062a\u0627\u0646\u064a", "\u0627\u0644\u0628\u063