ateTZ": "UTC", "fetched_at": "2026-03-25 00:05:11", "image_url": "https://www.newarab.com/sites/default/files/styles/medium_16_9/public/2265811328.jpeg?h=199d8c1f&itok=MJCPtEzh", "video_url": null, "source_id": "newarab", "source_name": "The New Arab", "source_priority": 30292, "source_url": "https://www.newarab.com", "source_icon": "https://n.bytvi.com/newarab.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": true}, {"article_id": "40c058d5dffa3bfb54b15eb739c6a867", "link": "https://www.alarabiya.net/arab-and-world/2026/03/25/%D8%A7%D8%B3%D8%B1%D8%A7%D8%A6%D9%8A%D9%84-%D8%AA%D9%87%D8%A7%D8%AC%D9%85-%D8%A8%D9%86%D9%89-%D8%AA%D8%AD%D8%AA%D9%8A%D8%A9-%D9%81%D9%8A-%D8%B7%D9%87%D8%B1%D8%A7%D9%86-%D8%A8%D8%B9%D8%AF-%D8%A7%D8%B3%D8%AA%D9%87%D8%AF%D8%A7%D9%81-%D8%A7%D9%8A%D8%B1%D8%A7%D9%86-%D8%A7%D9%8A%D9%84%D8%A7%D8%AA", "title": "\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u062a\u0647\u0627\u062c\u0645 \u0628\u0646\u0649 \u062a\u062d\u062a\u064a\u0629 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646.. \u0648\u062f\u0641\u0639\u0629 \u0635\u0648\u0627\u0631\u064a\u062e \u062c\u062f\u064a\u062f\u0629 \u062a\u062c\u0627\u0647 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644", "description": "\u0627\u0654\u0639\u0644\u0646 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u060c \u0641\u062c\u0631 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u0627\u0654\u0646\u0647 \u0628\u062f\u0627\u0654 \u0645\u0646\u0630 \u0648\u0642\u062a \u0642\u0635\u064a\u0631 \u0645\u0648\u062c\u0629 \u062c\u062f\u064a\u062f\u0629 \u0645\u0646 \u0627\u0644\u0647\u062c\u0645\u0627\u062a \u0639\u0644\u0649 \u0628\u0646\u0649 \u062a\u062d\u062a\u064a\u0629 \u0644\u0644\u0646\u0638\u0627\u0645 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0641\u064a \u0627\u0654\u0646\u062d\u0627\u0621 \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0637\u0647\u0631\u0627\u0646.\u0648\u064a\u0627\u0654\u062a\u064a \u0627\u0655\u0639\u0644\u0627\u0646 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u0628\u0639\u062f \u0648\u0642\u062a \u0642\u0635\u064a\u0631 \u0645\u0646 \u0631\u0635\u062f \u0647\u062c\u0648\u0645 \u0635\u0627\u0631\u0648\u062e\u064a \u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0639\u0644\u0649 \u0645\u062f\u064a\u0646\u0629 \u0627\u0655\u064a\u0644\u0627\u062a \u062c\u0646\u0648\u0628 \u0627\u0644\u0628\u0644\u0627\u062f.\u0648\u0643\u0627\u0646\u062a \u0635\u0641\u0627\u0631\u0627\u062a \u0627\u0644\u0627\u0655\u0646\u0630\u0627\u0631 \u062f\u0648\u062a \u0641\u064a \u0645\u062f\u064a\u0646\u0629 \u0627\u0655\u064a\u0644\u0627\u062a \u0648\u0645\u062d\u064a\u0637\u0647\u0627 \u062c\u0646\u0648\u0628\u064a \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u060c \u0641\u062c\u0631 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u0627\u0655\u062b\u0631 \u0627\u0655\u0637\u0644\u0627\u0642 \u0631\u0634\u0642\u0629 \u0635\u0648\u0627\u0631\u064a\u062e \u0645\u0646 \u0627\u0655\u064a\u0631\u0627\u0646.\u0648\u0627\u0654\u0641\u0627\u062f\u062a \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0655\u0639\u0644\u0627\u0645 \u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0628\u0648\u0642\u0648\u0639 \u0627\u0646\u0641\u062c\u0627\u0631\u0627\u062a \u0641\u064a \u0637\u0647\u0631\u0627\u0646 \u0648\u0643\u0631\u062c \u0648\u0647\u062c\u0645\u0627\u062a \u0639\u0644\u0649 \u0645\u0633\u062a\u0648\u062f\u0639\u0627\u062a \u0639\u0633\u0643\u0631\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0635\u0646\u0627\u0639\u064a\u0629 \u0641\u064a \u0642\u0632\u0648\u064a\u0646 \u0634\u0645\u0627\u0644 \u0627\u0644\u0628\u0644\u0627\u062f.\u0643\u0645\u0627 \u0627\u0654\u0641\u0627\u062f\u062a \u0645\u0631\u0627\u0633\u0644\u0629 \"\u0627\u0644\u0639\u0631\u0628\u064a\u0629\" \u0628\u0631\u0635\u062f \u062f\u0641\u0639\u0629 \u0635\u0648\u0627\u0631\u064a\u062e \u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u062c\u062f\u064a\u062f\u0629 \u0627\u0654\u0637\u0644\u0642\u062a \u062a\u062c\u0627\u0647 \u0648\u0633\u0637 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0648\u062a\u0644 \u0627\u0654\u0628\u064a\u0628\u0648\u0627\u0654\u0639\u0644\u0646\u062a \u0627\u0644\u062c\u0628\u0647\u0629 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 \u0628\u062a\u0641\u0639\u064a\u0644 \u0635\u0641\u0627\u0631\u0627\u062a \u0627\u0644\u0627\u0655\u0646\u0630\u0627\u0631 \u0641\u064a \u0627\u0655\u064a\u0644\u0627\u062a\u060c \u0648\u0627\u0644\u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0635\u0646\u0627\u0639\u064a\u0629 \"\u0634\u062d\u0648\u0631\u064a\u062a\"\u060c \u0648\u0645\u0633\u062a\u0648\u0637\u0646\u0629 \"\u0627\u0655\u064a\u0644\u0648\u062a\" \u062c\u0646\u0648\u0628\u064a \u0627\u0644\u0628\u0644\u0627\u062f\u060c \u0639\u0642\u0628 \u0631\u0635\u062f \u0635\u0648\u0627\u0631\u064a\u062e \u0627\u0654\u0637\u0644\u0642\u062a \u0645\u0646 \u0627\u0655\u064a\u0631\u0627\u0646.\u0648\u0630\u0643\u0631\u062a \u0627\u0644\u0642\u0646\u0627\u0629 (12) \u0627\u0644\u0639\u0628\u0631\u064a\u0629 \u0627\u0644\u062e\u0627\u0635\u0629\u060c \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u0631\u0634\u0642\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0647\u064a \u0627\u0644\u062b\u0627\u0644\u062b\u0629 \u0627\u0644\u062a\u064a \u062a\u0633\u062a\u0647\u062f\u0641 \u0627\u0655\u064a\u0644\u0627\u062a\u060c \u0648\u0627\u0644 14 \u062a\u062c\u0627\u0647 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u06