627\u062a \u0627\u0644\u062f\u0648\u0631\u0629 \u0627\u0644\u0645\u0631\u0643\u0628\u0629 \u0644\u0644\u063a\u0627\u0632 (CCGT) \u0628\u0646\u0633\u0628\u0629 66%\u060c \u0644\u062a\u0635\u0644 \u0627\u0655\u0644\u0649 2157 \u062f\u0648\u0644\u0627\u0631\u064b\u0627 \u0644\u0643\u0644 \u0643\u064a\u0644\u0648\u0648\u0627\u0637 \u0645\u0646 \u0627\u0644\u0642\u062f\u0631\u0629 \u0627\u0644\u0627\u0655\u0646\u062a\u0627\u062c\u064a\u0629\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0654\u0642\u0644 \u0645\u0646 1500 \u062f\u0648\u0644\u0627\u0631 \u0641\u064a \u0639\u0627\u0645 2023\u060c \u0645\u0639 \u0632\u064a\u0627\u062f\u0629 \u0632\u0645\u0646 \u0627\u0644\u062a\u0646\u0641\u064a\u0630 \u0628\u0646\u062d\u0648 23%.\u0637\u0644\u0628 \u0645\u062a\u0632\u0627\u064a\u062f \u062a\u0642\u0648\u062f\u0647 \u0634\u0631\u0643\u0627\u062a \u0627\u0644\u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u0627\u0648\u062a\u0642\u0648\u062f \u0634\u0631\u0643\u0627\u062a \u0645\u062b\u0644 \"\u0645\u0627\u064a\u0643\u0631\u0648\u0633\u0648\u0641\u062a\" \u0648\"\u0645\u064a\u062a\u0627\" \u0645\u0648\u062c\u0629 \u0627\u0644\u0627\u0639\u062a\u0645\u0627\u062f \u0639\u0644\u0649 \u0627\u0644\u063a\u0627\u0632 \u0627\u0644\u0637\u0628\u064a\u0639\u064a\u060c \u0641\u064a \u0645\u062d\u0627\u0648\u0644\u0629 \u0644\u062a\u0644\u0628\u064a\u0629 \u0627\u0644\u0637\u0644\u0628 \u0627\u0644\u0645\u062a\u0632\u0627\u064a\u062f \u0639\u0644\u0649 \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0621 \u0644\u062a\u0634\u063a\u064a\u0644 \u0645\u0631\u0627\u0643\u0632 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a\u060c \u062e\u0627\u0635\u0629 \u0645\u0639 \u0627\u0644\u062a\u0648\u0633\u0639 \u0627\u0644\u0633\u0631\u064a\u0639 \u0641\u064a \u062a\u0642\u0646\u064a\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a\u060c \u0628\u062d\u0633\u0628 \u062a\u0642\u0631\u064a\u0631 \u0646\u0634\u0631\u0647 \u0645\u0648\u0642\u06