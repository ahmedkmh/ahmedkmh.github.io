\u0643\u0628\u064a\u0631\u0629 \u0641\u064a \u0627\u0644\u062a\u0645\u0648\u064a\u0644\u060c \u0648\u062a\u0631\u0627\u062c\u0639 \u0641\u0631\u0635 \u0627\u0644\u0648\u0635\u0648\u0644 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u062d\u062a\u0627\u062c\u064a\u0646. \u0648\u062d\u0630\u0631 \u0627\u0644\u0628\u064a\u0627\u0646 \u0627\u0644\u0627\u0654\u0645\u0645\u064a \u0645\u0646 \u0627\u0654\u0646\u0647 \"\u0628\u062f\u0648\u0646 \u062a\u062d\u0631\u0643 \u0639\u0627\u062c\u0644\u060c \u0633\u062a\u064f\u0632\u0647\u0642 \u0627\u0654\u0631\u0648\u0627\u062d\u060c \u0648\u0633\u062a\u062a\u0632\u0639\u0632\u0639 \u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0627\u0644\u0645\u062c\u062a\u0645\u0639\u0627\u062a\u060c \u0648\u0633\u062a\u0642\u062a\u0631\u0628 \u0627\u0644\u0627\u0654\u0646\u0638\u0645\u0629 \u0627\u0644\u0627\u0654\u0633\u0627\u0633\u064a\u0629 \u0645\u0646 \u0627\u0644\u0627\u0646\u0647\u064a\u0627\u0631\". \u0643\u0645\u0627 \u062d\u0630\u0631 \u0627\u0644\u0628\u064a\u0627\u0646 \u0645\u0646 \u0627\u0654\u0646 \u0627\u0644\u062a\u0642\u0627\u0639\u0633 \u0633\u064a\u062f\u0641\u0639 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 18 \u0645\u0644\u064a\u0648\u0646 \u0634\u062e\u0635 \u0627\u0655\u0644\u0649 \u062c\u0648\u0639 \u0634\u062f\u064a\u062f \u0645\u0639 \u062a\u0641\u0627\u0642\u0645 \u0627\u0646\u0639\u062f\u0627\u0645 \u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u063a\u0630\u0627\u064a\u0654\u064a \u0648\u0627\u0646\u0632\u0644\u0627\u0642 \u0627\u0644\u0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u0645\u0646\u0627\u0637\u0642 \u0646\u062d\u0648 \u0638\u0631\u0648\u0641 \u0627\u0644\u0637\u0648\u0627\u0631\u064a\u0654 \u0627\u0644\u0643\u0627\u0631\u062b\u064a\u0629. \u0648\u0646\u0628\u0647 \u0627\u0644\u0628\u064a\u0627\u0646 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 19.3 \u0645\u0644\u064a\u0648\u0646 \u0634\u062e\u0635 \u0642\u062f \u064a\u0648\u0627\u062c\u0647\u0648\u0646 \u0645\u062e\u0627\u0637\u0631 \u0635\u062d\u064a\u0