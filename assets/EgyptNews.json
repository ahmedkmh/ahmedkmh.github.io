\u062a\u0647\u0645 \u0646\u062d\u0648 \u0627\u0644\u062d\u062f\u0648\u062f \u0627\u0644\u0641\u0631\u0646\u0633\u064a\u0629 \u0648\u0627\u062a\u062c\u0647\u0648\u0627 \u0644\u0645\u063a\u0627\u0644\u0637\u0629 \u0627\u0644\u0641\u0631\u0646\u0633\u064a\u064a\u0646 \u0639\u0628\u0631 \u062a\u062c\u0627\u0648\u0632 \u062e\u0637 \u0645\u0627\u062c\u064a\u0646\u0648 (Maginot) \u0627\u0644\u062f\u0641\u0627\u0639\u064a \u0648\u0627\u0644\u0645\u0631\u0648\u0631 \u0645\u0646 \u063a\u0627\u0628\u0627\u062a \u0627\u0644\u0627\u0654\u0631\u062f\u064a\u0646 (Ardennes) \u0627\u0644\u0643\u062b\u064a\u0641\u0629 \u0627\u0644\u062a\u064a \u0648\u0635\u0641\u0647\u0627 \u0627\u0644\u0641\u0631\u0646\u0633\u064a\u0648\u0646 \u0633\u0627\u0628\u0642\u0627 \u0628\u0627\u0644\u062f\u0641\u0627\u0639\u0627\u062a \u0627\u0644\u0637\u0628\u064a\u0639\u064a\u0629.\u0648\u062e\u0644\u0627\u0644 \u0647\u0630\u0647 \u0627\u0644\u062d\u0631\u0628\u060c \u0644\u0645 \u064a\u0635\u0645\u062f \u0627\u0644\u0641\u0631\u0646\u0633\u064a\u0648\u0646 \u0637\u0648\u064a\u0644\u0627\u064b \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0627\u0654\u0644\u0645\u0627\u0646 \u062d\u064a\u062b \u0627\u0646\u0637\u0644\u0642\u062a \u0627\u0644\u062d\u0645\u0644\u0629 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u064a\u0648\u0645 10 \u0645\u0627\u064a\u0648 (\u0627\u0654\u064a\u0627\u0631) 1940 \u0648\u0627\u0646\u062a\u0647\u062a \u0628\u0627\u0633\u062a\u0633\u0644\u0627\u0645 \u0641\u0631\u0646\u0633\u0627 \u0628\u0639\u062f \u0646\u062d\u0648 45 \u064a\u0648\u0645\u060c \u0648\u0642\u062f \u0634\u0647\u062f\u062a \u0647\u0630\u0647 \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629 \u062d\u064a\u0646\u0647\u0627 \u062a\u062f\u062e\u0644 \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u0627\u0655\u064a\u0637\u0627\u0644\u064a\u0629 \u0636\u062f \u0627\u0644\u0641\u0631\u0646\u0633\u064a\u064a\u0646 \u0628\u0646\u0627\u0621 \u0639\u0644\u0649 \u0627\u0654\u0648