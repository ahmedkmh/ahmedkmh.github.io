9%8A%D8%AF%D8%A9", "title": "\u062a\u0631\u0627\u0645\u0628: \u0645\u0637\u0644\u0642 \u0627\u0644\u0646\u0627\u0631 \u0645\u062e\u062a\u0644 \u0639\u0642\u0644\u064a\u0627\u064b\u064b \u0648\u0627\u0654\u0639\u062a\u0642\u062f \u0627\u0654\u0646\u064a \u0627\u0644\u0645\u0633\u062a\u0647\u062f\u0641", "description": "\u0627\u0654\u0639\u0631\u0628 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u0628 \u0639\u0646 \u0627\u0639\u062a\u0642\u0627\u062f\u0647 \u0628\u0627\u0654\u0646 \u0627\u0644\u0645\u0634\u062a\u0628\u0647 \u0628\u0647 \u0627\u0644\u0630\u064a \u0627\u0642\u062a\u062d\u0645 \u062d\u0641\u0644 \u0639\u0634\u0627\u0621 \u0645\u0631\u0627\u0633\u0644\u064a \u0627\u0644\u0628\u064a\u062a \u0627\u0644\u0627\u0654\u0628\u064a\u0636 \u0645\u0633\u0627\u0621 \u0627\u0644\u0633\u0628\u062a \u0648\u0627\u0654\u0637\u0644\u0642 \u0627\u0644\u0646\u0627\u0631 \u0643\u0627\u0646 \"\u0630\u064a\u0654\u0628\u0627\u064b \u0645\u0646\u0641\u0631\u062f\u0627\u064b\".\u0648\u0642\u0627\u0644 \u062a\u0631\u0627\u0645\u0628 \u062e\u0644\u0627\u0644 \u0645\u0648\u0654\u062a\u0645\u0631 \u0635\u062d\u0627\u0641\u064a \u0641\u064a \u0627\u0644\u0628\u064a\u062a \u0627\u0644\u0627\u0654\u0628\u064a\u0636: \"\u0628\u0631\u0627\u0654\u064a\u064a\u060c \u0643\u0627\u0646 \u0630\u064a\u0654\u0628\u0627\u064b \u0645\u0646\u0641\u0631\u062f\u0627\u064b\"\u060c \u0648\u0627\u0635\u0641\u0627\u064b \u0627\u0644\u0631\u062c\u0644 \u0628\u0627\u0654\u0646\u0647 \"\u0645\u062e\u062a\u0644 \u0639\u0642\u0644\u064a\u0627\u064b\"\u060c \u0648\u0641\u0642 \u0641\u0631\u0627\u0646\u0633 \u0628\u0631\u0633.\u0643\u0645\u0627 \u0639\u0628\u0631 \u0639\u0646 \u0627\u0639\u062a\u0642\u0627\u062f\u0647 \u0628\u0627\u0654\u0646\u0647 \u0643\u0627\u0646 \u0627\u0644\u0645\u0633\u062a\u0647\u062f\u0641 \u0641\u064a \u0627\u0644\u062d\u0627\u062f\u062b\u0629\u060c \u062d\u0633\u0628 \u0631\u0648\u064a\u062a\u0631\u0632.\u0641\u064a\u0645\u0627 \u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646\u0647 \u0644\u0627 \u064a\u0634\u0639\u0631 \u0628\u0648\u062c\u0648\u062f \u0627\u0654\u064a \u0633\u0628\u0628 \u0644\u0644\u0627\u0639\u062a\u0642\u0627\u062f \u0628\u0627\u0654\u0646 \u0627\u0644\u0647\u062c\u0648\u0645 \u0645\u0631\u062a\u0628\u0637 \u0628\u0627\u0644\u062d\u0631\u0628 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646.\"\u0642\u0627\u062a\u0644 \u0645\u062d\u062a\u0645\u0644\"\u0627\u0655\u0644\u0649 \u0630\u0644\u0643 \u0648\u0635\u0641 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u0627\u0644\u0645\u0634\u062a\u0628\u0647 \u0628\u0647 \u0641\u064a \u0627\u0655\u0637\u0644\u0627\u0642\u0647 \u0627\u0644\u0646\u0627\u0631 \u062e\u0644\u0627\u0644 \u0627\u0644\u062d\u0641\u0644 \u0627\u0644\u0630\u064a \u0643\u0627\u0646 \u064a\u062d\u0636\u0631\u0647 \u0628\u0648\u0627\u0634\u0646\u0637\u0646 \u0628\u0627\u0654\u0646\u0647 \u0643\u0627\u0646 \"\u0642\u0627\u062a\u0644\u0627\u064b \u0645\u062d\u062a\u0645\u0644\u0627\u064b\"\u060c \u0645\u0634\u064a\u0631\u0627\u064b \u0627\u0655\u0644\u0649 \u062d\u064a\u0627\u0632\u062a\u0647 \"\u0627\u0644\u0639\u062f\u064a\u062f \u0645\u0646 \u0627\u0644\u0627\u0654\u0633\u0644\u062d\u0629\".\u0648\u0642\u0627\u0644 \u0627\u0655\u0646 \u0627\u0644\u0631\u062c\u0644 \u0627\u0642\u062a\u062d\u0645 \u0646\u0642\u0637\u0629 \u062a\u0641\u062a\u064a\u0634 \u0627\u0654\u0645\u0646\u064a\u0629\u060c \u0645\u0631\u062f\u0641\u0627\u064b: \"\u0627\u0654\u0635\u064a\u0628 \u0627\u0654\u062d\u062f \u0627\u0644\u0636\u0628\u0627\u0637 \u0628\u0627\u0644\u0631\u0635\u0627\u0635 \u0644\u0643\u0646 \u0645\u0646 \u0627\u0644\u0648\u0627\u0636\u062d \u0627\u0654\u0646\u0647 \u0646\u062c\u0627 \u0628\u0641\u0636\u0644 \u0627\u0631\u062a\u062f\u0627\u064a\u0654\u0647 \u0644\u0633\u062a\u0631\u0629 \u062c\u064a\u062f\u0629 \u062c\u062f\u0627\u064b \u0648\u0627\u0642\u064