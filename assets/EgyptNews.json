%AD%D8%A8-%D9%88%D8%A7%D9%84%D8%B2%D9%88%D8%A7%D8%AC", "title": "\u0627\u0654\u0643\u062b\u0631 \u0627\u0644\u0627\u0654\u0628\u0631\u0627\u062c \u062a\u0648\u0627\u0641\u0642\u0627\u064b \u0645\u0639 \u0628\u0631\u062c \u0627\u0644\u062d\u0645\u0644 \u0641\u064a \u0627\u0644\u062d\u0628 \u0648\u0627\u0644\u0632\u0648\u0627\u062c", "description": "\u064a\u062a\u0645\u064a\u0651\u0632 \u0645\u0648\u0627\u0644\u064a\u062f \u0627\u0644\u062d\u0645\u0644 \u0628\u0634\u062e\u0635\u064a\u062a\u0647\u0645 \u0627\u0644\u0646\u0627\u0631\u064a\u0629 \u0627\u0644\u0645\u0644\u064a\u064a\u0654\u0629 \u0628\u0627\u0644\u062d\u0645\u0627\u0633 \u0648\u0627\u0644\u0637\u0627\u0642\u0629\u060c \u0641\u0647\u0645 \u0627\u0654\u0634\u062e\u0627\u0635 \u064a\u062d\u0628\u0648\u0646 \u0627\u0644\u0645\u063a\u0627\u0645\u0631\u0629 \u0648\u0627\u0644\u062a\u062c\u062f\u064a\u062f\u060c \u0648\u064a\u0628\u062d\u062b\u0648\u0646 \u062f\u0627\u064a\u0654\u0645\u0627\u064b \u0639\u0646 \u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0645\u0646\u062d\u0647\u0645 \u0634\u0639\u0648\u0631\u0627\u064b \u0628\u0627\u0644\u0634\u063a\u0641 \u0648\u0627\u0644\u062d\u064a\u0648\u064a\u0629. \u0648\u0639\u0646\u062f\u0645\u0627 \u064a\u062a\u0639\u0644\u0642 \u0627\u0644\u0627\u0654\u0645\u0631 \u0628\u0627\u0644\u062d\u0628 \u0648\u0627\u0644\u0632\u0648\u0627\u062c\u060c \u064a\u062d\u062a\u0627\u062c \u0628\u0631\u062c \u0627\u0644\u062d\u0645\u0644 \u0627\u0655\u0644\u0649 \u0634\u0631\u064a\u0643 \u064a\u0641\u0647\u0645 \u0637\u0628\u064a\u0639\u062a\u0647 \u0627\u0644\u0642\u0648\u064a\u0629 \u0648\u064a\u0633\u062a\u0637\u064a\u0639 \u0645\u0648\u0627\u0643\u0628\u0629 \u0633\u0631\u0639\u062a\u0647 \u0641\u064a \u0627\u0644\u062d\u064a\u0627\u0629. \u0644\u0630\u0644\u0643\u060c \u0642\u062f \u064a\u0646\u062c\u062d \u0641\u064a \u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0645\u0639 \u0628\u0639\u0636 \u0627\u0644\u0627\u0654\u0628\u0631\u0627\u062c \u0627\u0644\u062a\u064a \u062a\u062a\u0646\u0627\u063a\u0645 \u0645\u0639 \u0637\u0627\u0642\u062a\u0647 \u0648\u062a\u0634\u0627\u0631\u0643\u0647 \u0631\u0648\u062d \u0627\u0644\u0645\u063a\u0627\u0645\u0631\u0629. \u0628\u0631\u062c \u0627\u0644\u0627\u0654\u0633\u062f : \u0639\u0644\u0627\u0642\u0629 \u0645\u0644\u064a\u064a\u0654\u0629 \u0628\u0627\u0644\u0634\u063a\u0641 \u0648\u0627\u0644\u0642\u0648\u0629 \u064a\u064f\u0639\u062a\u0628\u0631 \u0628\u0631\u062c \u0627\u0644\u0627\u0654\u0633\u062f \u0645\u0646 \u0627\u0654\u0643\u062b\u0631 \u0627\u0644\u0627\u0654\u0628\u0631\u0627\u062c \u062a\u0648\u0627\u0641\u0642\u0627\u064b \u0645\u0639 \u0627\u0644\u062d\u0645\u0644 \u0641\u064a \u0627\u0644\u062d\u0628. \u0641\u0643\u0644\u0627\u0647\u0645\u0627 \u0645\u0646 \u0627\u0644\u0627\u0654\u0628\u0631\u0627\u062c \u0627\u0644\u0646\u0627\u0631\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u062a\u0633\u0645 \u0628\u0627\u0644\u062d\u0645\u0627\u0633 \u0648\u0627\u0644\u062b\u0642\u0629 \u0628\u0627\u0644\u0646\u0641\u0633. \u064a\u062c\u0645\u0639 \u0628\u064a\u0646\u0647\u0645\u0627 \u0634\u063a\u0641 \u0643\u0628\u064a\u0631 \u0628\u0627\u0644\u062d\u064a\u0627\u0629 \u0648\u0631\u063a\u0628\u0629 \u0641\u064a \u0627\u0644\u062a\u0645\u064a\u0632 \u0648\u0627\u0644\u0646\u062c\u0627\u062d\u060c \u0645\u0627 \u064a\u062c\u0639\u0644 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0628\u064a\u0646\u0647\u0645\u0627 \u0645\u0644\u064a\u064a\u0654\u0629 \u0628\u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u0627\u0655\u064a\u062c\u0627\u0628\u064a\u0629. \u064a\u0645\u064a\u0644 \u0627\u0644\u0627\u0654\u0633\u062f \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0655\u0639\u062c\u0627\u0628 \u0628\u0634\u062c\u0627\u0639\u0629 \u0627\u0644\u062d\u0645\u0644 \u0648\u0637\u0645\u0648\u062d\u0647\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0646\u062c\u0630\u0628 \u0627\u0644\u062d\u0645\u0644 \u0627\u0655\u0644\u0649 \u0634\u062e\u0635\u064a\u0629 \u0627\u0644\u0627\u0654\u0633\u062f \u0627\u0644\u0642\u0648\u064a\u0629 \u0648\u062d\u0636\u0648\u0631\u0647 \u0627\u0644\u0644\u0627\u0641\u062a. \u0648\u0645\u0639 \u0648\u062c\u0648\u062f \u0627\u0644\u0627\u062d\u062a\u0631\u0627\u0645 \u0627\u0644\u0645\u062a\u0628\u0627\u062f\u0644 \u0628\u064a\u0646\u0647\u0645\u0627\u060c \u064a\u0645\u0643\u0646 \u0644\u0647\u0630\u0647 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0627\u0654\u0646 \u062a\u062a\u062d\u0648\u0644 \u0627\u0655\u0644\u0649 \u0634\u0631\u0627\u0643\u0629 \u0642\u0648\u064a\u0629 \u0642\u0627\u064a\u0654\u0645\u0629 \u0639\u0644\u0649 \u0627\u0644\u062f\u0639\u0645 \u0648\u0627\u0644\u062a\u0634\u062c\u064a\u0639 \u0627\u0644\u0645\u0633\u062a\u0645\u0631. \u0628\u0631\u062c \u0627\u0644\u0642\u0648\u0633: \u0645\u063a\u0627\u0645\u0631\u0629 \u0644\u0627 \u062a\u0646\u062a\u0647\u064a \u064a\u064f\u0639\u062f \u0628\u0631\u062c \u0627\u0644\u0642\u0648\u0633 \u0645\u0646 \u0627\u0644\u0627\u0654\u0628\u0631\u0627\u062c \u0627\u0644\u062a\u064a \u062a\u0646\u0633\u062c\u0645 \u0628\u0634\u0643\u0644 \u0643\u0628\u064a\u0631 \u0645\u0639 \u0634\u062e\u0635\u064a\u0629 \u0627\u0644\u062d\u0645\u0644. \u0641\u0643\u0644\u0627\u0647\u0645\u0627 \u064a\u0639\u0634\u0642 \u0627\u0644\u062d\u0631\u064a\u0629 \u0648\u0627\u0644\u0645\u063a\u0627\u0645\u0631\u0629\u060c \u0648\u0644\u0627 \u064a\u062d\u0628 \u0627\u0644\u0642\u064a\u0648\u062f \u0627\u0654\u0648 \u0627\u0644\u0631\u0648\u062a\u064a\u0646. \u0644\u0630\u0644\u0643 \u063a\u0627\u0644\u0628\u0627\u064b \u0645\u0627 \u062a\u0643\u0648\u0646 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0628\u064a\u0646\u0647\u0645\u0627 \u0645\u0644\u064a\u064a\u0654\u0629 \u0628\u0627\u0644\u062d\u0645\u0627\u0633 \u0648\u0627\u0644\u062a\u062c\u0627\u0631\u0628 \u0627\u0644\u062c\u062f\u064a\u062f\u0629. \u064a\u0634\u0639\u0631 \u0627\u0644\u062d\u0645\u0644 \u0628\u0627\u0644\u0631\u0627\u062d\u0629 \u0645\u0639 \u0627\u0644\u0642\u0648\u0633 \u0644\u0627\u0654\u0646\u0647 \u064a\u0645\u0646\u062d\u0647 \u0627\u0644\u0645\u0633\u0627\u062d\u0629 \u0627\u0644\u062a\u064a \u064a\u062d\u062a\u0627\u062c\u0647\u0627\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0633\u062a\u0645\u062a\u0639 \u0627\u0644\u0642\u0648\u0633 \u0628\u0637\u0627\u0642\u0629 \u0627\u0644\u062d\u0645\u0644 \u0627\u0644\u0627\u0655\u064a\u062c\u0627\u0628\u064a\u0629 \u0648\u0631\u0648\u062d\u0647 \u0627\u0644\u0642\u064a\u0627\u062f\u064a\u0629. \u0647\u0630\u0627 \u0627\u0644\u062a\u0641\u0627\u0647\u0645 \u0627\u0644\u0637\u0628\u064a\u0639\u064a \u0628\u064a\u0646\u0647\u0645\u0627 \u0642\u062f \u064a\u062c\u0639\u0644 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0628\u064a\u0646\u0647\u0645\u0627 \u0642\u0648\u064a\u0629 \u0648\u0645\u0645\u062a\u0639\u0629 \u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0646\u0641\u0633\u0647. \u0628\u0631\u062c \u0627\u0644\u062c\u0648\u0632\u0627\u0621: \u062a\u0648\u0627\u0632\u0646 \u0628\u064a\u0646 \u0627\u0644\u062d\u0645\u0627\u0633 \u0648\u0627\u0644\u0630\u0643\u0627\u0621 \u064a\u0645\u0643\u0646 \u0627\u0654\u0646 \u064a\u0634\u0643\u0644 \u0628\u0631\u062c \u0627\u0644\u062c\u0648\u0632\u0627\u0621 \u0634\u0631\u064a\u0643\u0627\u064b \u0645\u0646\u0627\u0633\u0628\u0627\u064b \u0644\u0644\u062d\u0645\u0644 \u0641\u064a \u0643\u062b\u064a\u0631 \u0645\u0646 \u0627\u0644\u0627\u0654\u062d\u064a\u0627\u0646. \u0641\u0627\u0644\u062c\u0648\u0632\u0627\u0621 \u064a\u062a\u0645\u062a\u0639 \u0628\u0630\u0643\u0627\u0621 \u0627\u062c\u062a\u0645\u0627\u0639\u064a \u0648\u062d\u064a\u0648\u064a\u0629 \u062a\u062c\u0639\u0644\u0647 \u0642\u0627\u062f\u0631\u0627\u064b \u0639\u0644\u0649 \u0645\u0648\u0627\u0643\u0628\u0629 \u0637\u0627\u0642\u0629 \u0627\u0644\u062d\u0645\u0644 \u0627\u0644\u0645\u062a\u062c\u062f\u062f\u0629. \u0643\u0645\u0627 \u0627\u0654\u0646 \u0634\u062e\u0635\u064a\u062a\u0647 \u0627\u0644\u0645\u0631\u0646\u0629 \u062a\u0633\u0627\u0639\u062f \u0639\u0644\u0649 \u062e\u0644\u0642 \u062a\u0648\u0627\u0632\u0646 \u062f\u0627\u062e\u0644 \u0627\u0644\u0639\u0644\u0627\u0642\u0629. \u064a\u062d\u0628 \u0627\u0644\u062d\u0645\u0644 \u0631\u0648\u062d \u0627\u0644\u0645\u0631\u062d \u0627\u0644\u062a\u064a \u064a\u062a\u0645\u062a\u0639 \u0628\u0647\u0627 \u0627\u0644\u062c\u0648\u0632\u0627\u0621\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0646\u062c\u0630\u0628 \u0627\u0644\u062c\u0648\u0632\u0627\u0621 \u0627\u0655\u0644\u0649 \u062c\u0631\u0627\u0654\u0629 \u0627\u0644\u062d\u0645\u0644 \u0648\u0634\u062c\u0627\u0639\u062a\u0647. \u0647\u0630\u0627 \u0627\u0644\u062a\u0641\u0627\u0639\u0644 \u0628\u064a\u0646 \u0627\u0644\u062d\u0645\u0627\u0633 \u0648\u0627\u0644\u0630\u0643\u0627\u0621 \u0642\u062f \u064a\u0645\u0646\u062d \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0628\u064a\u0646\u0647\u0645\u0627 \u0637\u0627\u0628\u0639\u0627\u064b \u0645\u0645\u064a\u0632\u0627\u064b \u0645\u0644\u064a\u064a\u0654\u0627\u064b \u0628\u0627\u0644\u062d\u064a\u0648\u064a\u0629. \u0628\u0631\u062c \u0627\u0644\u0645\u064a\u0632\u0627\u0646: \u062a\u0643\u0627\u0645\u0644 \u0627\u0644\u0627\u0654\u0636\u062f\u0627\u062f \u0631\u063a\u0645 \u0627\u0644\u0627\u062e\u062a\u0644\u0627\u0641 \u0627\u0644\u0643\u0628\u064a\u0631 \u0628\u064a\u0646\u0647\u0645\u0627\u060c \u0627\u0655\u0644\u0627 \u0627\u0654\u0646 \u0628\u0631\u062c \u0627\u0644\u0645\u064a\u0632\u0627\u0646 \u064a\u0645\u0643\u0646 \u0627\u0654\u0646 \u064a\u0643\u0648\u0646 \u0634\u0631\u064a\u0643\u0627\u064b \u0645\u062b\u0627\u0644\u064a\u0627\u064b \u0644\u0644\u062d\u0645\u0644. \u0641\u0627\u0644\u0645\u064a\u0632\u0627\u0646 \u064a\u062a\u0645\u064a\u0632 \u0628\u0627\u0644\u0647\u062f\u0648\u0621 \u0648\u0627\u0644\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a\u0629\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0645\u062a\u0644\u0643 \u0627\u0644\u062d\u0645\u0644 \u0637\u0627\u0642\u0629 \u0642\u0648\u064a\u0629 \u0648\u0634\u062e\u0635\u064a\u0629 \u0645\u0628\u0627\u0634\u0631\u0629. \u0647\u0630\u0627 \u0627\u0644\u062a\u0628\u0627\u064a\u0646 \u0642\u062f \u064a\u062e\u0644\u0642 \u0646\u0648\u0639\u0627\u064b \u0645\u0646 \u0627\u0644\u062a\u0643\u0627\u0645\u0644 \u062f\u0627\u062e\u0644 \u0627\u0644\u0639\u0644\u0627\u0642\u0629. \u064a\u0633\u0627\u0639\u062f \u0627\u0644\u0645\u064a\u0632\u0627\u0646 \u0627\u0644\u062d\u0645\u0644 \u0639\u0644\u0649 \u0627\u0644\u062a\u0641\u0643\u064a\u0631 \u0628\u0647\u062f\u0648\u0621 \u0642\u0628\u0644 \u0627\u062a\u062e\u0627\u0630 \u0627\u0644\u0642\u0631\u0627\u0631\u0627\u062a\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u0645\u0646\u062d \u0627\u0644\u062d\u0645\u0644 \u0627\u0644\u0645\u064a\u0632\u0627\u0646 \u062c\u0631\u0627\u0654\u0629 \u0627\u0654\u0643\u0628\u0631 \u0641\u064a \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u062d\u064a\u0627\u0629. \u0648\u0639\u0646\u062f\u0645\u0627 \u064a\u062a\u0639\u0644\u0645 \u0627\u0644\u0637\u0631\u0641\u0627\u0646 \u0641\u0647\u0645 \u0627\u062e\u062a\u0644\u0627\u0641\u0627\u062a\u0647\u0645\u0627\u060c \u064a\u0645\u0643\u0646 \u0627\u0654\u0646 \u062a\u062a\u062d\u0648\u0644 \u0647\u0630\u0647 \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0627\u0655\u0644\u0649 \u0634\u0631\u0627\u0643\u0629 \u0645\u062a\u0648\u0627\u0632\u0646\u0629 \u062a\u062c\u0645\u0639 \u0628\u064a\u0646 \u0627\u0644\u062d\u0645\u0627\u0633 \u0648\u0627\u0644\u0627\u0646\u0633\u062c\u0627\u0645. \u0641\u064a \u0627\u0644\u0646\u0647\u0627\u064a\u0629\u060c \u064a\u0639\u062a\u0645\u062f \u0646\u062c\u0627\u062d \u0627\u0644\u0639\u0644\u0627\u0642\u0629 \u0645\u0639 \u0628\u0631\u062c \u0627\u0644\u062d\u0645\u0644 \u0639\u0644\u0649 \u0648\u062c\u0648\u062f \u0634\u0631\u064a\u0643 \u064a\u0633\u062a\u0637\u064a\u0639 \u0641\u0647\u0645 \u0637\u0628\u064a\u0639\u062a\u0647 \u0627\u0644\u0646\u0627\u0631\u064a\u0629 \u0648\u0627\u0644\u062a\u0639\u0627\u0645\u0644 \u0645\u0639 \u0637\u0627\u0642\u062a\u0647 \u0627\u0644\u0643\u0628\u064a\u0631\u0629. \u0641\u0627\u0644\u062d\u0645\