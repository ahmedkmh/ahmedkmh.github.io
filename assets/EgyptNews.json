u0627\u0639\u064a \u062f\u0627\u062e\u0644 \u062a\u0637\u0628\u064a\u0642\u0647\u0627\u060c \u0639\u0628\u0631 \u062a\u062d\u062f\u064a\u062b \u062c\u062f\u064a\u062f \u0644\u0645\u0633\u0627\u0639\u062f\u0647\u0627 \u0627\u0644\u0630\u0643\u064a \u064a\u062a\u064a\u062d \u0644\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0627\u0644\u0628\u062d\u062b \u0648\u0627\u062a\u062e\u0627\u0630 \u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0639\u0645\u0644\u064a\u0629 \u2014 \u0645\u062b\u0644 \u0627\u0644\u062d\u062c\u0632 \u0648\u0637\u0644\u0628 \u0627\u0644\u0637\u0639\u0627\u0645 \u2014 \u062f\u0648\u0646 \u0645\u063a\u0627\u062f\u0631\u0629 \u0627\u0644\u0645\u062d\u0627\u062f\u062b\u0629.\u0645\u0646 \u0627\u0644\u0628\u062d\u062b \u0627\u0655\u0644\u0649 \u0627\u0644\u062a\u0646\u0641\u064a\u0630\u0641\u064a \u0627\u0644\u0628\u062f\u0627\u064a\u0629\u060c \u0627\u0654\u0637\u0644\u0642\u062a \"Yelp\" \u0645\u0633\u0627\u0639\u062f\u0647\u0627 \u0627\u0644\u0630\u0643\u064a \u0639\u0627\u0645 2024 \u0644\u0645\u0633\u0627\u0639\u062f\u0629 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a\u0646 \u0641\u064a \u0627\u0644\u0639\u062b\u0648\u0631 \u0639\u0644\u0649 \u062e\u062f\u0645\u0627\u062a \u0645\u062d\u0644\u064a\u0629 \u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0627\u062d\u062a\u064a\u0627\u062c\u0627\u062a\u0647\u0645\u060c \u0628\u062d\u0633\u0628 \u062a\u0642\u0631\u064a\u0631 \u0646\u0634\u0631\u0647 \u0645\u0648\u0642\u0639 \"\u062a\u0643 \u0643\u0631\u0627\u0646\u0634\" \u0648\u0627\u0637\u0644\u0639\u062a \u0639\u0644\u064a\u0647 \"\u0627\u0644\u0639\u0631\u0628\u064a\u0629 Business\".\u0644\u0643\u0646 \u0627\u0644\u062a\u062d\u062f\u064a\u062b \u0627\u0644\u062c\u062f\u064a\u062f \u064a\u0646\u0642\u0644 \u0627\u0644\u062a\u062c\u0631\u0628\u0629 \u0627\u0655\u0644\u0649 \u0645\u0633\u062a\u0648\u0649 \u0645\u062e\u062a\u0644\u0641\u060c \u062d\u064a\u062b \u0627\u0654\u0635\u0628\u062d \u0628\u0627\u0655\u0645\u0643\u0627\u0646 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645:- \u0627\u0644\u0628\u062d\u062b \u0639\u0646 \u0627\u0644\u0645\u0637\u0627\u0639\u0645 \u0648\u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629.- \u062d\u062c\u0632 \u0637\u0627\u0648\u0644\u0627\u062a \u0645\u0628\u0627\u0634\u0631\u0629.- \u0637\u0644\u0628 \u0627\u0644\u0637\u0639\u0627\u0645 \u0639\u0628\u0631 \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u062a\u0648\u0635\u064a\u0644.- \u062d\u062c\u0632 \u062e\u062f\u0645\u0627\u062a \u0645\u062b\u0644 \u0627\u0644\u0635\u064a\u0627\u0646\u0629 \u0627\u0654\u0648 \u0627\u0644\u062a\u062c\u0645\u064a\u0644.\u0643\u0644 \u0630\u0644\u0643 \u064a\u062a\u0645 \u062f\u0627\u062e\u0644 \u0645\u062d\u0627\u062f\u062b\u0629 \u0648\u0627\u062d\u062f\u0629 \u0645\u0639 \u0627\u0644\u0645\u0633\u0627\u0639\u062f.\u062a\u062c\u0631\u0628\u0629 \u0627\u0654\u0642\u0631\u0628 \u0627\u0655\u0644\u0649 \u0645\u0633\u0627\u0639\u062f \u0634\u062e\u0635\u064a\u062e\u0644\u0627\u0644 \u0639\u0631\u0636 \u062a\u0648\u0636\u064a\u062d\u064a\u060c \u0627\u0654\u0638\u0647\u0631 \u0641\u0631\u064a\u0642 \"Yelp\" \u0643\u064a\u0641 \u064a\u0645\u0643\u0646 \u0644\u0644\u0645\u0633\u0627\u0639\u062f:- \u0627\u0642\u062a\u0631\u0627\u062d \u0627\u0654\u0645\u0627\u0643\u0646 \u062a\u0646\u0632\u0647 \u0645\u0646\u0627\u0633\u0628\u0629 \u0644\u0644\u0643\u0644\u0627\u0628.- \u0639\u0631\u0636 \u0645\u0637\u0627\u0639\u0645 \u0639\u0644\u0649 \u0627\u0644\u0637\u0631\u064a\u0642 \u0645\u0639 \u062e\u064a\u0627\u0631 \u0627\u0644\u0637\u0644\u0628 \u0639\u0628\u0631 DoorDash.- \u0627\u0642\u062a\u0631\u0627\u062d \u0645\u0637\u0627\u0639\u0645 \u0644\u0639\u0637\u0644\u0629 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639 \u0645\u0639 \u0627\u0655\u0645\u0643\u0627\u0646\u064a\u0629 \u0627\u0644\u062d\u062c\u0632.- \u0627\u0644\u0628\u062d\u062b \u0639\u0646 \u062e\u062f\u0645\u0627\u062a \u0645\u0646\u0632\u0644\u064a\u0629 \u0645\u062b\u0644