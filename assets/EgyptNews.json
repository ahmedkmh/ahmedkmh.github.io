\u0627\u0644\u0643\u0628\u064a\u0631\u0629 \u0628\u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0629 \u0645\u0639 \u0627\u0644\u0641\u0631\u0627\u0639\u0646\u0629\u060c \u0641\u064a \u0628\u0637\u0648\u0644\u0629 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026. \u0648\u0634\u0627\u0631\u0643 \u0645\u0635\u0637\u0641\u0649 \u0634\u0648\u0628\u064a\u0631 \u0641\u064a \u062c\u0645\u064a\u0639 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631\u060c \u062e\u0644\u0627\u0644 \u062f\u0648\u0631 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0628\u0628\u0637\u0648\u0644\u0629 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026\u060c \u0648\u0627\u0644\u062a\u064a \u0634\u0647\u062f\u062a \u0627\u0644\u062a\u0639\u0627\u062f\u0644 \u0645\u0639 \u0645\u0646\u062a\u062e\u0628\u064a \u0628\u0644\u062c\u064a\u0643\u0627 \u0648\u0627\u0655\u064a\u0631\u0627\u0646\u060c \u0648\u0627\u0644\u0641\u0648\u0632 \u0639\u0644\u0649 \u0646\u064a\u0648\u0632\u064a\u0644\u0646\u062f\u0627. \u0648\u0642\u0627\u0644 \u0645\u0635\u0637\u0641\u0649 \u0634\u0648\u0628\u064a\u0631 \u0641\u064a \u062a\u0635\u0631\u064a\u062d\u0627\u062a \u0644\u0645\u0648\u0642\u0639 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u062f\u0648\u0644\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645: \"\u0627\u0654\u0646 \u064a\u0643\u0648\u0646 \u0627\u0654\u064a \u0645\u0648\u0627\u0637\u0646 \u0645\u0635\u0631\u064a \u062c\u0632\u0621\u064b\u0627 \u0645\u0646 \u0627\u0644\u0645\u0646\u062a\u062e\u0628\u060c \u0641\u0647\u0630\u0627 \u0627\u0654\u0645\u0631 \u0645\u0630\u0647\u0644 \u0644\u0644\u063a\u0627\u064a\u0629.. \u0627\u0654\u0646\u0627 \u0627\u0654\u062d\u0628 \u0627\u0644\u0636\u063a\u0637\u060c \u0648\u0627\u0654\u062d\u0628 \u0627\u0654\u062c\u0648\u0627\u0621 \u0647\u0630\u0647 \u0627\u0644\u0645\u0646\u0627\u0641\u0633\u0629 \u0648\u0637\u0639\u0645\u0647\u0627.. \u0627\u0655\u0646\u0647 \u062d\u06