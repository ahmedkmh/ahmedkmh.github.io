u064a \u0641\u064a \u0646\u0634\u0627\u0637 \u0627\u0644\u062e\u062f\u0645\u0627\u062a \u0627\u0644\u0645\u0635\u0631\u0641\u064a\u0629 \u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631\u064a\u0629 \u0648\u0642\u0641\u0632\u0629 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u062f\u0627\u062a \u0627\u0644\u062a\u062f\u0627\u0648\u0644\u060c \u0645\u0633\u062a\u0641\u064a\u062f\u0627\u064b \u0645\u0646 \u0645\u0648\u062c\u0629 \u0627\u0644\u0627\u0643\u062a\u062a\u0627\u0628\u0627\u062a \u0627\u0644\u0643\u0628\u0631\u0649 \u0648\u062a\u0642\u0644\u0628\u0627\u062a \u0627\u0644\u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629.\u0648\u0633\u062c\u0644 \u0627\u0644\u0628\u0646\u0643 \u0627\u0654\u0631\u0628\u0627\u062d\u0627\u064b \u0628\u0644\u063a\u062a 21.2 \u0645\u0644\u064a\u0627\u0631 \u062f\u0648\u0644\u0627\u0631\u060c \u0627\u0654\u0648 7.70 \u062f\u0648\u0644\u0627\u0631 \u0644\u0644\u0633\u0647\u0645\u060c \u062e\u0644\u0627\u0644 \u0627\u0644\u0627\u0654\u0634\u0647\u0631 \u0627\u0644\u062b\u0644\u0627\u062b\u0629 \u0627\u0644\u0645\u0646\u062a\u0647\u064a\u0629 \u0641\u064a 30 \u064a\u0648\u0646\u064a\u0648\u060c \u0645\u0642\u0627\u0631\u0646\u0629 \u0645\u0639 14.99 \u0645\u0644\u064a\u0627\u0631 \u062f\u0648\u0644\u0627\u0631\u060c \u0627\u0654\u0648 5.24 \u062f\u0648\u0644\u0627\u0631 \u0644\u0644\u0633\u0647\u0645\u060c \u0642\u0628\u0644 \u0639\u0627\u0645. \u0643\u0645\u0627 \u062f\u0639\u0645\u062a \u0627\u0644\u0646\u062a\u0627\u064a\u0654\u062c \u0645\u0643\u0627\u0633\u0628 \u0627\u0633\u062a\u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0628\u0642\u064a\u0645\u0629 4.6 \u0645\u0644\u064a\u0627\u0631 \u062f\u0648\u0644\u0627\u0631 \u0645\u0631\u062a\u0628\u0637\u0629 \u0628\u062d\u0635\u0629 \u0627\u0644\u0628\u0646\u0643 \u0641\u064a \u0634\u0631\u0643\u0629 \u0641\u064a\u0632\u0627\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0645\u0643\u0627\u0633\u0628 \u0627\u0654\u062e\u0631\u064