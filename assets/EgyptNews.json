4\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u060c \u0627\u0655\u0630 \u064a\u062a\u0648\u0644\u0649 \u0645\u0646\u0630 \u064a\u0648\u0644\u064a\u0648 (\u062a\u0645\u0648\u0632) 2019 \u0631\u064a\u0654\u0627\u0633\u0629 \u0645\u0646\u0638\u0645\u0629 \u0627\u0644\u0628\u0627\u0633\u064a\u062c.\u0648\u0627\u0646\u0636\u0645 \u0627\u0655\u0644\u0649 \u0627\u0644\u062d\u0631\u0633 \u0627\u0644\u062b\u0648\u0631\u064a \u0639\u0627\u0645 1981\u060c \u062b\u0645 \u0642\u0627\u062f \u062e\u0644\u0627\u0644 \u0627\u0644\u062d\u0631\u0628 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0627\u0644\u0639\u0631\u0627\u0642\u064a\u0629 \u0633\u0631\u064a\u0629 \u062b\u0645 \u0643\u062a\u064a\u0628\u0629\u060c \u0648\u0634\u0627\u0631\u0643 \u0628\u0639\u062f\u0647\u0627 \u0641\u064a \u0639\u062f\u062f \u0643\u0628\u064a\u0631 \u0645\u0646 \u0627\u0644\u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629.\u0644\u0643\u0646 \u0631\u063a\u0645 \u062a\u0634\u0627\u0628\u0647 \u0627\u0633\u0645 \u0627\u0644\u0639\u0627\u064a\u0654\u0644\u0629\u060c \u0641\u0644\u0627 \u0635\u0644\u0629 \u062a\u0631\u0628\u0637\u0647 \u0628\u0642\u0627\u0633\u0645 \u0633\u0644\u064a\u0645\u0627\u0646\u064a\u060c \u0627\u0644\u0642\u0627\u064a\u0654\u062f \u0627\u0644\u0633\u0627\u0628\u0642 \u0644\u0641\u064a\u0644\u0642 \u0627\u0644\u0642\u062f\u0633 \u0627\u0644\u0630\u064a \u0627\u063a\u062a\u064a\u0644 \u0639\u0644\u0649 \u064a\u062f \u0627\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0641\u064a \u064a\u0646\u0627\u064a\u0631 (\u0643\u0627\u0646\u0648\u0646 \u0627\u0644\u062b\u0627\u0646\u064a) 2020.\u0647\u0630\u0627 \u0648\u062a\u062a\u0647\u0645 \u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 \u0648\u062d\u062f\u0629 \"\u0627\u0644\u0628\u0627\u0633\u064a\u062c\" \u062a\u062d\u062a \u0642\u064a\u0627\u062f\u062a\u0647\u060c \u0628\u0627\u0654\u0646\u0647\u0627 \u0634\u0643\u0651\u0644\u062a \u0627\u0654\u062f\u0627\u0629 \u0631\u064a\u0654\u064a\u0633\u064a\u0629 \u0641\u064a \u0642\u0645\u0639 \u0627\u0644\u0627\u062d\u062a\u062c\u0627\u062c\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629.\u0643\u0645\u0627 \u062a\u0631\u062c\u0651\u062d \u0627\u0654\u0646 \u064a\u0648\u0654\u062f\u064a \u0645\u0642\u062a\u0644 \u0633\u0644\u064a\u0645\u0627\u0646\u064a \u0627\u0655\u0644\u0649 \u0627\u0655\u0636\u0639\u0627\u0641 \u0642\u062f\u0631\u0629 \u0627\u0644\u0628\u0627\u0633\u064a\u062c \u0639\u0644\u0649 \u0636\u0628\u0637 \u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u062f\u0627\u062e\u0644\u064a \u0627\u0655\u0644\u0649 \u062d\u062f \u0643\u0628\u064a\u0631\u060c \u062e\u0627\u0635\u0629 \u0645\u0639 \u062a\u0635\u0627\u0639\u062f \u0627\u0644\u0636\u063a\u0648\u0637 \u062f\u0627\u062e\u0644 \u0627\u0655\u064a\u0631\u0627\u0646\u060c \u0648\u0641\u0642\u0627 \u0644\u0645\u0648\u0642\u0639 \"Israelnationalnews\".\u0627\u063a\u062a\u064a\u0627\u0644 \u0627\u0644\u0642\u0627\u062f\u0629\u064a\u0630\u0643\u0631 \u0627\u0654\u0646 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0643\u0627\u0646\u062a \u062a\u0648\u0639\u062f\u062a \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0645\u0631\u0629 \u0628\u0627\u063a\u062a\u064a\u0627\u0644 \u0642\u0627\u062f\u0629 \u0627\u0655\u064a\u0631\u0627\u0646 \u0627\u0644\u0643\u0628\u0627\u0631\u060c \u0641\u0636\u0644\u0627\u064b \u0639\u0646 \u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0646 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u064a\u0646.\u0643\u0645\u0627 \u0627\u0654\u0639\u0644\u0646 \u0645\u0643\u062a\u0628 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u0628\u0646\u064a\u0627\u0645\u064a\u0646 \u0646\u062a\u0646\u064a\u0627\u0647\u0648 \u0641\u064a \u0648\u0642\u062a \u0633\u0627\u0628\u0642 \u0627\u0644\u064a\u0648\u0645 \u0627