a.net/arab-and-world/american-elections-2016/2026/03/20/%D8%A7%D9%85%D9%8A%D8%B1%D9%83%D8%A7-%D8%AA%D9%81%D9%83%D9%83-%D8%B4%D8%A8%D9%83%D8%A9-%D8%B3%D9%8A%D8%A8%D8%B1%D8%A7%D9%86%D9%8A%D8%A9-%D8%A7%D9%8A%D8%B1%D8%A7%D9%86%D9%8A%D8%A9-%D9%84%D8%A7%D8%B3%D8%AA%D9%87%D8%AF%D8%A7%D9%81-%D8%B5%D8%AD%D9%81%D9%8A%D9%8A%D9%86-%D9%88%D9%85%D8%B9%D8%A7%D8%B1%D8%B6%D9%8A%D9%86", "title": "\u0627\u0654\u0645\u064a\u0631\u0643\u0627 \u062a\u0641\u0643\u0643 \u0634\u0628\u0643\u0629 \u0633\u064a\u0628\u0631\u0627\u0646\u064a\u0629 \u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0644\u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0635\u062d\u0641\u064a\u064a\u0646 \u0648\u0645\u0639\u0627\u0631\u0636\u064a\u0646", "description": "\u0627\u0654\u0639\u0644\u0646\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0639\u062f\u0644 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0645\u0635\u0627\u062f\u0631\u0629 \u0627\u0654\u0631\u0628\u0639\u0629 \u0646\u0637\u0627\u0642\u0627\u062a \u0627\u0655\u0644\u0643\u062a\u0631\u0648\u0646\u064a\u0629 \u0642\u0627\u0644\u062a \u0627\u0655\u0646\u0647\u0627 \u0643\u0627\u0646\u062a \u062a\u064f\u0633\u062a\u062e\u062f\u0645 \u0645\u0646 \u0642\u0628\u0644 \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0627\u0633\u062a\u062e\u0628\u0627\u0631\u0627\u062a \u0648\u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u0641\u064a \u062a\u0646\u0641\u064a\u0630 \u0639\u0645\u0644\u064a\u0627\u062a \u0627\u062e\u062a\u0631\u0627\u0642 \u0648\u0647\u062c\u0645\u0627\u062a \u0646\u0641\u0633\u064a\u0629 \u0639\u0627\u0628\u0631\u0629 \u0644\u0644\u062d\u062f\u0648\u062f.\u0648\u0630\u0643\u0631\u062a \"\u0627\u0644\u0639\u062f\u0644 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629\" \u0627\u0654\u0646 \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u0645\u0635\u0627\u062f\u0631\u0629 \u0627\u0633\u062a\u062e\u062f\u0645\u062a \u0644\u0646\u0634\u0631 \u0628\u064a\u0627\u0646