ription": "\u0642\u0627\u0644 \u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0645\u064a \u0648\u0627\u0644\u0643\u0627\u062a\u0628 \u0627\u0644\u0635\u062d\u0641\u064a \u0645\u062c\u062f\u064a \u0627\u0644\u062c\u0644\u0627\u062f\u060c \u0631\u064a\u0654\u064a\u0633 \u062a\u062d\u0631\u064a\u0631 \u0645\u0648\u0654\u0633\u0633\u0629 \"\u0627\u0654\u0648\u0646\u0627\" \u0644\u0644\u0635\u062d\u0627\u0641\u0629 \u0648\u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \u0627\u0644\u062a\u064a \u062a\u0636\u0645 \u0645\u0648\u0627\u0642\u0639: (\u0645\u0635\u0631\u0627\u0648\u064a\u060c \u064a\u0644\u0627 \u0643\u0648\u0631\u0629\u060c \u0634\u064a\u0641\u062a\u060c \u0627\u0644\u0643\u0648\u0646\u0633\u062a\u0644\u0648)\u060c \u0627\u0655\u0646 \u062d\u062f\u064a\u062b\u0647 \u0627\u0644\u0627\u0654\u062e\u064a\u0631 \u062c\u0627\u0621 \u0645\u0648\u062c\u0647\u064b\u0627 \u0627\u0655\u0644\u0649 \u0645\u062c\u0644\u0633 \u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0648\u0627\u0644\u062c\u0645\u0639\u064a\u0629 \u0627\u0644\u0639\u0645\u0648\u0645\u064a\u0629 \u0648\u062c\u0645\u0627\u0647\u064a\u0631 \u0627\u0644\u0643\u0631\u0629 \u0627\u0644\u0645\u0635\u0631\u064a\u0629\u060c \u0645\u0648\u0654\u0643\u062f\u064b\u0627 \u0627\u0654\u0646\u0647 \u064a\u062a\u062d\u062f\u062b \u0645\u0646 \u0645\u0646\u0637\u0644\u0642 \"\u0645\u062d\u0628 \u0644\u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u062d\u062a\u0649 \u0627\u0644\u0646\u062e\u0627\u0639\"\u060c \u0639\u0644\u0649 \u062d\u062f \u0642\u0648\u0644\u0647. \u0648\u0627\u0654\u0648\u0636\u062d \"\u0627\u0644\u062c\u0644\u0627\u062f\" \u062e\u0644\u0627\u0644 \u0641\u064a\u062f\u064a\u0648 \u062a\u0645 \u0628\u062b\u0647 \u0639\u0628\u0631 \u0645\u0646\u0635\u0627\u062a \u064a\u0644\u0627 \u0643\u0648\u0631\u0629\u060c \u0627\u0654\u0646 \u0627\u0646\u062a\u0645\u0627\u0621\u0647 \u0644\u0644\u0627\u0654\u0647\u0644\u064