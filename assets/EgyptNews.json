0646 \u0627\u0644\u0628\u0644\u062f\u064a\u0646\u060c \u0648\u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0641\u0639\u064a\u0644 \u0627\u0644\u062c\u0627\u0646\u0628 \u0627\u0644\u062a\u062f\u0631\u064a\u0628\u064a \u0644\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u0639\u0631\u0627\u0642\u064a\u0629. \u0648\u062c\u0627\u0621 \u0630\u0644\u0643 \u062e\u0644\u0627\u0644 \u0627\u062a\u0635\u0627\u0644 \u0647\u0627\u062a\u0641\u064a \u062a\u0644\u0642\u0627\u0647 \u0627\u0644\u0632\u064a\u062f\u064a \u0645\u0646 \u0647\u064a\u063a\u0633\u064a\u062b\u060c \u062d\u064a\u062b \u0642\u062f\u0645 \u0627\u0644\u0627\u0654\u062e\u064a\u0631 \u0627\u0644\u062a\u0647\u0646\u064a\u0654\u0629 \u0628\u0645\u0646\u0627\u0633\u0628\u0629 \u062a\u0643\u0644\u064a\u0641 \u0627\u0644\u0632\u064a\u062f\u064a \u0628\u062a\u0634\u0643\u064a\u0644 \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629. \u0648\u0648\u0641\u0642\u0627\u064b \u0644\u0628\u064a\u0627\u0646 \u0635\u0627\u062f\u0631 \u0639\u0646 \u0645\u0643\u062a\u0628 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0645\u0643\u0644\u0641\u060c \u0627\u0654\u0643\u062f \u0627\u0644\u062c\u0627\u0646\u0628\u0627\u0646 \u0639\u0644\u0649 \u0627\u0654\u0647\u0645\u064a\u0629 \u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0627\u0644\u062b\u0646\u0627\u064a\u0654\u064a\u0629 \u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u0627\u062a\u0641\u0627\u0642\u064a\u0629 \u0627\u0644\u0627\u0655\u0637\u0627\u0631 \u0627\u0644\u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a \u0644\u0639\u0627\u0645 2008\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u0646\u0638\u0645 \u0627\u0644\u0648\u062c\u0648\u062f \u0627\u0644\u0645\u0648\u0654\u0642\u062a \u0644\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0648\u0627\u0654\u0646\u0634\u0637\u062a\u0647\u0627 \u0641\u064a \u0627\u0644\u0628\u0644\u0627\u062f. \u0643\u0645\u0627 \u063