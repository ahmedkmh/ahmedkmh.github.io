641\u060c \u0644\u0643\u0646 \u0627\u0644\u062d\u0642\u064a\u0642\u0629 \u0627\u0654\u0646 \u0644\u0643\u0644 \u0647\u0627\u062a\u0641 \u0627\u0654\u0646\u062f\u0631\u0648\u064a\u062f \"\u062a\u0627\u0631\u064a\u062e \u0627\u0646\u062a\u0647\u0627\u0621 \u0635\u0644\u0627\u062d\u064a\u0629\" \u062a\u062d\u062f\u062f\u0647 \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0645\u0635\u0646\u0639\u0629 \u062d\u062a\u0649 \u0642\u0628\u0644 \u0637\u0631\u062d \u0627\u0644\u062c\u0647\u0627\u0632 \u0641\u064a \u0627\u0644\u0627\u0654\u0633\u0648\u0627\u0642.\u0648\u0644\u0627 \u064a\u062a\u0639\u0644\u0642 \u0647\u0630\u0627 \u0627\u0644\u062a\u0627\u0631\u064a\u062e \u0628\u0627\u0644\u062d\u0627\u0644\u0629 \u0627\u0644\u0645\u0627\u062f\u064a\u0629 \u0644\u0644\u0647\u0627\u062a\u0641\u060c \u0628\u0644 \u0628\u0645\u0648\u0639\u062f \u062a\u0648\u0642\u0641 \u0627\u0644\u0634\u0631\u0643\u0629 \u0639\u0646 \u0627\u0655\u0635\u062f\u0627\u0631 \u0627\u0644\u062a\u062d\u062f\u064a\u062b\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0644\u0647\u060c \u0648\u0647\u0648 \u0645\u0627 \u064a\u064f\u0639\u0631\u0641 \u0628\u0627\u0633\u0645 End of Life (EOL) \u0627\u0654\u0648 \"\u0646\u0647\u0627\u064a\u0629 \u062f\u0648\u0631\u0629 \u0627\u0644\u062f\u0639\u0645\".\u0648\u0628\u0645\u062c\u0631\u062f \u0648\u0635\u0648\u0644 \u0627\u0644\u0647\u0627\u062a\u0641 \u0627\u0655\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0645\u0631\u062d\u0644\u0629\u060c \u0633\u064a\u0648\u0627\u0635\u0644 \u0627\u0644\u0639\u0645\u0644 \u0628\u0634\u0643\u0644 \u0637\u0628\u064a\u0639\u064a\u060c \u0644\u0643\u0646\u0647 \u064a\u0635\u0628\u062d \u0627\u0654\u0643\u062b\u0631 \u0639\u0631\u0636\u0629 \u0644\u0644\u0647\u062c\u0645\u0627\u062a \u0627\u0644\u0627\u0655\u0644\u0643\u062a\u0631\u0648\u0646\u064a\u0629 \u0648\u0627\u0644\u062b\u063a\u0631\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0645\u0639 \u0645\u0631\u0648\u0631 \u0627\u0644\u0648\u0642