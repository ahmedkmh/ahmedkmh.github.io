u0633\u062a\u0627\u0631 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u0631\u064a\u0627\u0636\u064a \u0628\u0627\u0644\u0646\u0633\u0628\u0629 \u0644\u0641\u0631\u0642 \u0627\u0644\u0627\u0654\u0644\u0639\u0627\u0628 \u0627\u0644\u062c\u0645\u0627\u0639\u064a\u0629 \u0628\u0627\u0644\u0642\u0644\u0639\u0629 \u0627\u0644\u0628\u064a\u0636\u0627\u0621\u060c \u0648\u0644\u0645 \u064a\u0643\u0646 \u0645\u0648\u0633\u0645 2025-2026 \u0628\u0627\u0644\u0635\u0648\u0631\u0629 \u0627\u0644\u062a\u064a \u0643\u0627\u0646 \u064a\u062d\u0644\u0645 \u0628\u0647\u0627 \u062c\u0645\u0627\u0647\u064a\u0631 \u0627\u0644\u0627\u0654\u0628\u064a\u0636. \u0648\u0643\u0627\u0646\u062a \u062c\u0645\u0627\u0647\u064a\u0631 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u062a\u062d\u0644\u0645 \u0628\u0645\u0648\u0633\u0645 \u0645\u0631\u0636\u064a \u0644\u064a\u0647\u0627 \u0628\u0639\u062f \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0641\u064a \u0638\u0644 \u0627\u0644\u062a\u062f\u0639\u064a\u0645\u0627\u062a \u0627\u0644\u062a\u064a \u0642\u0627\u0645\u062a \u0628\u0647\u0627 \u0627\u0644\u0641\u0631\u0642 \u0627\u0644\u062c\u0645\u0627\u0639\u064a\u0629 \u0628\u0627\u0644\u0642\u0644\u0639\u0629 \u0627\u0644\u0628\u064a\u0636\u0627\u0621 ( \u0633\u0644\u0629 \u0648\u0637\u0627\u064a\u0654\u0631\u0629 \u0648\u064a\u062f). \u0648\u0646\u062c\u062d\u062a \u0633\u0644\u0629 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u0641\u064a \u062d\u0641\u0638 \u0645\u0627\u0621 \u0648\u062c\u0647 \u0645\u0648\u0633\u0645 \u0627\u0644\u0627\u0654\u0644\u0639\u0627\u0628 \u0627\u0644\u062c\u0645\u0627\u0639\u064a\u0629 \u0644\u0641\u0631\u0642 \u0627\u0644\u0642\u0644\u0639\u0629 \u0627\u0644\u0628\u064a\u0636\u0627\u0621 \u0628\u0639\u062f \u0627\u0644\u062a\u062a\u0648\u064a\u062c \u0628\u0643\u0627\u0654\u0633 \u0645\u0635\u0631 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0635\u0631\u064a\u0629 \u0644\u0644\u0627\u062a\u0635\u0627\u0644\u0627\u062a \u0628\u0639\u062f \u0627\u0644\u062a\u063a\u0644\u0628 \u0639\u0644\u064a\u0647 \u0628\u0646\u062a\u064a\u062c\u0629 87-68. \u0628\u064a\u0646\u0645\u0627 \u0644\u0645 \u064a\u0646\u062c \u0641\u0631\u064a\u0642\u0627 \u0627\u0644\u064a\u062f \u0648\u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0629 \u0631\u062c\u0627\u0644 \u0628\u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u0641\u064a \u0627\u0644\u062e\u0631\u0648\u062c \u0628\u0627\u0654\u064a \u0628\u0637\u0648\u0644\u0629 \u0628\u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062d\u0627\u0644\u064a\u060c \u0648\u0628\u0627\u0644\u0631\u063a\u0645 \u0645\u0646 \u062a\u062a\u0648\u064a\u062c \u0637\u0627\u064a\u0654\u0631\u0629 \u0627\u0644\u0627\u0654\u0628\u064a\u0636 \u0628\u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0627\u0644\u0639\u0631\u0628\u064a\u0629 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u0645\u0627\u0636\u064a \u0644\u0643\u0646 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0644\u0645 \u064a\u062d\u0642\u0642\u0648\u0627 \u0627\u0654\u064a \u0644\u0642\u0628. \u0648\u0646\u0641\u0633 \u0627\u0644\u062d\u0627\u0644 \u064a\u0646\u0637\u0628\u0642 \u0639\u0644\u0649 \u0637\u0627\u064a\u0654\u0631\u0629 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u0633\u064a\u062f\u0627\u062a \u0648\u0627\u0644\u062a\u064a \u0643\u0627\u0646\u062a \u062a\u0648\u062c\u062a \u0628\u0644\u0642\u0628\u064a\u0646 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0644\u0643\u0646 \u0641\u064a \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062d\u0627\u0644\u064a \u0644\u0645 \u064a\u0646\u062c\u062d \u0627\u0644\u0641\u0631\u064a\u0642 \u0641\u064a \u062d\u0635\u062f \u0627\u0654\u064a \u0628\u0637\u0648\u0644\u0629. \u062e\u0633\u0631 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u0628\u0637\u0648\u0644\u0629 \u062f\u0648\u0631\u064a \u0627\u0644\u0633\u0648\u0628\u0631 \u0644\u0644\u0633\u0644\u0629 \u0628\u0639\u062f \u0627\u0644\u062e\u0631\u0648\u062c \u0645\u0646 \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0628\u0639\u062f \u0627\u0644\u0647\u0632\u064a\u0645\u0629 \u0627\u0654\u0645\u0627\u0645 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0633\u0643\u0646\u062f\u0631\u064a \u0628\u0646\u062a\u064a\u062c\u0629 1-3 \u0641\u064a \u0633\u0644\u0633\u0644\u0629 \u0645\u0648\u0627\u062c\u0647\u0627\u062a \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a. \u0643\u0645\u0627 \u0648\u062f\u0639 \u0631\u062c\u0627\u0644 \u0633\u0644\u0629 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u062f\u0648\u0631\u064a \u0627\u0644\u0645\u0631\u062a\u0628\u0637 \u0645\u0646 \u0631\u0628\u0639 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0628\u0639\u062f \u062e\u0633\u0627\u0631\u0629 \u0641\u0631\u064a\u0642 \u0627\u0644\u0645\u0631\u062a\u0628\u0637 \u062a\u062d\u062a 18 \u0639\u0627\u0645\u0627 \u0630\u0647\u0627\u0628\u0627 \u0648\u0627\u0655\u064a\u0627\u0628 \u0627\u0654\u0645\u0627\u0645 \u0633\u0645\u0648\u062d\u0629\u060c \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u062e\u0633\u0627\u0631\u0629 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u0644\u0627\u0654\u0628\u064a\u0636 \u0627\u0654\u0645\u0627\u0645 \u0646\u0638\u064a\u0631\u0647 \u0633\u0645\u0648\u062d\u0629 \u0628\u0646\u062a\u064a\u062c\u0629 72-73. \u0646\u062c\u062d \u0631\u062c\u0627\u0644 \u0633\u0644\u0629 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u0641\u064a \u0627\u0644\u0641\u0648\u0632 \u0628\u0644\u0642\u0628 \u0643\u0627\u0654\u0633 \u0645\u0635\u0631 \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0627\u0644\u0645\u0635\u0631\u064a\u0629 \u0644\u0644\u0627\u062a\u0635\u0627\u0644\u0627\u062a \u0628\u0646\u062a\u064a\u062c\u0629 87-68\u060c \u0644\u064a\u0639\u062f \u0647\u0630\u0627 \u0627\u0644\u0644\u0642\u0628 \u0647\u0648 \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u0633\u0644\u0629 \u0627\u0644\u0642\u0644\u0639\u0629 \u0627\u0644\u062d\u0645\u0631\u0627\u0621 \u0645\u0646\u0630 2006. \u0627\u0654\u064a \u0627\u0654\u0646 \u0641\u0631\u064a\u0642 \u0627\u0644\u0633\u0644\u0629 \u0628\u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u0641\u0627\u0632 \u0628\u0628\u0637\u0648\u0644\u0629 \u0648\u062e\u0633\u0631 \u0628\u0637\u0648\u0644\u062a\u064a\u0646 \u0648\u0647\u0645 \u062f\u0648\u0631\u064a \u0627\u0644\u0633\u0648\u0628\u0631 \u0648\u062f\u0648\u0631\u064a \u0627\u0644\u0645\u0631\u062a\u0628\u0637. \u064a\u0634\u0627\u0631\u0643 \u0641\u0631\u064a\u0642 \u0633\u064a\u062f\u0627\u062a \u0627\u0644\u0633\u0644\u0629 \u0628\u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u0628\u062f\u0648\u0631\u064a \u0627\u0644\u062f\u0631\u062c\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629. \u062e\u0633\u0631 \u0641\u0631\u064a\u0642 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u062c\u0645\u064a\u0639 \u0627\u0644\u0628\u0637\u0648\u0644\u0627\u062a \u0627\u0644\u0645\u062d\u0644\u064a\u0629 \u0627\u0644\u062a\u064a \u0634\u0627\u0631\u0643 \u0641\u064a\u0647\u0627 \u0641\u064a \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u0645\u062d\u0644\u064a ( \u062f\u0648\u0631\u064a \u0648\u0643\u0627\u0654\u0633 \u0645\u0635\u0631 \u0648\u0643\u0627\u0654\u0633 \u0627\u0644\u0633\u0648\u0628\u0631). \u0648\u062e\u0633\u0631 \u0641\u0631\u064a\u0642 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 \u0631\u062c\u0627\u0644 \u0644\u0643\u0631\u0629 \u0627\u0644\u064a\u062f \u0627\u0654\u0648\u0644\u0649 \u0628\u0637\u0648\u0644\u0627\u062a \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u0645\u062d\u0644\u064a \u0628\u0639\u062f \u0627\u0644\u062e\u0631\u0648\u062c \u0627\u0654\u0645\u0627\u0645 \u0633\u0645\u0648\u062d\u0629 \u0641\u064a \u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a \u0643\u0627\u0654\u0633 \u0627\u0644\u0633\u0648\u0628\u0631 \u0628\u0639\u062f \u0627\u0644\u0647\u0632\u064a\u0645\u0629 \u0628\u0646\u062a\u064a\u062c\u0629