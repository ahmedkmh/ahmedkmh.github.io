86-%D9%88%D8%A7%D9%84%D8%AD%D8%B5%D9%8A%D9%84%D8%A9-%D8%AA%D8%B1%D8%AA%D9%81%D8%B9-%D8%A7%D9%84%D9%89-1888", "title": "\u0627\u0654\u0643\u062b\u0631 \u0645\u0646 300 \u0642\u062a\u064a\u0644 \u0641\u064a \u0644\u0628\u0646\u0627\u0646 \u0648\u0627\u0644\u062d\u0635\u064a\u0644\u0629 \u062a\u0631\u062a\u0641\u0639 \u0627\u0655\u0644\u0649 1888", "description": "\u0627\u0654\u0641\u0627\u062f\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0635\u062d\u0629 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a\u0629 \u0641\u064a \u062d\u0635\u064a\u0644\u0629 \u062c\u062f\u064a\u062f\u0629\u060c \u0645\u0633\u0627\u0621 \u0627\u0644\u062e\u0645\u064a\u0633\u060c \u0628\u0627\u0654\u0646 \u0645\u0648\u062c\u0629 \u0627\u0644\u063a\u0627\u0631\u0627\u062a \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 \u0627\u0644\u0643\u062b\u064a\u0641\u0629 \u0639\u0644\u0649 \u0644\u0628\u0646\u0627\u0646\u060c \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u0627\u0654\u0633\u0641\u0631\u062a \u0639\u0646 \u0645\u0642\u062a\u0644 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 300 \u0634\u062e\u0635\u060c \u0648\u0627\u0655\u0635\u0627\u0628\u0629 \u0645\u0627 \u0644\u0627 \u064a\u0642\u0644 \u0639\u0646 1150 \u0627\u0653\u062e\u0631\u064a\u0646.\u0648\u0642\u0627\u0644\u062a \u0627\u0644\u0648\u0632\u0627\u0631\u0629 \u0641\u064a \u0628\u064a\u0627\u0646\u060c \u0627\u0655\u0646 \u0627\u0644\u062d\u0635\u064a\u0644\u0629 \u0627\u0644\u0627\u0655\u062c\u0645\u0627\u0644\u064a\u0629 \u0645\u0646\u0630 \u0628\u062f\u0621 \u0627\u0644\u062d\u0631\u0628 \u0628\u064a\u0646 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0648\u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0641\u064a \u0627\u0644\u062b\u0627\u0646\u064a \u0645\u0646 \u0645\u0627\u0631\u0633 (\u0627\u0653\u0630\u0627\u0631) \u0628\u0644\u063a\u062a 1888 \u0642\u062a\u064a\u0644\u0627\u064b \u06486092 \u062c\u0631\u064a\u062d\u0627\u064b.\u0643\u0645\u0627 \u0627\u0654\u0634\u0627\u0631\u062a \u0627\u0644\u0648\u0632\u0627\u0631\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u062d\u0635\u064a\u0644\u0629 \u0642\u062a\u0644\u0649 \u0636\u0631\u0628\u0627\u062a \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 \u062a\u0636\u0645 71 \u0627\u0645\u0631\u0627\u0654\u0629 \u064830 \u0637\u0641\u0644\u0627\u064b \u06489 \u0645\u0633\u0646\u064a\u0646.\u0648\u0644\u0641\u062a\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u062d\u0635\u064a\u0644\u0629 \u0645\u0631\u0634\u062d\u0629 \u0644\u0644\u0627\u0631\u062a\u0641\u0627\u0639 \u0645\u0639 \u062a\u0648\u0627\u0635\u0644 \u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u0628\u062d\u062b \u0648\u0627\u0644\u0627\u0655\u0646\u0642\u0627\u0630 \u0648\u0641\u062d\u0648\u0635 \u0627\u0644\u062d\u0645\u0636 \u0627\u0644\u0646\u0648\u0648\u064a \u0627\u0644\u062a\u064a \u062a\u062c\u0631\u0649 \u0639\u0644\u0649 \u0627\u0644\u062c\u062b\u062b.\u0645\u0642\u062a\u0644 4 \u062c\u0646\u0648\u062f \u0644\u0628\u0646\u0627\u0646\u064a\u064a\u0646\u0648\u0646\u0639\u0649 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a \u0627\u0654\u0631\u0628\u0639\u0629 \u062c\u0646\u0648\u062f \u0642\u062a\u0644\u0648\u0627 \u0641\u064a \u0636\u0631\u0628\u0627\u062a \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u0628\u064a\u0646\u0647\u0645 \u0631\u0642\u064a\u0628 \u0627\u0654\u0648\u0644 \u0642\u062a\u0644 \u0641\u064a \u0635\u064a\u062f\u0627 (\u062c\u0646\u0648\u0628)\u060c \u0641\u064a\u0645\u0627 \u0642\u062a\u0644 \u0627\u0644\u0628\u0642\u064a\u0629 \u0641\u064a \u0628\u0644\u062f\u0629 \u0634\u0645\u0633\u0637\u0627\u0631 \u0641\u064a \u0628\u0639\u0644\u0628\u0643 \u0648\u0628\u0644\u062f\u0629 \u0627\u0644\u0645\u0646\u0635\u0648\u0631\u0629 \u0641\u064a \u0627\u0644\u0647\u0631\u0645\u0644 \u0628\u0634\u0631\u0642 \u0627\u0644\u0628\u0644\u0627\u062f.\u0628\u0630\u0644\u0643\u060c \u062a\u0631\u062a\u0641\u0639 \u0627\u0655\u0644\u0649 