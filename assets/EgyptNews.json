4 \u06482025.\u0648\u064a\u0634\u0647\u062f \u0627\u0644\u0633\u0648\u062f\u0627\u0646 \u0645\u0646\u0630 \u0627\u0654\u0628\u0631\u064a\u0644 (\u0646\u064a\u0633\u0627\u0646) 2023 \u062d\u0631\u0628\u0627\u064b \u0628\u064a\u0646 \u0627\u0644\u062c\u064a\u0634 \u0648\u0642\u0648\u0627\u062a \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0627\u0654\u0633\u0641\u0631\u062a \u0628\u062d\u0633\u0628 \u0627\u0644\u0627\u0654\u0645\u0645 \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0639\u0646 \u0645\u0642\u062a\u0644 \u0639\u0634\u0631\u0627\u062a \u0627\u0653\u0644\u0627\u0641 \u0627\u0644\u0627\u0654\u0634\u062e\u0627\u0635 \u0648\u0646\u0632\u0648\u062d \u0627\u0644\u0645\u0644\u0627\u064a\u064a\u0646.\u0648\u0643\u0627\u0646\u062a \u0628\u0639\u062b\u0629 \u062f\u0648\u0644\u064a\u0629 \u0645\u0633\u062a\u0642\u0644\u0629 \u0644\u062a\u0642\u0635\u064a \u0627\u0644\u062d\u0642\u0627\u064a\u0654\u0642 \u0641\u064a \u0627\u0644\u0633\u0648\u062f\u0627\u0646 \u0642\u062f \u062e\u0644\u0635\u062a \u0641\u064a \u0641\u0628\u0631\u0627\u064a\u0631 (\u0634\u0628\u0627\u0637) \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u062c\u0648\u0645 \u0639\u0627\u0645 2025 \u0639\u0644\u0649 \u0627\u0644\u0641\u0627\u0634\u0631 \u064a\u062d\u0645\u0644 \"\u0633\u0645\u0627\u062a \u0627\u0644\u0627\u0655\u0628\u0627\u062f\u0629 \u0627\u0644\u062c\u0645\u0627\u0639\u064a\u0629\".\u0648\u062a\u0648\u0635\u0644 \u062a\u0642\u0631\u064a\u0631 \u0645\u0646\u0638\u0645\u0629 \u0627\u0644\u0639\u0641\u0648 \u0627\u0644\u062f\u0648\u0644\u064a\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0642\u0648\u0627\u062a \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \"\u0627\u0631\u062a\u0643\u0628\u062a \u062c\u0631\u0627\u064a\u0654\u0645 \u0636\u062f \u0627\u0644\u0627\u0655\u0646\u0633\u0627\u0646\u064a\u0629 \u0648\u062a\u0637\u0647\u064a\u0631\u0627\u064b \u0639\u0631\u0642\u064a\u0627\u064b \u062e\u0644\u0627\u0644 \u062d\u0645\u0644\u062a\u0647\u0627 \u0644\u0644\u0633\u064a\u0637\u0631\u0629 \u0639\u0644\u0649 \u0627\u0644\u0641\u0627\u0634\u0631\".\u0648\u0627\u0654\u062c\u0631\u062a \u0627\u0644\u0645\u0646\u0638\u0645\u0629 \u0645\u0642\u0627\u0628\u0644\u0627\u062a \u0645\u0639 247 \u0645\u0646 \u0627\u0644\u0636\u062d\u0627\u064a\u0627 \u0627\u0654\u0648 \u0627\u0644\u0634\u0647\u0648\u062f \u0641\u064a \u0634\u0645\u0627\u0644 \u062f\u0627\u0631\u0641\u0648\u0631 \u0628\u064a\u0646 \u0627\u0654\u0648\u0627\u064a\u0654\u0644 \u0639\u0627\u0645 2024 \u0648\u0627\u0654\u0643\u062a\u0648\u0628\u0631 (\u062a\u0634\u0631\u064a\u0646 \u0627\u0644\u0627\u0654\u0648\u0644) 2025.\u0648\u0627\u0654\u0641\u0627\u062f \u0627\u0644\u062a\u0642\u0631\u064a\u0631 \u0628\u0627\u0654\u0646 \u0642\u0648\u0627\u062a \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u0633\u0631\u064a\u0639 \u0634\u0646\u062a \u0647\u062c\u0645\u0627\u062a \u0645\u0645\u0646\u0647\u062c\u0629 \u0639\u0644\u0649 \u062a\u062c\u0645\u0639\u0627\u062a \u0633\u0643\u0627\u0646\u064a\u0629 \u0641\u064a \u0645\u062d\u064a\u0637 \u0645\u062f\u064a\u0646\u0629 \u0627\u0644\u0641\u0627\u0634\u0631\u060c \u0643\u0627\u0646\u062a \u062a\u0648\u0654\u0648\u064a \u0627\u0654\u0628\u0646\u0627\u0621 \u0645\u0646 \u0642\u0628\u064a\u0644\u0629 \u0627\u0644\u0632\u063a\u0627\u0648\u0629 \u0627\u0644\u0639\u0631\u0642\u064a\u0629 \u0641\u064a \u063a\u0631\u0628 \u062f\u0627\u0631\u0641\u0648\u0631.\u0648\u0627\u0654\u0634\u0627\u0631 \u0627\u0644\u062a\u0642\u0631\u064a\u0631 \u0627\u0655\u0644\u0649 \u0648\u0642\u0648\u0639 \u0627\u0654\u0639\u0645\u0627\u0644 \u0639\u0646\u0641 \u0648\u0627\u0633\u0639\u0629 \u0627\u0644\u0646\u0637\u0627\u0642 \u0648\u0645\u062a\u0639\u0645\u062f\u0629 \u0636\u062f \u0627\u0654\u0637\u0641\u0627\u0644\u060c \u0634\u0645\u0644\u062a \u0627\u0644\u0642\u062a\u0644 \u0648\u0627\u0644\u0627\u062e\u062a\u0637\u0627\u0641 \u0648\u0627\u0644\u062a\u062c\u0646\u064a\u062f \u0627\u0644\u0642\u0633\u0631\u064a \u0648\u0627\u0644\u