u0646\u063a \u062b\u0644\u0627\u062b\u064a \u0627\u0644\u0637\u064a\u0627\u062a \"Galaxy Z TriFold 2\" \u0642\u062f \u064a\u064f\u0637\u0631\u062d \u0628\u0645\u0641\u0635\u0644\u0627\u062a \u0645\u062d\u0633\u0651\u0646\u0629. \u062d\u064a\u062b \u0642\u062f \u0644\u0627 \u064a\u0642\u062a\u0635\u0631 \u0627\u0644\u062a\u062d\u0633\u064a\u0646 \u0639\u0644\u0649 \u0627\u0644\u0645\u062a\u0627\u0646\u0629 \u0641\u0642\u0637\u060c \u0628\u0644 \u0642\u062f \u064a\u0634\u0645\u0644 \u0627\u0654\u064a\u0636\u064b\u0627 \u062c\u0648\u0627\u0646\u0628 \u0627\u0654\u062e\u0631\u0649 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u062c\u064a\u0644 \u0627\u0644\u0627\u0654\u0648\u0644 \u0645\u0646 \u0627\u0644\u0647\u0627\u062a\u0641.\u0648\u0628\u062d\u0633\u0628 \u0645\u0627 \u0642\u0627\u0644\u0647 \u0645\u0635\u062f\u0631 \u0644\u0645\u0646\u0635\u0629 \"Naver\" \u0627\u0644\u0643\u0648\u0631\u064a\u0629 \u0627\u0644\u062c\u0646\u0648\u0628\u064a\u0629\u060c \u062a\u0639\u0645\u0644 \"\u0633\u0627\u0645\u0633\u0648\u0646\u063a\" \u0639\u0644\u0649 \u062a\u0637\u0648\u064a\u0631 \u0645\u0641\u0635\u0644\u0627\u062a \u0645\u062d\u0633\u0646\u0629 \u0644\u0647\u0627\u062a\u0641 Galaxy Z TriFold 2\u060c \u062d\u064a\u062b \u062a\u064f\u0639\u0637\u064a \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0648\u064a\u0629 \u0644\u0644\u062a\u0635\u0645\u064a\u0645 \u062e\u0641\u064a\u0641 \u0627\u0644\u0648\u0632\u0646 \u0648\u0627\u0644\u0646\u062d\u064a\u0641 \u0644\u0644\u063a\u0627\u064a\u0629.\u0648\u0642\u062f \u062a\u064f\u0633\u062a\u062e\u062f\u0645 \u0647\u0630\u0647 \u0627\u0644\u0645\u0641\u0635\u0644\u0629 \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0641\u064a \u0647\u0648\u0627\u062a\u0641 \u0627\u0654\u062e\u0631\u0649 \u0642\u0627\u0628\u0644\u0629 \u0644\u0644\u0637\u064a \u0645\u0646 \"\u0633\u0627\u0645\u0633\u0648\u0646\u063a\"\u060c \u0628\u062d\u0633\u0628 \u0645\u0627 \u0646\u0642\u0644\u0647 \u062a\u0642\u0631\u064a\u0631 \u0644\u0645\u0648\u0642\u0639 \"Sammy Fans\" \u0639\u0646 \"Naver\"\u060c \u0627\u0637\u0644\u0639\u062a \u0639\u0644\u064a\u0647 \"\u0627\u0644\u0639\u0631\u0628\u064a\u0629 Business\".\u064a\u0628\u0644\u063a \u0633\u064f\u0645\u0643 \u0647\u0627\u062a\u0641 Galaxy Z TriFold \u0627\u0644\u0627\u0654\u0635\u0644\u064a 12.9 \u0645\u0644\u0645 \u0639\u0646\u062f \u0627\u0655\u063a\u0644\u0627\u0642\u0647\u060c \u0648\u0647\u0648 \u0627\u0654\u0643\u062b\u0631 \u0633\u064f\u0645\u0643\u064b\u0627 \u0628\u0643\u062b\u064a\u0631 \u0645\u0646 \u0647\u0627\u062a\u0641 Galaxy Z Fold 7 \u0627\u0644\u0630\u064a \u064a\u0628\u0644\u063a 8.9 \u0645\u0644\u0645\u060c \u0648\u0647\u0627\u062a\u0641 Galaxy S26 Ultra \u0627\u0644\u0630\u064a \u064a\u0628\u0644\u063a 7.9 \u0645\u0644\u0645.\u0648\u064a\u0632\u0646 \u0627\u0644\u0647\u0627\u062a\u0641 \u062b\u0644\u0627\u062b\u064a \u0627\u0644\u0637\u064a\u0627\u062a 309 \u063a\u0631\u0627\u0645\u0627\u062a\u060c \u0648\u0647\u0648 \u0641\u0631\u0642 \u0643\u0628\u064a\u0631 \u0645\u0642\u0627\u0631\u0646\u0629\u064b \u0628\u0640 Z Fold 7 \u0648S26 Ultra \u0627\u0644\u0644\u0630\u064a\u0646 \u064a\u0632\u0646 \u0643\u0644 \u0645\u0646\u0647\u0645\u0627 215 \u0648214 \u063a\u0631\u0627\u0645\u064b\u0627 \u0639\u0644\u0649 \u0627\u0644\u062a\u0648\u0627\u0644\u064a.\u062a\u0639\u062a\u0645\u062f \u0627\u0644\u0627\u0654\u062c\u0647\u0632\u0629 \u0627\u0644\u0642\u0627\u0628\u0644\u0629 \u0644\u0644\u0637\u064a \u0628\u0634\u0643\u0644 \u0643\u0628\u064a\u0631 \u0639\u0644\u0649 \u0627\u0644\u0645\u0641\u0635\u0644\u0627\u062a\u060c \u0627\u0644\u062a\u064a \u062a\u062f\u0639\u0645 \u0647\u064a\u0643\u0644 \u0627\u0644\u062c\u0647\u0627\u0632 \u0628\u0627\u0644\u0643\u0627\u0645\u0644. \u0641\u0627\u0644\u0645\u0641\u0635\u0644\u0629 \u0647\u064a \u0627\u0644\u0645\u0643\u0648\u0646 \u0627\u0644\u0630\u064a \u064a\u0631\u0628\u0637 \u0627\u0644\u0634\u0627\u0634\u0627\u062a \u0628\u0628\u0639\u0636\u0647\u0627\u060c \u0643\u0645\u