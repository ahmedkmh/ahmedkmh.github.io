0641\u0631\u0628\u0648\u0644\u060c \u0641\u064a\u0645\u0627 \u062a\u0627\u0654\u0647\u0644 \u0627\u0654\u062a\u0644\u062a\u064a\u0643\u0648 \u0645\u062f\u0631\u064a\u062f \u0628\u0639\u062f \u062a\u062e\u0637\u064a\u0647 \u0639\u0642\u0628\u0629 \u0628\u0631\u0634\u0644\u0648\u0646\u0629. \u0648\u0639\u0644\u0649 \u0627\u0644\u062c\u0627\u0646\u0628 \u0627\u0644\u0627\u0653\u062e\u0631\u060c \u0646\u062c\u062d \u0628\u0627\u064a\u0631\u0646 \u0645\u064a\u0648\u0646\u062e \u0641\u064a \u0627\u0655\u0642\u0635\u0627\u0621 \u0631\u064a\u0627\u0644 \u0645\u062f\u0631\u064a\u062f\u060c \u0628\u064a\u0646\u0645\u0627 \u062d\u062c\u0632 \u0627\u0653\u0631\u0633\u0646\u0627\u0644 \u0645\u0642\u0639\u062f\u0647 \u0641\u064a \u0646\u0635\u0641 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0639\u0644\u0649 \u062d\u0633\u0627\u0628 \u0633\u0628\u0648\u0631\u062a\u0646\u062c \u0644\u0634\u0628\u0648\u0646\u0629. \u0645\u0648\u0627\u0639\u064a\u062f \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0654\u0648\u0631\u0648\u0628\u0627 2026 \u0645\u0648\u0627\u062c\u0647\u0627\u062a \u0646\u0635\u0641 \u0646\u0647\u0627\u064a\u0654\u064a \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0654\u0648\u0631\u0648\u0628\u0627 \u0628\u0627\u0631\u064a\u0633 \u0633\u0627\u0646 \u062c\u064a\u0631\u0645\u0627\u0646 \u00d7 \u0628\u0627\u064a\u0631\u0646 \u0645\u064a\u0648\u0646\u062e \u0627\u0644\u0630\u0647\u0627\u0628: \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 28 \u0627\u0654\u0628\u0631\u064a\u0644 \u2013 10 \u0645\u0633\u0627\u0621\u064b \u0627\u0644\u0627\u0655\u064a\u0627\u0628: \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 6 \u0645\u0627\u064a\u0648 \u2013 10 \u0645\u0633\u0627\u0621\u064b \u0627\u0654\u062a\u0644\u062a\u064a\u0643\u0648 \u0645\u062f\u0631\u064a\u062f \u00d7 \u0627\u0653\u0631\u0633\u0646\u0627\u0644 \u0627\u064