0645\u0627\u0631\u0627\u062a \u062a\u062d\u0628\u0637 \u0645\u062e\u0637\u0637\u0627\u064b \u0644\u062a\u0631\u0648\u064a\u062c \u0627\u0644\u0645\u062e\u062f\u0631\u0627\u062a \u062f\u0627\u062e\u0644 \u0627\u0644\u0628\u0644\u0627\u062f \u064a\u0636\u0645 23 \u0645\u062a\u0647\u0645\u0627\u064b", "description": "\u0627\u0654\u062d\u0628\u0637\u062a \u0627\u0644\u0627\u0655\u0645\u0627\u0631\u0627\u062a \u0645\u062e\u0637\u0637\u0627\u064b \u064a\u0633\u062a\u0647\u062f\u0641 \u062a\u0631\u0648\u064a\u062c \u0627\u0644\u0645\u062e\u062f\u0631\u0627\u062a\u060c \u064a\u0636\u0645 \u0646\u062d\u0648 23 \u0645\u062a\u0647\u0645\u0627\u064b \u062f\u0627\u062e\u0644 \u0627\u0644\u0628\u0644\u0627\u062f\u060c \u0641\u064a \u062d\u064a\u0646 \u0645\u0627 \u064a\u0632\u0627\u0644 \u0627\u0644\u0645\u062a\u0647\u0645 \u0628\u0627\u0655\u062f\u0627\u0631\u0629 \u0627\u0644\u0634\u0628\u0643\u0629 \u0641\u064a \u0627\u0644\u062e\u0627\u0631\u062c\u060c \u0643\u0645\u0627 \u0636\u064f\u0628\u0637 \u0628\u062d\u0648\u0632\u062a\u0647\u0645 \u0643\u0645\u064a\u0627\u062a \u0643\u0628\u064a\u0631\u0629 \u0645\u0646 \u0627\u0644\u0645\u0648\u0627\u062f \u0627\u0644\u0645\u062e\u062f\u0631\u0629 \u0648\u0627\u0644\u0645\u0648\u0654\u062b\u0631\u0627\u062a \u0627\u0644\u0639\u0642\u0644\u064a\u0629.\u0648\u0646\u0634\u0631\u062a \u0648\u0643\u0627\u0644\u0629 \u0627\u0654\u0646\u0628\u0627\u0621 \u0627\u0644\u0627\u0655\u0645\u0627\u0631\u0627\u062a \u062a\u0641\u0627\u0635\u064a\u0644 \u0627\u0644\u0642\u0636\u064a\u0629\u060c \u0627\u0655\u0630 \u062a\u0639\u0648\u062f \u0627\u0655\u0644\u0649 \u0648\u0631\u0648\u062f \u0645\u0639\u0644\u0648\u0645\u0627\u062a \u062a\u0641\u064a\u062f \u0628\u0648\u062c\u0648\u062f \u0645\u0648\u0627\u062f \u0645\u062e\u062f\u0631\u0629 \u0645\u062e\u0628\u0627\u0654\u0629 \u0641\u064a \u0627\u0654\u062d\u062f \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u062c\u063a\u0631\u0627\u0641\u064a\u0629 \u0628\u0627\u0655\u062d\u062f\u0649 \u06