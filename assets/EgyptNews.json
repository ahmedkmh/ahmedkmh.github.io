\u0644\u0628\u0644\u062f\u064a\u0646\u060c \u0627\u0644\u0630\u064a \u0628\u062f\u0627\u0654 \u0641\u064a \u0645\u0627\u0631\u0633 (\u0627\u0653\u0630\u0627\u0631) \u062a\u0642\u0631\u064a\u0628\u0627\u064b\u060c \u0633\u064a\u062d\u0642\u0642 \"\u0646\u062a\u064a\u062c\u0629 \u062c\u064a\u062f\u0629\".\u0648\u0642\u0627\u0644\u062a \u0627\u0644\u0633\u0644\u0637\u0627\u062a \u0627\u0644\u0643\u0648\u0628\u064a\u0629 \u0627\u0655\u0646\u0647\u0627 \u0644\u0646 \u062a\u0633\u0645\u062d \u0628\u0627\u0644\u062a\u062f\u062e\u0644 \u0641\u064a \u0627\u0644\u0634\u0648\u0654\u0648\u0646 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629 \u0648\u0627\u0646\u062a\u0642\u062f\u062a \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0644\u0644\u0627\u0641\u062a\u0642\u0627\u0631 \u0644\u062d\u0633\u0646 \u0627\u0644\u0646\u064a\u0629.\u0648\u0642\u0627\u0644\u062a \u0641\u064a\u062f\u0627\u0644: \"\u0644\u0627 \u062a\u0632\u0627\u0644 \u0642\u0646\u0627\u0629 \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0628\u064a\u0646 \u0627\u0644\u062d\u0643\u0648\u0645\u062a\u064a\u0646 \u0645\u0641\u062a\u0648\u062d\u0629\u060c \u0644\u0643\u0646 \u0644\u0645 \u064a\u062a\u0645 \u0627\u0655\u062d\u0631\u0627\u0632 \u062a\u0642\u062f\u0645 \u0643\u0628\u064a\u0631. \u0644\u062f\u064a\u0646\u0627 \u0627\u0654\u0633\u0628\u0627\u0628 \u062a\u062f\u0639\u0648\u0646\u0627 \u0644\u0644\u0634\u0643 \u0641\u064a \u062c\u062f\u064a\u0629 \u0648\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0629 \u062d\u0643\u0648\u0645\u0629", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["egypt"], "category": ["world"], "datatype": "news", "pubDate": "2026-05-29 04:49:02", "pubDateTZ": "UTC", "fetched_at": "2026-05-29 13:11:16", "image_url": "https://vid.alarabiya.net/images/2026/05/29/a801de6d-55d6-4883-9586-d4863b0c54bb/a801de6d-55d6-4883-9586-d4863b0c54bb_16x9_1200x676.jpg", "video_url": null, "source_id":