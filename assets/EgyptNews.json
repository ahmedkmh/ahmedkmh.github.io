3cd\u5bf9\u7f8e\u4ee5\u4e24\u56fd\u6253\u51fb\u4f0a\u6717\u7684\u4e5f\u95e8\u80e1\u585e\u6b66\u88c5\u5df2\u5f00\u59cb\u5377\u5165\u4e2d\u4e1c\u5730\u533a\u5f53\u524d\u6218\u4e8b,\u5e76\u4e8e\u6628\u592903\u670828\u65e5\u5468\u516d\u4e24\u6b21\u5411\u4ee5\u8272\u5217\u53d1\u5c04\u5bfc\u5f39\u548c\u65e0\u4eba\u673a\u3002", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u975e\u6d32", "\u4e2d\u4e1c", "\u4e5f\u95e8", "\u6d77\u6e7e\u56fd\u5bb6", "\u4f0a\u6717", "\u4e9a\u6d32", "\u57c3\u585e\u4fc4\u6bd4\u4e9a", "\u5409\u5e03\u63d0"], "creator": ["\u5c3c\u53e4\u62c9"], "language": "chinese", "country": ["libya", "qatar", "somalia", "turkmenistan", "djibouti", "tunisia", "kyrgyzstan", "azerbaijan", "tajikistan", "turkey", "algeria", "syria", "uzbekistan", "oman", "united arab emirates", "lebanon", "iran", "georgia", "morocco", "mauritania", "armenia", "kuwait", "ethiopia", "egypt", "israel", "saudi arabia", "cyprus", "kazakhstan", "sudan", "afghanistan", "bahrain", "iraq", "pakistan", "jordan", "india", "yemen"], "category": ["top", "lifestyle"], "datatype": "news", "pubDate": "2026-03-29 10:48:58", "pubDateTZ": "UTC", "fetched_at": "2026-03-29 11:10:07", "image_url": "https://s.rfi.fr/media/display/435f301e-2b5a-11f1-9d15-005056bf30b7/w:1280/p:16x9/2026-03-29-D-FMM-archive-Yemen-et-Djibouti-x-logo-RFI.jpg", "video_url": null, "source_id": "rfi_fr", "source_name": "Rfi", "source_priority": 8490, "source_url": "https://www.rfi.fr", "source_icon": "https://n.bytvi.com/rfi_fr.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "3e505ab63db183ff725e8ccfc758af65", "link": "https://www.rfi.fr/tw/%E4%B8%AD%E6%9D%B1/20260329-rfi%E6%B3%95%E5%