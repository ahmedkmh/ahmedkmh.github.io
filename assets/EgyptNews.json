4a\u0654\u0639 \u0648\u0627\u0654\u0631\u0642\u0627\u0645 \u0639\u0646 \u0627\u0644\u0633\u0641\u0646 \u0627\u0644\u062a\u064a \u0639\u0628\u0631\u062a \u0627\u0644\u0645\u0636\u064a\u0642 \u0627\u0644\u0628\u0627\u0644\u063a \u0637\u0648\u0644\u0647 167 \u0643\u064a\u0644\u0648\u0645\u062a\u0631\u0627\u064b\u060c \u0645\u0646\u0630 \u0627\u0646\u062f\u0644\u0627\u0639 \u0627\u0644\u062d\u0631\u0628 \u0639\u0642\u0628 \u0636\u0631\u0628\u0627\u062a \u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 \u0639\u0644\u0649 \u0627\u0655\u064a\u0631\u0627\u0646 \u0641\u064a 28 \u0641\u0628\u0631\u0627\u064a\u0631.\u0627\u0646\u062e\u0641\u0627\u0636 \u0628\u0646\u0633\u0628\u0629 95% \u0641\u064a \u062d\u0631\u0643\u0629 \u0627\u0644\u0634\u062d\u0646\u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 \u0645\u0646 \u0627\u0644\u0627\u0654\u0648\u0644 \u0645\u0627\u0631\u0633 \u0648\u062d\u062a\u0649 \u0627\u0644\u0633\u0627\u0639\u0629 04:00 \u0628\u062a\u0648\u0642\u064a\u062a \u063a\u0631\u064a\u0646\u062a\u0634 \u0645\u0646 \u064a\u0648\u0645 23 \u0645\u0627\u0631\u0633 \u0627\u0654\u062c\u0631\u062a \u0633\u0641\u0646 \u0627\u0644\u0634\u062d\u0646 138 \u0639\u0645\u0644\u064a\u0629 \u0639\u0628\u0648\u0631 \u0641\u0642\u0637 \u0644\u0644\u0645\u0636\u064a\u0642\u060c \u062d\u0633\u0628\u0645\u0627 \u0627\u0654\u0641\u0627\u062f\u062a \u0645\u0648\u0654\u0633\u0633\u0629 \u0627\u0644\u062a\u062d\u0644\u064a\u0644\u0627\u062a \"\u0643\u0628\u0644\u0631\"\u060c \u0627\u0654\u064a \u0628\u0627\u0646\u062e\u0641\u0627\u0636 \u0642\u062f\u0631\u0647 95% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0641\u062a\u0631\u0629 \u0645\u0627 \u0642\u0628\u0644 \u0627\u0644\u062d\u0631\u0628.\u064887 \u0645\u0646 \u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u0639\u0628\u0648\u0631 \u0643\u0627\u0646\u062a \u0644\u0646\u0627\u0642\u0644\u0627\u062a \u0646\u0641\u0637 \u0648\u063a\u0627\u0632 \u0648\u0627\u0