0639 \u0628\u064a\u062a \u0647\u064a\u063a\u0633\u064a\u062b\u060c \u064a\u0648\u0645 \u0627\u0644\u062e\u0645\u064a\u0633\u060c \u0627\u0644\u062c\u0646\u0631\u0627\u0644 \u0631\u0627\u0646\u062f\u064a \u062c\u0648\u0631\u062c\u060c \u0631\u064a\u0654\u064a\u0633 \u0627\u0654\u0631\u0643\u0627\u0646 \u0627\u0644\u062c\u064a\u0634\u060c \u0641\u064a \u062e\u0637\u0648\u0629 \u062a\u0639\u0643\u0633 \u062a\u0635\u0627\u0639\u062f \u0627\u0644\u062a\u0648\u062a\u0631 \u0628\u064a\u0646 \u0647\u064a\u063a\u0633\u064a\u062b \u0648\u0642\u064a\u0627\u062f\u0629 \u0627\u0644\u062c\u064a\u0634\u060c \u0648\u0641\u0642\u064b\u0627 \u0644\u0645\u0627 \u0627\u0654\u0641\u0627\u062f \u0628\u0647 \u0645\u0633\u0648\u0654\u0648\u0644\u0648\u0646 \u0639\u0633\u0643\u0631\u064a\u0648\u0646.\u0648\u0643\u0627\u0646 \u0627\u0644\u062c\u0646\u0631\u0627\u0644 \u062c\u0648\u0631\u062c\u060c \u0627\u0644\u0630\u064a \u0639\u064f\u064a\u0651\u0646 \u0641\u064a \u0645\u0646\u0635\u0628\u0647 \u0639\u0627\u0645 2023\u060c \u0642\u062f \u0642\u0627\u062f \u0627\u0644\u062c\u064a\u0634 \u0644\u0644\u062e\u0631\u0648\u062c \u0645\u0646 \u0627\u0655\u062d\u062f\u0649 \u0627\u0654\u0633\u0648\u0627\u0654 \u0627\u0654\u0632\u0645\u0627\u062a \u0627\u0644\u062a\u062c\u0646\u064a\u062f \u0641\u064a \u062a\u0627\u0631\u064a\u062e\u0647 \u0639\u0627\u0645 2024\u060c \u0648\u0636\u063a\u0637 \u0645\u0648\u0654\u062e\u0631\u064b\u0627 \u0639\u0644\u0649 \u0627\u0644\u062c\u064a\u0634 \u0644\u062a\u0633\u0631\u064a\u0639 \u0648\u062a\u064a\u0631\u0629 \u0627\u0642\u062a\u0646\u0627\u0621 \u0637\u0627\u064a\u0654\u0631\u0627\u062a \u0645\u0633\u064a\u0651\u0631\u0629 \u0631\u062e\u064a\u0635\u0629 \u0627\u0644\u062b\u0645\u0646 \u0648\u0627\u0654\u0646\u0648\u0627\u0639 \u0627\u0654\u062e\u0631\u0649 \u0645\u0646 \u0627\u0644\u0627\u0654\u0633\u0644\u062d\u0629 \u0627\u0644\u062a\u064a \u0628\u0627\u062a\u062a \u062a\u064f\u0647\u064a\u0645\u0646 \u0639\u0644\u0649 \u0627\u0644\u062d\u0631\u0628 \u0641