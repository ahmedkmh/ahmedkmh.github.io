60c \u0643\u0645\u0627 \u0635\u0639\u062f \u0645\u0648\u0654\u0634\u0631 \u0627\u0644\u0634\u0631\u064a\u0639\u0629 \u0641\u064a \u0627\u0644\u0628\u0648\u0631\u0635\u0629 \u0627\u0644\u0645\u0635\u0631\u064a\u0629 0.86% \u0639\u0646\u062f \u0645\u0633\u062a\u0648\u0649 5832 \u0646\u0642\u0637\u0629. \u0648\u0627\u0631\u062a\u0641\u0639 \u0645\u0648\u0654\u0634\u0631 EGX 100 \u0627\u0644\u0627\u0654\u0648\u0633\u0639 \u0646\u0637\u0627\u0642\u0627 \u0628\u0646\u0633\u0628\u0629.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": ["\u0627\u0644\u0623\u0633\u0628\u0648\u0639"], "language": "arabic", "country": ["egypt"], "category": ["business"], "datatype": "news", "pubDate": "2026-06-15 11:57:23", "pubDateTZ": "UTC", "fetched_at": "2026-06-15 12:06:43", "image_url": "https://www.elaosboa.com/wp-content/uploads/2026/05/elaosboa74936.jpg", "video_url": null, "source_id": "elaosboa", "source_name": "\u0627\u0644\u0623\u0633\u0628\u0648\u0639", "source_priority": 38788, "source_url": "https://www.elaosboa.com", "source_icon": "https://n.bytvi.com/elaosboa.jpg", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "e9926541ed2cad155900031153af01ad", "link": "https://www.alarabiya.net/aswaq/economy/2026/06/15/%D8%A7%D9%84%D9%86%D8%A7%D8%AA%D8%AC-%D8%A7%D9%84%D8%B5%D9%86%D8%A7%D8%B9%D9%8A-%D9%81%D9%8A-%D9%85%D9%86%D8%B7%D9%82%D8%A9-%D8%A7%D9%84%D9%8A%D9%88%D8%B1%D9%88-%D9%8A%D8%B1%D8%AA%D9%81%D8%B9-%D9%84%D9%84%D8%B4%D9%87%D8%B1-%D8%A7%D9%84%D8%AB%D8%A7%D9%84%D8%AB-%D8%B9%D9%84%D9%89-%D8%A7%D9%84%D8%AA%D9%88%D8%A7%D9%84%D9%8A-%D9%81%D9%8A-%D8%A7%D8%A8%D8%B1%D9%8A%D9%84", "title": "\u0627\u0644\u0646\u0627\u062a\u062c \u0627\u0644\u0635\u0646\u0627\u0639\u064a \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u064a\u0648\u0631\u0648 \u064a\u0631\u062a\u0641\u0639 \u0644\u0644\u0634\u0647\u0631 \u0627\u0644\u062b\u0627\u0644\u062b \u0639\u0644\u0649 \u0627\u0644\u062a\u0648\u0627\u0644\u064a \u0641\u064a \u0627\u0654\u0628\u0631\u064a\u0644", "description": "\u0627\u0654\u0638\u0647\u0631\u062a \u0628\u064a\u0627\u0646\u0627\u062a \u0648\u0643\u0627\u0644\u0629 \u0627\u0644\u0627\u0655\u062d\u0635\u0627\u0621 \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a\u0629 \"\u064a\u0648\u0631\u0648\u0633\u062a\u0627\u062a\" \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0655\u062b\u0646\u064a\u0646\u060c \u0627\u0654\u0646 \u0627\u0644\u0646\u0627\u062a\u062c \u0627\u0644\u0635\u0646\u0627\u0639\u064a \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u064a\u0648\u0631\u0648 \u0633\u062c\u0644 \u0646\u0645\u0648\u0627\u064b \u0647\u0627\u0645\u0634\u064a\u0627\u064b \u0641\u064a \u0627\u0654\u0628\u0631\u064a\u0644/\u0646\u064a\u0633\u0627\u0646.\u0648\u0627\u0631\u062a\u0641\u0639 \u0627\u0644\u0646\u0627\u062a\u062c \u0627\u0644\u0635\u0646\u0627\u0639\u064a 0.1% \u0645\u0646 \u0645\u0627\u0631\u0633/\u0627\u0653\u0630\u0627\u0631 \u0639\u0646\u062f\u0645\u0627 \u0627\u0631\u062a\u0641\u0639 \u0627\u0644\u0646\u0627\u062a\u062c 0.4%. \u0648\u0643\u0627\u0646 \u0645\u0646 \u0627\u0644\u0645\u062a\u0648\u0642\u0639 \u0627\u0654\u0646 \u064a\u0642\u0641\u0632 0.2%. \u0648\u0631\u063a\u0645 \u0630\u0644\u0643 \u0641\u0647\u0630\u0627 \u062b\u0627\u0644\u062b \u0646\u0645\u0648 \u0639\u0644\u0649 \u0627\u0644\u062a\u0648\u0627\u0644\u064a \u0641\u064a \u0627\u0644\u0627\u0655\u0646\u062a\u0627\u062c. \u0627\u0644\u0646\u0641\u0637 \u064a\u0647\u0628\u0637 \u0628\u0627\u0654\u0643\u062b\u0631 \u0645\u0646 5% \u0639\u0642\u0628 \u0627\u062a\u0641\u0627\u0642 \u0627\u0654\u0645\u064a\u0631\u0643\u064a \u0627\u0655\u064a\u0631\u0627\u0646\u064a \u064a\u0639\u064a\u062f \u0627\u0644\u0645\u0644\u0627\u062d\u0629 \u0641\u064a \u0647\u0631\u0645\u0632\u0648\u0643\u0627\u0646 \u0627\u0644\u062a\u0631\u0627\u062c\u0639 \u0645\u062f\u0641\u0648\u0639\u0627\u064b \u0628\u0627\u0646\u062e\u0641\u0627\u0636 \u0628\u0648\u0627\u0642\u0639 0.4% \u0641\u064a \u0627\u0644\u0637\u0627\u0642\u0629 \u06480.5% \u0641\u064a \u0646\u0627\u062a\u062c \u0627\u0644\u0633\u0644\u0639 \u0627\u0644\u0631\u0627\u0654\u0633\u0645\u0627\u0644\u064a\u0629.\u0648\u0645\u0646 \u0646\u0627\u062d\u064a\u0629 \u0627\u0654\u062e\u0631\u0649\u060c \u0627\u0631\u062a\u0641\u0639\u062a \u0627\u0644\u0633\u0644\u0639 \u0627\u0644\u0627\u0633\u062a\u0647\u0644\u0627\u0643\u064a\u0629 \u063a\u064a\u0631 \u0627\u0644\u0645\u0639\u0645\u0631\u0629 \u0648\u0627\u0644\u0633\u0644\u0639 \u0627\u0644\u0627\u0633\u062a\u0647\u0644\u0627\u0643\u064a\u0629 \u0627\u0644\u0645\u0639\u0645\u0631\u0629 1.7% \u06481% \u0639\u0644\u0649 \u0627\u0644\u062a\u0648\u0627\u0644\u064a. \u0648\u0627\u0631\u062a\u0641\u0639 \u0646\u0627\u062a\u062c \u0627\u0644\u0633\u0644\u0639 \u0627\u0644\u0648\u0633\u064a\u0637\u0629 0.8%.\u0648\u0639\u0644\u0649 \u0627\u0654\u0633\u0627\u0633 \u0633\u0646\u0648\u064a\u060c \u0646\u0645\u0627 \u0627\u0644\u0646\u0627\u062a\u062c \u0627\u0644\u0635\u0646\u0627\u0639\u064a 0.3% \u0645\u0642\u0627\u0628\u0644 \u062a\u0631\u0627\u062c\u0639 2.8% \u0641\u064a \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0633\u0627\u0628\u0642. \u0648\u0643\u0627\u0646 \u0647\u0630\u0627 \u0627\u0654\u0648\u0644 \u0646\u0645\u0648 \u062e\u0644\u0627\u0644 \u0627\u0654\u0631\u0628\u0639 \u0633\u0646\u0648\u0627\u062a.\u0643\u0645\u0627 \u0633\u062c\u0644 \u0627\u0644\u0646\u0627\u062a\u062c \u0627\u0644\u0635\u0646\u0627\u0639\u064a \u0628\u064a\u0646 \u062f\u0648\u0644 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a \u0627\u0644\u064027 \u0646\u0645\u0648\u0627\u064b \u0634\u0647\u0631\u064a\u0627\u064b \u0647\u0627\u0645\u0634\u064a\u0627\u0