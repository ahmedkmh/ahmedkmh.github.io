55\u0644\u0649 27 \u0646\u0642\u0637\u0629\u060c \u0628\u0627\u0644\u062a\u0641\u0648\u0642 \u0639\u0644\u0649 \u0627\u0654\u0628\u0646\u0627\u0621 \u0645\u064a\u062a \u0639\u0642\u0628\u0629 \u0627\u0654\u0635\u062d\u0627\u0628 \u0627\u0644\u0645\u0631\u0643\u0632 \u0627\u0644\u062b\u0627\u0646\u064a \u0628\u0640 3.5 \u0646\u0642\u0637\u0629. 10 13.0107 ,\u0648\u0628\u0646\u0627\u0621\u064b \u0639\u0644\u0649 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u0630\u0647\u0627\u0628\u060c \u062c\u0627\u0621 \u062a\u0631\u062a\u064a\u0628 \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0645\u0646 \u062f\u0648\u0631\u064a \u0627\u0644\u0645\u062d\u062a\u0631\u0641\u064a\u0646 \u0644\u0643\u0631\u0629 \u0627\u0644\u064a\u062f \u0639\u0644\u0649 \u0627\u0644\u0646\u062d\u0648 \u0627\u0644\u062a\u0627\u0644\u064a 10 13.0107 ,1 \u0627\u0644\u0627\u0654\u0647\u0644\u064a 27 \u0646\u0642\u0637\u0629 10 13.0107 ,2 \u0627\u0644\u0632\u0645\u0627\u0644\u0643 23.5 \u0646\u0642\u0637\u0629 10 13.0107 ,3 \u0627\u0644\u0628\u0646\u0643 \u0627\u0644\u0627\u0654\u0647\u0644\u064a 18.5 \u0646\u0642\u0637\u0629 10 13.0107 ,4 \u0637\u0644\u0627\u064a\u0654\u0639 \u0627\u0644\u062c\u064a\u0634 18 \u0646\u0642\u0637\u0629 10 13.0107 ,5 \u0633\u0645\u0648\u062d\u0629 17 \u0646\u0642\u0637\u0629 10 13.0107 ,6 \u0633\u0628\u0648\u0631\u062a\u0646\u062c 16.5 \u0646\u0642\u0637\u0629 10 13.0107 ,7 \u0627\u0644\u062c\u0632\u064a\u0631\u0629 11.5 \u0646\u0642\u0637\u0629 10 13.0107 ,8 \u0627\u0644\u0634\u0645\u0633 8 \u0646\u0642\u0627\u0637 10 13.0107 ,\u0648\u0642\u0628\u0644 \u0627\u0646\u0637\u0644\u0627\u0642 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u0627\u0655\u064a\u0627\u0628\u060c \u0646\u0633\u062a\u0639\u0631\u0636 \u062c\u062f\u0648\u0644 \u062a\u0631\u062a\u064a\u0628 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0627\u0644\u0627\u0654\u0647\u0644\u064a 10 13.0107 ,\u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u0