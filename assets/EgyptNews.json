9%D8%AF%D8%A7%D8%AF%D8%A7-%D9%84%D9%85%D9%88%D9%86%D8%AF%D9%8A%D8%A7%D9%84-2026-%D9%84%D9%83%D8%B1%D8%A9-%D8%A7%D9%84%D9%82%D8%AF%D9%85", "title": "\u0645\u064a\u0633\u064a \u0627\u0654\u0633\u0627\u0633\u064a\u064b\u0627 \u0641\u064a \u0648\u062f\u064a\u0629 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646 \u0648\u0632\u0627\u0645\u0628\u064a\u0627 \u0627\u0633\u062a\u0639\u062f\u0627\u062f\u0627 \u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644 2026 \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645", "description": "\u0627\u0654\u0643\u0651\u062f \u0627\u0644\u0645\u062f\u0631\u0628 \u0644\u064a\u0648\u0646\u064a\u0644 \u0633\u0643\u0627\u0644\u0648\u0646\u064a\u060c \u0627\u0654\u0646 \u0646\u062c\u0645 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0644\u064a\u0648\u0646\u064a\u0644 \u0645\u064a\u0633\u064a \u0633\u064a\u0643\u0648\u0646 \u0636\u0645\u0646 \u0627\u0644\u062a\u0634\u0643\u064a\u0644\u0629 \u0627\u0644\u0627\u0654\u0633\u0627\u0633\u064a\u0629 \u0627\u0644\u062a\u064a \u0633\u062a\u0648\u0627\u062c\u0647 \u0632\u0627\u0645\u0628\u064a\u0627 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 \u0641\u064a \u0645\u0628\u0627\u0631\u0627\u0629 \u0648\u062f\u064a\u0629 \u0627\u0633\u062a\u0639\u062f\u0627\u062f\u0627 \u0644 \u0645\u0648\u0646\u062f\u064a\u0627\u0644 2026 \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 . \u0642\u0627\u0644 \u0633\u0643\u0627\u0644\u0648\u0646\u064a '\u0645\u064a\u0633\u064a \u0633\u064a\u0628\u062f\u0627\u0654 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u064a\u0648\u0645 (\u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621)'. \u0648\u0633\u062a\u0642\u0627\u0645 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0641\u064a \u0645\u0644\u0639\u0628 \u0628\u0648\u0645\u0628\u0648\u0646\u064a\u0631\u0627 \u0641\u064a \u0628\u0648\u064a\u0646\u0633 \u0627\u0653\u064a\u0631\u0633\u060c \u0644\u064a\u0644 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u0648\u0633\u062a\u0643\u0648\u0646 \u0627\u0653\u062e\u0631 \u0645\u0628\u0627\u0631\u0627\u0629 \u0648\u062f\u064a\u0629 \u064a\u062e\u0648\u0636\u0647\u0627 \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0644\u0639\u0627\u0644\u0645 '\u0642\u0637\u0631 2022'\u060c \u0639\u0644\u0649 \u0627\u0654\u0631\u0636\u0647\u0645 \u0642\u0628\u0644 \u0627\u0644\u0645\u0648\u0646\u062f\u064a\u0627\u0644. \u0648\u0643\u0627\u0646 \u0646\u062c\u0645 \u0628\u0631\u0634\u0644\u0648\u0646\u0629 \u0627\u0644\u0627\u0655\u0633\u0628\u0627\u0646\u064a \u0648\u0628\u0627\u0631\u064a\u0633 \u0633\u0627\u0646 \u062c\u064a\u0631\u0645\u0627\u0646 \u0627\u0644\u0641\u0631\u0646\u0633\u064a \u0627\u0644\u0633\u0627\u0628\u0642\u060c \u0648\u0644\u0627\u0639\u0628 \u0627\u0655\u0646\u062a\u0631 \u0645\u064a\u0627\u0645\u064a \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u062d\u0627\u0644\u064a\u0627\u064b \u0627\u0644\u0645\u062a\u0648\u062c \u062b\u0645\u0627\u0646\u064a \u0645\u0631\u0627\u062a \u0628\u0627\u0644\u0643\u0631\u0629 \u0627\u0644\u0630\u0647\u0628\u064a\u0629\u060c \u0648\u0627\u0644\u0630\u064a \u0633\u064a\u0628\u0644\u063a 39 \u0639\u0627\u0645\u0627\u064b \u0641\u064a \u0646\u0647\u0627\u064a\u0629 \u062d\u0632\u064a\u0631\u0627\u0646/\u064a\u0648\u0646\u064a\u0648\u060c \u0628\u062f\u064a\u0644\u0627\u064b \u0641\u064a \u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062c\u0645\u0639\u0629 \u0627\u0644\u062a\u064a \u0641\u0627\u0632 \u0641\u064a\u0647\u0627 \u0627\u0644\u0645\u0646\u062a\u062e\u0628 \u0627\u0644\u0627\u0654\u0631\u062c\u0646\u062a\u064a\u0646\u064a \u0628\u0635\u0639\u0648\u0628\u0629 \u0639\u0644\u0649 \u0645\u0648\u0631\u064a\u062a\u0627\u0646\u064a\u0627 (2-1)\u060c \u0648\u062f\u062e\u0644 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0644\u0639\u0628 \u0628\u0639\u062f \u0627\u0644\u0627\u0633\u062a\u0631\u0627\u062d\u0629.