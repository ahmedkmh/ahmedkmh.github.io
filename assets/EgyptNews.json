\u064a\u0629\u060c \u0643\u0645\u0627 \u0648\u0631\u062f \u0641\u064a \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0627\u0644\u062a\u062c\u0627\u0631\u064a. \u0648\u0645\u0639 \u0630\u0644\u0643\u060c \u0648\u0628\u0639\u062f \u0645\u0631\u0648\u0631 \u062a\u0633\u0639\u0629 \u0627\u0654\u0634\u0647\u0631 \u0639\u0644\u0649 \u0627\u0655\u0628\u0631\u0627\u0645 \u0627\u0644\u0627\u062a\u0641\u0627\u0642\u060c \u0644\u0627 \u064a\u0632\u0627\u0644 \u0627\u0644\u0628\u0631\u0644\u0645\u0627\u0646 \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a \u0648\u0645\u062c\u0644\u0633 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a \u0628\u062d\u0627\u062c\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0639\u0644\u0649 \u0646\u0635 \u0645\u0634\u062a\u0631\u0643 \u0642\u0628\u0644 \u062f\u062e\u0648\u0644 \u062a\u062e\u0641\u064a\u0636\u0627\u062a \u0627\u0644\u0631\u0633\u0648\u0645 \u062d\u064a\u0632 \u0627\u0644\u062a\u0646\u0641\u064a\u0630. \u0648\u064a\u0631\u063a\u0628 \u0645\u0634\u0631\u0651\u0639\u0648 \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a \u0641\u064a \u0641\u0631\u0636 \u0636\u0645\u0627\u0646\u0627\u062a \u0627\u0654\u0643\u062b\u0631 \u0635\u0631\u0627\u0645\u0629\u060c \u062a\u0634\u0645\u0644 \u062a\u0639\u0644\u064a\u0642 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0627\u0655\u0630\u0627 \u0644\u0645 \u062a\u0644\u062a\u0632\u0645 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0628\u0647\u060c \u0648\u0631\u0628\u0637 \u062a\u062e\u0641\u064a\u0636 \u0627\u0644\u0631\u0633\u0648\u0645 \u0628\u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0654\u0645\u0631\u064a\u0643\u064a\u0629 \u0645\u0642\u0627\u0628\u0644\u0629\u060c \u0648\u0627\u0655\u0646\u0647\u0627\u0621 \u0627\u0644\u062a\u0646\u0627\u0632\u0644\u0627\u062a \u0627\u0644\u062c\u0645\u0631\u0643\u064a\u0629 \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a\u0629 \u0628\u0627\u0644\u0643\u0627\u0645\u0644 \u0628\u062d\u0644\u0648\u0644 31 \u0645\u0627\u0631\u0633 2028. \u0644\u0643\u0646 \u062d\u0643\u0648\u0645\u0627\u062a \u0627\u0644\u0627\u062a\u062d\u0627\u062f \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a \u0644\u0627 \u062a\u0628\u062f\u064a \u062d\u0645\u0627\u0633\u064b\u0627 \u0643\u0628\u064a\u0631\u064b\u0627 \u0644\u0627\u0655\u062f\u0631\u0627\u062c \u0647\u0630\u0647 \u0627\u0644\u0628\u0646\u0648\u062f\u060c \u0628\u062d\u0633\u0628 \u0627\u0654\u062d\u062f \u0627\u0644\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a\u064a\u0646\u060c \u0641\u064a\u0645\u0627 \u0627\u0654\u0634\u0627\u0631 \u0627\u0653\u062e\u0631 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u0641\u062c\u0648\u0629 \u0644\u0627 \u062a\u0632\u0627\u0644 \u0643\u0628\u064a\u0631\u0629 \u0628\u064a\u0646 \u0627\u0644\u0637\u0631\u0641\u064a\u0646\u060c \u0645\u0639 \u062a\u0648\u0642\u0639 \u0627\u0644\u062d\u0627\u062c\u0629 \u0627\u0655\u0644\u0649 \u062c\u0648\u0644\u0627\u062a \u062a\u0641\u0627\u0648\u0636 \u0627\u0655\u0636\u0627\u0641\u064a\u0629 \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0645\u0642\u0628\u0644. \u0648\u0642\u0627\u0644 \u0645\u0627\u0646\u0641\u0631\u064a\u062f \u0648\u064a\u0628\u0631\u060c \u0631\u064a\u0654\u064a\u0633 \u062d\u0632\u0628 \u0627\u0644\u0634\u0639\u0628 \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a \u0648\u0627\u0654\u0643\u0628\u0631 \u0643\u062a\u0644\u0629 \u0641\u064a \u0627\u0644\u0628\u0631\u0644\u0645\u0627\u0646 \u0627\u0644\u0627\u0654\u0648\u0631\u0648\u0628\u064a\u060c \u0627\u0655\u0646\u0647 \u064a\u0631\u063a\u0628 \u0641\u064a \u0627\u0655\u062c\u0631\u0627\u0621 \u062a\u0635\u0648\u064a\u062a \u0646\u0647\u0627\u064a\u0654\u064a \u062f\u0627\u062e\u0644 \u0627\u0644\u0628\u0631\u0644\u0645\u0627\u0646 \u062e\u0644\u0627\u0644 \u0645\u0627\u064a\u0648\u060c \u0627\u0655\u0644\u0627 \u0627\u0654\u