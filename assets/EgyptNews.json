rge/29731880090306202603201153485348.jpg", "video_url": null, "source_id": "almalnews", "source_name": "\u062c\u0631\u064a\u062f\u0629 \u0627\u0644\u0645\u0627\u0644", "source_priority": 250811, "source_url": "https://www.almalnews.com", "source_icon": "https://n.bytvi.com/almalnews.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "963c9003a82d3539eacb3327f58dd532", "link": "https://elaph.com/Web/News/2026/03/1591921.html", "title": "\u062e\u0628\u0631\u0627\u0621: \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0639\u0644\u0649 \u062d\u0627\u0641\u0629 \u0627\u0655\u0639\u0627\u062f\u0629 \u062a\u0634\u0643\u064a\u0644 \u0627\u0644\u062c\u063a\u0631\u0627\u0641\u064a\u0627 \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u0629", "description": "\u0627\u0655\u064a\u0644\u0627\u0641 \u0645\u0646 \u0644\u0646\u062f\u0646 : \u0627\u0654\u0642\u0627\u0645 \u0645\u0631\u0643\u0632 \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0641\u064a \u0643\u0644\u064a\u0629 \u0644\u0646\u062f\u0646 \u0644\u0644\u0627\u0642\u062a\u0635\u0627\u062f \u0648\u0627\u0644\u062f\u0631\u0627\u0633\u0627\u062a \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u0629 \u0628\u0644\u0646\u062f\u0646 \u0646\u062f\u0648\u0629\u064b \u0628\u0639\u0646\u0648\u0627\u0646 \"\u0627\u0644\u062a\u062f\u0627\u0639\u064a\u0627\u062a \u0627\u0644\u062c\u064a\u0648\u0633\u064a\u0627\u0633\u064a\u0629 \u0644\u0644\u062d\u0631\u0628 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a\u0629 - \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0639\u0644\u0649 \u0627\u0655\u064a\u0631\u0627\u0646\"\u060c \u0645\u0633\u0627\u0621 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 \u0627\u0644\u0645\u0635\u0627\u062f\u0641 17 \u0627\u0653\u0630\u0627\u0631 (\u0645\u0627\u0631\u0633) 2026. \u0627\u0654\u062f\u0627\u0631\u062a \u0627\u0644\u0646\u062f\u0648\u0629 \u062f. \u0643\u0627\u062a\u0631\u064a\u0646 \u062f\u0627\u0644\u0627\u0643\u0648\u0631\u0627\u060c \u0645\u062f\u064a\u0631\u0629 \u0645\u0631\u0643\u0632 \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0641\u064a \u0643\u0644\u064a\u0629 \u0644\u0646\u062f\u0646 \u0644\u0644\u0627\u0642\u062a\u0635\u0627\u062f \u0648\u0627\u0644\u062f\u0631\u0627\u0633\u0627\u062a \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u0629\u060c \u0648\u062a\u062d\u062f\u062b \u0641\u064a\u0647\u0627 \u0627\u0644\u0628\u0631\u0648\u0641\u0633\u0648\u0631 \u062a\u0648\u0628\u064a \u062f\u0648\u0643 \u0641\u064a \u0627\u0644\u0643\u0644\u064a\u0629\u060c \u0648\u0627\u0644\u0628\u0631\u0648\u0641\u0633\u0648\u0631 \u0628\u064a\u062a\u0631 \u062a\u0631\u0648\u0628\u0648\u0648\u062a\u0632 \u0641\u064a \u0627\u0644\u0643\u0644\u064a\u0629 \u0646\u0641\u0633\u0647\u0627\u060c \u0648\u062f. \u0633\u0646\u0627\u0645 \u0648\u0643\u064a\u0644 \u0645\u0646 \u0634\u062a\u0627\u0645 \u0647\u0627\u0648\u0633. \u062a\u062d\u062f\u062b \u062a\u0648\u0628\u064a \u0639\u0646 \u062a\u0627\u0631\u064a\u062e \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0641\u064a \u0627\u0644\u062c\u0631\u0627\u064a\u0654\u0645\u060c \u0644\u0627\u0633\u064a\u0645\u0627 \u062c\u0631\u0627\u064a\u0654\u0645 \u0627\u0644\u0627\u0655\u0628\u0627\u062f\u0629 \u0627\u0644\u062c\u0645\u0627\u0639\u064a\u0629 \u0641\u064a \u063a\u0632\u0629 \u0648\u0627\u0644\u0636\u0641\u0629 \u0627\u0644\u063a\u0631\u0628\u064a\u0629 \u0648\u0644\u0628\u0646\u0627\u0646 \u0628\u0639\u062f \u0627\u0644\u0633\u0627\u0628\u0639 \u0645\u0646 \u062a\u0634\u0631\u064a\u0646 \u0627\u0644\u0627\u0654\u0648\u0644 (\u0627\u0654\u0643\u062a\u0648\u0628\u0631)\u060c \u0643\u0645\u0627 \u062a\u062d\u062f\u062b \u0639\u0646 \u0627\u062d\u062a\u0644\u0627\u0644 \u0627\u0654\u0645\u064a\u0631\u0643\u0627 \u0644\u0644\u0639\u0631\u0627\u0642 \u0628\u062f\u0648\u0646 \u0645\u0648\u0627\u0641\u0642\u0629 \u0627\u0644\u0627\u0654\u0645\u0645 \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0628\u0627\u062f\u0639\u0627\u0621\u0627\u062a\u064d \u0628\u0627\u0637\u0644\u0629\u060c \u0648\u0647\u064a \u0639\u0644\u0627\u0642\u0627\u062a\u0647 \u0628\u0627\u0644\u0642\u0627\u0639\u062f\u0629 \u0648\u0627\u0645\u062a\u0644\u0627\u0643\u0647 \u0627\u0654\u0633\u0644\u062d\u0629 \u0627\u0644\u062f\u0645\u0627\u0631 \u0627\u0644\u0634\u0627\u0645\u0644 \u0627\u0644\u062a\u064a \u0644\u0645 \u064a\u062c\u062f\u0648\u0647\u0627 \u0627\u0655\u0644\u0649 \u064a\u0648\u0645\u0646\u0627 \u0647\u0630\u0627. \u0648\u062a\u062d\u062f\u062b \u0628\u064a\u062a\u0631 \u0627\u0654\u0646 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u062f\u0648\u0646\u0627\u0644\u062f \u062a\u0631\u0627\u0645\u0628 \u064a\u062a\u0648\u0642\u0639 \u0627\u0644\u062d\u0631\u0628 \u0646\u0632\u0647\u0629\u064b \u0633\u0631\u064a\u0639\u0629\u064b\u060c \u0641\u0644\u0645 \u062a\u0643\u0646 \u0646\u0632\u0647\u0629\u064b \u0648\u0644\u0627 \u0643\u0627\u0646\u062a \u0633\u0631\u064a\u0639\u0629\u064b. \u0648\u062a\u062d\u062f\u062b \u0639\u0646 \u062f\u062e\u0648\u0644 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0627\u0655\u0644\u0649 \u0633\u0648\u0631\u064a\u0627 \u0628\u0645\u0646\u0627\u0637\u0642 \u0643\u0628\u064a\u0631\u0629 \u0648\u0636\u0631\u0628\u0647\u0627 \u0633\u0648\u0631\u064a\u0627 \u0648\u062a\u062f\u062e\u0644\u0647\u0627 \u0645\u0639 \u0627\u0644\u062f\u0631\u0648\u0632. \u0648\u062a\u062d\u062f\u062b \u0645\u0646 \u062c\u0647\u0629\u064d \u062b\u0627\u0646\u064a\u0629\u064d \u0639\u0646 \u0627\u0644\u0645\u0642\u0627\u0648\u0645\u0629 \u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0645\u0646 \u062d\u0645\u0627\u0633 \u0648\u0627\u0644\u062c\u0647\u0627\u062f \u0648\u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a \u0648\u0627\u0644\u062d\u0648\u062b\u064a \u0641\u064a \u0627\u0644\u064a\u0645\u0646\u060c \u062d\u064a\u062b \u0644\u0643\u0644 \u0627\u062d\u062a\u0644\u0627\u0644\u064d \u0645\u0642\u0627\u0648\u0645\u0629\u064c \u0645\u0642\u0631\u0651\u0629\u064c \u0641\u064a \u0627\u0644\u0627\u0654\u0645\u0645 \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0648\u0627\u0644\u0642\u0648\u0627\u0646\u064a\u0646 \u0627\u0644\u062f\u0648\u0644\u064a\u0629. \u062b\u0645 \u062a\u062d\u062f\u062b\u062a \u0633\u0646\u0627\u0645 \u0639\u0645\u0627 \u0642\u0627\u0644\u0647 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u0628\u0646\u064a\u0627\u0645\u064a\u0646 \u0646\u062a\u0627\u0646\u064a\u0627\u0647\u0648 \u0639\u0646 \u062d\u0631\u0628\u0647 \u0645\u0639 \u0633\u0628\u0639 \u062c\u0628\u0647\u0627\u062a: \u063a\u0632\u0629\u060c \u0648\u0627\u0644\u0636\u0641\u0629 \u0627\u0644\u063a\u0631\u0628\u064a\u0629\u060c \u0648\u0644\u0628\u0646\u0627\u0646\u060c \u0648\u0627\u0644\u0639\u0631\u0627\u0642\u060c \u0648\u0627\u0644\u064a\u0645\u0646\u060c \u0648\u0633\u0648\u0631\u064a\u0627\u060c \u0648\u0627\u0655\u064a\u0631\u0627\u0646. \u062b\u0645 \u062a\u062d\u062f\u062b\u062a \u0633\u0646\u0627\u0645 \u0639\u0646 \u0627\u0644\u062d\u0631\u0628 \u0627\u0644\u062a\u064a \u0627\u0633\u062a\u063a\u0631\u0642\u062a 12 \u064a\u0648\u0645\u0627\u064b \u0628\u064a\u0646 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0648\u0627\u0655\u064a\u0631\u0627\u0646\u060c \u0648\u0643\u064a\u0641 \u0627\u0633\u062a\u0637\u0627\u0639 \u062a\u0631\u0627\u0645\u0628 \u0627\u0654\u0646 \u064a\u062f\u062e\u0644 \u0641\u064a \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u062b\u0627\u0646\u064a \u0639\u0634\u0631 \u0644\u064a\u063