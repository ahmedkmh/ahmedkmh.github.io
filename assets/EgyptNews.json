44\u0649 \u0645\u0644\u0639\u0628 \u0641\u0627\u0646\u0643\u0648\u0641\u0631\u060c \u0641\u064a \u0643\u0646\u062f\u0627\u060c \u0644\u062d\u0633\u0627\u0628 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0645\u0646 \u062f\u0648\u0631 \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0627\u062a \u0644\u0628\u0637\u0648\u0644\u0629 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026. \u0648\u0643\u0627\u0646 \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631 \u0642\u062f \u062a\u0639\u0627\u062f\u0644 \u0645\u0639 \u0646\u0638\u064a\u0631\u0647\u060c \u0628\u0644\u062c\u064a\u0643\u0627\u060c \u0628\u0647\u062f\u0641 \u0644\u0645\u062b\u0644\u0647\u060c \u0641\u064a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062a\u064a \u062c\u0645\u0639\u062a \u0627\u0644\u0641\u0631\u064a\u0642\u064a\u0646\u060c \u0645\u0633\u0627\u0621 \u064a\u0648\u0645 \u0627\u0644\u0627\u0655\u062b\u0646\u064a\u0646 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u0639\u0644\u0649 \u0645\u0644\u0639\u0628 \u0633\u064a\u0627\u062a\u0644\u060c \u0644\u062d\u0633\u0627\u0628 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0645\u0646 \u0645\u0648\u0646\u062f\u064a\u0627\u0644 2026. \u0648\u062e\u0627\u0636 \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631 \u062a\u062d\u062a \u0642\u064a\u0627\u062f\u0629 \u062d\u0633\u0627\u0645 \u062d\u0633\u0646\u060c \u0627\u0644\u0645\u062f\u064a\u0631 \u0627\u0644\u0641\u0646\u064a \u062d\u0635\u0629 \u062a\u062f\u0631\u064a\u0628\u064a\u0629 \u0642\u0648\u064a\u0629\u060c \u0635\u0628\u0627\u062d \u0627\u0644\u064a\u0648\u0645\u060c \u0627\u0644\u062c\u0645\u0639\u0629\u060c \u0641\u064a \u062c\u0627\u0645\u0639\u0629 \u0642\u0648\u0627\u0646\u0632\u0627\u0642\u0627\u060c \u0628\u0645\u062f\u064a\u0646\u0629 \u0633\u0628\u0648\u0643\u064a\u0646 \u0627\u0644\u0627\u0654\u0645\u0631\u0