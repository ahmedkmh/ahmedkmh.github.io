7\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621\u060c \u0642\u0627\u064a\u0654\u0644\u0627\u064b: \"\u0627\u062d\u062a\u0641\u0627\u0644\u0627\u064b \u0628\u0627\u0644\u0630\u0643\u0631\u0649 \u0627\u0644\u0633\u0646\u0648\u064a\u0629 \u0627\u0644\u0640175 \u0644\u062a\u0627\u0654\u0633\u064a\u0633 \u0648\u0644\u0627\u064a\u0629 \u0643\u0627\u0644\u064a\u0641\u0648\u0631\u0646\u064a\u0627\u060c \u0633\u0646\u0635\u062f\u0631 \u0631\u062e\u0635\u0629 \u0642\u064a\u0627\u062f\u0629 \u0645\u0645\u064a\u0632\u0629 \u0644\u0644\u063a\u0627\u064a\u0629 \u0644\u0643\u0644 \u0645\u0648\u0627\u0637\u0646 \u0643\u0627\u0644\u064a\u0641\u0648\u0631\u0646\u064a \u0647\u0630\u0627 \u0627\u0644\u0635\u064a\u0641!\".\u0643\u0645\u0627 \u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646 \u0627\u0644\u0631\u062e\u0635\u0629 \u0633\u062a\u062a\u0636\u0645\u0646 \"\u0635\u0648\u0631\u0629 \u0631\u0627\u064a\u0654\u0639\u0629 \u0648\u0639\u0627\u0644\u064a\u0629 \u0627\u0644\u062c\u0648\u062f\u0629\" \u0644\u0647\u060c \u0645\u0631\u062f\u0641\u0627\u064b: \"\u064a\u0642\u0648\u0644 \u0627\u0644\u0643\u062b\u064a\u0631\u0648\u0646 \u0627\u0655\u0646\u0647\u0627 \u0627\u0654\u0641\u0636\u0644 \u0631\u062e\u0635\u0629 \u0642\u064a\u0627\u062f\u0629 \u0635\u062f\u0631\u062a \u0639\u0644\u0649 \u0627\u0644\u0627\u0655\u0637\u0644\u0627\u0642. \u0647\u0630\u0627 \u0627\u062d\u062a\u0641\u0627\u0644 \u0628\u0648\u0644\u0627\u064a\u062a\u0646\u0627 \u0627\u0644\u062c\u0645\u064a\u0644\u0629 (\u0648\u0644\u064a\u0633 \u0644\u064a \u0639\u0644\u0627\u0642\u0629 \u0628\u0647\u0627\u060c \u0631\u063a\u0645 \u0627\u0644\u0635\u0648\u0631\u0629 \u0627\u0644\u0631\u0627\u064a\u0654\u0639\u0629!). \u0627\u0633\u062a\u0645\u062a\u0639\u0648\u0627!\".\u0627\u0644\u0630\u0643\u0631\u0649 \u0627\u0644\u0633\u0646\u0648\u064a\u0629 250 \u0644\u0627\u0655\u0639\u0644\u0627\u0646 \u0627\u0633\u062a\u0642\u0644\u0627\u0644\u0627\u0654\u062a\u0649 \u0630\u0644\u0643 \u0628\u0639\u062f\u0645\u0627 \u0643\u0634\u0641 \u0627\u0644\u0645\u062a\u062d\u062f\u062b \u0628\u0627\u0633\u0645 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u062a\u0648\u0645\u064a \u0628\u064a\u063a\u0648\u062a \u0641\u064a \u0628\u064a\u0627\u0646 \u0627\u0654\u0646 \u062c\u0648\u0627\u0632\u0627\u062a \u0627\u0644\u0633\u0641\u0631 \u0633\u062a\u0635\u062f\u0631 \u0643\u062c\u0632\u0621 \u0645\u0646 \u0627\u0644\u0627\u062d\u062a\u0641\u0627\u0644\u0627\u062a \u0628\u0627\u0644\u0630\u0643\u0631\u0649 \u0627\u0644\u0633\u0646\u0648\u064a\u0629 250 \u0644\u0627\u0655\u0639\u0644\u0627\u0646 \u0627\u0633\u062a\u0642\u0644\u0627\u0644 \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0641\u064a \u064a\u0648\u0644\u064a\u0648 (\u062a\u0645\u0648\u0632)\u060c \u0641\u064a\u0645\u0627 \u0644\u0645 \u064a\u0630\u0643\u0631 \u0627\u0644\u0628\u064a\u0627\u0646 \u0627\u0654\u0646 \u062c\u0648\u0627\u0632\u0627\u062a \u0627\u0644\u0633\u0641\u0631 \u0633\u062a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 \u0635\u0648\u0631\u0629 \u062a\u0631\u0627\u0645\u0628.\u0644\u0643\u0646 \u0631\u0633\u0648\u0645 \u0642\u062f\u0645\u062a\u0647\u0627 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0654\u0638\u0647\u0631\u062a \u0635\u0648\u0631\u0629 \u062a\u0631\u0627\u0645\u0628 \u0639\u0644\u0649 \u0635\u0641\u062d\u0629 \u062f\u0627\u062e\u0644 \u062c\u0648\u0627\u0632 \u0627\u0644\u0633\u0641\u0631 \u0645\u0642\u0627\u0628\u0644 \u0635\u0641\u062d\u0629 \u062a\u062d\u0645\u0644 \u0635\u0648\u0631\u0629 \u0644\u062a\u0648\u0642\u064a\u0639 \u0627\u0655\u0639\u0644\u0627\u0646 \u0627\u0644\u0627\u0633\u062a\u0642\u0644\u0627\u0644 \u0639\u0627\u0645", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["egypt"], "category": ["politics", "top"], "datatype": "news", "pubDate": "2026-04-29 08:18:02", "pubDateTZ": "UTC", "fetched_at": "2026-04-29 12:22:22", "image_url": "https: