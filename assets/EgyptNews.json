u062a\u0642\u0644\u064a\u0646.\u0648\u0642\u062f \u0627\u064c\u0654\u0637\u0644\u0642 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0644\u0645\u0633\u062a\u062e\u062f\u0645\u064a iOS \u0641\u064a \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0648\u0643\u0646\u062f\u0627 \u0647\u0630\u0627 \u0627\u0644\u0634\u0647\u0631 \u0628\u0639\u062f \u0645\u0631\u062d\u0644\u0629 \u062a\u062c\u0631\u064a\u0628\u064a\u0629 \u0628\u062f\u0627\u0654\u062a \u0641\u064a \u0646\u0648\u0641\u0645\u0628\u0631\u060c \u0628\u062d\u0633\u0628 \u062a\u0642\u0631\u064a\u0631 \u0644\u0645\u0648\u0642\u0639 \"\u062a\u0643 \u0643\u0631\u0627\u0646\u0634\" \u0627\u0644\u0645\u062a\u062e\u0635\u0635 \u0641\u064a \u0627\u0654\u062e\u0628\u0627\u0631 \u0627\u0644\u062a\u0643\u0646\u0648\u0644\u0648\u062c\u064a\u0627\u060c \u0627\u0637\u0644\u0639\u062a \u0639\u0644\u064a\u0647 \"\u0627\u0644\u0639\u0631\u0628\u064a\u0629 Business\".\u064a\u0647\u062f\u0641 \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0627\u0655\u0644\u0649 \u062a\u0645\u064a\u064a\u0632 \u0646\u0641\u0633\u0647 \u0639\u0646 \u0627\u0644\u0645\u0646\u0635\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u0631\u0649 \u0645\u0646 \u062e\u0644\u0627\u0644 \u062a\u0642\u062f\u064a\u0645 \u062a\u062c\u0631\u0628\u0629 \u0627\u0655\u062e\u0628\u0627\u0631\u064a\u0629 \u0627\u0654\u0643\u062b\u0631 \u062a\u0631\u0643\u064a\u0632\u064b\u0627 \u0648\u062a\u062e\u0635\u064a\u0635\u064b\u0627 \u062a\u062a\u062c\u0646\u0628 \u0627\u0644\u062a\u0645\u0631\u064a\u0631 \u0627\u0644\u0644\u0627\u0646\u0647\u0627\u064a\u0654\u064a.\u0648\u0645\u0646 \u0627\u0644\u0645\u062a\u0648\u0642\u0639 \u0627\u0655\u0637\u0644\u0627\u0642 \"SaySo\" \u0641\u064a \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0635\u064a\u0641\u060c \u0645\u0639 \u0627\u0644\u062a\u0648\u0633\u0639 \u0644\u0627\u062d\u0642\u064b\u0627 \u0641\u064a \u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0654\u062e\u0631\u0649 \u062e\u0644\u0627\u0644 \u0647\u0630\u0627 \u0627\u0644\u0639\u0627\u0645 \u0648\u0639\u0627\u0645 2027.\u064a\u064f\u0639\u062f \"SaySo\" \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0627\u0644\u0631\u064a\u0654\u064a\u0633\u064a \u0644\u0634\u0631\u0643\u0629 \"Caliber\"\u060c \u0627\u0644\u0645\u0639\u0631\u0648\u0641\u0629 \u0633\u0627\u0628\u0642\u064b\u0627 \u0628\u0627\u0633\u0645 \"The News Movement\"\u060c \u0648\u0627\u0644\u062a\u064a \u062a\u0627\u0654\u0633\u0633\u062a \u0639\u0627\u0645 2022 \u0648\u0627\u064f\u0654\u0639\u064a\u062f \u062a\u0633\u0645\u064a\u062a\u0647\u0627 \u0639\u0627\u0645 2025 \u0644\u0644\u062a\u0631\u0643\u064a\u0632 \u0639\u0644\u0649 \u0627\u0644\u0635\u062d\u0627\u0641\u0629 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639\u064a\u0629 \u0627\u0644\u0642\u0635\u064a\u0631\u0629.\u0627\u0653\u0644\u064a\u0629 \u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u062a\u0637\u0628\u064a\u0642\u0645\u0646 \u0627\u0654\u0628\u0631\u0632 \u0645\u064a\u0632\u0627\u062a \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u062e\u0644\u0627\u0635\u0629 \"Daily Digest\". \u0639\u0646\u062f \u0627\u0655\u0646\u0634\u0627\u0621 \u0645\u0644\u0641 \u0634\u062e\u0635\u064a\u060c", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u062a\u0637\u0628\u064a\u0642\u0627\u062a", "\u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u0623\u062e\u0628\u0627\u0631", "sayso"], "creator": ["\u0627\u0644\u0639\u0631\u0628\u064a\u0629"], "language": "arabic", "country": ["egypt"], "category": ["technology"], "datatype": "news", "pubDate": "2026-04-18 11:48:08", "pubDateTZ": "UTC", "fetched_at": "2026-04-18 18:23:17", "image_url": "https://vid.alarabiya.net/images/2026/04/18/2b844f06-2b22-4644-8d64-7f9648a6eb1c/2b844f06-2b22-4644-8d64-7f9648a6eb1c_16x9_1200x676.jpeg", "video_url": null, "source_id": "alarabiya", "source_name": "Alarabiya", "source_priority": 13507, "source_url": "https://www.al