45\u064b\u0627 \u0645\u0635\u062f\u0631 \u062f\u0639\u0645 \u0648\u0627\u062d\u062a\u0648\u0627\u0621 \u0641\u064a \u0643\u0644 \u0644\u062d\u0638\u0629. \u0627\u0654\u0635\u0639\u0628 \u062d\u0627\u062c\u0629 \u0628\u0627\u0644\u0646\u0633\u0628\u0627\u0644\u064a \u0627\u0655\u0646\u064a \u0648\u0642\u062a\u0647\u0627 \u0643\u0646\u062a \u0628\u0639\u064a\u062f \u0648\u0645\u0642\u062f\u0631\u062a\u0634 \u0627\u0654\u0643\u0648\u0646 \u062c\u0646\u0628\u0647 \u0648\u0644\u0627 \u0627\u0653\u062e\u062f \u0627\u0653\u062e\u0631 \u062d\u0636\u0646 \u0645\u0646\u0647\u060c \u0648\u062f\u064a \u062d\u0627\u062c\u0629 \u0647\u062a\u0641\u0636\u0644 \u0648\u062c\u0639 \u062c\u0648\u0627\u064a\u0627 \u0637\u0648\u0644 \u0627\u0644\u0639\u0645\u0631.. \u0644\u0643\u0646 \u062f\u0647 \u0642\u0636\u0627\u0621 \u0631\u0628\u0646\u0627 \u0648\u0642\u062f\u0631\u0647\u060c \u0648\u0627\u0644\u062d\u0645\u062f \u0644\u0644\u0647 \u0639\u0644\u0649 \u0643\u0644 \u0634\u064a\u0621. \u0648\u064a\u0645\u0643\u0646 \u0641\u064a \u0648\u0642\u062a \u0627\u0644\u062d\u0632\u0646 \u0627\u0644\u0648\u0627\u062d\u062f \u0645\u0628\u064a\u0628\u0642\u0627\u0634 \u0639\u0627\u0631\u0641 \u064a\u0639\u0628\u0651\u0631 \u0648\u0644\u0627 \u064a\u0642\u0648\u0644 \u0627\u0644\u0644\u064a \u062c\u0648\u0627\u0647\u060c \u0644\u0643\u0646 \u0628\u062c\u062f \u0643\u0644 \u0631\u0633\u0627\u0644\u0629\u060c \u0643\u0644 \u062f\u0639\u0648\u0629\u060c \u0643\u0644 \u0643\u0644\u0645\u0629 \u062d\u0644\u0648\u0629 \u0648\u0635\u0644\u062a\u0644\u064a \u0641\u0631\u0651\u0642\u062a \u0645\u0639\u0627\u064a\u0627\u060c \u062d\u062a\u0649 \u0627\u0644\u0646\u0627\u0633 \u0627\u0644\u0644\u064a \u0645\u0639\u0631\u0641\u0647\u0627\u0634 \u062d\u0633\u0633\u062a\u0646\u064a \u0627\u0655\u0646\u064a \u0645\u0634 \u0644\u0648\u062d\u062f\u064a\u060c \u0648\u062f\u0627 \u0634\u064a\u0621 \u0639\u0645\u0631\u064a \u0645\u0627 \u0647\u0646\u0633\u0627\u0647. \u0648\u0627\u062a\u0639\u0644\u0645\u062a \u0627\u