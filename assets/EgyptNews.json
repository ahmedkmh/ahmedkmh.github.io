631\u0633/\u0627\u0653\u0630\u0627\u0631.\u0648\u0627\u0646\u062e\u0641\u0636 \u0639\u062f\u062f \u0627\u0644\u0639\u0627\u0637\u0644\u064a\u0646 \u0628\u0648\u0627\u0642\u0639 22934 \u0634\u062e\u0635\u0627\u064b \u0627\u0654\u0648 \u0628\u0648\u0627\u0642\u0639 0.9% \u0641\u064a \u0645\u0627\u0631\u0633/\u0627\u0653\u0630\u0627\u0631 \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u0633\u0627\u0628\u0642 \u0639\u0644\u064a\u0647. \u0628\u064a\u0646 \u062a\u0647\u062f\u064a\u062f\u0627\u062a \u062a\u0631\u0627\u0645\u0628 \u0648\u0627\u0653\u0645\u0627\u0644 \u0627\u0644\u0627\u062a\u0641\u0627\u0642 \u0645\u0639 \u0627\u0655\u064a\u0631\u0627\u0646.. \u0627\u0644\u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629 \u0641\u064a \u062d\u0627\u0644\u0629 \u062a\u0631\u0642\u0628\u0648\u0627\u0654\u0636\u0627\u0641\u062a \u0627\u0644\u0648\u0632\u0627\u0631\u0629 \u0627\u0654\u0646 \u0639\u062f\u062f \u0627\u0644\u0639\u0627\u0637\u0644\u064a\u0646 \u0627\u0644\u0645\u0633\u062c\u0644\u064a\u0646 \u0628\u0644\u063a 2.42 \u0645\u0644\u064a\u0648\u0646\u060c \u0648\u0647\u0648 \u0627\u0654\u0642\u0644 \u0639\u062f\u062f \u0644\u0634\u0647\u0631 \u0645\u0627\u0631\u0633/\u0627\u0653\u0630\u0627\u0631 \u062e\u0644\u0627\u0644 18 \u0639\u0627\u0645\u0627\u064b.\u0648\u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0645\u0627\u0631\u0633/\u0627\u0653\u0630\u0627\u0631 \u0645\u0646 \u0627\u0644\u0639\u0627\u0645 \u0627\u0644\u0645\u0627\u0636\u064a\u060c \u062a\u0631\u0627\u062c\u0639 \u0639\u062f\u062f \u0627\u0644\u0639\u0627\u0637\u0644\u064a\u0646 \u0628\u0648\u0627\u0642\u0639 160426 \u0627\u0654\u0648 6.2%.\u0648\u0627\u0654\u0638\u0647\u0631\u062a \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0646\u062e\u0641\u0627\u0636 \u0645\u0639\u062f\u0644 \u0627\u0644\u0628\u0637\u0627\u0644\u0629 \u0628\u064a\u0646 \u0627\u0644\u0634\u0628\u0627\u0628 \u0627\u0644\u0628\u0627\u0644\u063a\u064a\u0646