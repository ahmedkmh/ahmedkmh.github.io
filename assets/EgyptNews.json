u0627 \u0628\u0639\u062f\u0645\u0627 \u0633\u062c\u0644 13 \u0647\u062f\u0641\u064b\u0627 \u0648\u0635\u0646\u0639 10 \u0627\u0654\u062e\u0631\u0649 \u0641\u064a \u0645\u062e\u062a\u0644\u0641 \u0627\u0644\u0628\u0637\u0648\u0644\u0627\u062a\u060c \u0628\u064a\u0646\u0645\u0627 \u064a\u062a\u0636\u0645\u0646 \u0639\u0642\u062f\u0647 \u0634\u0631\u0637\u064b\u0627 \u062c\u0632\u0627\u064a\u0654\u064a\u064b\u0627 \u062a\u0635\u0644 \u0642\u064a\u0645\u062a\u0647 \u0627\u0655\u0644\u0649 100 \u0645\u0644\u064a\u0648\u0646 \u064a\u0648\u0631\u0648. \u0648\u064a\u0645\u0644\u0643 \u0644\u064a\u0641\u0631\u0628\u0648\u0644 \u0639\u0644\u0627\u0642\u0629 \u0642\u0648\u064a\u0629 \u0645\u0639 \u0646\u0627\u062f\u064a \u0644\u0627\u064a\u0628\u0632\u064a\u062c \u062e\u0644\u0627\u0644 \u0627\u0644\u0633\u0646\u0648\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629\u060c \u0628\u0639\u062f\u0645\u0627 \u0646\u062c\u062d \u0641\u064a \u0636\u0645 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u0644\u0627\u0639\u0628 \u0645\u0646 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0627\u0654\u0644\u0645\u0627\u0646\u064a\u060c \u0627\u0654\u0628\u0631\u0632\u0647\u0645 \u062f\u0648\u0645\u064a\u0646\u064a\u0643 \u0633\u0648\u0628\u0648\u0633\u0644\u0627\u064a \u0648\u0627\u0655\u0628\u0631\u0627\u0647\u064a\u0645\u0627 \u0643\u0648\u0646\u0627\u062a\u064a \u0648\u0646\u0627\u0628\u064a \u0643\u064a\u062a\u0627\u060c \u0648\u0647\u0648 \u0645\u0627 \u0642\u062f \u064a\u0633\u0647\u0644 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a \u0628\u064a\u0646 \u0627\u0644\u0637\u0631\u0641\u064a\u0646. \u0648\u0641\u064a \u0627\u0644\u0648\u0642\u062a \u0646\u0641\u0633\u0647\u060c \u064a\u0648\u0627\u0635\u0644 \u0627\u0644\u0646\u0627\u062f\u064a \u0627\u0644\u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a \u0645\u062a\u0627\u0628\u0639\u0629 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 \u062e\u064a\u0627\u0631 \u0647\u062c\u0648\u0645\u064a \u0627\u0653\u062e\u0631\u060c \u0645\u0646 \u0628\u064a\u0646\u0647\u0645 \u0627\u0654\u0646\u062a\u0648\u0646\u064a \u062c\u0648\u0631\u062f\u0648\u0646 \u0644\u0627\u0639\u0628 \u0646\u064a\u0648\u0643\u0627\u0633\u0644 \u064a\u0648\u0646\u0627\u064a\u062a\u062f\u060c \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0628\u0631\u0627\u062f\u0644\u064a \u0628\u0627\u0631\u0643\u0648\u0644\u0627 \u062c\u0646\u0627\u062d \u0628\u0627\u0631\u064a\u0633 \u0633\u0627\u0646 \u062c\u064a\u0631\u0645\u0627\u0646\u060c \u0636\u0645\u0646 \u062e\u0637\u0629 \u0627\u0644\u0627\u0655\u062f\u0627\u0631\u0629 \u0644\u0627\u0655\u0639\u0627\u062f\u0629 \u0628\u0646\u0627\u0621 \u0627\u0644\u062e\u0637 \u0627\u0644\u0647\u062c\u0648\u0645\u064a \u0628\u0639\u062f \u0631\u062d\u064a\u0644 \u0645\u062d\u0645\u062f \u0635\u0644\u0627\u062d. \u0642\u062f \u064a\u0647\u0645\u0643 \u0627\u0654\u064a\u0636\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0640\u0627 \u0633\u0644\u0648\u062a \u064a\u062a\u0645\u0633\u0643 \u0628\u0627\u0644\u0628\u0642\u0627\u0621 \u0645\u0639 \u0644\u064a\u0641\u0631\u0628\u0648\u0644 \u0628\u0639\u062f \u0631\u062d\u064a\u0644 \u0635\u0644\u0627\u062d \u0645\u062d\u0645\u062f \u0635\u0644\u0627\u062d \u0627\u0654\u064a\u0642\u0648\u0646\u0629 \u062e\u0627\u0644\u062f\u0629 \u0641\u064a \u062a\u0627\u0631\u064a\u062e \u0644\u064a\u0641\u0631\u0628\u0648\u0644", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": ["\u0644\u0646\u062f\u0646 \u0640 \u0645\u0635\u0631 \u0627\u0644\u064a\u0648\u0645"], "language": "arabic", "country": ["egypt"], "category": ["sports"], "datatype": "news", "pubDate": "2026-05-26 04:43:14", "pubDateTZ": "UTC", "fetched_at": "2026-05-26 04:43:14", "image_url": "https://www.egypt-today.com/img/2021/07/exlarge/R7W8PP-july2021.jpg", "video_url": null, "source_id": "egypt_today", "source_name": "Egypt Today", "source_priority": 477098, "source_url": "https://www.egypt-today.com", 