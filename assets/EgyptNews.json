648\u0627\u062c\u0647\u0648\u0647\u0645\".\u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0644\u0628\u0646\u0627\u0646\u064a\u0629 \u0636\u062f \u0627\u0655\u064a\u0631\u0627\u0646\u0648\u062a\u0627\u0654\u062a\u064a \u0647\u0630\u0647 \u0627\u0644\u062a\u0648\u062c\u064a\u0647\u0627\u062a \u0641\u064a \u0648\u0642\u062a \u0628\u062f\u0627\u0654\u062a \u0641\u064a\u0647 \u0627\u0644\u062d\u0643\u0648\u0645\u0629 \u0627\u0644\u0644\u0628\u0646\u0627\u0646\u064a\u0629 \u0627\u062a\u062e\u0627\u0630 \u062e\u0637\u0648\u0627\u062a \u0636\u062f \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u064a\u0646 \u0648\u0639\u0646\u0627\u0635\u0631 \u0627\u0644\u062d\u0631\u0633 \u0627\u0644\u062b\u0648\u0631\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0641\u064a \u0627\u0644\u0628\u0644\u0627\u062f. \u0648\u0645\u0646 \u0628\u064a\u0646 \u0627\u0644\u062a\u062f\u0627\u0628\u064a\u0631 \u0627\u0644\u0627\u0654\u062e\u0631\u0649\u060c \u0627\u0654\u0639\u0644\u0646 \u0644\u0628\u0646\u0627\u0646 \u0627\u0654\u0646 \u0627\u0644\u0645\u0648\u0627\u0637\u0646\u064a\u0646 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u064a\u0646 \u0644\u0627 \u064a\u0645\u0643\u0646\u0647\u0645 \u0627\u0644\u062f\u062e\u0648\u0644 \u0627\u0655\u0644\u0627 \u0628\u062a\u0627\u0654\u0634\u064a\u0631\u0629\u060c \u0648\u0635\u0646\u0651\u0641 \u0627\u0644\u062d\u0631\u0633 \u0627\u0644\u062b\u0648\u0631\u064a \u0645\u0646\u0638\u0645\u0629 \u063a\u064a\u0631 \u0642\u0627\u0646\u0648\u0646\u064a\u0629\u060c \u0648\u0637\u0631\u062f \u0643\u0628\u0627\u0631 \u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644\u064a\u0646 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u064a\u0646. \u0648\u062a\u0627\u0654\u062a\u064a \u062e\u0637\u0648\u0629 \u0644\u0628\u0646\u0627\u0646 \u0627\u0633\u062a\u062c\u0627\u0628\u0629 \u0644\u0645\u0637\u0627\u0644\u0628 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644 \u0628\u0627\u0644\u062a\u062d\u0631\u0643 \u0636\u062f \u0639