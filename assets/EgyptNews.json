\u064a\u0629 \u0648\u0627\u0644\u0637\u0627\u064a\u0654\u0631\u0627\u062a \u0627\u0644\u0645\u0633\u064a\u0631\u0629 \u0627\u0644\u062a\u064a \u0627\u0633\u062a\u0647\u062f\u0641\u062a \u0639\u062f\u0629 \u0645\u0646\u0627\u0637\u0642 \u0641\u064a \u0627\u0644\u0628\u0644\u0627\u062f. \u0641\u0642\u062f \u0631\u0635\u062f\u062a \u0627\u0654\u0646\u0638\u0645\u0629 \u0627\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u062c\u0648\u064a \u0627\u0644\u0642\u0637\u0631\u064a\u0629 65 \u0635\u0627\u0631\u0648\u062e\u0627\u064b \u0628\u0627\u0644\u064a\u0633\u062a\u064a\u0627\u064b \u064812 \u0637\u0627\u064a\u0654\u0631\u0629 \u0645\u0633\u064a\u0631\u0629 \u0642\u0627\u062f\u0645\u0629 \u0645\u0646 \u0627\u062a\u062c\u0627\u0647\u0627\u062a \u0645\u062e\u062a\u0644\u0641\u0629\u060c \u0648\u062a\u0645 \u0627\u0639\u062a\u0631\u0627\u0636 \u0648\u062a\u062f\u0645\u064a\u0631 63 \u0635\u0627\u0631\u0648\u062e\u0627\u064b \u064811 \u0637\u0627\u064a\u0654\u0631\u0629 \u0645\u0633\u064a\u0631\u0629 \u0642\u0628\u0644 \u0648\u0635\u0648\u0644\u0647\u0627 \u0627\u0655\u0644\u0649 \u0627\u0654\u0647\u062f\u0627\u0641\u0647\u0627.\u0633\u0642\u0637 \u0635\u0627\u0631\u0648\u062e\u0627\u0646 \u0628\u0627\u0644\u064a\u0633\u062a\u064a\u0627\u0646 \u0641\u064a \u0645\u062d\u064a\u0637 \u0642\u0627\u0639\u062f\u0629 \u0627\u0644\u0639\u062f\u064a\u062f \u0627\u0644\u062c\u0648\u064a\u0629\u060c \u0648\u0627\u0654\u0635\u0627\u0628\u062a \u0637\u0627\u064a\u0654\u0631\u0629 \u0645\u0633\u064a\u0631\u0629 \u0648\u0627\u062d\u062f\u0629 \u0645\u0646\u0634\u0627\u0654\u0629 \u0631\u0627\u062f\u0627\u0631 \u0644\u0644\u0627\u0655\u0646\u0630\u0627\u0631 \u0627\u0644\u0645\u0628\u0643\u0631\u060c \u062f\u0648\u0646 \u062a\u0633\u062c\u064a\u0644 \u0627\u0654\u064a \u062e\u0633\u0627\u064a\u0654\u0631 \u0628\u0634\u0631\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u0648\u0627\u0642\u0639 \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629.\u0648\u0627\u0654\u0643\u062f\u062a \u0627\u0644\u0633\u0644\u0637\u0627\u062a \u0627\u0654\u0646 \u0627\u0644\u0648\u0636\u0639 \u062a\u062d\u062a \u0627\u0644\u0633\u064a\u0637\u0631\u0629 \u0627\u0644\u0643\u0627\u0645\u0644\u0629\u060c \u0648\u0644\u0645 \u062a\u0633\u062c\u0644 \u0627\u0644\u0645\u0633\u0648\u062d\u0627\u062a \u0627\u0644\u0645\u064a\u062f\u0627\u0646\u064a\u0629 \u0627\u0654\u064a \u0627\u0655\u0635\u0627\u0628\u0627\u062a \u0628\u0634\u0631\u064a\u0629 \u0627\u0654\u0648 \u0627\u0654\u0636\u0631\u0627\u0631 \u0645\u0627\u062f\u064a\u0629 \u0641\u064a \u0627\u0644\u0645\u0646\u0627\u0637\u0642 \u0627\u0644\u0633\u0643\u0646\u064a\u0629. \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0645\u0637\u0627\u0631 \u0627\u0644\u0628\u062d\u0631\u064a\u0646 \u0627\u0644\u062f\u0648\u0644\u064a\u0641\u064a\u0645\u0627 \u0627\u0654\u0639\u0644\u0646\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629 \u0627\u0644\u0628\u062d\u0631\u064a\u0646\u064a\u0629\u060c \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0645\u0637\u0627\u0631 \u0627\u0644\u0628\u062d\u0631\u064a\u0646 \u0627\u0644\u062f\u0648\u0644\u064a \u0628\u0637\u0627\u064a\u0654\u0631\u0629 \u0645\u0633\u064a\u0631\u0629 \u0645\u0627 \u0627\u0654\u0633\u0641\u0631 \u0639\u0646 \u0627\u0654\u0636\u0631\u0627\u0631 \u0645\u0627\u062f\u064a\u0629 \u0641\u0642\u0637.\u0648\u0643\u0627\u0646\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062f\u0627\u062e\u0644\u064a\u0629 \u0641\u064a \u0627\u0644\u0628\u062d\u0631\u064a\u0646 \u0642\u062f \u0627\u0654\u0639\u0644\u0646\u062a \u0627\u0633\u062a\u0647\u062f\u0627\u0641 \u0645\u0628\u0646\u0649 \u0633\u0643\u0646\u064a \u0641\u064a \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0627\u0644\u0645\u0646\u0627\u0645\u0629\u060c \u0645\u0634\u064a\u0631\u0629 \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0645\u062e\u062a\u0635\u0629 \u0628\u0627\u0634\u0631\u062a \u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a\u0647\u0627 \u0644\u062a\u0627\u0654\u0645\u064a\u0646 \u0627\u0644\u0645\u0648\u0642\u0639 \u0648\u0627\u0644\u062a\u062d\u0642\u064a\u0642 \u0641\u064a \u0645\u0644\u0627\u0628\u0633\u0627\u062a \u0627\u0644\u062d\u0627\u062f\u062b\u060c \u0645\u0639 \u0627\u062a\u062e\u0627\u0630 \u0643\u0627\u0641\u0629 \u0627\u0644\u062a\u062f\u0627\u0628\u064a\u0631 \u0644\u062d\u0645\u0627\u064a\u0629 \u0627\u0644\u0645\u062f\u0646\u064a\u064a\u0646 \u0648\u0636\u0645\u0627\u0646 \u0633\u0644\u0627\u0645\u062a\u0647\u0645.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0627\u0644\u0625\u0645\u0627\u0631\u0627\u062a", "\u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0627", "\u0627\u0644\u0628\u062d\u0631\u064a\u0646", "\u0627\u0644\u062d\u0631\u0628 \u0639\u0644\u0649 \u0625\u064a\u0631\u0627\u0646", "\u0627\u0644\u0643\u0648\u064a\u062a", "\u0623\u0645\u064a\u0631\u0643\u0627", "\u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629"], "creator": ["\u0641\u0631\u0647\u0627\u062f \u0627\u0644\u0631\u0641\u0627\u0639\u064a"], "language": "arabic", "country": ["egypt"], "category": ["lifestyle", "top"], "datatype": "news", "pubDate": "2026-03-01 05:30:57", "pubDateTZ": "UTC", "fetched_at": "2026-03-01 06:41:19", "image_url": "https://s1.elaph.com/resources/images/News/2026/03/week1/2c150c190eb2d54eee6e3b397f676c35.jpg", "video_url": null, "source_id": "elaph", "source_name": "Elaph", "source_priority": 197218, "source_url": "https://elaph.com", "source_icon": "https://n.bytvi.com/elaph.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "1b058303ab52cb2a8891b6712a2f7137", "link": "https://elaph.com/Web/News/2026/03/1589748.html", "title": "\u0648\u0643\u0627\u0644\u0