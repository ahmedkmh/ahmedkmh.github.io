64a\u0641\u0629 \"\u062a\u0627\u064a\u0645\u0632 \u0627\u0654\u0648\u0641 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\"\u060c \u0641\u0642\u062f \u0627\u062e\u062a\u0631\u0642 \u0627\u0644\u0635\u0627\u0631\u0648\u062e \u0627\u0644\u0628\u0627\u0644\u064a\u0633\u062a\u064a \u0645\u0646\u0637\u0642\u0629 \u0633\u0643\u0646\u064a\u0629 \u0645\u062f\u0645\u0631\u0627\u064b \u0627\u0644\u0643\u0646\u064a\u0633 \u0648\u0645\u0644\u062c\u0627\u064b\u0654 \u0639\u0627\u0645\u0627\u064b \u064a\u0642\u0639 \u0627\u0654\u0633\u0641\u0644\u0647\u060c \u0648\u0645\u062e\u0644\u0641\u0627\u064b \u0627\u0654\u0636\u0631\u0627\u0631\u0627\u064b \u062c\u0633\u064a\u0645\u0629 \u0641\u064a \u0627\u0644\u0645\u0646\u0627\u0632\u0644 \u0627\u0644\u0645\u062c\u0627\u0648\u0631\u0629.\u062d\u0635\u064a\u0644\u0629 \u0627\u0644\u062f\u0645\u0627\u0621 \u0648\u0627\u0644\u062a\u062d\u0642\u064a\u0642\u0627\u062a \u0627\u0644\u0639\u0627\u062c\u0644\u0629\u0648\u0646\u0642\u0644\u062a \"\u062a\u0627\u064a\u0645\u0632 \u0627\u0654\u0648\u0641 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\" \u0639\u0646 \u062e\u062f\u0645\u0629 \"\u0645\u062c\u0646 \u062f\u0627\u0648\u062f \u0627\u0654\u062f\u0648\u0645\" \u0644\u0644\u0627\u0655\u0633\u0639\u0627\u0641\u060c \u0648\u0641\u0627\u0629 8 \u0627\u0654\u0634\u062e\u0627\u0635 \u0641\u064a \u0639\u064a\u0646 \u0627\u0644\u0645\u0643\u0627\u0646\u060c \u0628\u064a\u0646\u0645\u0627 \u0641\u0627\u0631\u0642 \u0627\u0644\u062a\u0627\u0633\u0639 \u0627\u0644\u062d\u064a\u0627\u0629 \u0645\u062a\u0627\u0654\u062b\u0631\u0627\u064b \u0628\u062c\u0631\u0627\u062d\u0647\u060c \u0648\u0646\u064f\u0642\u0644 28 \u0645\u0635\u0627\u0628\u0627\u064b \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u064a\u0627\u062a\u060c \u0645\u0646 \u0628\u064a\u0646\u0647\u0645 \u0627\u062b\u0646\u0627\u0646 \u0641\u064a \u062d\u0627\u0644\u0629 \u062e\u0637\u0631\u0629 \u0648\u0637\u0641\u0644 \u0641\u064a \u0627\u0644\u0631\u0627\u0628\u0639\u0629 \u0645\u0646 \u0639\u0645\u0631\u0647. \u0648\u0641\u064a \u0647\u0632\u0629 \u0627\u0654\u0645\u0646\u064a\u0629 \u0642\u0648\u064a\u0629\u060c \u0641\u062a\u062d \u0633\u0644\u0627\u062d \u0627\u0644\u062c\u0648 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u062a\u062d\u0642\u064a\u0642\u0627\u064b \u0639\u0627\u062c\u0644\u0627\u064b \u0641\u064a \u0627\u0654\u0633\u0628\u0627\u0628 \u0627\u0655\u062e\u0641\u0627\u0642 \u0645\u0646\u0638\u0648\u0645\u0627\u062a \u0627\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u062c\u0648\u064a \u0641\u064a \u0627\u0644\u062a\u0635\u062f\u064a \u0644\u0644\u0635\u0627\u0631\u0648\u062e \u0631\u063a\u0645 \u062a\u0641\u0639\u064a\u0644\u0647\u0627\u060c \u062d\u064a\u062b \u064a\u064f\u0642\u062f\u0631 \u0648\u0632\u0646 \u0631\u0627\u0654\u0633\u0647 \u0627\u0644\u062d\u0631\u0628\u064a \u0628\u0646\u062d\u0648 500 \u0643\u064a\u0644\u0648\u063a\u0631\u0627\u0645.\u0645\u062e\u0632\u0648\u0646 \u0627\u0644\u0635\u0648\u0627\u0631\u064a\u062e \u0648\"\u0632\u064a\u0654\u064a\u0631 \u0627\u0644\u0627\u0654\u0633\u062f\"\u062a\u0627\u0654\u062a\u064a \u0647\u0630\u0647 \u0627\u0644\u0636\u0631\u0628\u0629\u060c \u0648\u0641\u0642\u0627\u064b \u0644\u0644\u0645\u0635\u062f\u0631 \u0630\u0627\u062a\u0647\u060c \u0628\u0639\u062f \u0627\u0654\u0642\u0644 \u0645\u0646 36 \u0633\u0627\u0639\u0629 \u0639\u0644\u0649 \u0627\u0646\u0637\u0644\u0627\u0642 \"\u0639\u0645\u0644\u064a\u0629 \u0632\u064a\u0654\u064a\u0631 \u0627\u0644\u0627\u0654\u0633\u062f\" \u0627\u0644\u0639\u0633\u0643\u0631\u064a\u0629\u060c \u0648\u0633\u0637 \u062a\u0642\u062f\u064a\u0631\u0627\u062a \u0644\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u0628\u0627\u0654\u0646 \u0627\u0644\u0645\u062e\u0632\u0648\u0646 \u0627\u0644\u0635\u0627\u0631\u0648\u062e\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u064a\u0628\u0644\u063a \u0646\u062d\u0648 2500 \u0635\