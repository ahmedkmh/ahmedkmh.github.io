8 \u0627\u0655\u0633 \u0627\u0655\u0633 \u0631\u0627\u0641\u0627\u064a\u0654\u064a\u0644 \u0628\u064a\u0631\u0627\u0644\u062a\u0627\" \u0627\u0639\u062a\u0631\u0636\u062a \u0633\u0641\u064a\u0646\u0629 \u0643\u0627\u0646\u062a \u0645\u062a\u062c\u0647\u0629 \u0644\u0627\u0654\u062d\u062f \u0627\u0644\u0645\u0648\u0627\u0646\u064a\u0654 \u0641\u064a \u0627\u0655\u064a\u0631\u0627\u0646 \u0627\u0654\u0645\u0633.\u0648\u0646\u0634\u0631\u062a \u0633\u0646\u062a\u0643\u0648\u0645 \u0641\u064a \u062a\u063a\u0631\u064a\u062f\u0629 \u0639\u0644\u0649 \u0627\u0655\u0643\u0633 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0633\u0628\u062a \u0635\u0648\u0631\u0629 \u0644\u0644\u0645\u062f\u0645\u0631\u0629 \u062a\u062d\u0627\u0635\u0631 \u0627\u0644\u0645\u0648\u0627\u0646\u064a\u0654 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629.3 \u062d\u0627\u0645\u0644\u0627\u062a \u0637\u0627\u064a\u0654\u0631\u0627\u062a\u0627\u0654\u062a\u0649 \u0630\u0644\u0643\u060c \u0641\u064a\u0645\u0627 \u062a\u0631\u0627\u0628\u0636 3 \u062d\u0627\u0645\u0644\u0627\u062a \u0637\u0627\u064a\u0654\u0631\u0627\u062a \u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0641\u064a \u0627\u0653\u0646\u064d \u0648\u0627\u062d\u062f \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u0627\u0654\u0648\u0644\u0649 \u0645\u0646\u0630 \u0639\u0642\u0648\u062f\u060c \u0648\u0641\u0642 \u0645\u0627 \u0627\u0654\u0639\u0644\u0646 \u0633\u0627\u0628\u0642\u0627 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a. \u0648\u0644\u0641\u062a \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0647\u0630\u0647 \u0627\u0644\u062d\u0627\u0645\u0644\u0627\u062a \u0647\u064a: \u064a\u0648 \u0627\u0654\u0633 \u0627\u0654\u0633 \u0627\u0654\u0628\u0631\u0627\u0647\u0627\u0645 \u0644\u064a\u0646\u0643\u0648\u0644\u0646 (CVN 72)\u060c \u0648\u064a\u0648 \u0627\u0654\u0633 \u0627\u0654\u0633 \u062c\u064a\u0631\u0627\u0644\u062f \u0627\u0653\u0631. \u0641\u0648\u0631\u062f (CVN 78)\u060c \u0648\u064a\u0648 \u0627\u0654\u0633 \u0627\u0654\u0633 \u062c\u0648\u0631\u062c \u0627\u0655\u062a\u0634. \u062f\u0628\u0644\u064a\u0648. \u0628\u0648\u0634 (CVN 77).\u0647\u0630\u0627 \u0648\u062a\u062d\u0645\u0644 \u0639\u0644\u0649 \u0645\u062a\u0646\u0647\u0627 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 200 \u0637\u0627\u064a\u0654\u0631\u0629 \u064815000 \u0645\u0646 \u0627\u0644\u0628\u062d\u0627\u0631\u0629 \u0648\u0645\u0634\u0627\u0629 \u0627\u0644\u0628\u062d\u0631\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629.\"\u0627\u0644\u062d\u0635\u0627\u0631 \u064a\u062a\u0633\u0639\"\u0648\u0643\u0627\u0646 \u0648\u0632\u064a\u0631 \u0627\u0644\u062f\u0641\u0627\u0639 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u0628\u064a\u062a \u0647\u064a\u062c\u0633\u064a\u062b \u0627\u0654\u0643\u062f \u0641\u064a \u0627\u0655\u062d\u0627\u0637\u0629 \u0635\u062d\u0641\u064a\u0629 \u0627\u0654\u0645\u0633 \u0627\u0654\u0646 \u0627\u0644\u062d\u0635\u0627\u0631 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u0639\u0644\u0649 \u0627\u0655\u064a\u0631\u0627\u0646 \u064a\u062a\u0633\u0639 \u0627\u0655\u0644\u0649 \u0646\u0637\u0627\u0642 \u0639\u0627\u0644\u0645\u064a.\u0643\u0645\u0627 \u0627\u0654\u0636\u0627\u0641 \u0627\u0654\u0646\u0647 \"\u0644\u0627 \u064a\u064f\u0633\u0645\u062d \u0644\u0627\u0654\u064a \u0633\u0641\u064a\u0646\u0629 \u0628\u0627\u0644\u0627\u0655\u0628\u062d\u0627\u0631 \u0645\u0646 \u0645\u0636\u064a\u0642 \u0647\u0631\u0645\u0632 \u0627\u0655\u0644\u0649 \u0627\u0654\u064a \u0645\u0643\u0627\u0646 \u0641\u064a \u0627\u0644\u0639\u0627\u0644\u0645 \u062f\u0648\u0646 \u0627\u0655\u0630\u0646 \u0645\u0646 \u0627\u0644\u0628\u062d\u0631\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629\".\u0628\u062f\u0648\u0631\u0647\u060c \u0642\u0627\u0644 \u0631\u064a\u0654\u064a\u0633 