7\u0655\u0631\u062b \u064a\u0645\u062a\u062f \u0644\u0639\u0634\u0631\u0627\u062a \u0627\u0644\u0633\u0646\u064a\u0646\u060c \u062c\u0639\u0644\u0647\u0627 \u0645\u0631\u0643\u0632\u0627\u064b \u0631\u064a\u0654\u064a\u0633\u064a\u0627\u064b \u0641\u064a \u0635\u0646\u0627\u0639\u0629 \u0627\u0644\u0627\u0654\u0633\u0645\u0627\u0643 \u0627\u0644\u0645\u0645\u0644\u062d\u0629. \u0642\u0628\u0644 \u0627\u0654\u064a\u0627\u0645\u060c \u062a\u062d\u0648\u0644\u062a \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u0627\u0655\u0644\u0649 \u062e\u0644\u064a\u0629 \u0646\u062d\u0644 \u0628\u0634\u0631\u064a\u0629\u060c \u062a\u0633\u062a\u0642\u0628\u0644 \u0632\u0648\u0627\u0631\u0627\u064b \u0645\u0646 \u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u062d\u0627\u0641\u0638\u0627\u062a \u0627\u0644\u0645\u0635\u0631\u064a\u0629\u060c \u0648\u062a\u0645\u062a\u062f \u0634\u0647\u0631\u062a\u0647\u0627 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0635\u0631\u064a\u064a\u0646 \u0641\u064a \u0627\u0654\u0648\u0631\u0648\u0628\u0627 \u0648\u0627\u0654\u0645\u064a\u0631\u0643\u0627\u060c \u0627\u0644\u0630\u064a\u0646 \u064a\u062d\u0631\u0635\u0648\u0646 \u0639\u0644\u0649 \u062a\u0632\u064a\u064a\u0646 \u0645\u0648\u0627\u064a\u0654\u062f\u0647\u0645 \u0628 \"\u0641\u0633\u064a\u062e \u0646\u0628\u0631\u0648\u0647\".\u0648\u0642\u0627\u0644 \u0645\u062d\u0645\u062f \u0627\u0644\u064a\u0645\u0627\u0646\u064a\u060c \u0627\u0654\u062d\u062f \u0627\u0654\u0635\u062d\u0627\u0628 \u0645\u062d\u0644\u0627\u062a \u0627\u0644\u0627\u0654\u0633\u0645\u0627\u0643 \u0627\u0644\u0645\u0645\u0644\u062d\u0629 \u0641\u064a \u0646\u0628\u0631\u0648\u0647\u060c \u0644\u0640 \"\u0627\u0644\u0639\u0631\u0628\u064a\u0629.\u0646\u062a\" \u0648\"\u0627\u0644\u062d\u062f\u062b.\u0646\u062a\"\u060c \u0627\u0655\u0646 \u0627\u0644\u0645\u062f\u064a\u0646\u0629 \u062a\u0634\u062a\u0647\u0631 \u0628\u0627\u0655\u0639\u062f\u0627\u062f \u0627\u0644\u0641\u0633\u064a\u062e \u0645\u0646 \u0633\u0645\u0643 \u0627\u06