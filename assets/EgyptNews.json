u0631\u062c\u064a \u0627\u0644\u062a\u0648\u0646\u0633\u064a\u060c \u0645\u0633\u0627\u0621 \u0627\u0644\u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u062d\u062f\u060c \u0641\u064a \u0630\u0647\u0627\u0628 \u0627\u0644\u062f\u0648\u0631 \u0631\u0628\u0639 \u0627\u0644\u0646\u0647\u0627\u064a\u0654\u064a \u0645\u0646 \u0628\u0637\u0648\u0644\u0629 \u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0654\u0641\u0631\u064a\u0642\u064a\u0627.\u0648\u062a\u0646\u0637\u0644\u0642 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0648\u0627\u0644\u062a\u0631\u062c\u064a\u060c \u0641\u064a \u062a\u0645\u0627\u0645 \u0627\u0644\u0633\u0627\u0639\u0629 \u0627\u0644\u062d\u0627\u062f\u064a\u0629 \u0639\u0634\u0631 \u0645\u0633\u0627\u0621\u060c \u0628\u062a\u0648\u0642\u064a\u062a \u0627\u0644\u0642\u0627\u0647\u0631\u0629\u060c \u0639\u0644\u0649 \u0627\u0654\u0631\u0636\u064a\u0629 \u0645\u0644\u0639\u0628 \u062d\u0645\u0627\u062f\u064a \u0627\u0644\u0639\u0642\u0631\u0628\u064a \u0628\u0631\u0627\u062f\u0633.\u0648\u064a\u0633\u0639\u0649 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0628\u0642\u064a\u0627\u062f\u0629 \u0645\u062f\u0631\u0628\u0647 \u064a\u064a\u0633 \u062a\u0648\u0631\u0648\u0628\u060c \u0644\u0645\u0635\u0627\u0644\u062d\u0629 \u062c\u0645\u0627\u0647\u064a\u0631\u0647\u060c \u0628\u0639\u062f \u0627\u0644\u0633\u0642\u0648\u0637 \u0641\u064a \u0641\u062e \u0627\u0644\u0647\u0632\u064a\u0645\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0645\u062d\u0644\u064a\u064b\u0627 \u0636\u062f \u0637\u0644\u0627\u064a\u0654\u0639 \u0627\u0644\u062c\u064a\u0634\u060c \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0645\u0635\u0631\u064a.\u0648\u064a\u062f\u062e\u0644 \u0627\u0644\u0641\u0631\u064a\u0642 \u0627\u0644\u0627\u0654\u062d\u0645\u0631 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u064a\u0648\u0645\u060c \u0645\u062a\u0633\u0644\u062d\u064b\u0627 \u0628\u062a\u0627\u0631\u064a\u062e\u0647 \u0648\u0627\u0655\u0631\u062b\u0647 \u0641\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0627\u0644\u0642\u0627\u0631\u064a\u0629\u060c \u0648\u062a\u062d\u062f\u064a\u062f\u064b\u0627 \u0636\u062f \u063a\u0631\u064a\u0645\u0647 \u0627\u0644\u062a\u0648\u0646\u0633\u064a\u060c \u0627\u0644\u0630\u064a \u064a\u0639\u0631\u0641\u0647 \u062c\u064a\u062f\u064b\u0627\u060c \u062d\u064a\u062b \u062a\u0639\u062a\u0628\u0631 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0637\u0631\u0641\u064a\u0646 \u0643\u0644\u0627\u0633\u064a\u0643\u064a\u0629 \u0641\u064a \u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0654\u0628\u0637\u0627\u0644.\u0648\u0627\u0644\u062a\u0642\u0649 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0641\u064a 24 \u0645\u0646\u0627\u0633\u0628\u0629 \u0645\u0646 \u0642\u0628\u0644 \u0645\u0639 \u0627\u0644\u062a\u0631\u062c\u064a\u060c \u062a\u0641\u0648\u0642 \u062e\u0644\u0627\u0644\u0647\u0627 \u0641\u064a 11 \u0644\u0642\u0627\u0621\u060c \u0628\u064a\u0646\u0645\u0627 \u062a\u0639\u0627\u062f\u0644 \u0641\u064a 9\u060c \u0648\u0643\u0627\u0646 \u0627\u0644\u0627\u0646\u062a\u0635\u0627\u0631 \u0645\u0646 \u0646\u0635\u064a\u0628 \u0627\u0644\u062a\u0631\u062c\u064a \u0641\u064a 4 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0641\u0642\u0637.\u0648\u0643\u0627\u0646\u062a \u0627\u0653\u062e\u0631 \u0645\u0648\u0627\u062c\u0647\u0629 \u0628\u064a\u0646 \u0627\u0644\u0641\u0631\u064a\u0642\u064a\u0646 \u0645\u0646 \u0646\u0648\u0639 \u062e\u0627\u0635\u060c \u062d\u064a\u062b \u062c\u0645\u0639\u062a \u0628\u064a\u0646\u0647\u0645\u0627 \u0641\u064a \u0646\u0647\u0627\u064a\u0654\u064a \u0627\u0644\u0628\u0637\u0648\u0644\u0629 \u0630\u0627\u062a\u0647\u0627\u060c \u0644\u0646\u0633\u062e\u0629 2023-2024\u060c \u0648\u062a\u0641\u0648\u0642 \u0627\u0644\u0627\u0654\u0647\u0644\u064a \u0628\u0647\u062f\u0641 \u0646\u0638\u064a\u0641 \u0641\u064a \u0645\u062c\u0645\u0