", "source_name": "\u0635\u062f\u0649 \u0627\u0644\u0628\u0644\u062f", "source_priority": 66548, "source_url": "https://www.elbalad.news", "source_icon": "https://n.bytvi.com/elbalad_news.jpg", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}, {"article_id": "c2a160dfd2e3b9a9fd95706b2fc8fcff", "link": "https://elaph.com/Web/News/2026/02/1589388.html", "title": "\u0646\u0642\u0644 \u0645\u0644\u0643 \u0627\u0644\u0646\u0631\u0648\u064a\u062c \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u0649", "description": "\u0627\u0655\u064a\u0644\u0627\u0641 \u0645\u0646 \u0644\u0646\u062f\u0646: \u0642\u0627\u0644\u062a \u062a\u0642\u0627\u0631\u064a\u0631 \u0627\u0655\u0646 \u0645\u0644\u0643 \u0627\u0644\u0646\u0631\u0648\u064a\u062c \u0647\u0627\u0631\u0627\u0644\u062f \u0646\u064f\u0642\u0644 \u0627\u0655\u0644\u0649 \u0645\u0633\u062a\u0634\u0641\u0649 \u0641\u064a \u062c\u0632\u0631 \u0627\u0644\u0643\u0646\u0627\u0631\u064a \u0628\u0639\u062f \u062a\u0639\u0631\u0636\u0647 \u0644\u0648\u0639\u0643\u0629 \u0635\u062d\u064a\u0629 \u0627\u0654\u062b\u0646\u0627\u0621 \u0639\u0637\u0644\u062a\u0647.\u0643\u0627\u0646 \u0627\u0644\u0645\u0644\u0643 \u0627\u0644\u0628\u0627\u0644\u063a \u0645\u0646 \u0627\u0644\u0639\u0645\u0631 89 \u0639\u0627\u0645\u064b\u0627\u060c \u0648\u0647\u0648 \u0627\u0654\u0643\u0628\u0631 \u0645\u0644\u0648\u0643 \u0627\u0654\u0648\u0631\u0648\u0628\u0627 \u0627\u0644\u0627\u0654\u062d\u064a\u0627\u0621 \u0633\u0646\u064b\u0627\u060c \u0641\u064a \u0631\u062d\u0644\u0629 \u0645\u0639 \u0632\u0648\u062c\u062a\u0647 \u0627\u0644\u0645\u0644\u0643\u0629 \u0633\u0648\u0646\u064a\u0627 \u0639\u0646\u062f\u0645\u0627 \u0634\u0639\u0631 \u0628\u062a\u0648\u0639\u0643.\u0648\u0645\u0646 \u0627\u0644\u0645\u062a\u0648\u0642\u0639 \u0635\u062f\u0648\u0631 \u0628\u064a\u0627\u0646 \u062d\u0648\u0644 \u0627\u0644\u062d\u0627\u0644\u0629 \u0627\u0644\u0635\u062d\u064a\u0629 \u0644\u0644\u0645\u0644\u0643 \u064a\u0648\u0645 \u0627\u0644\u0627\u0654\u0631\u0628\u0639\u0627\u0621 \u0628\u0639\u062f \u062e\u0636\u0648\u0639\u0647 \u0644\u0641\u062d\u0635 \u0645\u0646 \u0642\u0628\u0644 \u0637\u0628\u064a\u0628\u0647 \u0627\u0644\u062e\u0627\u0635.\u0648\u0646\u064f\u0642\u0644 \u0627\u0644\u0645\u0644\u0643\u060c \u0627\u0644\u0630\u064a \u0627\u062d\u062a\u0641\u0644 \u0628\u0639\u064a\u062f \u0645\u064a\u0644\u0627\u062f\u0647 \u064a\u0648\u0645 \u0627\u0644\u0633\u0628\u062a\u060c \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0633\u062a\u0634\u0641\u0649 \u0645\u0633\u0627\u0621 \u0627\u0644\u062b\u0644\u0627\u062b\u0627\u0621 \u0648\u0647\u0648 \u064a\u0639\u0627\u0646\u064a \u0645\u0646 \u0639\u062f\u0648\u0649 \u0648\u062c\u0641\u0627\u0641.\u0648\u0642\u0627\u0644 \u0645\u062a\u062d\u062f\u062b \u0628\u0627\u0633\u0645 \u0627\u0644\u0642\u0635\u0631 \u0627\u0644\u0645\u0644\u0643\u064a \u0627\u0644\u0646\u0631\u0648\u064a\u062c\u064a \u0627\u0655\u0646 \u0627\u0644\u0645\u0644\u0643\u060c \u0627\u0644\u0630\u064a \u064a\u0634\u063a\u0644 \u0645\u0646\u0635\u0628 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u062f\u0648\u0644\u0629 \u0627\u0644\u0634\u0631\u0641\u064a \u0645\u0646\u0630 \u0639\u0627\u0645 1991\u060c \u064a\u062a\u0645\u062a\u0639 \u0628\u0635\u062d\u0629 \u062c\u064a\u062f\u0629.\u0648\u0635\u0631\u062d \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0646\u0631\u0648\u064a\u062c\u064a \u062c\u0648\u0646\u0627\u0633 \u063a\u0627\u0631 \u0633\u062a\u0648\u064a\u0631 \u0644\u0647\u064a\u064a\u0654\u0629 \u0627\u0644\u0627\u0655\u0630\u0627\u0639\u0629 \u0627\u0644\u0646\u0631\u0648\u064a\u062c\u064a\u0629 NRK: \"\u0627\u0654\u062a\u0645