0633\u064a\u0644\u0641\u0627 \u0633\u064a\u063a\u0627\u062f\u0631 \u0627\u0644\u0641\u0631\u064a\u0642 \u0628\u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0645\u0648\u0633\u0645 \u0627\u0644\u062c\u0627\u0631\u064a.\u0648\u0633\u064a\u0631\u062d\u0644 \u0633\u064a\u0644\u0641\u0627 \u0627\u0644\u062f\u0648\u0644\u064a \u0627\u0644\u0628\u0631\u062a\u063a\u0627\u0644\u064a \u0627\u0644\u0628\u0627\u0644\u063a \u0645\u0646 \u0627\u0644\u0639\u0645\u0631 31 \u0639\u0627\u0645\u0627\u064b\u060c \u0648\u0627\u0644\u0630\u064a \u0641\u0627\u0632 \u0628\u0633\u062a\u0629 \u0627\u0654\u0644\u0642\u0627\u0628 \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0627\u0655\u0646\u062c\u0644\u064a\u0632\u064a \u0627\u0644\u0645\u0645\u062a\u0627\u0632 \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645 \u0648\u0641\u0627\u0632 \u0628\u062f\u0648\u0631\u064a \u0627\u0654\u0628\u0637\u0627\u0644 \u0627\u0654\u0648\u0631\u0648\u0628\u0627 \u062e\u0644\u0627\u0644 \u062a\u0633\u0639 \u0633\u0646\u0648\u0627\u062a \u0642\u0636\u0627\u0647\u0627 \u0628\u0645\u0644\u0639\u0628 \u0627\u0644\u0627\u062a\u062d\u0627\u062f\u060c \u0643\u0644\u0627\u0639\u0628 \u062d\u0631 \u0639\u0646\u062f\u0645\u0627 \u064a\u0646\u062a\u0647\u064a \u0639\u0642\u062f\u0647 \u0628\u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0645\u0648\u0633\u0645.\u0648\u0642\u0627\u0644 \u0644\u064a\u0646\u062f\u0631\u0632 \u0644\u0644\u0635\u062d\u0641\u064a\u064a\u0646 \u0628\u0639\u062f \u0641\u0648\u0632 \u0633\u064a\u062a\u064a 4-\u0635\u0641\u0631 \u0639\u0644\u0649 \u0644\u064a\u0641\u0631\u0628\u0648\u0644 \u0641\u064a \u062f\u0648\u0631 \u0627\u0644\u062b\u0645\u0627\u0646\u064a\u0629 \u0645\u0646 \u0643\u0627\u0654\u0633 \u0627\u0644\u0627\u062a\u062d\u0627\u062f: \u0644\u0643\u0644 \u0642\u0635\u0629 \u062c\u0645\u064a\u0644\u0629 \u0646\u0647\u0627\u064a\u0629. \u0627\u0654\u062a\u0645\u0646\u0649 \u0644\u0647 \u0627\u0644\u0627\u0633\u062a\u0645\u062a\u0627\u0639 \u0628\u0627\u0644\u0641\u062a