27\u0644\u062a\u0642\u0644\u064a\u062f\u064a\u0629\u060c \u0627\u0633\u062a\u0636\u0627\u0641\u062a \u0627\u0644\u0639\u0627\u0635\u0645\u0629 \u0627\u0644\u0647\u0646\u063a\u0627\u0631\u064a\u0629 \u0628\u0648\u062f\u0627\u0628\u0633\u062a\u060c \u064a\u0648\u0645\u064a 14 \u064815 \u0627\u0654\u0628\u0631\u064a\u0644 (\u0646\u064a\u0633\u0627\u0646) 2026\u060c \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u062e\u0627\u0645\u0633 \u0644\u0640 \"\u0645\u0646\u062a\u062f\u0649 \u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u0627\u0655\u0631\u0647\u0627\u0628 \u0627\u0644\u0639\u0627\u0628\u0631 \u0644\u0644\u062d\u062f\u0648\u062f \u0627\u0644\u0648\u0637\u0646\u064a\u0629\" (TCTF). \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u0630\u064a \u0639\u064f\u0642\u062f \u0641\u064a \u0627\u0644\u0627\u0654\u0643\u0627\u062f\u064a\u0645\u064a\u0629 \u0627\u0644\u062f\u0648\u0644\u064a\u0629 \u0644\u0627\u0655\u0646\u0641\u0627\u0630 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u060c \u0636\u0645 \u0645\u0645\u062b\u0644\u064a\u0646 \u0639\u0646 35 \u062d\u0643\u0648\u0645\u0629 \u0645\u0646 \u0645\u062e\u062a\u0644\u0641 \u0627\u0644\u0642\u0627\u0631\u0627\u062a\u060c \u0641\u064a \u062a\u0638\u0627\u0647\u0631\u0629 \u0627\u0654\u0645\u0646\u064a\u0629 \u0648\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a\u0629 \u0647\u062f\u0641\u062a \u0627\u0655\u0644\u0649 \u062a\u0646\u0633\u064a\u0642 \u0627\u0644\u0645\u0648\u0627\u0642\u0641 \u062d\u064a\u0627\u0644 \u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u0645\u0632\u0639\u0632\u0639\u0629 \u0644\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u062a\u064a \u062a\u0646\u0641\u0630\u0647\u0627 \u0627\u0654\u0637\u0631\u0627\u0641 \u0641\u0627\u0639\u0644\u0629 \u0645\u0646 \u063a\u064a\u0631 \u0627\u0644\u062f\u0648\u0644 \u0648\u062c\u0647\u0627\u062a \u0627\u0655\u0642\u0644\u064a\u0645\u064a\u0629 \u0645\u0631\u062a\u0628\u0637\u0629 \u0628\u0647\u0627. \u062a\u0646\u0633\u064a\u0642 \u062e\u0645\u0627\u0633\u064a \u0627\u0644\u0642\u0627\u0631\u0627\u062a \u062a\u0631\u0627\u0654\u0633\u062a \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639 \u0627\u0644\u0645\u0633\u0648\u0654\u0648\u0644\u0629 \u0627\u0644\u0631\u0641\u064a\u0639\u0629 \u0627\u0644\u0645\u0633\u062a\u0648\u0649 \u0641\u064a \u0645\u0643\u062a\u0628 \u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u0627\u0655\u0631\u0647\u0627\u0628 \u0628\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062e\u0627\u0631\u062c\u064a\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629\u060c \u0645\u0648\u0646\u064a\u0643\u0627 \u062c\u0627\u0643\u0648\u0628\u0633\u0646\u060c \u0628\u0645\u0634\u0627\u0631\u0643\u0629 \u0648\u0627\u0633\u0639\u0629 \u0645\u0646 \u0635\u0627\u0646\u0639\u064a \u0627\u0644\u0633\u064a\u0627\u0633\u0627\u062a \u0648\u0645\u0645\u0627\u0631\u0633\u064a \u0627\u0655\u0646\u0641\u0627\u0630 \u0627\u0644\u0642\u0627\u0646\u0648\u0646 \u0645\u0646 \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0648\u0627\u0654\u0648\u0631\u0648\u0628\u0627 \u0648\u0627\u0655\u0641\u0631\u064a\u0642\u064a\u0627 \u0648\u0627\u0653\u0633\u064a\u0627 \u0648\u0627\u0644\u0627\u0654\u0645\u0631\u064a\u0643\u062a\u064a\u0646. \u0648\u0628\u062d\u0633\u0628 \u0645\u0635\u0627\u062f\u0631 \"\u0627\u0655\u064a\u0644\u0627\u0641\"\u060c \u0641\u0642\u062f \u062a\u0631\u0643\u0632\u062a \u0627\u0644\u0646\u0642\u0627\u0634\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u062a\u064a \u064a\u0646\u0641\u0630\u0647\u0627 \u0627\u0644\u062d\u0631\u0633 \u0627\u0644\u062b\u0648\u0631\u064a \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0648\u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u0627\u0633\u062a\u062e\u0628\u0627\u0631\u0627\u062a \u0648\u0627\u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0634\u0631\u0643\u0627\u064a\u0654\u0647\u0645 \u0648\u0648\u0643\u0644\u0627\u064a\u0654\u0647\u0645\u060c \u0645\u0639\u0628\u0631\u064a\u0646 \u0639\u0646 \u062a\u0636\u0627\u0645\u0646 \u062f\u0648\u0644\u064a \u0644\u0627\u062a\u062e\u0627\u0630 \u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u062d\u0627\u0632\u0645\u0629 \u0644\u0631\u062f\u0639 \u0647\u0630\u0647 \u0627\u0644\u0645\u0645\u0627\u0631\u0633\u0627\u062a. \u0627\u0633\u062a\u0631\u0627\u062a\u064a\u062c\u064a\u0627\u062a \"\u0627\u0644\u062a\u0639\u0637\u064a\u0644 \u0648\u0627\u0644\u0631\u062f\u0639\" \u0627\u0633\u062a\u0639\u0631\u0636 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0648\u0646 \u0627\u0644\u0627\u0654\u0633\u0627\u0644\u064a\u0628 \u0648\u0627\u0644\u0627\u0654\u0646\u0645\u0627\u0637 \u0627\u0644\u062c\u062f\u064a\u062f\u0629 \u0627\u0644\u062a\u064a \u0627\u0639\u062a\u0645\u062f\u062a\u0647\u0627 \u0627\u0644\u062c\u0647\u0627\u062a \u0627\u0644\u0645\u0632\u0639\u0632\u0639\u0629 \u0644\u0644\u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u0641\u064a \u0647\u062c\u0645\u0627\u062a\u0647\u0627 \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u062d\u0648\u0644 \u0627\u0644\u0639\u0627\u0644\u0645. \u0648\u0627\u062a\u0641\u0642 \u0627\u0644\u0645\u062c\u062a\u0645\u0639\u0648\u0646 \u0639\u0644\u0649 \u062c\u0645\u0644\u0629 \u0645\u0646 \u0627\u0644\u062a\u0648\u0635\u064a\u0627\u062a \u0627\u0644\u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u0631\u0627\u0645\u064a\u0629 \u0644\u062a\u0639\u0637\u064a\u0644 \u0627\u0644\u0645\u062e\u0637\u0637\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629\u060c \u0648\u0645\u0646 \u0627\u0654\u0628\u0631\u0632\u0647\u0627: \u0636\u0628\u0637 \u0627\u0644\u062a\u0646\u0642\u0644\u0627\u062a: \u062a\u0639\u0632\u064a\u0632 \u0627\u0644\u0631\u0642\u0627\u0628\u0629 \u0644\u0644\u062d\u062f \u0645\u0646 \u0633\u0641\u0631 \u0627\u0644\u0639\u0646\u0627\u0635\u0631 \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629 \u0628\u0627\u0644\u0643\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0635\u0646\u0641\u0629 \u0627\u0655\u0631\u0647\u0627\u0628\u064a\u0627\u064b. \u0627\u0655\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u062a\u0627\u0654\u0634\u064a\u0631\u0627\u062a: \u062a\u062f\u0642\u064a\u0642 \u0639\u0645\u0644\u064a\u0627\u062a \u0645\u0646\u062d \u0633\u0645\u0627\u062a \u0627\u0644\u062f\u062e\u0648\u0644 \u0644\u0636\u0645\u0627\u0646 \u0639\u062f\u0645 \u0627\u0633\u062a\u063a\u0644\u0627\u0644 \u0627\u0644\u0642\u0646\u0648\u0627\u062a \u0627\u0644\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a\u0629 \u0648\u0627\u0644\u0642\u0646\u0635\u0644\u064a\u0629 \u0641\u064a \u0627\u0654\u0646\u0634\u0637\u0629 \u063a\u064a\u0631 \u0645\u0634\u0631\u0648\u0639\u0629. \u0627\u0644\u062a\u0639\u0627\u0648\u0646 \u0627\u0644\u0642\u0636\u0627\u064a\u0654\u064a: \u062a\u0641\u0639\u064a\u0644 \u0627\u0644\u0645\u0633\u0627\u0631\u0627\u062a \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629 \u0644\u0645\u0644\u0627\u062d\u0642\u0629 \u0627\u0644\u0645\u062a\u0648\u0631\u0637\u064a\u0646 \u0641\u064a \u0627\u0644\u0642\u0636\u0627\u064a\u0627 \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0627\u0644\u0639\u0627\u0628\u0631\u0629 \u0644\u0644\u062d\u062f\u0648\u062f. \u0645\u0646\u0638\u0648\u0645\u0629 \u0627\u0644\u0639\u0642\u0648\u0628\u0627\u062a: \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u062a\u0646\u0633\u064a\u0642 \u0641\u064a \u0641\u0631\u0636 \u0627\u0644\u0639\u0642\u0648\u0628\u0627\u062a \u0648\u0627\u0644\u062a\u0635\u0646\u064a\u0641\u0627\u062a \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629 \u0636\u062f \u0627\u0644\u0643\u064a\u0627\u0646\u0627\u062a \u0648\u0627\u0644\u0627\u0654\u0641\u0631\u0627\u062f \u0627\u0644\u0645\u0647\u062f\u062f\u064a\u0646 \u0644\u0644\u0633\u0644\u0645 \u0627\u0644\u062f\u0648\u0644\u064a. \u0645\u0646\u0635\u0629 \u0639\u0645\u0644 \u0645\u0646\u0630 2019 \u064a\u064f\u0630\u0643\u0631 \u0627\u0654\u0646 \"\u0645\u0646\u062a\u062f\u0649 \u0645\u0643\u0627\u0641\u062d\u0629 \u0627\u0644\u0627\u0655\u0631\u0647\u0627\u0628 \u0627\u0644\u0639\u0627\u0628\u0631 \u0644\u0644\u062d\u062f\u0648\u062f \u0627\u0644\u0648\u0637\u0646\u064a\u0629\" \u0642\u062f \u062a\u0627\u0654\u0633\u0633 \u0639\u0627\u0645 2019 \u0643\u0645\u0646\u0635\u0629 \u0639\u0645\u0644 \u0639\u0627\u0644\u0645\u064a\u0629\u060c \u062a\u0647\u062f\u0641 \u0627\u0655\u0644\u0649 \u0631\u0641\u0639 \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0648\u0639\u064a \u0627\u0644\u062f\u0648\u0644\u064a \u0648\u062a\u0637\u0648\u064a\u0631 \u0627\u0653\u0644\u064a\u0627\u062a \u0627\u0644\u062a\u0646\u0633\u064a\u0642 \u0628\u0634\u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u0627\u0655\u062c\u0631\u0627\u0645\u064a\u0629 \u0648\u0627\u0644\u0627\u0655\u0631\u0647\u0627\u0628\u064a\u0629 \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629 \u0628\u0627\u0644\u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0627\u0644\u0627\u0655\u0633\u0644\u0627\u0645\u064a\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629. \u0648\u064a\u0631\u0649 \u0645\u0631\u0627\u0642\u0628\u0648\u0646 \u0644\u0640 \"\u0627\u0655\u064a\u0644\u0627\u0641\" \u0627\u0654\u0646 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0647\u0630\u0627 \u0627\u0644\u0645\u0646\u062a\u062f\u0649 \u0641\u064a \u0639\u0642\u062f \u0627\u062c\u062a\u0645\u0627\u0639\u0627\u062a\u0647 \u0628\u0627\u0646\u062a\u0638\u0627\u0645\u060c \u064a\u0639\u0643\u0633 \u0627\u0644\u062a\u0632\u0627\u0645\u0627\u064b \u062f\u0648\u0644\u064a\u0627\u064b \u0637\u0648\u064a\u0644 \u0627\u0644\u0627\u0654\u0645\u062f \u0628\u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u062a\u062d\u062f\u064a\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u0646\u064a\u0629 \u0627\u0644\u062a\u064a \u062a\u0641\u0631\u0636\u0647\u0627 \u0627\u0644\u0627\u0654\u0646\u0634\u0637\u0629 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a\u0629 \u062e\u0627\u0631\u062c \u062d\u062f\u0648\u062f\u0647\u0627 \u0627\u0644\u0627\u0655\u0642\u0644\u064a\u0645\u064a\u0629. \u0648\u062e\u0644\u0635 \u0627\u0644\u0627\u062c\u062a\u0645\u0627\u0639 \u0627\u0655\u0644\u0649 \u0636\u0631\u0648\u0631\u0629 \u0627\u0644\u062d\u0641\u0627\u0638 \u0639\u0644\u0649 \u0627\u0654\u0642\u0635\u0649 \u062f\u0631\u062c\u0627\u062a \u0627\u0644\u064a\u0642\u0638\u0629\u060c \u0648\u062a\u0633\u062e\u064a\u0631 \u0643\u0627\u0641\u0629 \u0627\u0644\u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u0642\u0627\u0646\u0648\u0646\u064a\u0629 \u0648\u0627\u0644\u062f\u0628\u0644\u0648\u0645\u0627\u0633\u064a\u0629 \u0627\u0644\u0645\u062a\u0627\u062d\u0629 \u0644\u0636\u0645\u0627\u0646 \u0627\u0633\u062a\u062c\u0627\u0628\u0629 \u062f\u0648\u0644\u064a\u0629 \u0645\u0646\u0633\u0642\u0629 \u0648\u0641\u0639\u0627\u0644\u0629\u060c \u0642\u0627\u062f\u0631\u0629 \u0639\u0644\u0649 \u0627\u0633\u062a\u0628\u0627\u0642 \u0627\u0644\u0645\u062e\u0637\u0637\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u0633\u062a\u0647\u062f\u0641 \u0627\u0654\u0645\u0646 \u0627\u0644\u062f\u0648\u0644 \u0648\u0633\u064a\u0627\u062f\u062a\u0647\u0627.", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": null, "creator": null, "language": "arabic", "country": ["egypt"], "category": ["entertainment", "top"], "datatype": "news", "pubDate": "2026-04-21 18:06:12", "pubDateTZ": "UTC", "fetched_at": "2026-04-21 19:10:16", "image_url": null, "video_url": null, "source_id": "elaph", "source_name": "Elaph", "source_priority": 197218, "source_url": "https://elaph.com", "source_icon": "https://n.bytvi.com/elaph.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_tag": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "ai_region": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_org": "ONLY AVAILABLE IN CORPORATE PLANS", "ai_summary": "ONLY AVAILABLE IN PAID PLANS", "duplicate": false}], "nextPage