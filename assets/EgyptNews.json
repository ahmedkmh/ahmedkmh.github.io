 "title": "\u0642\u0628\u0644 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629.. \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631 \u064a\u062a\u0637\u0644\u0639 \u0644\u0627\u0655\u0646\u0647\u0627\u0621 \u0645\u0641\u0627\u0631\u0642\u0629 \u0627\u0644\u0640166 \u0634\u0647\u0631\u0627", "description": "\u064a\u0633\u062a\u0639\u062f \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631 \u0627\u0644\u0627\u0654\u0648\u0644 \u0644\u062e\u0648\u0636 \u0627\u0654\u0648\u0644\u0649 \u0645\u0628\u0627\u0631\u064a\u0627\u062a\u0647 \u0627\u0644\u0648\u062f\u064a\u0629\u060c \u062e\u0644\u0627\u0644 \u0634\u0647\u0631 \u0645\u0627\u0631\u0633 \u0627\u0644\u062c\u0627\u0631\u064a\u060c \u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u062e\u0637\u0629 \u0627\u0644\u0627\u0633\u062a\u0639\u062f\u0627\u062f \u0644\u0644\u0645\u0634\u0627\u0631\u0643\u0629 \u0641\u064a \u0628\u0637\u0648\u0644\u0629 \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026. \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631 \u064a\u0642\u0639 \u0641\u064a \u0627\u0644\u0645\u062c\u0645\u0648\u0639\u0629 \u0627\u0644\u0633\u0627\u0628\u0639\u0629 \u062e\u0644\u0627\u0644 \u0645\u0646\u0627\u0641\u0633\u0627\u062a \u0643\u0627\u0654\u0633 \u0627\u0644\u0639\u0627\u0644\u0645 2026\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u0628\u0644\u062c\u064a\u0643\u0627 \u0648\u0627\u0655\u064a\u0631\u0627\u0646 \u0648\u0646\u064a\u0648\u0632\u064a\u0644\u0646\u062f\u0627. \u0648\u0643\u0627\u0646 \u0645\u0639\u0633\u0643\u0631 \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631 \u0627\u0644\u0627\u0654\u0648\u0644 \u0642\u062f \u0627\u0646\u0637\u0644\u0642 \u0627\u0654\u0645\u0633 \u0627\u0644\u0627\u0654\u062d\u062f \u0627\u0644\u0645\u0648\u0627\u0641\u0642 22 \u0645\u0627\u0631\u0633 \u0648\u0627\u0644\u0630\u064a \u064a\u0633\u062a\u0645\u0631 \u062d\u062a\u0649 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0634\u0647\u0631 \u0627\u0644\u062c\u0627\u0631\u064a\u060c \u0628\u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0621 \u0645\u0646 \u0645\u0648\u0627\u062c\u0647\u0629 \u0645\u0646\u062a\u062e\u0628 \u0627\u0655\u0633\u0628\u0627\u0646\u064a\u0627 \u0641\u064a \u0628\u0631\u0634\u0644\u0648\u0646\u0629. \u0648\u064a\u0628\u062f\u0627\u0654 \u0645\u0646\u062a\u062e\u0628 \u0645\u0635\u0631 \u0648\u062f\u064a\u0627\u062a\u0647 \u0628\u0645\u0648\u0627\u062c\u0647\u0629 \u0646\u0638\u064a\u0631\u0647 \u0627\u0644\u0633\u0639\u0648\u062f\u064a \u0641\u064a \u062c\u062f\u0629\u060c \u0648\u0647\u0648 \u0645\u0627 \u064a\u0627\u0654\u062e\u0630\u0646\u0627 \u0644\u0627\u0633\u062a\u0643\u0634\u0627\u0641 \u0646\u062a\u0627\u064a\u0654\u062c \u0627\u0644\u0641\u0631\u0627\u0639\u0646\u0629 \u0641\u064a \u0627\u0644\u0645\u0648\u0627\u062c\u0647\u0627\u062a \u0627\u0644\u0627\u0654\u062e\u064a\u0631\u0629 \u0627\u0644\u062a\u064a \u062c\u0645\u0639\u062a\u0647 \u0628\u0645\u0646\u062a\u062e\u0628\u0627\u062a \u0645\u0646 \u0642\u0627\u0631\u0629 \u0627\u0653\u0633\u064a\u0627. \u062d\u064a\u062b \u062c\u0627\u0621\u062a \u0646\u062a\u0627\u064a\u0654\u062c \u0645\u0635\u0631 \u0636\u062f \u0645\u0646\u062a\u062e\u0628\u0627\u062a \u0627\u0653\u0633\u064a\u0627 \u0639\u0644\u0649 \u062e\u0644\u0627\u0644 \u0627\u0653\u062e\u0631 15 \u0639\u0627\u0645\u064b\u0627\u060c \u0628\u0648\u0627\u0642\u0639 8 \u0645\u0628\u0627\u0631\u064a\u0627\u062a \u0648\u062f\u064a\u0629\u060c \u0639\u0644\u0649 \u0627\u0644\u0646\u062d\u0648 \u0627\u0644\u0627\u0653\u062a\u064a: \u0646\u0648\u0641\u0645\u0628\u0631 2025: \u0627\u0644\u062e\u0633\u0627\u0631\u0629 \u0627\u0654\u0645\u0627\u0645 \u0627\u0654\u0648\u0632\u0628\u0643\u0633\u062a\u0627\u0646 2-0. \u064a\u0648\u0646\u064a\u0648 2022: \u0627\u0644\u062e\u0633\u0627\u0631\u0629 \u0627\u0654\u0645\u0627\u0645 \u0643\u0648\u0631\u064a\u0627 \u0627\u0644\u062c\u0646\u0648\u0628\u064a\u0629 4-1. \u0645\u0627\u064a\u0648 2018: \u0627\u0644\u062a\u0639\u0627\u062f\u0644 \u0645\u0639 \u0627