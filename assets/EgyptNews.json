060c \u0641\u064a \u062d\u0627\u0644 \u0642\u0631\u0631\u062a \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0627\u0644\u0627\u0646\u0633\u062d\u0627\u0628 \u0645\u0646 \u062d\u0644\u0641 \u0627\u0644\u0646\u0627\u062a\u0648\u060c \u0648\u0647\u0648 \u0627\u0644\u0627\u0646\u0633\u062d\u0627\u0628 \u0627\u0644\u0630\u064a \u064a\u0648\u0654\u064a\u062f\u0647 \u0633\u062a\u0627\u0631\u0645\u0631 \u0648\u0641\u0642\u0627\u064b \u0644\u0644\u0645\u0646\u0634\u0648\u0631\u0627\u062a \u0627\u0644\u0645\u0632\u064a\u0641\u0629 \u0627\u0644\u062a\u064a \u0644\u0642\u064a\u062a \u0631\u0648\u0627\u062c\u0627\u064b \u0645\u0630\u0647\u0644\u0627\u064b. \u0648\u0645\u0646 \u062e\u0644\u0627\u0644 \u0645\u062a\u0627\u0628\u0639\u0629 \"\u0627\u0655\u064a\u0644\u0627\u0641\" \u0644\u062d\u0633\u0627\u0628\u0627\u062a \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0628\u0631\u064a\u0637\u0627\u0646\u064a\u060c \u0641\u0627\u0655\u0646\u0647 \u0644\u0627 \u064a\u0648\u062c\u062f \u0628\u0647\u0627 \u0645\u0646 \u0627\u0644\u0627\u0654\u062e\u0628\u0627\u0631 \u0648\u0627\u0644\u0645\u0648\u0636\u0648\u0639\u0627\u062a \u0627\u0644\u0645\u0637\u0631\u0648\u062d\u0629 \u062e\u0644\u0627\u0644 \u0627\u0644\u064a\u0648\u0645\u064a\u0646 \u0627\u0644\u0645\u0627\u0636\u064a\u064a\u0646 \u0633\u0648\u0649 \u062a\u0647\u0646\u064a\u0654\u062a\u0647 \u0644\u0644\u0645\u0633\u0644\u0645\u064a\u0646 \u0628\u0639\u064a\u062f \u0627\u0644\u0641\u0637\u0631\u060c \u0648\u0627\u062a\u0635\u0627\u0644 \u0628\u0631\u064a\u0654\u064a\u0633 \u0648\u0632\u0631\u0627\u0621 \u0627\u0644\u0628\u062d\u0631\u064a\u0646 \u0648\u0648\u0644\u064a \u0627\u0644\u0639\u0647\u062f \u0648\u0643\u0630\u0644\u0643 \u0627\u062a\u0635\u0627\u0644\u0647 \u0628\u0631\u064a\u0654\u064a\u0633 \u062c\u0645\u0647\u0648\u0631\u064a\u0629 \u0642\u0628\u0631\u0635 \u0648\u0641\u0642\u0627\u064b \u0644\u0644\u0645\u0639\u0644\u0648\u0645\u0627\u062a \u0627\u0644\u0645\u062a\u0648\u0641\u0631\u0629 \u0644\u062f\u0649 \u0645\u0635\u0627\u062f\u0631 10 \u062f\u0627\u0648\u0646\u0646\u063a Street. \u0648\u0628\u0627\u0644\u0639\u0648\u062f\u0629 \u0627\u0655\u0644\u0649 \u0627\u0644\u0645\u0646\u0634\u0648\u0631 \u0627\u0644\u0645\u0632\u064a\u0641 \u0641\u0642\u062f \u062c\u0627\u0621 \u0628\u0647 :\"\u0628\u0635\u0641\u062a\u064a \u0631\u064a\u0654\u064a\u0633\u064b\u0627 \u0644\u0644\u0648\u0632\u0631\u0627\u0621\u060c \u0633\u0627\u0654\u0643\u0648\u0646 \u062f\u0627\u064a\u0654\u0645\u064b\u0627 \u0648\u0627\u0636\u062d\u064b\u0627 \u0645\u0639 \u062d\u0644\u0641\u0627\u064a\u0654\u0646\u0627 \u0648\u0645\u0646\u062a\u0642\u062f\u064a\u0646\u0627 \u0639\u0644\u0649 \u062d\u062f \u0633\u0648\u0627\u0621\"\u060c \u0647\u0643\u0630\u0627 \u064a\u0628\u062f\u0627\u0654 \u0627\u0644\u0645\u0646\u0634\u0648\u0631 \u0627\u0644\u0645\u0632\u064a\u0641. \u0643\u0645\u0627 \u062c\u0627\u0621 \u0641\u064a \u0627\u0644\u0645\u0646\u0634\u0648\u0631 \u0627\u0644\u0630\u064a \u0627\u0654\u062b\u0627\u0631 \u062c\u062f\u0644\u0627\u064b \u0648\u0642\u0644\u0642\u0627\u064b \u0639\u0627\u0644\u0645\u064a\u0627\u064b: \"\u0627\u0655\u0630\u0627 \u0643\u0627\u0646 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u062a\u0631\u0627\u0645\u0628 \u064a\u0646\u0648\u064a \u0627\u0655\u0646\u0647\u0627\u0621 \u0627\u0644\u062a\u0632\u0627\u0645 \u0627\u0654\u0645\u064a\u0631\u0643\u0627 \u062a\u062c\u0627\u0647 \u0627\u0644\u0646\u0627\u062a\u0648\u060c \u0641\u0627\u0654\u062a\u0648\u0642\u0639 \u0627\u0644\u0627\u0646\u0633\u062d\u0627\u0628 \u0627\u0644\u0633\u0631\u064a\u0639 \u0644\u0644\u0642\u0648\u0627\u062a \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0645\u0646 \u0627\u0644\u0642\u0648\u0627\u0639\u062f \u0627\u0644\u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0629 \u0641\u064a \u063a\u0636\u0648\u0646 48 \u0633\u0627\u0639\u0629\"\u060c \u0642\u0628\u0644 \u0627\u0654\u0646 \u064a\u0642\u0648\u0644 \u0627\u0655\u0646 \u0627\u0644\u0645\u0645\u0644\u0643\u0629 \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \"\u062a\u062a\u0648\u0642\u0639 \u062a\u0633\u0648\u064a\u0629 \u0643\u0627\u0645\u0644\u0629 \u0648\u0646\u0647\u0627\u064a\u0654\u064a\u0629 \u0644\u0644\u0627\u0631\u062a\u0628\u0627\u0637 \u0627\u0644\u062a\u0627\u0631\u064a\u062e\u064a \u0628\u062d\u0644\u0648\u0644 \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u0627\u0654\u0633\u0628\u0648\u0639\". \u062a\u0645\u062a \u0645\u0634\u0627\u0647\u062f\u0629 \u0644\u0642\u0637\u0629 \u0634\u0627\u0634\u0629 \u0648\u0627\u062d\u062f\u0629 \u0644\u0647\u0630\u0627 \u0627\u0644\u0645\u0646\u0634\u0648\u0631 \u0627\u0644\u0645\u0632\u064a\u0641 \u0645\u0644\u0627\u064a\u064a\u0646 \u0627\u0644\u0645\u0631\u0627\u062a \u0639\u0644\u0649 \u0645\u0646\u0635\u0629 \u0627\u0655\u0643\u0633 X\u060c \u0648\u062a\u0645\u062a \u0627\u0655\u0639\u0627\u062f\u0629 \u0645\u0634\u0627\u0631\u0643\u062a\u0647\u0627 \u0627\u0654\u0643\u062b\u0631 \u0645\u0646 12 \u0645\u0644\u064a\u0648\u0646 \u0645\u0631\u0629 \u0639\u0644\u0649 \u0641\u064a\u0633\u0628\u0648\u0643\u060c \u0628\u0627\u0644\u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0645\u0646\u0634\u0648\u0631\u0627\u062a \u0627\u0654\u062e\u0631\u0649 \u0639\u0644\u0649 \u0627\u0655\u0646\u0633\u062a\u063a\u0631\u0627\u0645 \u0648\u062b\u0631\u064a\u062f\u0632 \u0648\u0631\u064a\u062f\u064a\u062a. \u064a\u0628\u062f\u0648 \u0627\u0654\u0646 \u0627\u0644\u0645\u0646\u0634\u0648\u0631 \u0627\u0644\u0645\u0632\u064a\u0641 \u0642\u062f \u062a\u0645 \u0646\u0634\u0631\u0647 \u0641\u064a 18 \u0645\u0627\u0631\u0633 (\u0627\u0653\u0630\u0627\u0631)\u060c \u0628\u0639\u062f \u0627\u0654\u0646 \u0627\u0654\u062f\u0644\u0649 \u062a\u0631\u0627\u0645\u0628 \u0628\u062a\u0639\u0644\u064a\u0642\u0627\u062a \u063a\u0627\u0636\u0628\u0629 \u062d\u0648\u0644 \u0627\u0654\u0639\u0636\u0627\u0621 \u0627\u0653\u062e\u0631\u064a\u0646 \u0641\u064a \u062d\u0644\u0641 \u0627\u0644\u0646\u0627\u062a\u0648 \u064a\u0631\u0641\u0636\u0648\u0646 \u0627\u0644\u0627\u0646\u0636\u0645\u0627\u0645 \u0627\u0655\u0644\u0649 \u0627\u0644\u062d\u0631\u0628 \u0627\u0644\u062a\u064a \u0634\u0646\u0647\u0627 \u0636\u062f \u0627\u0655\u064a\u0631\u0627\u0646. \u0648\u062a\u0627\u0654\u062a\u064a \u0647\u0630\u0647 \u0627\u0644\u062a\u0639\u0644\u064a\u0642\u0627\u062a \u0627\u0644\u0645\u0632\u064a\u0641\u0629 \u0627\u0654\u064a\u0636\u0627\u064b \u0641\u064a \u0627\u0654\u0639\u0642\u0627\u0628 \u062a\u0648\u062a\u0631 \u0627\u0644\u0639\u0644\u0627\u0642\u0627\u062a \u0628\u064a\u0646 \u0633\u062a\u0627\u0631\u0645\u0631 \u0648\u062a\u0631\u0627\u0645\u0628\u060c \u0628\u0645\u0627 \u0641\u064a \u0630\u0644\u0643 \u062d\u0627\u062f\u062b\u0629 \u0648\u0642\u0639\u062a \u0641\u064a \u064a\u0648\u0645 \u0627\u0644\u0642\u062f\u064a\u0633 \u0628\u0627\u062a\u0631\u064a\u0643 \u062f\u0627\u0641\u0639 \u0641\u064a\u0647\u0627 \u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0648\u0632\u0631\u0627\u0621 \u0645\u064a\u0634\u064a\u0644 \u0645\u0627\u0631\u062a\u0646 \u0639\u0646 \u0633\u062a\u0627\u0631\u0645\u0631 \u0641\u064a \u0627\u062c\u062a\u0645\u0627\u0639 \u0645\u0639 \u062a\u0631\u0627\u0645\u0628 \u0641\u064a \u0627\u0644\u0645\u0643\u062a\u0628 \u0627\u0644\u0628\u064a\u0636\u0627\u0648\u064a. \u0627\u0654\u0644\u0645\u062d \u062a\u0631\u0627\u0645\u0628 \u0645\u0631\u0627\u0631\u0627\u064b \u0648\u062a\u0643\u0631\u0627\u0631\u0627\u064b \u0627\u0655\u0644\u0649 \u0627\u0654\u0646\u0647 \u064a\u0641\u0643\u0631 \u0641\u064a \u0627\u0655\u062e\u0631\u0627\u062c \u0627\u0644\u0648\u0644\u0627\u064a\u0627\u062a \u0627\u0644\u0645\u062a\u062d\u062f\u0629 \u0645\u0646 \u062d\u0644\u0641 \u0627\u0644\u0646\u0627\u062a\u0648. \u0648\u0645\u0639 \u0630\u0644\u0643\u060c \u0641\u0627\u0655\u0646 \u0627\u0644\u0645\u0646\u0634\u0648\u0631 \u0627\u0644\u0630\u064a \u064a\u064f\u0632\u0639\u0645 \u0627\u0654\u0646\u0647 \u064a\u064f\u0638\u0647\u0631 \u0643\u064a\u0631