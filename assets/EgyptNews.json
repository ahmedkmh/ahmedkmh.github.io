062c\u0631\u0648\u0646\u0647\u0627\u064a\u062f\u0647\u060c \u0645\u0639 \u062e\u0637\u0637 \u0644\u062f\u062e\u0648\u0644 \u0627\u0654\u0633\u0648\u0627\u0642 \u0627\u0655\u0636\u0627\u0641\u064a\u0629.\u0648\u0627\u0654\u0639\u0644\u0646\u062a \"\u062a\u0633\u0644\u0627\" \u0628\u0627\u0644\u0641\u0639\u0644 \u0647\u0630\u0627 \u0627\u0644\u0639\u0627\u0645 \u0627\u0654\u0646\u0647\u0627 \u062a\u0633\u062a\u0647\u062f\u0641 \u0632\u064a\u0627\u062f\u0629 \u0627\u0655\u0646\u062a\u0627\u062c\u0647\u0627 \u0641\u064a \u062c\u0631\u0648\u0646\u0647\u0627\u064a\u062f\u0647 \u0627\u0655\u0644\u0649 \u0645\u0627 \u064a\u0635\u0644 \u0627\u0655\u0644\u0649 7500 \u0633\u064a\u0627\u0631\u0629 \u0627\u0654\u0633\u0628\u0648\u0639\u064a\u0627\u064b\u060c \u0627\u0654\u064a \u0645\u0627 \u064a\u0639\u0627\u062f\u0644 375 \u0627\u0654\u0644\u0641\u0627 \u0633\u0646\u0648\u064a\u0627\u060c \u0627\u0655\u0644\u0649 \u062c\u0627\u0646\u0628 \u062a\u0648\u0633\u064a\u0639 \u0627\u0655\u0646\u062a\u0627\u062c \u062e\u0644\u0627\u064a\u0627 \u0627\u0644\u0628\u0637\u0627\u0631\u064a\u0627\u062a.\u0648\u0645\u0646 \u0627\u0644\u0645\u0642\u0631\u0631 \u062a\u0648\u0641\u064a\u0631 3500 \u0641\u0631\u0635\u0629 \u0639\u0645\u0644 \u062c\u062f\u064a\u062f\u0629. \u0648\u062a\u0633\u0639\u0649 \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0655\u0644\u0649 \u062a\u062c\u0645\u064a\u0639 \u0633\u0644\u0633\u0644\u0629 \u0627\u0644\u0642\u064a\u0645\u0629 \u0628\u0627\u0644\u0643\u0627\u0645\u0644\u060c \u0628\u062f\u0621\u0627\u064b \u0645\u0646 \u062e\u0644\u0627\u064a\u0627 \u0627\u0644\u0628\u0637\u0627\u0631\u064a\u0627\u062a \u0648\u0635\u0648\u0644\u0627 \u0627\u0655\u0644\u0649 \u0627\u0644\u0633\u064a\u0627\u0631\u0629 \u0627\u0644\u062c\u0627\u0647\u0632\u0629\u060c \u0645\u0639\u062a\u0628\u0631\u0629 \u0627\u0654\u0646 \u0630\u0644\u0643 \"\u0641\u0631\u064a\u062f \u0645\u0646 \u0646\u0648\u0639\u0647 \u0641\u064a \u0627\u0654\u0648\u0631\u0648\u0628\u0627\".\u0648\u0643\u0627\u0646 \u062a\u0648\u0633\u064a\u0639 \u0627\u0644\u0645\u0635\u0646\u0639 \u062d\u062a\u0649 \u0627\u0644\u0627\u0653\u0646 \u0645\u0631\u062a\u0628\u0637\u0627 \u0628\u062a\u0637\u0648\u0631 \u0627\u0644\u0627\u0654\u0633\u0648\u0627\u0642. \u0643\u0645\u0627 \u062a\u0633\u062a\u0641\u064a\u062f \"\u062a\u0633\u0644\u0627\" \u0645\u0646 \u0627\u0633\u062a\u064a\u0654\u0646\u0627\u0641 \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a.\u063a\u064a\u0631 \u0627\u0654\u0646 \u0627\u0644\u0634\u0631\u0643\u0629 \u062a\u0631\u0649 \u0627\u0654\u064a\u0636\u0627 \u0648\u062c\u0648\u062f \u0645\u062e\u0627\u0637\u0631. \u0648\u0643\u062a\u0628\u062a \"\u062a\u0633\u0644\u0627\" \u0641\u064a \u0627\u0644\u062a\u0642\u0631\u064a\u0631 \u0627\u0654\u0646 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u062a\u0635\u0627\u0639\u062f \u0627\u0644\u062a\u0648\u062a\u0631\u0627\u062a", "content": "ONLY AVAILABLE IN PAID PLANS", "keywords": ["\u0635\u0646\u0627\u0639\u0629 \u0627\u0644\u0633\u064a\u0627\u0631\u0627\u062a", "\u062a\u0633\u0644\u0627", "\u0627\u0644\u0633\u064a\u0627\u0631\u0627\u062a \u0627\u0644\u0643\u0647\u0631\u0628\u0627\u0626\u064a\u0629", "\u0627\u0644\u0627\u0633\u062a\u062b\u0645\u0627\u0631 \u0641\u064a \u0623\u0644\u0645\u0627\u0646\u064a\u0627"], "creator": ["\u0627\u0644\u0639\u0631\u0628\u064a\u0629"], "language": "arabic", "country": ["egypt"], "category": ["business"], "datatype": "news", "pubDate": "2026-07-19 05:10:24", "pubDateTZ": "UTC", "fetched_at": "2026-07-19 07:25:59", "image_url": "https://vid.alarabiya.net/images/2025/06/08/f83ef9d2-ab9d-4618-84c1-ea1f9d5552cc/f83ef9d2-ab9d-4618-84c1-ea1f9d5552cc_16x9_1200x676.JPG", "video_url": null, "source_id": "alarabiya", "source_name": "Alarabiya", "source_priority": 13507, "source_url": "https://www.alarabiya.net", "source_icon": "https://n.bytvi.com/alarabiya.png", "sentiment": "ONLY AVAILABLE IN PROFESSIONAL AND CORPORATE PLANS", "sentiment_stats": "ONLY AVAILABLE IN PROFESSION