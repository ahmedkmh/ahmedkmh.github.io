064a \u064a\u0628\u0644\u063a 799 \u064a\u0648\u0627\u0646 (\u0646\u062d\u0648 117 \u062f\u0648\u0644\u0627\u0631\u064b\u0627)\u060c \u064a\u0646\u062e\u0641\u0636 \u0627\u0655\u0644\u0649 \u062d\u0648\u0627\u0644\u064a 100 \u062f\u0648\u0644\u0627\u0631 \u0628\u0639\u062f \u0627\u0644\u062f\u0639\u0645 \u0627\u0644\u062d\u0643\u0648\u0645\u064a\u060c \u0645\u0627 \u064a\u062c\u0639\u0644\u0647 \u0627\u0654\u062d\u062f \u0627\u0654\u0643\u062b\u0631 \u0627\u0654\u062c\u0647\u0632\u0629 \u0627\u0644\u0645\u0646\u0632\u0644 \u0627\u0644\u0630\u0643\u064a \u062c\u0630\u0628\u064b\u0627 \u0645\u0646 \u062d\u064a\u062b \u0627\u0644\u0633\u0639\u0631.\u062a\u0642\u0646\u064a\u0627\u062a \u0630\u0643\u0627\u0621 \u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0644\u0641\u062a\u062d \u0627\u0654\u0633\u0631\u0639\u0648\u064a\u0639\u062a\u0645\u062f \u0627\u0644\u0642\u0641\u0644 \u0627\u0644\u062c\u062f\u064a\u062f \u0639\u0644\u0649 \u062a\u0642\u0646\u064a\u0627\u062a \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a \u0646\u0638\u0627\u0645 \u0627\u0644\u062a\u0639\u0631\u0641 \u0639\u0644\u0649 \u0627\u0644\u0628\u0635\u0645\u0627\u062a\u060c \u062d\u064a\u062b \u064a\u0633\u062a\u062e\u062f\u0645 \u0645\u0633\u062a\u0634\u0639\u0631\u064b\u0627 \u0642\u0627\u062f\u0631\u064b\u0627 \u0639\u0644\u0649 \u0627\u0644\u062a\u0643\u064a\u0641 \u0645\u0639 \u0627\u0644\u0627\u0633\u062a\u062e\u062f\u0627\u0645 \u0627\u0644\u0645\u062a\u0643\u0631\u0631 \u0644\u062a\u062d\u0633\u064a\u0646 \u062f\u0642\u0629 \u0627\u0644\u062a\u0639\u0631\u0641 \u062a\u062f\u0631\u064a\u062c\u064a\u064b\u0627.\u0648\u062a\u0648\u0654\u0643\u062f \"\u0647\u0648\u0627\u0648\u064a\" \u0627\u0654\u0646 \u0627\u0644\u0642\u0641\u0644 \u064a\u0641\u062a\u062d \u062e\u0644\u0627\u0644 0.5 \u062b\u0627\u0646\u064a\u0629 \u0641\u0642\u0637\u060c \u0645\u0639 \u0645\u0639\u062f\u0644 \u062e\u0637\u0627\u0654 \u0645\u0646\u062e\u0641\u0636 \u0644\u0644\u063a\u0627\u064a\u0629 \u064a\u0642\u0644 \u0639\u0646 0.00001\u060c \u0645\u0627 \u064a\u0639\u0643\u0633 \u0645\u0633\u062a\u0648\u0649 \u0645\u062a\u0642\u062f\u0645\u064b\u0627 \u0645\u0646 \u0627\u0644\u062f\u0642\u0629 \u0648\u0627\u0644\u0627\u0654\u0645\u0627\u0646\u060c \u0628\u062d\u0633\u0628 \u062a\u0642\u0631\u064a\u0631 \u0646\u0634\u0631\u0647 \u0645\u0648\u0642\u0639 \"gizmochina\" \u0648\u0627\u0637\u0644\u0639\u062a \u0639\u0644\u064a\u0647 \"\u0627\u0644\u0639\u0631\u0628\u064a\u0629 Business\".\u0637\u0631\u0642 \u0641\u062a\u062d \u0645\u062a\u0639\u062f\u062f\u0629\u0648\u0644\u0627 \u064a\u0642\u062a\u0635\u0631 \u0627\u0644\u0642\u0641\u0644 \u0639\u0644\u0649 \u0627\u0644\u0628\u0635\u0645\u0629 \u0641\u0642\u0637\u060c \u0627\u0655\u0630 \u064a\u062f\u0639\u0645 \u0645\u062c\u0645\u0648\u0639\u0629 \u0648\u0627\u0633\u0639\u0629 \u0645\u0646 \u0637\u0631\u0642 \u0627\u0644\u0641\u062a\u062d \u062a\u0634\u0645\u0644 \u0628\u0637\u0627\u0642\u0627\u062a NFC\u060c \u0648\u0643\u0644\u0645\u0627\u062a \u0627\u0644\u0645\u0631\u0648\u0631 \u0627\u0644\u0631\u0642\u0645\u064a\u0629\u060c \u0648\u0627\u0644\u0645\u0641\u0627\u062a\u064a\u062d \u0627\u0644\u062a\u0642\u0644\u064a\u062f\u064a\u0629\u060c \u0627\u0655\u0636\u0627\u0641\u0629 \u0627\u0655\u0644\u0649 \u0631\u0645\u0648\u0632 \u0645\u0648\u0654\u0642\u062a\u0629 \u0644\u0644\u0632\u0648\u0627\u0631\u060c \u0648\u0643\u0630\u0644\u0643 \u0639\u0628\u0631 \u0647\u0648\u0627\u062a\u0641 \u0648\u0633\u0627\u0639\u0627\u062a \u0647\u0648\u0627\u0648\u064a \u0627\u0644\u0630\u0643\u064a\u0629.\u062a\u0635\u0645\u064a\u0645 \u0646\u062d\u064a\u0641 \u0648\u0628\u0646\u064a\u0629 \u0645\u062a\u064a\u0646\u0629\u0648\u064a\u0627\u0654\u062a\u064a \u0627\u0644\u0642\u0641\u0644 \u0628\u062a\u0635\u0645\u064a\u0645 \u0646\u062d\u064a\u0641 \u0645\u0639 \u062d\u0648\u0627\u0641 \u062f\u0627\u064a\u0654\u0631\u064a\u0629\u060c \u0648\u0628\u0646\u064a\u0629 \u0645\u0648\u062d\u062f\u0629 \u0628\u06