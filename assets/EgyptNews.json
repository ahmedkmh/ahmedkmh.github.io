B1%D8%AC%D8%A7%D8%A1", "title": "\u062a\u0648\u0642\u064a\u0641 136 \u0634\u062e\u0635\u0627\u064b \u0641\u064a \u0627\u0644\u0645\u063a\u0631\u0628 \u0628\u0639\u062f \u0627\u0654\u062d\u062f\u0627\u062b \u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062c\u064a\u0634 \u0648\u0627\u0644\u0631\u062c\u0627\u0621", "description": "\u0627\u0654\u0648\u0642\u0641\u062a \u0627\u0644\u0634\u0631\u0637\u0629 \u0627\u0644\u0645\u063a\u0631\u0628\u064a\u0629 136 \u0634\u062e\u0635\u0627\u064b\u060c \u0628\u064a\u0646\u0647\u0645 \u0642\u0627\u0635\u0631\u0627\u0646\u060c \u0639\u0644\u0649 \u062e\u0644\u0641\u064a\u0629 \u0627\u0654\u062d\u062f\u0627\u062b \u0634\u063a\u0628 \u062d\u062f\u062b\u062a \u062e\u0644\u0627\u0644 \u0645\u0648\u0627\u062c\u0647\u0629 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0645\u0644\u0643\u064a \u0648\u0627\u0644\u0631\u062c\u0627\u0621 \u0627\u0644\u0628\u064a\u0636\u0627\u0648\u064a \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0645\u062d\u0644\u064a \u0644\u0643\u0631\u0629 \u0627\u0644\u0642\u062f\u0645\u060c \u0648\u0641\u0642 \u0645\u0627 \u0627\u0654\u0641\u0627\u062f \u0645\u0635\u062f\u0631 \u0645\u0646 \u0627\u0644\u0646\u064a\u0627\u0628\u0629 \u0627\u0644\u0639\u0627\u0645\u0629 \u0644\u0648\u0643\u0627\u0644\u0629 \"\u0641\u0631\u0627\u0646\u0633 \u0628\u0631\u0633\"\u060c \u0627\u0644\u062c\u0645\u0639\u0629.\u0634\u0647\u062f\u062a \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062a\u064a \u0627\u0654\u0642\u064a\u0645\u062a \u0641\u064a \u0645\u0631\u0643\u0628 \u0645\u0648\u0644\u0627\u064a \u0639\u0628\u062f \u0627\u0644\u0644\u0647 \u0628\u0627\u0644\u0631\u0628\u0627\u0637 \u0645\u0633\u0627\u0621 \u0627\u0644\u062e\u0645\u064a\u0633 \u0636\u0645\u0646 \u0627\u0644\u0645\u0631\u062d\u0644\u0629 \u0627\u0644\u0633\u0627\u0628\u0639\u0629 \u0639\u0634\u0631\u0629 \u0645\u0646 \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0645\u062d\u0644\u064a\u060c \u0645\u0648\u0627\u062c\u0647\u0627\u062a \u0639\u0646\u064a\u0641\u0629 \u0628\u064a\u0646 \u062c\u0645\u0627\u0647\u064a\u0631 \u0645\u0646 \u0627\u0644\u0641\u0631\u064a\u0642\u064a\u0646 \u0641\u064a \u062c\u0627\u0646\u0628 \u0645\u0646 \u0645\u062f\u0631\u062c\u0627\u062a \u0627\u0644\u0645\u0644\u0639\u0628\u060c \u0648\u0641\u0642 \u0645\u0627 \u0627\u0654\u0638\u0647\u0631\u062a \u0645\u0642\u0627\u0637\u0639 \u0641\u064a\u062f\u064a\u0648 \u0646\u0634\u0631\u062a\u0647\u0627 \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \u0627\u0644\u0645\u062d\u0644\u064a\u0629.\u0648\u0644\u0645 \u062a\u0648\u0654\u062b\u0631 \u0647\u0630\u0647 \u0627\u0644\u0627\u0654\u062d\u062f\u0627\u062b \u0639\u0644\u0649 \u0627\u0633\u062a\u0645\u0631\u0627\u0631 \u0627\u0644\u0645\u0628\u0627\u0631\u0627\u0629 \u0627\u0644\u062a\u064a \u0627\u0646\u062a\u0647\u062a \u0628\u0641\u0648\u0632 \u0627\u0644\u062c\u064a\u0634 \u0639\u0644\u0649 \u0636\u064a\u0641\u0647 \u0627\u0644\u0631\u062c\u0627\u0621 (2-1)\u060c \u0644\u0643\u0646\u0647\u0627 \u0627\u0654\u0633\u0641\u0631\u062a \u0639\u0646 \u062a\u0648\u0642\u064a\u0641 136 \u0634\u062e\u0635\u0627\u064b \u0648\u0636\u0639\u0648\u0627 \u0631\u0647\u0646 \u0627\u0644\u062d\u0631\u0627\u0633\u0629 \u0627\u0644\u0646\u0638\u0631\u064a\u0629 \u0644\u0644\u0627\u0634\u062a\u0628\u0627\u0647 \u0641\u064a \u062a\u0648\u0631\u0637\u0647\u0645 \u0641\u064a \u0627\u0654\u0639\u0645\u0627\u0644 \u0627\u0644\u0634\u063a\u0628\u060c \u0648\u0641\u0642 \u0645\u0627 \u0627\u0654\u0641\u0627\u062f \u0645\u0635\u062f\u0631 \u0645\u0646 \u0627\u0644\u0646\u064a\u0627\u0628\u0629 \u0627\u0644\u0639\u0627\u0645\u0629.\u0648\u0627\u0654\u062b\u0627\u0631 \u062a\u062c\u062f\u062f \u0627\u0644\u0634\u063a\u0628 \u0641\u064a \u0627\u0644\u062f\u0648\u0631\u064a \u0627\u0644\u0645\u063a\u0631\u0628\u064a \u0627\u0633\u062a\u064a\u0627\u0621\u064b \u0641\u064a \u0648\u0633\u0627\u064a\u0654\u0644 \u0627\u0644\u0627\u0655\u0639\u0644\u0627\u0645 \u