u0636\u0627\u062a \u0628\u0634\u0643\u0644 \u0633\u0644\u0633.\u0648\u0627\u0654\u0636\u0627\u0641 \u062a\u0631\u0627\u0645\u0628 \u0627\u0654\u0646 \u0627\u0644\u0627\u0654\u0633\u0648\u0627\u0642 \u062a\u0634\u0647\u062f \u0627\u0646\u062a\u0639\u0627\u0634\u0627\u064b \u0645\u0644\u062d\u0648\u0638\u0627\u064b \u0645\u0639 \u062a\u0631\u0627\u062c\u0639 \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0646\u0641\u0637 \u0648\u0627\u0631\u062a\u0641\u0627\u0639 \u0627\u0654\u0633\u0639\u0627\u0631 \u0627\u0644\u0627\u0654\u0633\u0647\u0645.\u0648\u062a\u0648\u0642\u0639 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u0627\u0644\u062a\u0648\u0635\u0644 \u0627\u0655\u0644\u0649 \u0648\u0642\u0641 \u0634\u0627\u0645\u0644 \u0644\u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631 \u0639\u0644\u0649 \u0645\u062e\u062a\u0644\u0641 \u0627\u0644\u062c\u0628\u0647\u0627\u062a\u060c \u0628\u0645\u0627 \u0641\u064a \u0630\u0644\u0643 \u0644\u0628\u0646\u0627\u0646 \u0648\u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0648\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644.\u0648\u0648\u0642\u0639 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a \u0648\u0646\u0638\u064a\u0631\u0647 \u0627\u0644\u0627\u0655\u064a\u0631\u0627\u0646\u064a \u0645\u0633\u0639\u0648\u062f \u0628\u0632\u0634\u0643\u064a\u0627\u0646 \u0639\u0646 \u0628\u064f\u0639\u062f \u0645\u0630\u0643\u0631\u0629 \u062a\u0641\u0627\u0647\u0645 \u0644\u0627\u0655\u0646\u0647\u0627\u0621 \u0627\u0644\u062d\u0631\u0628 \u0641\u064a \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0627\u0654\u0648\u0633\u0637 \u0627\u0644\u062a\u064a \u0628\u062f\u0627\u0654\u062a \u0641\u064a 28 \u0634\u0628\u0627\u0637 (\u0641\u0628\u0631\u0627\u064a\u0631).\u0641\u064a\u0645\u0627 \u0627\u0654\u0639\u0644\u0646 \u0646\u0627\u064a\u0654\u0628 \u0627\u0644\u0631\u064a\u0654\u064a\u0633 \u0627\u0644\u0627\u0654\u0645\u0