\u0627\u0641\u0633\u064a\u0646 \u0644\u0644\u0627\u0646\u062a\u0642\u0627\u0644 \u0627\u0655\u0644\u0649 \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629 \u0645\u0646 \u0627\u0644\u0645\u0632\u0627\u064a\u062f\u0629 \u0639\u0644\u0649 \u0648\u062d\u062f\u062a\u0647\u0627 \u0627\u0644\u0645\u062a\u062e\u0635\u0635\u0629 \u0641\u064a \u0645\u062d\u0631\u0643\u0627\u062a \u0627\u0644\u062f\u064a\u0632\u0644 \u0627\u0644\u062b\u0642\u064a\u0644\u0629 \"Everllence\"\u060c \u0641\u064a \u0635\u0641\u0642\u0629 \u0642\u062f \u062a\u0635\u0644 \u0642\u064a\u0645\u062a\u0647\u0627 \u0627\u0655\u0644\u0649 \u0646\u062d\u0648 8 \u0645\u0644\u064a\u0627\u0631\u0627\u062a \u064a\u0648\u0631\u0648.\u0648\u0628\u062d\u0633\u0628 \u0627\u0644\u0645\u0635\u0627\u062f\u0631\u060c \u062a\u062d\u0627\u0644\u0641 \u0635\u0646\u062f\u0648\u0642 \u0627\u0644\u0627\u0633\u062a\u062d\u0648\u0627\u0630 EQT AB \u0645\u0639 Porsche Automobil Holding SE\u060c \u0627\u0644\u0634\u0631\u0643\u0629 \u0627\u0644\u0642\u0627\u0628\u0636\u0629 \u0627\u0644\u0645\u062f\u0631\u062c\u0629 \u0644\u0639\u0627\u064a\u0654\u0644\u0629 \u0628\u0648\u0631\u0634\u0647 \u0628\u064a\u064a\u0634 \u0627\u0644\u0645\u0644\u064a\u0627\u0631\u062f\u064a\u0631\u0629 \u0627\u0644\u062a\u064a \u062a\u0633\u064a\u0637\u0631 \u0639\u0644\u0649 \u0641\u0648\u0644\u0643\u0633 \u0641\u0627\u063a\u0646. \u0643\u0645\u0627 \u062f\u0639\u064a \u0643\u0644 \u0645\u0646 \"\u0633\u064a \u0641\u064a \u0633\u064a \u0643\u0627\u0628\u064a\u062a\u0627\u0644 \u0628\u0627\u0631\u062a\u0646\u0631\u0632\" \u0648\"\u0628\u0627\u064a\u0646 \u0643\u0627\u0628\u064a\u062a\u0627\u0644\" \u0644\u0644\u0645\u0634\u0627\u0631\u0643\u0629 \u0641\u064a \u0627\u0644\u062c\u0648\u0644\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629 \u0645\u0646 \u0627\u0644\u0645\u0641\u0627\u0648\u0636\u0627\u062a.\u0648\u0643\u0627\u0646\u062a \u0628\u0644\u0648\u0645\u0628\u0631\u063a \u0642\u062f \u0627\u0654\u0641\u0627\u062f\u062a \u0633\u0627\u0628\u0642\u0627\u064b \u0628\u0627\u0654\u0646 Everllence\u060c \u0627\u0644\u062a\u064a \u062a\u0646\u062a\u062c \u0645\u062d\u0631\u0643\u0627\u062a \u0628\u062d\u0631\u064a\u0629 \u0648\u062a\u0648\u0631\u0628\u064a\u0646\u0627\u062a \u0644\u0645\u062d\u0637\u0627\u062a \u062a\u0648\u0644\u064a\u062f \u0627\u0644\u0637\u0627\u0642\u0629\u060c \u0627\u0633\u062a\u0642\u0637\u0628\u062a \u0639\u0631\u0648\u0636\u0627\u064b \u0644\u0627 \u062a\u0642\u0644 \u0639\u0646 8 \u0645\u0644\u064a\u0627\u0631\u0627\u062a \u064a\u0648\u0631\u0648 (\u0646\u062d\u0648 9.2 \u0645\u0644\u064a\u0627\u0631\u0627\u062a \u062f\u0648\u0644\u0627\u0631).\u0648\u0627\u0654\u0643\u062f\u062a \u0627\u0644\u0645\u0635\u0627\u062f\u0631 \u0627\u0654\u0646 \u0627\u0644\u0645\u062f\u0627\u0648\u0644\u0627\u062a \u0644\u0627 \u062a\u0632\u0627\u0644 \u062c\u0627\u0631\u064a\u0629\u060c \u0648\u0644\u0627 \u064a\u0648\u062c\u062f \u062d\u062a\u0649 \u0627\u0644\u0627\u0653\u0646 \u064a\u0642\u064a\u0646 \u0628\u0634\u0627\u0654\u0646 \u0627\u0644\u062a\u0648\u0635\u0644 \u0627\u0655\u0644\u0649 \u0627\u062a\u0641\u0627\u0642 \u0646\u0647\u0627\u064a\u0654\u064a\u060c \u0645\u0634\u064a\u0631\u0629\u064b \u0627\u0655\u0644\u0649 \u0627\u0654\u0646 \u0627\u0654\u0637\u0631\u0627\u0641\u0627\u064b \u0627\u0654\u062e\u0631\u0649 \u0642\u062f \u062a\u0628\u062f\u064a \u0627\u0647\u062a\u0645\u0627\u0645\u0647\u0627 \u0628\u0627\u0644\u0627\u0654\u0635\u0644 \u062e\u0644\u0627\u0644 \u0627\u0644\u0641\u062a\u0631\u0629 \u0627\u0644\u0645\u0642\u0628\u0644\u0629.\u0648\u062a\u0639\u0645\u0644 \u0641\u0648\u0644\u0643\u0633 \u0641\u0627\u063a\u0646 \u0639\u0644\u0649 \u0628\u064a\u0639 Everllence \u0641\u064a \u0627\u0655\u0637\u0627\u0631 \u0636\u063a\u0648\u0637 \u0644\u0631\u0641\u0639 \u0627\u0644\u0631\u0628\u062d\u064a\u0629 \u0648\u062a\u0628\u0633\u064a\u0637 \u0645\u062d\u0641\u0638\u0629 \u0639\u0645\u0644\u064a\u0627\u062a\u0647\u0627 \u0648\u0627\u0633\u0639\u0629 \u0627\u0