8\u062f\u0627\u064b \u0644\u0627\u0633\u062a\u064a\u0654\u0646\u0627\u0641 \u0645\u062d\u0627\u062f\u062b\u0627\u062a \u0648\u0642\u0641 \u0627\u0644\u062d\u0631\u0628.\u0648\u0627\u0633\u062a\u0647\u062f\u0641\u062a \u0648\u0632\u0627\u0631\u0629 \u0627\u0644\u062e\u0632\u0627\u0646\u0629 \u0627\u0644\u0627\u0654\u0645\u064a\u0631\u0643\u064a\u0629 \u0645\u0635\u0641\u0627\u0629 \"\u0647\u0646\u063a\u0644\u064a \u0644\u0644\u0628\u062a\u0631\u0648\u0643\u064a\u0645\u0627\u0648\u064a\u0627\u062a (\u062f\u0627\u0644\u064a\u0627\u0646)\"\u060c \u0627\u0644\u062a\u064a \u0648\u0635\u0641\u062a\u0647\u0627 \u0628\u0627\u0654\u0646\u0647\u0627 \u0645\u0646 \u0627\u0654\u0643\u0628\u0631 \u0639\u0645\u0644\u0627\u0621 \u0627\u0655\u064a\u0631\u0627\u0646 \u0644\u0634\u0631\u0627\u0621 \u0627\u0644\u0646\u0641\u0637 \u0627\u0644\u062e\u0627\u0645 \u0648\u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u0628\u062a\u0631\u0648\u0644\u064a\u0629. \"\u0627\u0644\u0637\u0627\u0642\u0629 \u0627\u0644\u062f\u0648\u0644\u064a\u0629\": \u0646\u0648\u0627\u062c\u0647 \u0627\u0654\u0643\u0628\u0631 \u062a\u0647\u062f\u064a\u062f \u0644\u0627\u0654\u0645\u0646 \u0627\u0644\u0637\u0627\u0642\u0629 \u0641\u064a \u0627\u0644\u062a\u0627\u0631\u064a\u062e.. \u0648\u062e\u0633\u0627\u0631\u0629 13 \u0645\u0644\u064a\u0648\u0646 \u0628\u0631\u0645\u064a\u0644 \u064a\u0648\u0645\u064a\u0627\u064b\u0648\u0627\u0654\u0639\u0644\u0646 \u0645\u0643\u062a\u0628 \u0645\u0631\u0627\u0642\u0628\u0629 \u0627\u0644\u0627\u0654\u0635\u0648\u0644 \u0627\u0644\u0627\u0654\u062c\u0646\u0628\u064a\u0629 \u0627\u0644\u062a\u0627\u0628\u0639 \u0644\u0644\u0648\u0632\u0627\u0631\u0629 \u0627\u0654\u0646\u0647 \u0641\u0631\u0636 \u0639\u0642\u0648\u0628\u0627\u062a \u0627\u0654\u064a\u0636\u0627\u064b \u0639\u0644\u0649 \u0646\u062d\u0648 40 \u0634\u0631\u0643\u0629 \u0634\u062d\u0646 \u0648\u0633\u0641\u064a\u0646\u0629 \u062a\u0639\u0645\u0644 \u0636\u0645\u0646 \u0627\u0654\u0633\u0637\u0648\u06