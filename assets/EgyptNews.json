654\u0646\u0647 \u0644\u0646 \u064a\u0633\u0645\u062d \u0644\u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0628\u0627\u0655\u0637\u0644\u0627\u0642 \u0627\u0644\u0646\u0627\u0631 \u062a\u062c\u0627\u0647 \u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644.\u0648\u0627\u0654\u0636\u0627\u0641 \u0641\u064a \u062a\u0635\u0631\u064a\u062d\u0627\u062a \u0627\u0655\u0639\u0644\u0627\u0645\u064a\u0629 \u0628\u0627\u0654\u0646 \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u064a\u0648\u062c\u0647 \u0636\u0631\u0628\u0627\u062a \u0642\u0648\u064a\u0629 \u0644\u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0648\u0647\u0648 \u0641\u064a \u062d\u0627\u0644\u0629 \u0641\u0631\u0627\u0631\u060c \u0645\u0648\u0654\u0643\u062f\u0627\u064b \u0628\u0627\u0644\u0642\u0648\u0644: \"\u0642\u0636\u064a\u0646\u0627 \u0639\u0644\u0649 350 \u0639\u0646\u0635\u0631\u0627\u064b \u0645\u0646 \u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u062e\u0644\u0627\u0644 \u0627\u0654\u0633\u0628\u0648\u0639\".\u0648\u0627\u0654\u0634\u0627\u0631 \u0646\u062a\u0646\u064a\u0627\u0647\u0648 \u0627\u0655\u0644\u0649 \u0627\u0644\u0639\u062b\u0648\u0631 \u0639\u0644\u0649 \u0628\u0646\u064a\u0629 \u062a\u062d\u062a\u064a\u0629 \u0636\u062e\u0645\u0629 \u062a\u062d\u062a \u0627\u0644\u0627\u0654\u0631\u0636 \u062e\u0644\u0627\u0644 \u0639\u0645\u0644\u064a\u0627\u062a \u0627\u0644\u062c\u064a\u0634 \u0627\u0644\u0627\u0655\u0633\u0631\u0627\u064a\u0654\u064a\u0644\u064a \u062c\u0646\u0648\u0628\u064a \u0644\u0628\u0646\u0627\u0646.\u0648\u0627\u0646\u062f\u0644\u0639\u062a \u0627\u0644\u062d\u0631\u0628 \u0641\u064a \u0644\u0628\u0646\u0627\u0646 \u0641\u064a \u0627\u0644\u062b\u0627\u0646\u064a \u0645\u0646 \u0645\u0627\u0631\u0633 (\u0627\u0653\u0630\u0627\u0631) \u0628\u0639\u062f \u0627\u0655\u0637\u0644\u0627\u0642 \u062d\u0632\u0628 \u0627\u0644\u0644\u0647 \u0635\u0648\u0627\u0631\u064a\u062e \u0639\u0644\u0649 \u0627\u0655\u0633\u0631\u0627\u064a